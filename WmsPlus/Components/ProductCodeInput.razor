@inject HttpClient Http
@inject IJSRuntime JS

<style>
/* ========== 货品选择器对话框 ========== */
.prd-selector-overlay {
    position: fixed; top: 0; left: 0; right: 0; bottom: 0;
    background-color: rgba(0, 0, 0, 0.45);
    z-index: 10000;
    display: flex; align-items: center; justify-content: center;
}
.prd-selector-dialog {
    background-color: #ffffff;
    border-radius: 6px;
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.15);
    width: 900px;
    max-width: 92vw;
    max-height: 80vh;
    display: flex; flex-direction: column;
    overflow: hidden;
}
.prd-selector-header {
    display: flex; justify-content: space-between; align-items: center;
    padding: 12px 18px; border-bottom: 1px solid #f0f0f0;
    font-size: 14px; font-weight: 500; color: #333333;
}
.prd-close-btn {
    background: none; border: none;
    font-size: 18px; color: #999999;
    cursor: pointer; padding: 0 2px; line-height: 1;
}
.prd-close-btn:hover { color: #333333; }
.prd-selector-body {
    display: flex; flex: 1; overflow: hidden;
    min-height: 380px;
}
.prd-left-panel {
    width: 180px; min-width: 180px;
    border-right: 1px solid #f0f0f0;
    padding: 16px 14px;
    display: flex; flex-direction: column;
    gap: 10px;
    background-color: #fafafa;
}
.prd-filter-title {
    font-size: 13px; font-weight: 500; color: #333333;
    margin-bottom: 4px;
}
.prd-search-input {
    height: 32px; padding: 0 8px;
    border: 1px solid #d9d9d9; border-radius: 4px;
    font-size: 13px; outline: none;
    transition: border-color 0.2s;
    box-sizing: border-box;
}
.prd-search-input:focus { border-color: #1890ff; box-shadow: 0 0 0 2px rgba(24,144,255,0.15); }
.prd-query-btn {
    height: 32px; background-color: #1890ff; color: #ffffff;
    border: none; border-radius: 4px; font-size: 13px; cursor: pointer;
    transition: background-color 0.2s;
}
.prd-query-btn:hover { background-color: #40a9ff; }
.prd-right-panel {
    flex: 1; overflow-y: auto;
    padding: 8px 12px;
    display: flex; flex-direction: column;
}
.prd-data-table {
    width: 100%; border-collapse: collapse; table-layout: auto;
}
.prd-data-table th {
    background-color: #fafafa;
    padding: 8px 6px;
    text-align: left;
    font-size: 12px; font-weight: 500; color: #666666;
    border-bottom: 1px solid #e8e8e8;
    white-space: nowrap;
}
.prd-data-table td {
    padding: 7px 6px;
    font-size: 12px; color: #333333;
    border-bottom: 1px solid #f5f5f5;
    vertical-align: middle;
    white-space: nowrap;
}
.prd-col-action { position: relative; white-space: nowrap; width: 70px !important; min-width: 70px !important; }
.prd-select-btn {
    background: none; border: 1px solid #d9d9d9; border-radius: 3px;
    padding: 2px 10px; font-size: 12px; color: #1890ff; cursor: pointer;
    transition: all 0.2s; white-space: nowrap;
}
.prd-select-btn:hover { border-color: #1890ff; color: #1890ff; background-color: #e6f7ff; }
.prd-pagination {
    display: flex; justify-content: space-between; align-items: center;
    padding: 10px 4px 4px; margin-top: auto;
}
.prd-total-info { font-size: 12px; color: #888888; }
.prd-page-controls { display: flex; align-items: center; gap: 4px; }
.prd-page-btn {
    width: 28px; height: 26px;
    border: 1px solid #d9d9d9; border-radius: 3px;
    background: #fff; font-size: 13px; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
}
.prd-page-btn:hover:not(:disabled) { border-color: #1890ff; color: #1890ff; }
.prd-page-btn:disabled { opacity: 0.4; cursor: not-allowed; }
.prd-page-input {
    width: 44px; height: 26px; text-align: center;
    border: 1px solid #d9d9d9; border-radius: 3px;
    font-size: 13px; outline: none;
}
.prd-page-input:focus { border-color: #1890ff; }
.prd-page-controls span { font-size: 12px; color: #666666; }
.prd-selector-footer {
    display: flex; justify-content: flex-end; align-items: center;
    padding: 10px 18px; border-top: 1px solid #f0f0f0;
}
.prd-footer-cancel {
    height: 30px; padding: 0 20px;
    border: 1px solid #d9d9d9; border-radius: 4px;
    background: #ffffff; font-size: 13px; color: #333333; cursor: pointer;
}
.prd-footer-cancel:hover { border-color: #1890ff; color: #1890ff; }

/* ========== 栏位设置按钮 ========== */
.prd-column-settings-btn {
    background: none; border: none;
    padding: 2px; margin-left: 4px;
    cursor: pointer; border-radius: 2px;
    display: inline-flex; align-items: center;
    transition: all 0.2s;
}
.prd-column-settings-btn:hover { background-color: #e6f7ff; }
.prd-column-settings-btn:hover svg { fill: #1890ff; }

/* ========== 栏位设计对话框 ========== */
.prd-column-settings-overlay {
    position: fixed; top: 0; left: 0; right: 0; bottom: 0;
    background-color: rgba(0, 0, 0, 0.45);
    z-index: 10001;
    display: flex; align-items: center; justify-content: center;
}
.prd-column-settings-dialog {
    background-color: #ffffff;
    border-radius: 6px;
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.15);
    width: 640px;
    max-height: 80vh;
    display: flex; flex-direction: column;
    overflow: hidden;
}
.prd-column-settings-header {
    display: flex; justify-content: space-between; align-items: center;
    padding: 14px 18px; border-bottom: 1px solid #f0f0f0;
    font-size: 14px; font-weight: 500; color: #333333;
}
.prd-column-settings-close {
    background: none; border: none;
    font-size: 18px; color: #999999;
    cursor: pointer; padding: 0 2px; line-height: 1;
}
.prd-column-settings-close:hover { color: #333333; }
.prd-column-settings-search {
    padding: 12px 18px 8px;
    border-bottom: 1px solid #f5f5f5;
}
.prd-column-search-input {
    width: 100%; height: 32px; padding: 0 10px;
    border: 1px solid #d9d9d9; border-radius: 4px;
    font-size: 13px; color: #333333; outline: none;
    transition: border-color 0.2s;
    box-sizing: border-box;
}
.prd-column-search-input:focus {
    border-color: #1890ff;
    box-shadow: 0 0 0 2px rgba(24, 144, 255, 0.15);
}
.prd-column-settings-body {
    flex: 1; overflow-y: auto;
    padding: 0 18px;
    min-height: 200px;
    max-height: 400px;
}
.prd-column-settings-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
}
.prd-column-settings-table thead th {
    background-color: #fafafa;
    padding: 8px 6px;
    text-align: left;
    font-size: 12px;
    font-weight: 500;
    color: #666666;
    border-bottom: 1px solid #e8e8e8;
    white-space: nowrap;
}
.prd-column-settings-table tbody td {
    padding: 6px 4px;
    font-size: 12px;
    color: #333333;
    border-bottom: 1px solid #f5f5f5;
    vertical-align: middle;
}
</style>

<!-- 货品代号输入框 -->
<div class="form-item">
    <label class="form-label">@Label</label>
    <div class="input-with-search">
        <input type="text" class="form-input" placeholder="" @bind="Value" @bind:event="oninput" />
        <button class="search-icon-btn" title="选择货品" @onclick="OpenProductSelector">
            <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="#999999" stroke-width="1.5">
                <circle cx="7" cy="7" r="5"/>
                <line x1="11" y1="11" x2="15" y2="15"/>
            </svg>
        </button>
    </div>
</div>

<!-- 货品选择器对话框 -->
@if (showProductDialog)
{
    <div class="prd-selector-overlay" @onclick="CloseProductSelector">
        <div class="prd-selector-dialog" @onclick:stopPropagation>
            <div class="prd-selector-header">
                <span>货品(PRDT)</span>
                <button class="prd-close-btn" @onclick="CloseProductSelector">&times;</button>
            </div>
            <div class="prd-selector-body">
                <div class="prd-left-panel">
                    <div class="prd-filter-title">过滤</div>
                    <input type="text" class="prd-search-input" placeholder="输入关键字查询" @bind="productSearchKeyword" @bind:event="oninput" @onkeyup="@((KeyboardEventArgs e) => { if(e.Key == "Enter") _ = SearchProduct(); })" />
                    <button class="prd-query-btn" @onclick="@(() => _ = SearchProduct())">查询</button>
                </div>
                <div class="prd-right-panel">
                    <table class="prd-data-table">
                        <thead>
                            <tr>
                                <th class="prd-col-action">
                                    操作
                                    <button class="prd-column-settings-btn" title="栏位设置" @onclick="OpenPrdColumnSettings">
                                        <svg viewBox="0 0 16 16" width="14" height="14" fill="#666666">
                                            <path d="M2 3h4v2H2V3zm0 4h4v2H2V7zm0 4h4v2H2v-2zm6-8h6v2H8V3zm0 4h6v2H8V7zm0 4h6v2H8v-2z"/>
                                        </svg>
                                    </button>
                                </th>
                                <th style="width:50px">项次</th>
                                @foreach (var col in prdColumnConfigs.Where(c => c.Visible))
                                {
                                    var wStyle = col.Width > 0 ? $"width:{col.Width}px" : "";
                                    <th style="@wStyle">@col.DisplayName</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @if (productData.Count == 0)
                            {
                                <tr><td colspan="@(PrdVisibleColumnCount + 2)" style="text-align:center;padding:30px;color:#999;">暂无数据</td></tr>
                            }
                            else
                            {
                                @for (int i = 0; i < productData.Count; i++)
                                {
                                    var item = productData[i];
                                    var rowIdx = (productPageIndex - 1) * productPageSize + i + 1;
                                    <tr>
                                        <td><button class="prd-select-btn" @onclick="() => SelectProduct(item)">选择</button></td>
                                        <td style="text-align:center">@rowIdx</td>
                                        @foreach (var col in prdColumnConfigs.Where(c => c.Visible))
                                        {
                                            var cw = col.Width > 0 ? $"width:{col.Width}px" : "";
                                            <td style="@cw">@GetPrdCellValue(item, col.FieldKey)</td>
                                        }
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                    <div class="prd-pagination">
                        <span class="prd-total-info">共 @productTotalCount 笔记录</span>
                        <div class="prd-page-controls">
                            <button class="prd-page-btn" disabled="@(productPageIndex <= 1)" @onclick="async () => await GoToPrdPage(productPageIndex - 1)">&lt;</button>
                            <input type="number" class="prd-page-input" value="@productPageIndex" min="1" max="@PrdTotalPages"
                                   @onchange="async (ChangeEventArgs e) => { if(int.TryParse(e.Value?.ToString(), out var p)) await GoToPrdPage(p); }" />
                            <span>/ @PrdTotalPages</span>
                            <button class="prd-page-btn" disabled="@(productPageIndex >= PrdTotalPages)" @onclick="async () => await GoToPrdPage(productPageIndex + 1)">&gt;</button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="prd-selector-footer">
                <button class="prd-footer-cancel" @onclick="CloseProductSelector">取消</button>
            </div>
        </div>
    </div>
}

<!-- 货品表格栏位设计对话框 -->
@if (showPrdColumnSettingsDialog && showProductDialog)
{
    <div class="prd-column-settings-overlay" @onclick="ClosePrdColumnSettings">
        <div class="prd-column-settings-dialog" @onclick:stopPropagation>
            <div class="prd-column-settings-header">
                <span>栏位设计</span>
                <button class="prd-column-settings-close" @onclick="ClosePrdColumnSettings">&times;</button>
            </div>
            <div class="prd-column-settings-search">
                <input type="text" class="prd-column-search-input" placeholder="搜索栏位原名..." @bind="prdColumnSearchKeyword" @bind:event="oninput" />
            </div>
            <div class="prd-column-settings-body">
                <table class="prd-column-settings-table">
                    <thead>
                        <tr>
                            <th style="width:40px;text-align:center">项次</th>
                            <th style="width:60px;text-align:center">显示否</th>
                            <th style="width:120px">原栏位名</th>
                            <th style="width:auto">栏位标题</th>
                            <th style="width:70px">宽度</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < FilteredPrdColumnConfigs.Count; i++)
                        {
                            var col = FilteredPrdColumnConfigs[i];
                            var idx = prdColumnConfigs.IndexOf(col) + 1;
                            <tr>
                                <td style="text-align:center">@idx</td>
                                <td style="text-align:center">
                                    <label class="toggle-switch">
                                        <input type="checkbox" checked="@col.Visible" @onchange="@((ChangeEventArgs e) => col.Visible = (bool)e.Value!)" />
                                        <span class="toggle-slider"></span>
                                    </label>
                                </td>
                                <td>@col.OriginalName</td>
                                <td>
                                    <input type="text" class="col-title-input" value="@col.DisplayName"
                                           @onchange="@((ChangeEventArgs e) => col.DisplayName = e.Value?.ToString() ?? col.OriginalName)" />
                                </td>
                                <td>
                                    <input type="number" class="col-width-input" value="@col.Width"
                                           min="0" max="500"
                                           @onchange="@((ChangeEventArgs e) => { if(int.TryParse(e.Value?.ToString(), out var w)) col.Width = w; })" />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="column-settings-footer">
                <div class="footer-left">
                    <button class="col-select-all" @onclick="SelectAllPrdColumns">全选</button>
                    <button class="col-restore-default" @onclick="RestoreDefaultPrdColumns">恢复默认</button>
                </div>
                <div class="footer-right">
                    <button class="col-btn-confirm" @onclick="ConfirmPrdColumnSettings">确定</button>
                    <button class="col-btn-cancel" @onclick="CancelPrdColumnSettings">取消</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    // ===== 参数 =====
    [Parameter] public string Value { get; set; } = "";
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public string Label { get; set; } = "货品代号";

    // ===== 货品选择器状态 =====
    private bool showProductDialog = false;
    private string productSearchKeyword = "";
    private List<ProductItem> productData = new();
    private int productPageIndex = 1;
    private int productPageSize = 20;
    private int productTotalCount = 0;
    private List<ColumnConfig> prdColumnConfigs = new();
    private List<ColumnConfig> prdDefaultColumnConfigs = new();
    private bool showPrdColumnSettingsDialog = false;
    private string prdColumnSearchKeyword = "";
    private const string PRD_COLUMN_SETTINGS_KEY = "wms_column_settings_product_selector";

    // ===== 数据模型 =====
    private class ProductItem
    {
        public string PRD_NO { get; set; } = "";
        public string NAME { get; set; } = "";
        public string SNM { get; set; } = "";
        public string IDX1 { get; set; } = "";
        public string UT { get; set; } = "";
        public string SPC { get; set; } = "";
    }

    private class ProductSearchResult
    {
        public List<ProductItem>? Items { get; set; }
        public int TotalCount { get; set; }
    }

    // ===== 栏位配置 =====
    private class ColumnConfig
    {
        public string FieldKey { get; set; } = "";
        public string OriginalName { get; set; } = "";
        public string DisplayName { get; set; } = "";
        public bool Visible { get; set; } = true;
        public int Width { get; set; } = 0;
        public int DefaultWidth { get; set; } = 0;
    }

    private void InitPrdDefaultColumnConfigs()
    {
        prdDefaultColumnConfigs = new List<ColumnConfig>
        {
            new() { FieldKey = "PRD_NO", OriginalName = "货品代号", DisplayName = "货品代号", Visible = true, Width = 120, DefaultWidth = 120 },
            new() { FieldKey = "NAME", OriginalName = "货品名称", DisplayName = "货品名称", Visible = true, Width = 180, DefaultWidth = 180 },
            new() { FieldKey = "SNM", OriginalName = "规格", DisplayName = "规格", Visible = true, Width = 100, DefaultWidth = 100 },
            new() { FieldKey = "IDX1", OriginalName = "行业码", DisplayName = "行业码", Visible = false, Width = 80, DefaultWidth = 80 },
            new() { FieldKey = "UT", OriginalName = "单位", DisplayName = "单位", Visible = true, Width = 60, DefaultWidth = 60 },
            new() { FieldKey = "SPC", OriginalName = "属性", DisplayName = "属性", Visible = false, Width = 80, DefaultWidth = 80 }
        };
        prdColumnConfigs = prdDefaultColumnConfigs.Select(c => new ColumnConfig
        {
            FieldKey = c.FieldKey,
            OriginalName = c.OriginalName,
            DisplayName = c.DisplayName,
            Visible = c.Visible,
            Width = c.Width,
            DefaultWidth = c.DefaultWidth
        }).ToList();
    }

    // ===== 货品选择器方法 =====
    private async Task OpenProductSelector()
    {
        InitPrdDefaultColumnConfigs();
        await LoadPrdColumnSettings();
        productSearchKeyword = "";
        productPageIndex = 1;
        await SearchProduct();
        showProductDialog = true;
        StateHasChanged();
    }

    private void CloseProductSelector()
    {
        showProductDialog = false;
        StateHasChanged();
    }

    private async Task SearchProduct()
    {
        try
        {
            var url = $"http://localhost:5102/api/warehouse/prdsearch?keyword={Uri.EscapeDataString(productSearchKeyword ?? "")}&pageIndex={productPageIndex}&pageSize={productPageSize}";

            var response = await Http.GetAsync(url);

            if (response.IsSuccessStatusCode)
            {
                var json = await response.Content.ReadAsStringAsync();
                var result = System.Text.Json.JsonSerializer.Deserialize<ProductSearchResult>(json, new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });

                if (result != null)
                {
                    productData = result.Items ?? new List<ProductItem>();
                    productTotalCount = result.TotalCount;
                }
            }
        }
        catch { }
        StateHasChanged();
    }

    private async Task SelectProduct(ProductItem item)
    {
        Value = item.PRD_NO;
        await ValueChanged.InvokeAsync(Value);
        showProductDialog = false;
        StateHasChanged();
    }

    // ===== 栏位设置方法 =====
    private async Task LoadPrdColumnSettings()
    {
        try
        {
            var json = await JS.InvokeAsync<string>("localStorage.getItem", PRD_COLUMN_SETTINGS_KEY);
            if (!string.IsNullOrWhiteSpace(json))
            {
                var options = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
                var saved = System.Text.Json.JsonSerializer.Deserialize<List<ColumnConfig>>(json, options);
                if (saved != null && saved.Count > 0)
                {
                    foreach (var col in prdColumnConfigs)
                    {
                        var savedCol = saved.FirstOrDefault(s => s.FieldKey == col.FieldKey);
                        if (savedCol != null)
                        {
                            col.Visible = savedCol.Visible;
                            col.DisplayName = !string.IsNullOrWhiteSpace(savedCol.DisplayName) ? savedCol.DisplayName : col.OriginalName;
                            col.Width = savedCol.Width >= 0 ? savedCol.Width : col.DefaultWidth;
                        }
                    }
                }
            }
        }
        catch { }
    }

    private async Task SavePrdColumnSettings()
    {
        try
        {
            var json = System.Text.Json.JsonSerializer.Serialize(prdColumnConfigs);
            await JS.InvokeVoidAsync("localStorage.setItem", PRD_COLUMN_SETTINGS_KEY, json);
        }
        catch { }
    }

    private void OpenPrdColumnSettings()
    {
        prdColumnSearchKeyword = "";
        showPrdColumnSettingsDialog = true;
        StateHasChanged();
    }

    private void ClosePrdColumnSettings()
    {
        showPrdColumnSettingsDialog = false;
        StateHasChanged();
    }

    private void ConfirmPrdColumnSettings()
    {
        showPrdColumnSettingsDialog = false;
        _ = SavePrdColumnSettings();
        StateHasChanged();
    }

    private void CancelPrdColumnSettings()
    {
        showPrdColumnSettingsDialog = false;
        _ = LoadPrdColumnSettings();
        StateHasChanged();
    }

    private void SelectAllPrdColumns()
    {
        foreach (var col in prdColumnConfigs) col.Visible = true;
        StateHasChanged();
    }

    private void RestoreDefaultPrdColumns()
    {
        for (int i = 0; i < prdColumnConfigs.Count && i < prdDefaultColumnConfigs.Count; i++)
        {
            prdColumnConfigs[i].Visible = prdDefaultColumnConfigs[i].Visible;
            prdColumnConfigs[i].DisplayName = prdDefaultColumnConfigs[i].DisplayName;
            prdColumnConfigs[i].Width = prdDefaultColumnConfigs[i].Width;
        }
        StateHasChanged();
    }

    private List<ColumnConfig> FilteredPrdColumnConfigs =>
        string.IsNullOrWhiteSpace(prdColumnSearchKeyword)
            ? prdColumnConfigs
            : prdColumnConfigs.Where(c => c.OriginalName.Contains(prdColumnSearchKeyword, StringComparison.OrdinalIgnoreCase) ||
                                          c.FieldKey.Contains(prdColumnSearchKeyword, StringComparison.OrdinalIgnoreCase)).ToList();

    private int PrdVisibleColumnCount => prdColumnConfigs.Count(c => c.Visible);

    private object GetPrdCellValue(ProductItem item, string fieldKey) => fieldKey switch
    {
        "PRD_NO" => item.PRD_NO,
        "NAME" => item.NAME,
        "SNM" => item.SNM,
        "IDX1" => item.IDX1,
        "UT" => item.UT,
        "SPC" => item.SPC,
        _ => ""
    };

    private int PrdTotalPages => productPageSize > 0 ? (int)Math.Ceiling((double)productTotalCount / productPageSize) : 1;

    private async Task GoToPrdPage(int page)
    {
        if (page >= 1 && page <= PrdTotalPages)
        {
            productPageIndex = page;
            await SearchProduct();
        }
    }
}
