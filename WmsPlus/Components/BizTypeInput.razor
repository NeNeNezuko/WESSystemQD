@inject HttpClient Http

<style>
/* ========== 业务类型选择器对话框 ========== */
.biz-type-selector-overlay {
    position: fixed; top: 0; left: 0; right: 0; bottom: 0;
    background-color: rgba(0, 0, 0, 0.45);
    z-index: 10000;
    display: flex; align-items: center; justify-content: center;
}
.biz-type-selector-dialog {
    background-color: #ffffff;
    border-radius: 6px;
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.15);
    width: 680px;
    max-width: 92vw;
    max-height: 78vh;
    display: flex; flex-direction: column;
    overflow: hidden;
}
.biz-type-header {
    display: flex; justify-content: space-between; align-items: center;
    padding: 12px 18px; border-bottom: 1px solid #f0f0f0;
    font-size: 14px; font-weight: 500; color: #333333;
}
.biz-type-close-btn {
    background: none; border: none;
    font-size: 18px; color: #999999;
    cursor: pointer; padding: 0 2px; line-height: 1;
}
.biz-type-close-btn:hover { color: #333333; }
.biz-type-body {
    display: flex; flex: 1; overflow: hidden;
    min-height: 340px;
}
.biz-type-left-panel {
    width: 160px; min-width: 160px;
    border-right: 1px solid #f0f0f0;
    padding: 16px 14px;
    display: flex; flex-direction: column;
    gap: 10px;
    background-color: #fafafa;
}
.biz-type-filter-title { font-size: 13px; font-weight: 500; color: #333333; margin-bottom: 4px; }
.biz-type-search-input {
    height: 32px; padding: 0 8px;
    border: 1px solid #d9d9d9; border-radius: 4px;
    font-size: 13px; outline: none;
    transition: border-color 0.2s; box-sizing: border-box;
}
.biz-type-search-input:focus { border-color: #1890ff; box-shadow: 0 0 0 2px rgba(24,144,255,0.15); }
.biz-type-query-btn {
    height: 32px; background-color: #1890ff; color: #ffffff;
    border: none; border-radius: 4px; font-size: 13px; cursor: pointer;
    transition: background-color 0.2s;
}
.biz-type-query-btn:hover { background-color: #40a9ff; }
.biz-type-right-panel {
    flex: 1; overflow-y: auto;
    padding: 8px 12px;
    display: flex; flex-direction: column;
}
.biz-type-table { width: 100%; border-collapse: collapse; table-layout: auto; }
.biz-type-table th {
    background-color: #fafafa; padding: 8px 6px;
    text-align: left; font-size: 12px; font-weight: 500; color: #666666;
    border-bottom: 1px solid #e8e8e8; white-space: nowrap;
}
.biz-type-table td {
    padding: 7px 6px; font-size: 12px; color: #333333;
    border-bottom: 1px solid #f5f5f5; vertical-align: middle; white-space: nowrap;
}
.biz-type-col-check { width: 40px; text-align: center; }
.biz-type-col-seq { width: 50px; text-align: center; }
.biz-type-col-code { width: 70px; }

/* 已选标签区域 */
.biz-type-tags-area {
    margin-top: 4px;
    min-height: 24px;
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    align-items: center;
}
.biz-type-tag {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    height: 22px;
    padding: 0 6px 0 8px;
    background-color: #e6f7ff;
    border: 1px solid #91d5ff;
    border-radius: 3px;
    font-size: 11px;
    color: #1890ff;
}
.biz-type-tag-close {
    background: none; border: none;
    cursor: pointer; padding: 0;
    font-size: 14px; line-height: 1;
    color: #1890ff; opacity: 0.6;
    display: flex; align-items: center;
}
.biz-type-tag-close:hover { opacity: 1; }

/* 分页 */
.biz-type-pagination {
    display: flex; justify-content: space-between; align-items: center;
    padding: 10px 4px 4px; margin-top: auto;
}
.biz-type-total-info { font-size: 12px; color: #888888; }
.biz-type-page-controls { display: flex; align-items: center; gap: 4px; }
.biz-type-page-btn {
    width: 28px; height: 26px;
    border: 1px solid #d9d9d9; border-radius: 3px;
    background: #fff; font-size: 13px; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
}
.biz-type-page-btn:hover:not(:disabled) { border-color: #1890ff; color: #1890ff; }
.biz-type-page-btn:disabled { opacity: 0.4; cursor: not-allowed; }
.biz-type-page-input {
    width: 44px; height: 26px; text-align: center;
    border: 1px solid #d9d9d9; border-radius: 3px;
    font-size: 13px; outline: none;
}
.biz-type-page-input:focus { border-color: #1890ff; }
.biz-type-page-controls span { font-size: 12px; color: #666666; }

/* 底部操作栏 */
.biz-type-footer {
    display: flex; justify-content: space-between; align-items: center;
    padding: 10px 18px; border-top: 1px solid #f0f0f0;
}
.biz-type-footer-left { display: flex; align-items: center; gap: 6px; font-size: 13px; color: #333333; }
.biz-type-select-all-check {
    width: 15px; height: 15px;
    cursor: pointer; accent-color: #1890ff;
}
.biz-type-footer-right { display: flex; gap: 8px; }
.biz-type-btn-clear {
    height: 30px; padding: 0 20px;
    border: 1px solid #d9d9d9; border-radius: 4px;
    background: #ffffff; font-size: 13px; color: #333333; cursor: pointer;
}
.biz-type-btn-clear:hover { border-color: #1890ff; color: #1890ff; }
.biz-type-btn-confirm {
    height: 30px; padding: 0 20px;
    border: 1px solid #1890ff; border-radius: 4px;
    background-color: #1890ff; font-size: 13px; color: #ffffff; cursor: pointer;
}
.biz-type-btn-confirm:hover { background-color: #40a9ff; }
</style>

<!-- 业务类型输入框 -->
<div class="form-item" style="flex-direction:column;align-items:stretch;height:auto;padding-bottom:4px;">
    <div style="display:flex;flex-direction:row;align-items:stretch;height:30px;">
        <label class="form-label" style="border-radius:2px 0 0 2px;">业务类型</label>
        <div class="input-with-search" style="flex:1;">
            <input type="text" class="form-input" placeholder="" value="@Value" readonly />
            <button class="search-icon-btn" title="选择业务类型" @onclick="OpenBizTypeSelector">
                <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="#999999" stroke-width="1.5">
                    <circle cx="7" cy="7" r="5"/>
                    <line x1="11" y1="11" x2="15" y2="15"/>
                </svg>
            </button>
        </div>
    </div>
    @if (selectedBizTypes.Count > 0)
    {
        <div class="biz-type-tags-area">
            @foreach (var tag in selectedBizTypes)
            {
                <span class="biz-type-tag">@tag.tYPE_ID @tag.nAME<button class="biz-type-tag-close" @onclick="() => RemoveBizTypeTag(tag.tYPE_ID)">&times;</button></span>
            }
        </div>
    }
</div>

<!-- 业务类型选择器对话框 -->
@if (showBizTypeDialog)
{
    <div class="biz-type-selector-overlay" @onclick="CloseBizTypeSelector">
        <div class="biz-type-selector-dialog" @onclick:stopPropagation>
            <!-- 头部 -->
            <div class="biz-type-header">
                <span>入库业务类型(RK_TYPE_SET)</span>
                <button class="biz-type-close-btn" @onclick="CloseBizTypeSelector">&times;</button>
            </div>
            <!-- 主体：左右分栏 -->
            <div class="biz-type-body">
                <!-- 左侧面板：过滤区 -->
                <div class="biz-type-left-panel">
                    <div class="biz-type-filter-title">过滤</div>
                    <input type="text" class="biz-type-search-input" placeholder="输入关键字查询" @bind="bizTypeSearchKeyword" @bind:event="oninput" @onkeyup="@((KeyboardEventArgs e) => { if(e.Key == "Enter") _ = SearchBizType(); })" />
                    <button class="biz-type-query-btn" @onclick="@(() => _ = SearchBizType())">查询</button>
                </div>
                <!-- 右侧区域：数据表格 -->
                <div class="biz-type-right-panel">
                    <table class="biz-type-table">
                        <thead>
                            <tr>
                                <th class="biz-type-col-check"></th>
                                <th style="width:50px">项次</th>
                                <th class="biz-type-col-code">代码</th>
                                <th>名称</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (bizTypeData.Count == 0)
                            {
                                <tr><td colspan="4" style="text-align:center;padding:30px;color:#999;">暂无数据</td></tr>
                            }
                            else
                            {
                                @for (int i = 0; i < bizTypeData.Count; i++)
                                {
                                    var item = bizTypeData[i];
                                    var rowIdx = (bizTypePageIndex - 1) * bizTypePageSize + i + 1;
                                    var isChecked = selectedBizTypes.Any(s => s.tYPE_ID == item.tYPE_ID);
                                    <tr>
                                        <td class="biz-type-col-check"><input type="checkbox" checked="@isChecked" @onchange="() => ToggleBizTypeSelect(item)" /></td>
                                        <td style="text-align:center">@rowIdx</td>
                                        <td>@item.tYPE_ID</td>
                                        <td>@item.nAME</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                    <!-- 分页 -->
                    <div class="biz-type-pagination">
                        <span class="biz-type-total-info">共 @bizTypeTotalCount 笔记录</span>
                        <div class="biz-type-page-controls">
                            <button class="biz-type-page-btn" disabled="@(bizTypePageIndex <= 1)" @onclick="async () => await GoToBizTypePage(bizTypePageIndex - 1)">&lt;</button>
                            <input type="number" class="biz-type-page-input" value="@bizTypePageIndex" min="1" max="@BizTypeTotalPages"
                                   @onchange="async (ChangeEventArgs e) => { if(int.TryParse(e.Value?.ToString(), out var p)) await GoToBizTypePage(p); }" />
                            <span>/ @BizTypeTotalPages</span>
                            <button class="biz-type-page-btn" disabled="@(bizTypePageIndex >= BizTypeTotalPages)" @onclick="async () => await GoToBizTypePage(bizTypePageIndex + 1)">&gt;</button>
                        </div>
                    </div>
                </div>
            </div>
            <!-- 底部 -->
            <div class="biz-type-footer">
                <div class="biz-type-footer-left">
                    <input type="checkbox" class="biz-type-select-all-check" id="bt-select-all" checked="@isAllBizTypeSelected" @onchange="SelectAllBizType" />
                    <label for="bt-select-all">选全部</label>
                </div>
                <div class="biz-type-footer-right">
                    <button class="biz-type-btn-clear" @onclick="ClearBizTypeSelection">清空</button>
                    <button class="biz-type-btn-confirm" @onclick="ConfirmBizTypeSelection">确定</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    // ===== 参数 =====
    [Parameter] public string Value { get; set; } = "";
    [Parameter] public EventCallback<string> ValueChanged { get; set; }

    // ===== 业务类型选择器状态 =====
    private bool showBizTypeDialog = false;
    private List<BizTypeItem> bizTypeData = new();
    private List<BizTypeItem> selectedBizTypes = new();
    private string bizTypeSearchKeyword = "";
    private int bizTypePageIndex = 1;
    private int bizTypePageSize = 10;
    private int bizTypeTotalCount = 0;

    // ===== 数据模型 =====
    private class BizTypeItem
    {
        public string tYPE_ID { get; set; } = "";
        public string nAME { get; set; } = "";
    }

    private class BizTypeSearchResult
    {
        public List<BizTypeItem>? Items { get; set; }
        public int TotalCount { get; set; }
    }

    // ===== 计算属性 =====
    private bool isAllBizTypeSelected => bizTypeData.Count > 0 && bizTypeData.All(item => selectedBizTypes.Any(s => s.tYPE_ID == item.tYPE_ID));
    private int BizTypeTotalPages => bizTypePageSize > 0 ? (int)Math.Ceiling((double)bizTypeTotalCount / bizTypePageSize) : 1;

    // ===== 初始化：从 Value 解析已选项 =====
    protected override void OnInitialized()
    {
        ParseValueToSelection();
    }

    protected override void OnParametersSet()
    {
        ParseValueToSelection();
    }

    private void ParseValueToSelection()
    {
        if (!string.IsNullOrWhiteSpace(Value))
        {
            // 仅在 selectedBizTypes 为空时从 Value 初始化，避免覆盖用户操作
            if (selectedBizTypes.Count == 0)
            {
                var codes = Value.Split(',', StringSplitOptions.RemoveEmptyEntries);
                // 先保留已有名称信息
                foreach (var code in codes)
                {
                    if (!selectedBizTypes.Any(s => s.tYPE_ID == code))
                    {
                        selectedBizTypes.Add(new BizTypeItem { tYPE_ID = code, nAME = "" });
                    }
                }
            }
        }
    }

    // ===== 弹窗方法 =====
    private async Task OpenBizTypeSelector()
    {
        bizTypeSearchKeyword = "";
        bizTypePageIndex = 1;
        await SearchBizType();
        showBizTypeDialog = true;
        StateHasChanged();
    }

    private void CloseBizTypeSelector()
    {
        showBizTypeDialog = false;
        StateHasChanged();
    }

    private async Task SearchBizType()
    {
        try
        {
            var url = $"http://localhost:5102/api/warehouse/rktypesearch?keyword={Uri.EscapeDataString(bizTypeSearchKeyword ?? "")}&pageIndex={bizTypePageIndex}&pageSize={bizTypePageSize}";

            var response = await Http.GetAsync(url);

            if (response.IsSuccessStatusCode)
            {
                var json = await response.Content.ReadAsStringAsync();
                var result = System.Text.Json.JsonSerializer.Deserialize<BizTypeSearchResult>(json, new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });

                if (result != null)
                {
                    bizTypeData = result.Items ?? new List<BizTypeItem>();
                    bizTypeTotalCount = result.TotalCount;

                    // 补充已选项的名称
                    foreach (var sel in selectedBizTypes.ToList())
                    {
                        var found = bizTypeData.FirstOrDefault(b => b.tYPE_ID == sel.tYPE_ID);
                        if (found != null && string.IsNullOrEmpty(sel.nAME))
                        {
                            sel.nAME = found.nAME;
                        }
                    }
                }
            }
        }
        catch { }
        StateHasChanged();
    }

    // ===== 多选方法 =====
    private void ToggleBizTypeSelect(BizTypeItem item)
    {
        var existing = selectedBizTypes.FirstOrDefault(s => s.tYPE_ID == item.tYPE_ID);
        if (existing != null)
        {
            selectedBizTypes.Remove(existing);
        }
        else
        {
            selectedBizTypes.Add(new BizTypeItem { tYPE_ID = item.tYPE_ID, nAME = item.nAME });
        }
        StateHasChanged();
    }

    private void SelectAllBizType(ChangeEventArgs e)
    {
        bool selectAll = (bool)e.Value!;
        if (selectAll)
        {
            foreach (var item in bizTypeData)
            {
                if (!selectedBizTypes.Any(s => s.tYPE_ID == item.tYPE_ID))
                {
                    selectedBizTypes.Add(new BizTypeItem { tYPE_ID = item.tYPE_ID, nAME = item.nAME });
                }
            }
        }
        else
        {
            foreach (var item in bizTypeData)
            {
                selectedBizTypes.RemoveAll(s => s.tYPE_ID == item.tYPE_ID);
            }
        }
        StateHasChanged();
    }

    private void RemoveBizTypeTag(string rkType)
    {
        selectedBizTypes.RemoveAll(s => s.tYPE_ID == rkType);
        SyncValueFromSelection();
        StateHasChanged();
    }

    private void ClearBizTypeSelection()
    {
        selectedBizTypes.Clear();
        SyncValueFromSelection();
        StateHasChanged();
    }

    private void ConfirmBizTypeSelection()
    {
        SyncValueFromSelection();
        showBizTypeDialog = false;
        StateHasChanged();
    }

    private async Task GoToBizTypePage(int page)
    {
        if (page < 1 || page > BizTypeTotalPages) return;
        bizTypePageIndex = page;
        await SearchBizType();
    }

    // ===== 同步值到父组件 =====
    private void SyncValueFromSelection()
    {
        Value = string.Join(",", selectedBizTypes.Select(s => s.tYPE_ID));
        _ = ValueChanged.InvokeAsync(Value);
    }
}
