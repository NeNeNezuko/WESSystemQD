@inject HttpClient Http
@inject IJSRuntime JS
@inject TokenProvider TokenProvider

<style>
/* ========== 仓库选择器对话框 ========== */
.wh-selector-overlay {
    position: fixed; top: 0; left: 0; right: 0; bottom: 0;
    background-color: rgba(0, 0, 0, 0.45);
    z-index: 10000;
    display: flex; align-items: center; justify-content: center;
}
.wh-selector-dialog {
    background-color: #ffffff;
    border-radius: 6px;
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.15);
    width: 900px;
    max-width: 92vw;
    max-height: 80vh;
    display: flex; flex-direction: column;
    overflow: hidden;
}
.wh-selector-header {
    display: flex; justify-content: space-between; align-items: center;
    padding: 12px 18px; border-bottom: 1px solid #f0f0f0;
    font-size: 14px; font-weight: 500; color: #333333;
}
.wh-close-btn {
    background: none; border: none;
    font-size: 18px; color: #999999;
    cursor: pointer; padding: 0 2px; line-height: 1;
}
.wh-close-btn:hover { color: #333333; }
.wh-selector-body {
    display: flex; flex: 1; overflow: hidden;
    min-height: 380px;
}
.wh-left-panel {
    width: 180px; min-width: 180px;
    border-right: 1px solid #f0f0f0;
    padding: 16px 14px;
    display: flex; flex-direction: column;
    gap: 10px;
    background-color: #fafafa;
}
.wh-filter-title {
    font-size: 13px; font-weight: 500; color: #333333;
    margin-bottom: 4px;
}
.wh-search-input {
    height: 32px; padding: 0 8px;
    border: 1px solid #d9d9d9; border-radius: 4px;
    font-size: 13px; outline: none;
    transition: border-color 0.2s;
    box-sizing: border-box;
}
.wh-search-input:focus { border-color: #1890ff; box-shadow: 0 0 0 2px rgba(24,144,255,0.15); }
.wh-query-btn {
    height: 32px; background-color: #1890ff; color: #ffffff;
    border: none; border-radius: 4px; font-size: 13px; cursor: pointer;
    transition: background-color 0.2s;
}
.wh-query-btn:hover { background-color: #40a9ff; }
.wh-right-panel {
    flex: 1; overflow-y: auto;
    padding: 8px 12px;
    display: flex; flex-direction: column;
}
.wh-data-table {
    width: 100%; border-collapse: collapse; table-layout: auto;
}
.wh-data-table th {
    background-color: #fafafa;
    padding: 8px 6px;
    text-align: left;
    font-size: 12px; font-weight: 500; color: #666666;
    border-bottom: 1px solid #e8e8e8;
    white-space: nowrap;
}
.wh-data-table td {
    padding: 7px 6px;
    font-size: 12px; color: #333333;
    border-bottom: 1px solid #f5f5f5;
    vertical-align: middle;
    white-space: nowrap;
}
.wh-col-action { position: relative; white-space: nowrap; width: 70px !important; min-width: 70px !important; }
.wh-select-btn {
    background: none; border: 1px solid #d9d9d9; border-radius: 3px;
    padding: 2px 10px; font-size: 12px; color: #1890ff; cursor: pointer;
    transition: all 0.2s; white-space: nowrap;
}
.wh-select-btn:hover { border-color: #1890ff; color: #1890ff; background-color: #e6f7ff; }
.wh-pagination {
    display: flex; justify-content: space-between; align-items: center;
    padding: 10px 4px 4px; margin-top: auto;
}
.wh-total-info { font-size: 12px; color: #888888; }
.wh-page-controls { display: flex; align-items: center; gap: 4px; }
.wh-page-btn {
    width: 28px; height: 26px;
    border: 1px solid #d9d9d9; border-radius: 3px;
    background: #fff; font-size: 13px; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
}
.wh-page-btn:hover:not(:disabled) { border-color: #1890ff; color: #1890ff; }
.wh-page-btn:disabled { opacity: 0.4; cursor: not-allowed; }
.wh-page-input {
    width: 44px; height: 26px; text-align: center;
    border: 1px solid #d9d9d9; border-radius: 3px;
    font-size: 13px; outline: none;
}
.wh-page-input:focus { border-color: #1890ff; }
.wh-page-controls span { font-size: 12px; color: #666666; }
.wh-selector-footer {
    display: flex; justify-content: flex-end; align-items: center;
    padding: 10px 18px; border-top: 1px solid #f0f0f0;
}
.wh-footer-cancel {
    height: 30px; padding: 0 20px;
    border: 1px solid #d9d9d9; border-radius: 4px;
    background: #ffffff; font-size: 13px; color: #333333; cursor: pointer;
}
.wh-footer-cancel:hover { border-color: #1890ff; color: #1890ff; }

/* ========== 栏位设置按钮 ========== */
.column-settings-btn {
    background: none; border: none;
    padding: 2px; margin-left: 4px;
    cursor: pointer; border-radius: 2px;
    display: inline-flex; align-items: center;
    transition: all 0.2s;
}
.column-settings-btn:hover { background-color: #e6f7ff; }
.column-settings-btn:hover svg { fill: #1890ff; }

/* ========== 栏位设计对话框 ========== */
.column-settings-overlay {
    position: fixed; top: 0; left: 0; right: 0; bottom: 0;
    background-color: rgba(0, 0, 0, 0.45);
    z-index: 10001;
    display: flex; align-items: center; justify-content: center;
}
.column-settings-dialog {
    background-color: #ffffff;
    border-radius: 6px;
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.15);
    width: 640px;
    max-height: 80vh;
    display: flex; flex-direction: column;
    overflow: hidden;
}
.column-settings-header {
    display: flex; justify-content: space-between; align-items: center;
    padding: 14px 18px; border-bottom: 1px solid #f0f0f0;
    font-size: 14px; font-weight: 500; color: #333333;
}
.column-settings-close {
    background: none; border: none;
    font-size: 18px; color: #999999;
    cursor: pointer; padding: 0 2px; line-height: 1;
}
.column-settings-close:hover { color: #333333; }
.column-settings-search {
    padding: 12px 18px 8px;
    border-bottom: 1px solid #f5f5f5;
}
.column-search-input {
    width: 100%; height: 32px; padding: 0 10px;
    border: 1px solid #d9d9d9; border-radius: 4px;
    font-size: 13px; color: #333333; outline: none;
    transition: border-color 0.2s;
    box-sizing: border-box;
}
.column-search-input:focus {
    border-color: #1890ff;
    box-shadow: 0 0 0 2px rgba(24, 144, 255, 0.15);
}
.column-settings-body {
    flex: 1; overflow-y: auto;
    padding: 0 18px;
    min-height: 200px;
    max-height: 400px;
}
.column-settings-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
}
.column-settings-table thead th {
    background-color: #fafafa;
    padding: 8px 6px;
    text-align: left;
    font-size: 12px;
    font-weight: 500;
    color: #666666;
    border-bottom: 1px solid #e8e8e8;
    white-space: nowrap;
}
.column-settings-table tbody td {
    padding: 6px 4px;
    font-size: 12px;
    color: #333333;
    border-bottom: 1px solid #f5f5f5;
    vertical-align: middle;
}
.col-seq { width: 40px; text-align: center; }
.col-visible { width: 60px; text-align: center; }
.col-original { width: 120px; }
.col-display { width: auto; }
.col-width { width: 70px; }
.toggle-switch {
    position: relative; display: inline-block;
    width: 36px; height: 20px;
}
.toggle-switch input { opacity: 0; width: 0; height: 0; }
.toggle-slider {
    position: absolute; cursor: pointer;
    top: 0; left: 0; right: 0; bottom: 0;
    background-color: #cccccc;
    border-radius: 20px; transition: 0.3s;
}
.toggle-slider::before {
    content: ""; position: absolute;
    height: 16px; width: 16px;
    left: 2px; bottom: 2px;
    background-color: white;
    border-radius: 50%; transition: 0.3s;
}
.toggle-switch input:checked + .toggle-slider { background-color: #1890ff; }
.toggle-switch input:checked + .toggle-slider::before { transform: translateX(16px); }
.col-title-input, .col-width-input {
    width: 100%; height: 26px; padding: 0 6px;
    border: 1px solid #d9d9d9; border-radius: 2px;
    font-size: 12px; color: #333333; outline: none;
    box-sizing: border-box; transition: border-color 0.2s;
}
.col-title-input:focus, .col-width-input:focus {
    border-color: #1890ff;
    box-shadow: 0 0 0 2px rgba(24, 144, 255, 0.15);
}
.column-settings-footer {
    display: flex; justify-content: space-between; align-items: center;
    padding: 12px 18px; border-top: 1px solid #f0f0f0;
}
.footer-left { display: flex; gap: 8px; }
.footer-right { display: flex; gap: 8px; }
.col-select-all, .col-restore-default {
    height: 28px; padding: 0 14px;
    border: 1px solid #d9d9d9; border-radius: 4px;
    background-color: #ffffff; font-size: 12px; color: #333333;
    cursor: pointer; transition: all 0.2s;
}
.col-select-all:hover, .col-restore-default:hover {
    border-color: #1890ff; color: #1890ff;
}
.col-btn-confirm {
    height: 28px; padding: 0 20px;
    border: 1px solid #1890ff; border-radius: 4px;
    background-color: #1890ff; font-size: 12px; color: #ffffff;
    cursor: pointer; transition: all 0.2s;
}
.col-btn-confirm:hover { background-color: #40a9ff; border-color: #40a9ff; }
.col-btn-cancel {
    height: 28px; padding: 0 16px;
    border: 1px solid #d9d9d9; border-radius: 4px;
    background-color: #ffffff; font-size: 12px; color: #333333;
    cursor: pointer; transition: all 0.2s;
}
.col-btn-cancel:hover { border-color: #1890ff; color: #1890ff; }
</style>

<!-- 仓库代号输入框 -->
<div class="form-item" @attributes="AdditionalAttributes">
    @if (!HideLabel)
    {
        <label class="form-label">仓库代号</label>
    }
    <div class="input-with-search">
        <input type="text" class="form-input" placeholder="" @bind="Value" @bind:event="oninput" />
        <button class="search-icon-btn" title="选择仓库" @onclick="OpenWarehouseSelector">
            <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="#999999" stroke-width="1.5">
                <circle cx="7" cy="7" r="5"/>
                <line x1="11" y1="11" x2="15" y2="15"/>
            </svg>
        </button>
    </div>
</div>

<!-- 仓库选择器对话框 -->
@if (showWarehouseDialog)
{
    <div class="wh-selector-overlay" @onclick="CloseWarehouseSelector">
        <div class="wh-selector-dialog" @onclick:stopPropagation>
            <div class="wh-selector-header">
                <span>仓库(MY_WH)</span>
                <button class="wh-close-btn" @onclick="CloseWarehouseSelector">&times;</button>
            </div>
            <div class="wh-selector-body">
                <div class="wh-left-panel">
                    <div class="wh-filter-title">过滤</div>
                    <input type="text" class="wh-search-input" placeholder="输入关键字查询" @bind="warehouseSearchKeyword" @bind:event="oninput" @onkeyup="@((KeyboardEventArgs e) => { if(e.Key == "Enter") _ = SearchWarehouse(); })" />
                    <button class="wh-query-btn" @onclick="@(() => _ = SearchWarehouse())">查询</button>
                </div>
                <div class="wh-right-panel">
                    <table class="wh-data-table">
                        <thead>
                            <tr>
                                <th class="wh-col-action">
                                    操作
                                    <button class="column-settings-btn" title="栏位设置" @onclick="OpenWhColumnSettings">
                                        <svg viewBox="0 0 16 16" width="14" height="14" fill="#666666">
                                            <path d="M2 3h4v2H2V3zm0 4h4v2H2V7zm0 4h4v2H2v-2zm6-8h6v2H8V3zm0 4h6v2H8V7zm0 4h6v2H8v-2z"/>
                                        </svg>
                                    </button>
                                </th>
                                <th style="width:50px">项次</th>
                                @foreach (var col in whColumnConfigs.Where(c => c.Visible))
                                {
                                    var wStyle = col.Width > 0 ? $"width:{col.Width}px" : "";
                                    <th style="@wStyle">@col.DisplayName</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @if (warehouseData.Count == 0)
                            {
                                <tr><td colspan="@(WhVisibleColumnCount + 2)" style="text-align:center;padding:30px;color:#999;">暂无数据</td></tr>
                            }
                            else
                            {
                                @for (int i = 0; i < warehouseData.Count; i++)
                                {
                                    var item = warehouseData[i];
                                    var rowIdx = (warehousePageIndex - 1) * warehousePageSize + i + 1;
                                    <tr>
                                        <td><button class="wh-select-btn" @onclick="() => SelectWarehouse(item)">选择</button></td>
                                        <td style="text-align:center">@rowIdx</td>
                                        @foreach (var col in whColumnConfigs.Where(c => c.Visible))
                                        {
                                            var cw = col.Width > 0 ? $"width:{col.Width}px" : "";
                                            <td style="@cw">@GetWhCellValue(item, col.FieldKey)</td>
                                        }
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                    <div class="wh-pagination">
                        <span class="wh-total-info">共 @warehouseTotalCount 笔记录</span>
                        <div class="wh-page-controls">
                            <button class="wh-page-btn" disabled="@(warehousePageIndex <= 1)" @onclick="async () => await GoToWhPage(warehousePageIndex - 1)">&lt;</button>
                            <input type="number" class="wh-page-input" value="@warehousePageIndex" min="1" max="@WhTotalPages"
                                   @onchange="async (ChangeEventArgs e) => { if(int.TryParse(e.Value?.ToString(), out var p)) await GoToWhPage(p); }" />
                            <span>/ @WhTotalPages</span>
                            <button class="wh-page-btn" disabled="@(warehousePageIndex >= WhTotalPages)" @onclick="async () => await GoToWhPage(warehousePageIndex + 1)">&gt;</button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="wh-selector-footer">
                <button class="wh-footer-cancel" @onclick="CloseWarehouseSelector">取消</button>
            </div>
        </div>
    </div>
}

<!-- 仓库表格栏位设计对话框 -->
@if (showWhColumnSettingsDialog && showWarehouseDialog)
{
    <div class="column-settings-overlay" @onclick="CloseWhColumnSettings">
        <div class="column-settings-dialog" @onclick:stopPropagation>
            <div class="column-settings-header">
                <span>栏位设计</span>
                <button class="column-settings-close" @onclick="CloseWhColumnSettings">&times;</button>
            </div>
            <div class="column-settings-search">
                <input type="text" class="column-search-input" placeholder="搜索栏位原名..." @bind="whColumnSearchKeyword" @bind:event="oninput" />
            </div>
            <div class="column-settings-body">
                <table class="column-settings-table">
                    <thead>
                        <tr>
                            <th class="col-seq">项次</th>
                            <th class="col-visible">显示否</th>
                            <th class="col-original">原栏位名</th>
                            <th class="col-display">栏位标题</th>
                            <th class="col-width">宽度</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < FilteredWhColumnConfigs.Count; i++)
                        {
                            var col = FilteredWhColumnConfigs[i];
                            var idx = whColumnConfigs.IndexOf(col) + 1;
                            <tr>
                                <td class="col-seq">@idx</td>
                                <td class="col-visible">
                                    <label class="toggle-switch">
                                        <input type="checkbox" checked="@col.Visible" @onchange="@((ChangeEventArgs e) => col.Visible = (bool)e.Value!)" />
                                        <span class="toggle-slider"></span>
                                    </label>
                                </td>
                                <td class="col-original">@col.OriginalName</td>
                                <td class="col-display">
                                    <input type="text" class="col-title-input" value="@col.DisplayName"
                                           @onchange="@((ChangeEventArgs e) => col.DisplayName = e.Value?.ToString() ?? col.OriginalName)" />
                                </td>
                                <td class="col-width">
                                    <input type="number" class="col-width-input" value="@col.Width"
                                           min="0" max="500"
                                           @onchange="@((ChangeEventArgs e) => { if(int.TryParse(e.Value?.ToString(), out var w)) col.Width = w; })" />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="column-settings-footer">
                <div class="footer-left">
                    <button class="col-select-all" @onclick="SelectAllWhColumns">全选</button>
                    <button class="col-restore-default" @onclick="RestoreDefaultWhColumns">恢复默认</button>
                </div>
                <div class="footer-right">
                    <button class="col-btn-confirm" @onclick="ConfirmWhColumnSettings">确定</button>
                    <button class="col-btn-cancel" @onclick="CancelWhColumnSettings">取消</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    // ===== 参数 =====
    [Parameter] public string Value { get; set; } = "";
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public bool HideLabel { get; set; } = false;
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    // ===== 仓库选择器状态 =====
    private bool showWarehouseDialog = false;
    private string warehouseSearchKeyword = "";
    private List<WarehouseItem> warehouseData = new();
    private int warehousePageIndex = 1;
    private int warehousePageSize = 20;
    private int warehouseTotalCount = 0;
    private List<ColumnConfig> whColumnConfigs = new();
    private List<ColumnConfig> whDefaultColumnConfigs = new();
    private bool showWhColumnSettingsDialog = false;
    private string whColumnSearchKeyword = "";
    private const string WH_COLUMN_SETTINGS_KEY = "wms_column_settings_warehouse_selector";

    // ===== 数据模型 =====
    private class WarehouseItem
    {
        public string wh { get; set; } = "";
        public string name { get; set; } = "";
        public string wH_TYPE { get; set; } = "";
        public string attrib { get; set; } = "";
        public string dep { get; set; } = "";
        public string invalid { get; set; } = "";
    }

    private class WarehouseSearchResult
    {
        public List<WarehouseItem>? Items { get; set; }
        public int TotalCount { get; set; }
    }

    // ===== 栏位配置 =====
    private class ColumnConfig
    {
        public string FieldKey { get; set; } = "";
        public string OriginalName { get; set; } = "";
        public string DisplayName { get; set; } = "";
        public bool Visible { get; set; } = true;
        public int Width { get; set; } = 0;
        public int DefaultWidth { get; set; } = 0;
    }

    private void InitWhDefaultColumnConfigs()
    {
        whDefaultColumnConfigs = new List<ColumnConfig>
        {
            new() { FieldKey = "wh", OriginalName = "仓库代号", DisplayName = "仓库代号", Visible = true, Width = 100, DefaultWidth = 100 },
            new() { FieldKey = "name", OriginalName = "仓库名称", DisplayName = "仓库名称", Visible = true, Width = 120, DefaultWidth = 120 },
            new() { FieldKey = "wH_TYPE", OriginalName = "仓库类型", DisplayName = "仓库类型", Visible = true, Width = 80, DefaultWidth = 80 },
            new() { FieldKey = "attrib", OriginalName = "属性", DisplayName = "属性", Visible = false, Width = 60, DefaultWidth = 60 },
            new() { FieldKey = "dep", OriginalName = "部门", DisplayName = "部门", Visible = false, Width = 80, DefaultWidth = 80 },
            new() { FieldKey = "invalid", OriginalName = "作废否", DisplayName = "作废否", Visible = false, Width = 60, DefaultWidth = 60 }
        };
        whColumnConfigs = whDefaultColumnConfigs.Select(c => new ColumnConfig
        {
            FieldKey = c.FieldKey,
            OriginalName = c.OriginalName,
            DisplayName = c.DisplayName,
            Visible = c.Visible,
            Width = c.Width,
            DefaultWidth = c.DefaultWidth
        }).ToList();
    }

    // ===== 仓库选择器方法 =====
    private async Task OpenWarehouseSelector()
    {
        InitWhDefaultColumnConfigs();
        await LoadWhColumnSettings();
        warehouseSearchKeyword = "";
        warehousePageIndex = 1;
        await SearchWarehouse();
        showWarehouseDialog = true;
        StateHasChanged();
    }

    private void CloseWarehouseSelector()
    {
        showWarehouseDialog = false;
        StateHasChanged();
    }

    private async Task SearchWarehouse()
    {
        try
        {
            var url = $"{ApiConfig.BaseUrl}/api/warehouse/search?keyword={Uri.EscapeDataString(warehouseSearchKeyword ?? "")}&pageIndex={warehousePageIndex}&pageSize={warehousePageSize}";
            var jsonOptions = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var request = AuthHttpClient.CreateRequest(HttpMethod.Get, url, TokenProvider.Token);
            var responseMsg = await Http.SendAsync(request);

            if (responseMsg.IsSuccessStatusCode)
            {
                var json = await responseMsg.Content.ReadAsStringAsync();
                var result = System.Text.Json.JsonSerializer.Deserialize<WarehouseSearchResult>(json, jsonOptions);

                if (result != null)
                {
                    warehouseData = result.Items ?? new List<WarehouseItem>();
                    warehouseTotalCount = result.TotalCount;
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[WarehouseCodeInput] 查询仓库数据失败: {ex.Message}");
        }
        StateHasChanged();
    }

    private async Task SelectWarehouse(WarehouseItem item)
    {
        Value = item.wh;
        await ValueChanged.InvokeAsync(Value);
        showWarehouseDialog = false;
        StateHasChanged();
    }

    // ===== 栏位设置方法 =====
    private async Task LoadWhColumnSettings()
    {
        try
        {
            var json = await JS.InvokeAsync<string>("localStorage.getItem", WH_COLUMN_SETTINGS_KEY);
            if (!string.IsNullOrWhiteSpace(json))
            {
                var options = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
                var saved = System.Text.Json.JsonSerializer.Deserialize<List<ColumnConfig>>(json, options);
                if (saved != null && saved.Count > 0)
                {
                    foreach (var col in whColumnConfigs)
                    {
                        var savedCol = saved.FirstOrDefault(s => s.FieldKey == col.FieldKey);
                        if (savedCol != null)
                        {
                            col.Visible = savedCol.Visible;
                            col.DisplayName = !string.IsNullOrWhiteSpace(savedCol.DisplayName) ? savedCol.DisplayName : col.OriginalName;
                            col.Width = savedCol.Width >= 0 ? savedCol.Width : col.DefaultWidth;
                        }
                    }
                }
            }
        }
        catch { }
    }

    private async Task SaveWhColumnSettings()
    {
        try
        {
            var json = System.Text.Json.JsonSerializer.Serialize(whColumnConfigs);
            await JS.InvokeVoidAsync("localStorage.setItem", WH_COLUMN_SETTINGS_KEY, json);
        }
        catch { }
    }

    private void OpenWhColumnSettings()
    {
        whColumnSearchKeyword = "";
        showWhColumnSettingsDialog = true;
        StateHasChanged();
    }

    private void CloseWhColumnSettings()
    {
        showWhColumnSettingsDialog = false;
        StateHasChanged();
    }

    private void ConfirmWhColumnSettings()
    {
        showWhColumnSettingsDialog = false;
        _ = SaveWhColumnSettings();
        StateHasChanged();
    }

    private void CancelWhColumnSettings()
    {
        showWhColumnSettingsDialog = false;
        _ = LoadWhColumnSettings();
        StateHasChanged();
    }

    private void SelectAllWhColumns()
    {
        foreach (var col in whColumnConfigs) col.Visible = true;
        StateHasChanged();
    }

    private void RestoreDefaultWhColumns()
    {
        for (int i = 0; i < whColumnConfigs.Count && i < whDefaultColumnConfigs.Count; i++)
        {
            whColumnConfigs[i].Visible = whDefaultColumnConfigs[i].Visible;
            whColumnConfigs[i].DisplayName = whDefaultColumnConfigs[i].DisplayName;
            whColumnConfigs[i].Width = whDefaultColumnConfigs[i].Width;
        }
        StateHasChanged();
    }

    private List<ColumnConfig> FilteredWhColumnConfigs =>
        string.IsNullOrWhiteSpace(whColumnSearchKeyword)
            ? whColumnConfigs
            : whColumnConfigs.Where(c => c.OriginalName.Contains(whColumnSearchKeyword, StringComparison.OrdinalIgnoreCase) ||
                                          c.FieldKey.Contains(whColumnSearchKeyword, StringComparison.OrdinalIgnoreCase)).ToList();

    private int WhVisibleColumnCount => whColumnConfigs.Count(c => c.Visible);

    private object GetWhCellValue(WarehouseItem item, string fieldKey) => fieldKey switch
    {
        "wh" => item.wh,
        "name" => item.name,
        "wH_TYPE" => item.wH_TYPE,
        "attrib" => item.attrib,
        "dep" => item.dep,
        "invalid" => item.invalid,
        _ => ""
    };

    private int WhTotalPages => warehousePageSize > 0 ? (int)Math.Ceiling((double)warehouseTotalCount / warehousePageSize) : 1;

    private async Task GoToWhPage(int page)
    {
        if (page >= 1 && page <= WhTotalPages)
        {
            warehousePageIndex = page;
            await SearchWarehouse();
        }
    }
}
