    protected override async Task OnInitializedAsync()
    {
        await LoadExpandedState();
    }

    private async Task LoadExpandedState()
    {
        try
        {
            var savedState = await JS.InvokeAsync<string>("localStorage.getItem", StorageKey);
            if (!string.IsNullOrEmpty(savedState))
            {
                var keys = System.Text.Json.JsonSerializer.Deserialize<List<string>>(savedState);
                if (keys != null)
                {
                    expandedMenus = new HashSet<string>(keys);
                }
            }
            else
            {
                expandedMenus = new HashSet<string> { "warehouse", "system", "external" };
            }
        }
        catch
        {
            expandedMenus = new HashSet<string> { "warehouse", "system", "external" };
        }
    }

    private async Task SaveExpandedState()
    {
        try
        {
            var json = System.Text.Json.JsonSerializer.Serialize(expandedMenus.ToList());
            await JS.InvokeVoidAsync("localStorage.setItem", StorageKey, json);
        }
        catch
        {
        }
    }

    private async Task ToggleMenu(string key)
    {
        if (expandedMenus.Contains(key))
            expandedMenus.Remove(key);
        else
            expandedMenus.Add(key);

        await SaveExpandedState();
    }

