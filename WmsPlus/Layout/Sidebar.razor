@inject IJSRuntime JS
@using WmsPlus.Models

<div class="sidebar-component">
    @foreach (var menu in _allMenus)
    {
        <SidebarItem 
            Menu="@menu" 
            OnToggle="ToggleMenu" 
            ExpandedKeys="expandedMenus"
            OnSecondLevelClick="HandleSecondLevelClick"
            ActiveSecondLevelKey="@activeSecondLevelKey"
            IsCollapsed="@IsCollapsed"
        />
    }
</div>

