    public EventCallback<SubMenuItem> OnSecondLevelMenuClick { get; set; }

    // ★ 侧边栏收缩状态
    [Parameter]
    public bool IsCollapsed { get; set; } = false;

    private async Task HandleSecondLevelClick(SubMenuItem menuItem)
    {
        activeSecondLevelKey = menuItem.Title;
        StateHasChanged();
        
        await OnSecondLevelMenuClick.InvokeAsync(menuItem);
    }
