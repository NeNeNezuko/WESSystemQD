        // ===== 系统管理 - 系统设定 =====
        if (itemTitle == "系统设定")
        {
            OpenTab("system-setting", "系统设定");
            await CloseMegaMenu();
            return;
        }

        // ===== 系统管理 - 用户设定 =====
        if (itemTitle == "用户设定")
        {
            OpenTab("user-setting", "用户设定");
            await CloseMegaMenu();
            return;
        }

        await CloseMegaMenu();
    }

