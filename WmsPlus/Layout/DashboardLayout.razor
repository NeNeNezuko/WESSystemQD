@inherits LayoutComponentBase
@inject IJSRuntime JS

<div class="dashboard-layout">
    <!-- 左侧边栏 -->
    <div class="dashboard-sider @(isSidebarCollapsed ? "collapsed" : "")" @onclick:stopPropagation>
        <div class="sider-logo">
            @if (!isSidebarCollapsed)
            {
                <svg viewBox="0 0 126 24" width="126" height="24">
                    <text x="0" y="18" font-family="Arial, sans-serif" font-size="16" font-weight="700" fill="#FFFFFF">AI-WMS PLUS</text>
                </svg>
            }
            else
            {
                <svg viewBox="0 0 24 24" width="28" height="28">
                    <rect x="2" y="4" width="20" height="16" rx="3" fill="#FFFFFF"/>
                    <text x="12" y="17" text-anchor="middle" font-family="Arial, sans-serif" font-size="12" font-weight="700" fill="#1a3a5c">AI</text>
                </svg>
            }
        </div>
        <div class="sider-menu">
            <Sidebar OnSecondLevelMenuClick="HandleSecondLevelMenuClick" IsCollapsed="@isSidebarCollapsed" />
        </div>
    </div>

    <!-- 右侧内容区 -->
    <div class="dashboard-content-area" @onclick="HandleContentAreaClick">
        <!-- 顶部导航 -->
        <div class="dashboard-header">
            <div class="header-collapse-btn" @onclick="ToggleSidebarCollapse">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="#666666">
                    <rect x="3" y="6" width="18" height="2" rx="1"/>
                    <rect x="3" y="11" width="18" height="2" rx="1"/>
                    <rect x="3" y="16" width="18" height="2" rx="1"/>
                </svg>
            </div>
            <span class="header-title">天津渤海化学试剂测试账套</span>
            <div class="header-search" @onfocusin="HandleSearchFocus" @onfocusout="async () => { await Task.Delay(200); showSearchResults = false; StateHasChanged(); }">
                <input type="text" placeholder="菜单搜索..." class="header-search-input"
                       @bind="searchKeyword" @bind:event="oninput" @onkeyup="HandleSearchInput" />
                @if (showSearchResults && searchResults.Count > 0)
                {
                    <div class="search-dropdown">
                        <div class="search-results-header">共 @searchResults.Count 个匹配项</div>
                        @foreach (var result in searchResults.Take(10))
                        {
                            <div class="search-result-item" @onclick="() => HandleSearchResultClick(result)">
                                <span class="result-path">@result.SecondLevelTitle › </span>
                                <span class="result-title">@result.ThirdLevelTitle</span>
                            </div>
                        }
                        @if (searchResults.Count > 10)
                        {
                            <div class="search-more">...还有 @(searchResults.Count - 10) 个结果</div>
                        }
                    </div>
                }
                else if (showSearchResults && !string.IsNullOrEmpty(searchKeyword) && searchResults.Count == 0)
                {
                    <div class="search-dropdown">
                        <div class="search-empty">未找到匹配的菜单项</div>
                    </div>
                }
            </div>
            <div class="header-spacer"></div>
            <div class="header-actions">
                <div class="header-refresh">
                    <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="#666666" stroke-width="2">
                        <path d="M1 4v6h6M23 20v-6h-6"/>
                        <path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 0 1 3.51 15"/>
                    </svg>
                </div>
                <div class="header-user" @onclick="ToggleUserMenu" @onclick:stopPropagation>
                    <div class="header-avatar">@(AuthService.CurrentUser?.Name?.Substring(0,1)?.ToUpper() ?? "A")</div>
                    <span class="header-username">@(AuthService.CurrentUser?.Name ?? "ADMIN")</span>
                    <span style="font-size: 10px; color: #999;">▼</span>
                    
                    @if (showUserMenu)
                    {
                        <div class="user-dropdown-menu">
                            <div class="dropdown-item" @onclick="HandleChangePassword">
                                <svg viewBox="0 0 16 16" width="14" height="14" fill="#666">
                                    <rect x="3" y="7" width="10" height="7" rx="1.5" fill="none" stroke="#666" stroke-width="1.5"/>
                                    <path d="M5 7V5a3 3 0 0 1 6 0v2" fill="none" stroke="#666" stroke-width="1.5"/>
                                    <circle cx="8" cy="10.5" r="1" fill="#666"/>
                                </svg>
                                <span>修改密码</span>
                            </div>
                            <div class="dropdown-item dropdown-divider"></div>
                            <div class="dropdown-item logout" @onclick="HandleLogout">
                                <svg viewBox="0 0 16 16" width="14" height="14" fill="#ff4d4f">
                                    <path d="M10 12v-1h3v-2h-3V8l-4 4 4 4v-2z" fill="#ff4d4f"/>
                                    <rect x="2" y="3" width="9" height="10" rx="1" fill="none" stroke="#ff4d4f" stroke-width="1.5"/>
                                </svg>
                                <span style="color:#ff4d4f;">退出登录</span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- ★ 三级菜单面板 -->
        @if (showMegaMenu && selectedSecondLevelMenu != null)
        {
            <MegaMenuPanel 
                MenuData="@selectedSecondLevelMenu" 
                IsVisible="true"
                OnItemClick="HandleMegaMenuItemClick"
            />
        }

        <!-- 标签页栏 -->
        <div class="dashboard-tags">
            @foreach (var tab in tabs)
            {
                <div class="tag-item @(tab.IsActive ? "active" : "")" @onclick="() => SwitchTab(tab.Id)">
                    <span>@tab.Title</span>
                    @if (tab.Id != "dashboard")
                    {
                        <span class="tag-close" @onclick:stopPropagation @onclick="() => CloseTab(tab.Id)">×</span>
                    }
                </div>
            }
        </div>

        <!-- 主内容区 -->
        <div class="dashboard-main">
            <CascadingValue Value="OpenTab" Name="OpenTabCallback">
            <CascadingValue Value="NotifyFavoriteChanged" Name="OnFavoriteChanged">
            <CascadingValue Value="_favoriteVersion" Name="FavoriteVersion">
            <!-- 工作台（始终存在） -->
            <div style="display:@(activeTabId == "dashboard" ? "block" : "none")">
                @Body
            </div>
            <!-- 已打开的标签页（保持组件实例不被销毁，用 CSS 控制显隐） -->
            @if (tabs.Any(t => t.Id == "inbound-notice"))
            {
                <div style="display:@(activeTabId == "inbound-notice" ? "flex" : "none")">
                    <InboundNotice />
                </div>
            }
            @if (tabs.Any(t => t.Id == "inbound-order"))
            {
                <div style="display:@(activeTabId == "inbound-order" ? "flex" : "none")">
                    <InboundOrder />
                </div>
            }
            @if (tabs.Any(t => t.Id == "inbound-notice-change"))
            {
                <div style="display:@(activeTabId == "inbound-notice-change" ? "flex" : "none")">
                    <InboundNoticeChange />
                </div>
            }
            </CascadingValue>
            </CascadingValue>
            </CascadingValue>
        </div>
    </div>

    <!-- 搜索结果提示（未开发页面自动消失提示） -->
    @if (_showToast)
    {
        <div class="search-toast">
            <span class="search-toast-text">@_toastMessage</span>
        </div>
    }

    @if (showChangePasswordModal)
    {
        <div class="modal-overlay" @onclick="() => showChangePasswordModal = false">
            <div class="modal-content" @onclick:stopPropagation>
                <div class="modal-header">
                    <h3>修改密码</h3>
                    <span class="modal-close" @onclick="() => showChangePasswordModal = false">×</span>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(changePasswordMessage))
                    {
                        <div class="alert-message @(changePasswordMessage.Contains("成功") ? "success" : "error")">
                            @changePasswordMessage
                        </div>
                    }
                    <div class="form-group">
                        <label>原密码</label>
                        <input type="password" @bind="oldPassword" placeholder="请输入原密码" />
                    </div>
                    <div class="form-group">
                        <label>新密码</label>
                        <input type="password" @bind="newPassword" placeholder="请输入新密码" />
                    </div>
                    <div class="form-group">
                        <label>确认新密码</label>
                        <input type="password" @bind="confirmPassword" placeholder="请再次输入新密码" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => showChangePasswordModal = false">取消</button>
                    <button class="btn btn-primary" @onclick="HandleSubmitChangePassword">确定</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    @using WmsPlus.Models
    @inject AuthService AuthService
    @inject NavigationManager NavigationManager
    
    // ★ 三级菜单状态管理
    private bool showMegaMenu = false;
    private SubMenuItem? selectedSecondLevelMenu = null;

    // ★ 侧边栏收缩状态
    private bool isSidebarCollapsed = false;
    
    // ★ 用户菜单状态
    private bool showUserMenu = false;
    private bool showChangePasswordModal = false;
    private string oldPassword = "";
    private string newPassword = "";
    private string confirmPassword = "";
    private string changePasswordMessage = "";

    // ★ 搜索结果提示（未开发页面）
    private string _toastMessage = "";
    private bool _showToast = false;

    // ★ 标签页管理系统
    public class TabItem
    {
        public string Id { get; set; } = "";
        public string Title { get; set; } = "";
        public bool IsActive { get; set; } = false;
        public bool IsClosable { get; set; } = true;
    }

    private List<TabItem> tabs = new();
    private string activeTabId = "dashboard";

    // ★ 初始化标签页
    protected override void OnInitialized()
    {
        tabs.Add(new TabItem 
        { 
            Id = "dashboard", 
            Title = "工作台", 
            IsActive = true, 
            IsClosable = false 
        });
    }

    // ★ 收藏状态版本号（每次收藏变化+1，Dashboard检测到变化后重新加载）
    private int _favoriteVersion = 0;

    // ★ 通知收藏状态已变更（子组件调用此方法触发Dashboard刷新）
    private void NotifyFavoriteChanged()
    {
        _favoriteVersion++;
        StateHasChanged();
    }

    // ★ 打开新标签页
    private void OpenTab(string tabId, string title)
    {
        var existingTab = tabs.FirstOrDefault(t => t.Id == tabId);
        
        if (existingTab == null)
        {
            tabs.Add(new TabItem 
            { 
                Id = tabId, 
                Title = title, 
                IsActive = true,
                IsClosable = true
            });
        }
        
        SwitchTab(tabId);
    }

    // ★ 切换标签页
    private void SwitchTab(string tabId)
    {
        foreach (var tab in tabs)
        {
            tab.IsActive = (tab.Id == tabId);
        }
        activeTabId = tabId;
        StateHasChanged();
    }

    // ★ 关闭标签页
    private void CloseTab(string tabId)
    {
        var tabIndex = tabs.FindIndex(t => t.Id == tabId);
        if (tabIndex < 0) return;

        tabs.RemoveAt(tabIndex);

        if (activeTabId == tabId && tabs.Count > 0)
        {
            int newIndex = Math.Min(tabIndex, tabs.Count - 1);
            SwitchTab(tabs[newIndex].Id);
        }

        StateHasChanged();
    }

    // ★ 切换侧边栏收缩/展开
    private void ToggleSidebarCollapse()
    {
        isSidebarCollapsed = !isSidebarCollapsed;
        StateHasChanged();
    }

    // ★ 用户菜单功能
    private void ToggleUserMenu()
    {
        showUserMenu = !showUserMenu;
        if (showUserMenu)
        {
            CloseMegaMenu();
        }
        StateHasChanged();
    }

    private async Task HandleLogout()
    {
        AuthService.Logout();
        NavigationManager.NavigateTo("/login", true);
    }

    private void HandleChangePassword()
    {
        showChangePasswordModal = true;
        oldPassword = "";
        newPassword = "";
        confirmPassword = "";
        changePasswordMessage = "";
        showUserMenu = false;
        StateHasChanged();
    }

    private async Task HandleSubmitChangePassword()
    {
        changePasswordMessage = "";

        if (string.IsNullOrEmpty(newPassword))
        {
            changePasswordMessage = "新密码不能为空";
            return;
        }

        if (newPassword != confirmPassword)
        {
            changePasswordMessage = "两次输入的密码不一致";
            return;
        }

        var result = await AuthService.ChangePasswordAsync(
            AuthService.CurrentUser?.Name ?? "",
            oldPassword,
            newPassword
        );

        if (result.Success)
        {
            changePasswordMessage = "密码修改成功";
            await Task.Delay(1500);
            showChangePasswordModal = false;
        }
        else
        {
            changePasswordMessage = result.Message ?? "修改失败";
        }
        
        StateHasChanged();
    }

    // ★ 搜索功能状态
    private string searchKeyword = "";
    private bool showSearchResults = false;
    private List<SearchResult> searchResults = new();

    public class SearchResult
    {
        public string FirstLevelTitle { get; set; } = "";
        public string SecondLevelTitle { get; set; } = "";
        public string ThirdLevelTitle { get; set; } = "";
        public SubMenuItem? ParentMenuItem { get; set; }
    }

    // ★ 处理二级菜单点击（显示/隐藏三级菜单）
    private async Task HandleSecondLevelMenuClick(SubMenuItem menuItem)
    {
        if (menuItem.Children.Count > 0)
        {
            // 切换逻辑：如果点击同一个菜单项，则关闭
            if (showMegaMenu && selectedSecondLevelMenu?.Title == menuItem.Title)
            {
                await CloseMegaMenu();
            }
            else
            {
                selectedSecondLevelMenu = menuItem;
                showMegaMenu = true;
                
                await Task.Delay(50);
                StateHasChanged();
            }
        }
    }

    // ★ 处理三级菜单项点击
    private async Task HandleMegaMenuItemClick(string itemTitle)
    {
        Console.WriteLine($"[DashboardLayout] 三级菜单点击: {itemTitle}");

        if (itemTitle == "入库通知单")
        {
            OpenTab("inbound-notice", "入库通知单");
            await CloseMegaMenu();
            return;
        }

        if (itemTitle == "入库单")
        {
            OpenTab("inbound-order", "入库单");
            await CloseMegaMenu();
            return;
        }

        if (itemTitle == "入库通知变更单")
        {
            OpenTab("inbound-notice-change", "入库通知变更单");
            await CloseMegaMenu();
            return;
        }

        await CloseMegaMenu();
    }

    // ★ 点击内容区其他区域关闭三级菜单
    private async Task HandleContentAreaClick()
    {
        if (showMegaMenu)
        {
            await CloseMegaMenu();
        }
    }

    // ★ 关闭三级菜单
