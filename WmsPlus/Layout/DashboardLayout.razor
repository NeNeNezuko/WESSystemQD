        {
            foreach (var secondLevel in group.Children)
            {
                if (secondLevel.Children != null && secondLevel.Children.Count > 0)
                {
                    foreach (var thirdLevel in secondLevel.Children)
                    {
                        if (!thirdLevel.IsCategoryHeader)
                        {
                            results.Add(new SearchResult
                            {
                                FirstLevelTitle = group.Title,
                                SecondLevelTitle = secondLevel.Title,
                                ThirdLevelTitle = thirdLevel.Title,
                                ParentMenuItem = secondLevel
                            });
                        }
                    }
                }
            }
        }

        return results;
    }

    // ★ 搜索输入处理
    private async Task HandleSearchInput(KeyboardEventArgs e)
    {
        if (string.IsNullOrWhiteSpace(searchKeyword))
        {
            searchResults.Clear();
            showSearchResults = false;
            return;
        }

        var allItems = GetAllMenuItems();
        searchResults = allItems
            .Where(r => r.ThirdLevelTitle.Contains(searchKeyword, StringComparison.OrdinalIgnoreCase) ||
                       r.SecondLevelTitle.Contains(searchKeyword, StringComparison.OrdinalIgnoreCase) ||
                       r.FirstLevelTitle.Contains(searchKeyword, StringComparison.OrdinalIgnoreCase))
            .ToList();

        showSearchResults = true;
        StateHasChanged();
    }

    // ★ 搜索框获得焦点
    private void HandleSearchFocus()
    {
        if (!string.IsNullOrWhiteSpace(searchKeyword))
        {
            showSearchResults = true;
            StateHasChanged();
        }
    }

    // ★ 点击搜索结果
    private async Task HandleSearchResultClick(SearchResult result)
    {
        Console.WriteLine($"[搜索] 点击了: {result.FirstLevelTitle} > {result.SecondLevelTitle} > {result.ThirdLevelTitle}");

        bool handled = false;

        // 已开发的页面 → 打开/切换选项卡
        if (result.ThirdLevelTitle == "入库通知单")
        {
            OpenTab("inbound-notice", "入库通知单");
            handled = true;
        }
        else if (result.ThirdLevelTitle == "入库单")
        {
            OpenTab("inbound-order", "入库单");
            handled = true;
        }
        else if (result.ThirdLevelTitle == "入库通知变更单")
        {
            OpenTab("inbound-notice-change", "入库通知变更单");
            handled = true;
        }

        if (!handled)
        {
            // 未开发的页面 → 显示自动消失的提示
            _toastMessage = $"即将开发: {result.ThirdLevelTitle}";
            _showToast = true;
            StateHasChanged();
            await Task.Delay(2500);
            _showToast = false;
            StateHasChanged();
        }

        showSearchResults = false;
        searchKeyword = "";
        StateHasChanged();
    }
