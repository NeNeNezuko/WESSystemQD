    private async Task HandleContentAreaClick()
    {
        if (showMegaMenu)
        {
            await CloseMegaMenu();
        }
    }

    // ★ 关闭三级菜单
    private async Task CloseMegaMenu()
    {
        showMegaMenu = false;
        await Task.Delay(300); // 等待退场动画完成
        selectedSecondLevelMenu = null;
        StateHasChanged();
    }

