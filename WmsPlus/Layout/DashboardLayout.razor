@inherits LayoutComponentBase
@inject IJSRuntime JS

<div class="dashboard-layout">
    <!-- 左侧边栏 -->
    <div class="dashboard-sider @(isSidebarCollapsed ? "collapsed" : "")" @onclick:stopPropagation>
        <div class="sider-logo">
            @if (!isSidebarCollapsed)
            {
                <svg viewBox="0 0 126 24" width="126" height="24">
                    <text x="0" y="18" font-family="Arial, sans-serif" font-size="16" font-weight="700" fill="#FFFFFF">AI-WMS PLUS</text>
                </svg>
            }
            else
            {
                <svg viewBox="0 0 24 24" width="28" height="28">
                    <rect x="2" y="4" width="20" height="16" rx="3" fill="#FFFFFF"/>
                    <text x="12" y="17" text-anchor="middle" font-family="Arial, sans-serif" font-size="12" font-weight="700" fill="#1a3a5c">AI</text>
                </svg>
            }
        </div>
        <div class="sider-menu">
            <Sidebar OnSecondLevelMenuClick="HandleSecondLevelMenuClick" IsCollapsed="@isSidebarCollapsed" />
        </div>
    </div>

    <!-- 右侧内容区 -->
    <div class="dashboard-content-area" @onclick="HandleContentAreaClick">
        <!-- 顶部导航 -->
        <div class="dashboard-header">
            <div class="header-collapse-btn" @onclick="ToggleSidebarCollapse">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="#666666">
                    <rect x="3" y="6" width="18" height="2" rx="1"/>
                    <rect x="3" y="11" width="18" height="2" rx="1"/>
                    <rect x="3" y="16" width="18" height="2" rx="1"/>
                </svg>
            </div>
            <span class="header-title">天津渤海化学试剂测试账套</span>
            <div class="header-search" @onfocusin="HandleSearchFocus" @onfocusout="async () => { await Task.Delay(200); showSearchResults = false; StateHasChanged(); }">
                <input type="text" placeholder="菜单搜索..." class="header-search-input"
                       @bind="searchKeyword" @bind:event="oninput" @onkeyup="HandleSearchInput" />
                @if (showSearchResults && searchResults.Count > 0)
                {
                    <div class="search-dropdown">
                        <div class="search-results-header">共 @searchResults.Count 个匹配项</div>
                        @foreach (var result in searchResults.Take(10))
                        {
                            <div class="search-result-item" @onclick="() => HandleSearchResultClick(result)">
                                <span class="result-path">@result.SecondLevelTitle › </span>
                                <span class="result-title">@result.ThirdLevelTitle</span>
                            </div>
                        }
                        @if (searchResults.Count > 10)
                        {
                            <div class="search-more">...还有 @(searchResults.Count - 10) 个结果</div>
                        }
                    </div>
                }
                else if (showSearchResults && !string.IsNullOrEmpty(searchKeyword) && searchResults.Count == 0)
                {
                    <div class="search-dropdown">
                        <div class="search-empty">未找到匹配的菜单项</div>
                    </div>
                }
            </div>
            <div class="header-spacer"></div>
            <div class="header-actions">
                <div class="header-refresh">
                    <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="#666666" stroke-width="2">
                        <path d="M1 4v6h6M23 20v-6h-6"/>
                        <path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 0 1 3.51 15"/>
                    </svg>
                </div>
                <div class="header-user" @onclick="ToggleUserMenu" @onclick:stopPropagation>
                    <div class="header-avatar">@(AuthService.CurrentUser?.Name?.Substring(0,1)?.ToUpper() ?? "A")</div>
                    <span class="header-username">@(AuthService.CurrentUser?.Name ?? "ADMIN")</span>
                    <span style="font-size: 10px; color: #999;">▼</span>
                    
                    @if (showUserMenu)
                    {
                        <div class="user-dropdown-menu">
                            <div class="dropdown-item" @onclick="HandleChangePassword">
                                <svg viewBox="0 0 16 16" width="14" height="14" fill="#666">
                                    <rect x="3" y="7" width="10" height="7" rx="1.5" fill="none" stroke="#666" stroke-width="1.5"/>
                                    <path d="M5 7V5a3 3 0 0 1 6 0v2" fill="none" stroke="#666" stroke-width="1.5"/>
                                    <circle cx="8" cy="10.5" r="1" fill="#666"/>
                                </svg>
                                <span>修改密码</span>
                            </div>
                            <div class="dropdown-item dropdown-divider"></div>
                            <div class="dropdown-item logout" @onclick="HandleLogout">
                                <svg viewBox="0 0 16 16" width="14" height="14" fill="#ff4d4f">
                                    <path d="M10 12v-1h3v-2h-3V8l-4 4 4 4v-2z" fill="#ff4d4f"/>
                                    <rect x="2" y="3" width="9" height="10" rx="1" fill="none" stroke="#ff4d4f" stroke-width="1.5"/>
                                </svg>
                                <span style="color:#ff4d4f;">退出登录</span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- ★ 三级菜单面板 -->
        @if (showMegaMenu && selectedSecondLevelMenu != null)
        {
            <MegaMenuPanel 
                MenuData="@selectedSecondLevelMenu" 
                IsVisible="true"
                OnItemClick="HandleMegaMenuItemClick"
            />
        }

        <!-- 标签页栏 -->
        <div class="dashboard-tags">
            @foreach (var tab in tabs)
            {
                <div class="tag-item @(tab.IsActive ? "active" : "")" @onclick="() => SwitchTab(tab.Id)">
                    <span>@tab.Title</span>
                    @if (tab.Id != "dashboard")
                    {
                        <span class="tag-close" @onclick:stopPropagation @onclick="() => CloseTab(tab.Id)">×</span>
                    }
                </div>
            }
        </div>

        <!-- 主内容区 -->
        <div class="dashboard-main">
            <CascadingValue Value="OpenTab" Name="OpenTabCallback">
            <CascadingValue Value="NotifyFavoriteChanged" Name="OnFavoriteChanged">
            <CascadingValue Value="_favoriteVersion" Name="FavoriteVersion">
            <!-- 工作台（始终存在） -->
