    private async Task HandleSaveParam()
    {
        try
        {

var jsonOptions = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var body = new { paramSetting.PickerAutoAssign, paramSetting.ShowWaveDetailWindow };
            var json = System.Text.Json.JsonSerializer.Serialize(body);
            var content = new StringContent(json, System.Text.Encoding.UTF8, "application/json");
            var request = AuthHttpClient.CreateRequest(HttpMethod.Post, $"{ApiConfig.BaseUrl}/api/OutboundTaskAssignment/param-setting", TokenProvider.Token);
            request.Content = content;
            var responseMsg = await Http.SendAsync(request);
            var response = await responseMsg.Content.ReadFromJsonAsync<ApiResponse<bool>>(jsonOptions);
            if (response?.Success == true)
            {
                await JS.InvokeVoidAsync("alert", "保存成功");
            }
        }
        catch (Exception ex)
        {
            _logger?.LogError(ex, "保存参数设定失败");
        }
    }

    // ====== 数据加载 ======
    private async Task HandleSearch() { await LoadData(); }

    private async Task LoadData()
    {
        try
        {

var today = DateTime.Today;
            var dateFromStr = today.ToString("yyyy-MM-dd");
            var dateToStr = today.ToString("yyyy-MM-dd");
            if (!string.IsNullOrWhiteSpace(query.DateRange) && query.DateRange.Contains("\u2192"))
            {
                var parts = query.DateRange.Split('\u2192', StringSplitOptions.TrimEntries);
                if (parts.Length >= 2) { dateFromStr = parts[0]; dateToStr = parts[1]; }
            }

            string url = "";
            System.Text.Json.JsonSerializerOptions jsonOptions = new() { PropertyNameCaseInsensitive = true };

            if (activeInnerTabId == "notice")
            {
                url = $"{ApiConfig.BaseUrl}/api/OutboundTaskAssignment/outbound-notice/search?dateFrom={dateFromStr}&dateTo={dateToStr}";
                BuildCommonQueryParams(ref url);
                if (!string.IsNullOrWhiteSpace(query.CustomerCode)) url += $"&customerCode={Uri.EscapeDataString(query.CustomerCode)}";

                var request = AuthHttpClient.CreateRequest(HttpMethod.Get, url, TokenProvider.Token);
                var responseMsg = await Http.SendAsync(request);
                var response = await responseMsg.Content.ReadFromJsonAsync<ApiResponse<List<OutboundNoticeModel>>>(jsonOptions);
                if (response != null && response.Success && response.Data != null)
                {
                    mainDataSource = response.Data.Cast<dynamic>().ToList();
                }
                else { mainDataSource = new List<dynamic>(); }
            }
            else if (activeInnerTabId == "wave")
            {
                url = $"{ApiConfig.BaseUrl}/api/OutboundTaskAssignment/wave-manage/search?dateFrom={dateFromStr}&dateTo={dateToStr}";
                BuildCommonQueryParams(ref url);
                if (!string.IsNullOrWhiteSpace(query.WaveNumber)) url += $"&waveNumber={Uri.EscapeDataString(query.WaveNumber)}";

                var request = AuthHttpClient.CreateRequest(HttpMethod.Get, url, TokenProvider.Token);
                var responseMsg = await Http.SendAsync(request);
                var response = await responseMsg.Content.ReadFromJsonAsync<ApiResponse<List<WaveManageModel>>>(jsonOptions);
                if (response != null && response.Success && response.Data != null)
                {
                    mainDataSource = response.Data.Cast<dynamic>().ToList();
                }
                else { mainDataSource = new List<dynamic>(); }
            }
            else if (activeInnerTabId == "pick-task")
            {
                url = $"{ApiConfig.BaseUrl}/api/OutboundTaskAssignment/wave-pick-task-manage/search?dateFrom={dateFromStr}&dateTo={dateToStr}";
                BuildCommonQueryParams(ref url);
                if (!string.IsNullOrWhiteSpace(query.WaveNumber)) url += $"&waveNumber={Uri.EscapeDataString(query.WaveNumber)}";

                var request = AuthHttpClient.CreateRequest(HttpMethod.Get, url, TokenProvider.Token);
                var responseMsg = await Http.SendAsync(request);
                var response = await responseMsg.Content.ReadFromJsonAsync<ApiResponse<List<WavePickTaskManageModel>>>(jsonOptions);
                if (response != null && response.Success && response.Data != null)
                {
                    mainDataSource = response.Data.Cast<dynamic>().ToList();
                }
                else { mainDataSource = new List<dynamic>(); }
            }
            else if (activeInnerTabId == "param")
            {
                var request = AuthHttpClient.CreateRequest(HttpMethod.Get, $"{ApiConfig.BaseUrl}/api/OutboundTaskAssignment/param-setting", TokenProvider.Token);
                var responseMsg = await Http.SendAsync(request);
                var response = await responseMsg.Content.ReadFromJsonAsync<ApiResponse<ParamSettingModel>>(jsonOptions);
                if (response != null && response.Success && response.Data != null)
                {
                    paramSetting = response.Data;
                }
            }
        }
        catch (Exception ex)
        {
            _logger?.LogError(ex, "加载数据失败");
            mainDataSource = new List<dynamic>();
        }
        StateHasChanged();
    }

    private void BuildCommonQueryParams(ref string url)
    {
        if (!string.IsNullOrWhiteSpace(query.WarehouseCode)) url += $"&warehouseCode={Uri.EscapeDataString(query.WarehouseCode)}";
        if (!string.IsNullOrWhiteSpace(query.BusinessType)) url += $"&businessType={Uri.EscapeDataString(query.BusinessType)}";
        if (!string.IsNullOrWhiteSpace(query.ApplyOrderNumber)) url += $"&applyOrderNumber={Uri.EscapeDataString(query.ApplyOrderNumber)}";
        if (!string.IsNullOrWhiteSpace(query.NoticeNumber)) url += $"&noticeNumber={Uri.EscapeDataString(query.NoticeNumber)}";
        if (!string.IsNullOrWhiteSpace(query.BusinessOrderNumber)) url += $"&businessOrderNumber={Uri.EscapeDataString(query.BusinessOrderNumber)}";
    }

    // ====== 主表行点击 → 加载明细 ======
    private async Task HandleMainRowClick(dynamic item)
    {
        try
        {
            selectedMainRowKey = GetMainRowKey(item);
            string keyVal = selectedMainRowKey;

var jsonOptions = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            string url = "";

            if (activeInnerTabId == "notice")
            {
                url = $"{ApiConfig.BaseUrl}/api/OutboundTaskAssignment/outbound-notice/detail/{Uri.EscapeDataString(keyVal)}";
                var request = AuthHttpClient.CreateRequest(HttpMethod.Get, url, TokenProvider.Token);
                var responseMsg = await Http.SendAsync(request);
                var response = await responseMsg.Content.ReadFromJsonAsync<ApiResponse<List<OutboundNoticeDetailModel>>>(jsonOptions);
                detailDataSource = (response?.Success == true && response.Data != null) ? response.Data.Cast<dynamic>().ToList() : new List<dynamic>();
            }
            else if (activeInnerTabId == "wave")
            {
                url = $"{ApiConfig.BaseUrl}/api/OutboundTaskAssignment/wave-manage/detail/{Uri.EscapeDataString(keyVal)}";
                var request = AuthHttpClient.CreateRequest(HttpMethod.Get, url, TokenProvider.Token);
                var responseMsg = await Http.SendAsync(request);
                var response = await responseMsg.Content.ReadFromJsonAsync<ApiResponse<List<WaveManageDetailModel>>>(jsonOptions);
                detailDataSource = (response?.Success == true && response.Data != null) ? response.Data.Cast<dynamic>().ToList() : new List<dynamic>();
            }
            else if (activeInnerTabId == "pick-task")
            {
                url = $"{ApiConfig.BaseUrl}/api/OutboundTaskAssignment/wave-pick-task-manage/detail/{Uri.EscapeDataString(keyVal)}";
                var request = AuthHttpClient.CreateRequest(HttpMethod.Get, url, TokenProvider.Token);
                var responseMsg = await Http.SendAsync(request);
                var response = await responseMsg.Content.ReadFromJsonAsync<ApiResponse<List<WavePickTaskManageDetailModel>>>(jsonOptions);
                detailDataSource = (response?.Success == true && response.Data != null) ? response.Data.Cast<dynamic>().ToList() : new List<dynamic>();
            }

            StateHasChanged();
        }
        catch (Exception ex)
        {
            _logger?.LogError(ex, "加载明细数据失败");
        }
    }

    private string GetMainRowKey(dynamic item) => activeInnerTabId switch
    {
        "notice" => item.NoticeNo ?? "",
        "wave" => item.WaveNo ?? "",
        "pick-task" => item.TaskNo ?? "",
        _ => ""
    };

