    // ====== 栏位配置对话框 - 主表 ======
    private List<ColumnConfig> FilteredColumnConfigs =>
        string.IsNullOrWhiteSpace(columnSearchKeyword)
            ? CurrentMainColumns
            : CurrentMainColumns.Where(c => c.OriginalName.Contains(columnSearchKeyword, StringComparison.OrdinalIgnoreCase) ||
                                               c.FieldKey.Contains(columnSearchKeyword, StringComparison.OrdinalIgnoreCase)).ToList();

    private void OpenColumnSettings() { columnSearchKeyword = ""; showColumnSettingsDialog = true; StateHasChanged(); }
    private void CloseColumnSettings() { showColumnSettingsDialog = false; StateHasChanged(); }
    private void ConfirmColumnSettings() { showColumnSettingsDialog = false; StateHasChanged(); }
    private void CancelColumnSettings() { showColumnSettingsDialog = false; StateHasChanged(); }
    private void SelectAllColumns() { foreach (var col in CurrentMainColumns) col.Visible = true; StateHasChanged(); }
    private void RestoreDefaultColumns()
    {
        var defaults = activeInnerTabId switch
        {
            "notice" => noticeDefaultMainColumns,
            "wave" => waveDefaultMainColumns,
            "pick-task" => pickTaskDefaultMainColumns,
            _ => noticeDefaultMainColumns
        };
        var target = CurrentMainColumns;
        for (int i = 0; i < target.Count && i < defaults.Count; i++)
        { target[i].Visible = defaults[i].Visible; target[i].DisplayName = defaults[i].DisplayName; target[i].Width = defaults[i].Width; }
        StateHasChanged();
    }

    // ====== 栏位配置对话框 - 明细表 ======
    private List<ColumnConfig> FilteredDetailColumnConfigs =>
        string.IsNullOrWhiteSpace(detailColumnSearchKeyword)
            ? CurrentDetailColumns
            : CurrentDetailColumns.Where(c => c.OriginalName.Contains(detailColumnSearchKeyword, StringComparison.OrdinalIgnoreCase) ||
                                               c.FieldKey.Contains(detailColumnSearchKeyword, StringComparison.OrdinalIgnoreCase)).ToList();

    private void OpenDetailColumnSettings() { detailColumnSearchKeyword = ""; showDetailColumnSettingsDialog = true; StateHasChanged(); }
    private void CloseDetailColumnSettings() { showDetailColumnSettingsDialog = false; StateHasChanged(); }
