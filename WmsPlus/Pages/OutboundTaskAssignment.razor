    private void CancelDetailColumnSettings() { showDetailColumnSettingsDialog = false; StateHasChanged(); }
    private void SelectAllDetailColumns() { foreach (var col in CurrentDetailColumns) col.Visible = true; StateHasChanged(); }
    private void RestoreDefaultDetailColumns()
    {
        var defaults = activeInnerTabId switch
        {
            "notice" => noticeDefaultDetailColumns,
            "wave" => waveDefaultDetailColumns,
            "pick-task" => pickTaskDefaultDetailColumns,
            _ => noticeDefaultDetailColumns
        };
        var target = CurrentDetailColumns;
        for (int i = 0; i < target.Count && i < defaults.Count; i++)
        { target[i].Visible = defaults[i].Visible; target[i].DisplayName = defaults[i].DisplayName; target[i].Width = defaults[i].Width; }
        StateHasChanged();
    }

    // ====== 栏位配置类 ======
    private class ColumnConfig
    {
        public string FieldKey { get; set; } = "";
        public string OriginalName { get; set; } = "";
        public string DisplayName { get; set; } = "";
        public bool Visible { get; set; } = true;
        public int Width { get; set; } = 0;
        public int DefaultWidth { get; set; } = 0;
        public bool Sortable { get; set; } = false;
    }

    // API响应模型
    private class ApiResponse<T>
    {
        public bool Success { get; set; }
        public string Message { get; set; } = "";
        public T? Data { get; set; }
        public int Total { get; set; }
    }
