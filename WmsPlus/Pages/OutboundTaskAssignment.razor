@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@inject HttpClient Http
@inject ILogger<OutboundTaskAssignment> _logger
@inject TokenProvider TokenProvider

<link rel="stylesheet" href="css/outbound-task-assignment.css" />

<div class="ota-page" style="display:flex;flex-direction:column;flex:1 1 0%;overflow:hidden;">
    <!-- 顶部标题栏 -->
    <div class="page-header">
        <div class="header-left">
            <button class="favorite-btn @(isFavorited ? "favorited" : "")" @onclick="ToggleFavorite" title="收藏">
                <svg viewBox="0 0 24 24" width="24" height="24">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
                          fill="@((isFavorited ? "#FFD700" : "none"))"
                          stroke="@((isFavorited ? "#FFD700" : "#666666"))"
                          stroke-width="2"/>
                </svg>
            </button>
            <span class="page-title">出库任务分配作业</span>
        </div>
        <div class="header-right">
            <button class="collapse-btn-fixed @(isCollapsed ? "collapsed" : "")" @onclick="ToggleCollapse" title="@(isCollapsed ? "展开查询" : "收起查询")">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="#666666">
                    <rect x="3" y="6" width="18" height="2" rx="1"/>
                    <rect x="3" y="11" width="18" height="2" rx="1"/>
                    <rect x="3" y="16" width="18" height="2" rx="1"/>
                </svg>
            </button>
        </div>
    </div>

    <!-- 收藏成功提示 -->
    @if (showFavoriteSuccess)
    {
        <div class="favorite-success-toast">
            <div class="toast-content">
                <svg viewBox="0 0 16 16" width="16" height="16" fill="#52C41A">
                    <circle cx="8" cy="8" r="8"/>
                    <path d="M5 8l2 2 4-4" stroke="white" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>收藏成功</span>
            </div>
        </div>
    }

    <!-- 内层选项卡栏 -->
    <div class="inner-tab-bar">
        <div class="tab-list">
            @foreach (var tab in innerTabs)
            {
                <div class="tab-item @(tab.Id == activeInnerTabId ? "active" : "")" @onclick="() => SwitchInnerTab(tab.Id)">
                    @tab.Title
                </div>
            }
        </div>
        <div class="tab-toolbar">
            @if (activeInnerTabId == "notice")
            {
                <button class="toolbar-action-btn primary" disabled title="生成波次">生成波次</button>
                <button class="toolbar-action-btn" disabled title="插单">插单</button>
            }
        </div>
    </div>

    <!-- 主内容区域 -->
    <div class="page-content">
        <!-- 左侧查询区域（Tab1-3共用，Tab4隐藏） -->
        @if (activeInnerTabId != "param")
        {
            <div class="query-panel @(isCollapsed ? "collapsed" : "")">
                <div class="query-header">
                    <span class="query-title">查询</span>
                    <button class="query-settings-btn" title="设置" @onclick="ToggleSettingsMenu">
                        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="#999999" stroke-width="2">
                            <circle cx="12" cy="12" r="3"/>
                            <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2.83 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2.83 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/>
                        </svg>
                    </button>
                    @if (showSettingsMenu)
                    {
                        <div class="settings-dropdown" @onclick:stopPropagation>
                            <div class="settings-dropdown-item" @onclick="BatchAddCondition">批次添加条件</div>
                            <div class="settings-dropdown-item" @onclick="AddSingleCondition">添加单一条件</div>
                            <div class="settings-dropdown-item" @onclick="CustomCondition">自定义条件</div>
                            <div class="settings-dropdown-item" @onclick="RemoveCondition">移除条件</div>
                            <div class="settings-dropdown-item" @onclick="SaveConditionValues">保存条件值</div>
                        </div>
                    }
                </div>

                <div class="query-form">
                    @if (activeInnerTabId == "notice")
                    {
                        <!-- ====== Tab1: 出库通知 查询条件 ====== -->
                        <!-- 来源单据类型 -->
                        <div class="form-item">
                            <label class="form-label">来源单据类型</label>
                            <div class="checkbox-group">
                                <label class="checkbox-label"><input type="checkbox" checked="@sourceTypeNotice" @onchange="(e) => sourceTypeNotice = (bool)e.Value!" /> 出库通知单</label>
                                <label class="checkbox-label"><input type="checkbox" checked="@sourceTypeTransfer" @onchange="(e) => sourceTypeTransfer = (bool)e.Value!" /> 调拨通知单</label>
                            </div>
                        </div>
                        <!-- 预计日期范围 -->
                        <DateRangeInput @bind-Value="query.DateRange" />
                        <!-- 预计到货时间 -->
                        <DateRangeInput @bind-Value="query.EstimateArriveRange" />
                        <!-- 仓库 -->
                        <WarehouseCodeInput @bind-Value="query.WarehouseCode" />
                        <!-- 业务类型（出库） -->
                        <CkTypeInput @bind-Value="query.BusinessType" />
                        <!-- 申请单号 -->
                        <div class="form-item">
                            <label class="form-label">申请单号</label>
                            <input type="text" class="form-input" placeholder="" @bind="query.ApplyOrderNumber" />
                        </div>
                        <!-- 通知单号 -->
                        <div class="form-item">
                            <label class="form-label">通知单号</label>
                            <input type="text" class="form-input" placeholder="" @bind="query.NoticeNumber" />
                        </div>
                        <!-- 业务单号 -->
                        <div class="form-item">
                            <label class="form-label">业务单号</label>
                            <input type="text" class="form-input" placeholder="" @bind="query.BusinessOrderNumber" />
                        </div>
                        <!-- 处理状态 -->
                        <div class="form-item">
                            <label class="form-label">处理状态</label>
                            <div class="select-wrapper">
                                <select class="form-select" @bind="query.ProcessStatus">
                                    <option value="待处理">待处理</option>
                                    <option value="全部">全部</option>
                                </select>
                                <svg class="select-arrow" viewBox="0 0 12 12" width="10" height="10" fill="#999999">
                                    <path d="M2 4l4 4 4-4"/>
                                </svg>
                            </div>
                        </div>
                        <!-- 跟踪否 -->
                        <div class="form-item">
                            <label class="form-label">跟踪否</label>
                            <div class="input-with-icon">
                                <input type="text" class="form-input" placeholder="待处理" value="待处理" readonly />
                                <svg class="input-icon-search" viewBox="0 0 16 16" width="14" height="14" fill="#999999">
                                    <circle cx="7" cy="7" r="5"/><line x1="11" y1="11" x2="15" y2="15" stroke="#999999" stroke-width="1.5"/>
                                </svg>
                            </div>
                        </div>
                        <!-- 收货点 -->
                        <div class="form-item">
                            <label class="form-label">收货点</label>
                            <div class="input-with-icon">
                                <input type="text" class="form-input" placeholder="" @bind="query.ReceivePoint" />
                                <svg class="input-icon-search" viewBox="0 0 16 16" width="14" height="14" fill="#999999">
                                    <circle cx="7" cy="7" r="5"/><line x1="11" y1="11" x2="15" y2="15" stroke="#999999" stroke-width="1.5"/>
                                </svg>
                            </div>
                        </div>
                        <!-- 客户代号 -->
                        <CustomerCodeInput @bind-Value="query.CustomerCode" />
                        <!-- 拣货员 -->
                        <div class="form-item">
                            <label class="form-label">拣货员</label>
                            <div class="input-with-icon">
                                <input type="text" class="form-input" placeholder="" @bind="query.PickerName" />
                                <svg class="input-icon-search" viewBox="0 0 16 16" width="14" height="14" fill="#999999">
                                    <circle cx="7" cy="7" r="5"/><line x1="11" y1="11" x2="15" y2="15" stroke="#999999" stroke-width="1.5"/>
                                </svg>
                            </div>
                        </div>
                    }
                    else if (activeInnerTabId == "wave")
                    {
                        <!-- ====== Tab2: 波次管理 查询条件 ====== -->
                        <DateRangeInput @bind-Value="query.DateRange" />
                        <DateRangeInput @bind-Value="query.EstimateArriveRange" />
                        <!-- 波次单号 -->
                        <div class="form-item">
                            <label class="form-label">波次单号</label>
                            <input type="text" class="form-input" placeholder="" @bind="query.WaveNumber" />
                        </div>
                        <WarehouseCodeInput @bind-Value="query.WarehouseCode" />
                        <CkTypeInput @bind-Value="query.BusinessType" />
                        <div class="form-item">
                            <label class="form-label">申请单号</label>
                            <input type="text" class="form-input" placeholder="" @bind="query.ApplyOrderNumber" />
                        </div>
                        <div class="form-item">
                            <label class="form-label">通知单号</label>
                            <input type="text" class="form-input" placeholder="" @bind="query.NoticeNumber" />
                        </div>
                        <div class="form-item">
                            <label class="form-label">业务单号</label>
                            <input type="text" class="form-input" placeholder="" @bind="query.BusinessOrderNumber" />
                        </div>
                        <!-- 进单等级 -->
                        <div class="form-item">
                            <label class="form-label">进单等级</label>
                            <div class="checkbox-group">
                                <label class="checkbox-label"><input type="checkbox" checked="@priorityQuery" @onchange="(e) => priorityQuery = (bool)e.Value!" /> 查询</label>
                                <label class="checkbox-label"><input type="checkbox" checked="@priorityUrgent" @onchange="(e) => priorityUrgent = (bool)e.Value!" /> 紧急</label>
                                <label class="checkbox-label"><input type="checkbox" checked="@priorityEmergency" @onchange="(e) => priorityEmergency = (bool)e.Value!" /> 特急</label>
                                <label class="checkbox-label"><input type="checkbox" checked="@priorityClosed" @onchange="(e) => priorityClosed = (bool)e.Value!" /> 已结</label>
                            </div>
                        </div>
                        <!-- 流程状态 -->
                        <div class="form-item">
                            <label class="form-label">流程状态</label>
                            <div class="checkbox-group">
                                <label class="checkbox-label"><input type="checkbox" checked="@flowUnassigned" @onchange="(e) => flowUnassigned = (bool)e.Value!" /> 未派工</label>
                                <label class="checkbox-label"><input type="checkbox" checked="@flowClosed" @onchange="(e) => flowClosed = (bool)e.Value!" /> 已结案</label>
                            </div>
                        </div>
                        <!-- 收货点 -->
                        <div class="form-item">
                            <label class="form-label">收货点</label>
                            <div class="input-with-icon">
                                <input type="text" class="form-input" placeholder="" @bind="query.ReceivePoint" />
                                <svg class="input-icon-search" viewBox="0 0 16 16" width="14" height="14" fill="#999999">
                                    <circle cx="7" cy="7" r="5"/><line x1="11" y1="11" x2="15" y2="15" stroke="#999999" stroke-width="1.5"/>
                                </svg>
                            </div>
                        </div>
                        <!-- 打印列示 -->
                        <div class="form-item">
                            <label class="form-label">打印列示</label>
                            <div class="select-wrapper">
                                <select class="form-select" @bind="query.PrintListType">
                                    <option value="全部">全部</option>
                                    <option value="已打印">已打印</option>
                                    <option value="未打印">未打印</option>
                                </select>
                                <svg class="select-arrow" viewBox="0 0 12 12" width="10" height="10" fill="#999999">
                                    <path d="M2 4l4 4 4-4"/>
                                </svg>
                            </div>
                        </div>
                    }
                    else if (activeInnerTabId == "pick-task")
                    {
                        <!-- ====== Tab3: 波次拣货任务管理 查询条件 ====== -->
                        <DateRangeInput @bind-Value="query.DateRange" />
                        <DateRangeInput @bind-Value="query.EstimateArriveRange" />
                        <div class="form-item">
                            <label class="form-label">波次单号</label>
                            <input type="text" class="form-input" placeholder="" @bind="query.WaveNumber" />
                        </div>
                        <WarehouseCodeInput @bind-Value="query.WarehouseCode" />
                        <CkTypeInput @bind-Value="query.BusinessType" />
                        <div class="form-item">
                            <label class="form-label">申请单号</label>
                            <input type="text" class="form-input" placeholder="" @bind="query.ApplyOrderNumber" />
                        </div>
                        <div class="form-item">
                            <label class="form-label">通知单号</label>
                            <input type="text" class="form-input" placeholder="" @bind="query.NoticeNumber" />
                        </div>
                        <div class="form-item">
                            <label class="form-label">业务单号</label>
                            <input type="text" class="form-input" placeholder="" @bind="query.BusinessOrderNumber" />
                        </div>
                        <!-- 进单等级 -->
                        <div class="form-item">
                            <label class="form-label">进单等级</label>
                            <div class="checkbox-group">
                                <label class="checkbox-label"><input type="checkbox" checked="@pickPriorityQuery" @onchange="(e) => pickPriorityQuery = (bool)e.Value!" /> 查询</label>
                                <label class="checkbox-label"><input type="checkbox" checked="@pickPriorityUrgent" @onchange="(e) => pickPriorityUrgent = (bool)e.Value!" /> 紧急</label>
                                <label class="checkbox-label"><input type="checkbox" checked="@pickPriorityEmergency" @onchange="(e) => pickPriorityEmergency = (bool)e.Value!" /> 特急</label>
                            </div>
                        </div>
                        <!-- 流程状态(派工) -->
                        <div class="form-item">
                            <label class="form-label">流程状态</label>
                            <div class="select-wrapper">
                                <select class="form-select" @bind="query.ProcessStatusPg">
                                    <option value="未派工">未派工</option>
                                    <option value="已派工">已派工</option>
                                    <option value="全部">全部</option>
                                </select>
                                <svg class="select-arrow" viewBox="0 0 12 12" width="10" height="10" fill="#999999">
                                    <path d="M2 4l4 4 4-4"/>
                                </svg>
                            </div>
                        </div>
                        <!-- 收货点 -->
                        <div class="form-item">
                            <label class="form-label">收货点</label>
                            <div class="input-with-icon">
                                <input type="text" class="form-input" placeholder="" @bind="query.ReceivePoint" />
                                <svg class="input-icon-search" viewBox="0 0 16 16" width="14" height="14" fill="#999999">
                                    <circle cx="7" cy="7" r="5"/><line x1="11" y1="11" x2="15" y2="15" stroke="#999999" stroke-width="1.5"/>
                                </svg>
                            </div>
                        </div>
                        <!-- 打印列示 -->
                        <div class="form-item">
                            <label class="form-label">打印列示</label>
                            <div class="select-wrapper">
                                <select class="form-select" @bind="query.PrintListType">
                                    <option value="全部">全部</option>
                                    <option value="已打印">已打印</option>
                                    <option value="未打印">未打印</option>
                                </select>
                                <svg class="select-arrow" viewBox="0 0 12 12" width="10" height="10" fill="#999999">
                                    <path d="M2 4l4 4 4-4"/>
                                </svg>
                            </div>
                        </div>
                    }

                    <!-- 查询按钮（Tab1-3共用） -->
                    <div class="form-item query-btn-wrapper">
                        <button class="query-submit-btn" @onclick="HandleSearch">
                            <svg viewBox="0 0 16 16" width="16" height="16" fill="white" stroke="white" stroke-width="1.5">
                                <circle cx="7" cy="7" r="5"/>
                                <line x1="11" y1="11" x2="15" y2="15"/>
                            </svg>
                            <span>查询</span>
                        </button>
                    </div>
                </div>
            </div>
        }

        <!-- 右侧数据区域 -->
        <div class="table-panel">
            @if (activeInnerTabId == "param")
            {
                <!-- ====== Tab4: 参数设定 ====== -->
                <div class="param-setting-area">
                    <div class="param-item">
                        <label class="param-checkbox-label">
                            <input type="checkbox" @bind="paramSetting.PickerAutoAssign" />
                            <span>拣货员先为空(受串自动化)</span>
                        </label>
                    </div>
                    <div class="param-item">
                        <label class="param-checkbox-label">
                            <input type="checkbox" @bind="paramSetting.ShowWaveDetailWindow" />
                            <span>生成波次-显示明细窗口</span>
                        </label>
                    </div>
                </div>
            }
            else
            {
                <!-- ====== Tab1-3: 双表格布局 ====== -->

                <!-- 上方：主表格 -->
                <div class="upper-table-section">
                    <div class="section-title">@CurrentMainTableTitle</div>
                    <div class="data-table-container">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    @foreach (var col in CurrentMainColumns.Where(c => c.Visible))
                                    {
                                        var widthStyle = col.Width > 0 ? $"width:{col.Width}px" : "";
                                        if (col.Sortable)
                                        {
                                            <th style="@widthStyle" class="sortable">
                                                @col.DisplayName
                                                <svg viewBox="0 0 12 12" width="10" height="10" fill="#999999">
                                                    <path d="M6 3l3 3H9l-3-3-3 3H3z"/>
                                                    <path d="M6 9l-3-3h3l3 3h-3z" opacity="0.3"/>
                                                </svg>
                                            </th>
                                        }
                                        else
                                        {
                                            <th style="@widthStyle">@col.DisplayName</th>
                                        }
                                    }
                                    <th class="col-action" style="display:flex;align-items:center;justify-content:space-between;white-space:nowrap;">
                                        <span>操作</span>
                                        <button class="column-settings-btn" title="栏位设置" @onclick="OpenColumnSettings">
                                            <svg viewBox="0 0 16 16" width="14" height="14" fill="#666666">
                                                <path d="M2 3h4v2H2V3zm0 4h4v2H2V7zm0 4h4v2H2v-2zm6-8h6v2H8V3zm0 4h6v2H8V7zm0 4h6v2H8v-2z"/>
                                            </svg>
                                        </button>
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (mainDataSource.Count == 0)
                                {
                                    <tr><td colspan="@(CurrentMainVisibleCount + 1)" class="empty-data-cell"><div class="empty-data"><svg viewBox="0 0 64 64" width="80" height="80" fill="none"><rect x="8" y="8" width="48" height="48" rx="8" fill="#F5F5F5" stroke="#E0E0E0" stroke-width="1"/><path d="M24 28h16M24 36h12" stroke="#D9D9D9" stroke-width="2" stroke-linecap="round"/></svg><p class="empty-text">暂无数据</p></div></td></tr>
                                }
                                else
                                {
                                    @foreach (var item in mainDataSource)
                                    {
                                        <tr class="@(selectedMainRowKey == GetMainRowKey(item) ? "selected-row" : "")" @onclick="() => HandleMainRowClick(item)">
                                            @foreach (var col in CurrentMainColumns.Where(c => c.Visible))
                                            {
                                                var wStyle = col.Width > 0 ? $"width:{col.Width}px" : "";
                                                <td style="@wStyle">@GetMainCellValue(item, col.FieldKey)</td>
                                            }
                                            <td><button class="action-btn" title="操作" @onclick:stopPropagation><svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="#1890FF" stroke-width="1.5"><circle cx="8" cy="3" r="1" fill="#1890FF"/><circle cx="8" cy="8" r="1" fill="#1890FF"/><circle cx="8" cy="13" r="1" fill="#1890FF"/></svg></button></td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                    <!-- 分页信息 -->
                    <div class="table-pagination">
                        <span class="pagination-info">共 @mainDataSource.Count 笔记录</span>
                        <div class="pagination-controls">
                            <button class="pagination-btn" disabled="@(mainPageIndex <= 0)" @onclick="() => { if(mainPageIndex > 0) { mainPageIndex--; StateHasChanged(); } }">&lt;</button>
                            <input type="number" class="pagination-page-input" @bind="mainPageIndex" @bind:event="oninput" min="0" />
                            <button class="pagination-btn" @onclick="() => { mainPageIndex++; StateHasChanged(); }">&gt;</button>
                        </div>
                    </div>
                </div>

                <!-- 下方：明细表格 -->
                <div class="lower-table-section">
                    <div class="section-title">@CurrentDetailTableTitle</div>
                    <div class="data-table-container">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    @foreach (var col in CurrentDetailColumns.Where(c => c.Visible))
                                    {
                                        var widthStyle = col.Width > 0 ? $"width:{col.Width}px" : "";
                                        <th style="@widthStyle">@col.DisplayName</th>
                                    }
                                    <th class="col-action" style="display:flex;align-items:center;justify-content:space-between;white-space:nowrap;">
                                        <span>操作</span>
                                        <button class="column-settings-btn" title="栏位设置" @onclick="OpenDetailColumnSettings">
                                            <svg viewBox="0 0 16 16" width="14" height="14" fill="#666666">
                                                <path d="M2 3h4v2H2V3zm0 4h4v2H2V7zm0 4h4v2H2v-2zm6-8h6v2H8V3zm0 4h6v2H8V7zm0 4h6v2H8v-2z"/>
                                            </svg>
                                        </button>
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (detailDataSource.Count == 0)
                                {
                                    <tr><td colspan="@(CurrentDetailVisibleCount + 1)" class="empty-data-cell"><div class="empty-data"><svg viewBox="0 0 64 64" width="80" height="80" fill="none"><rect x="8" y="8" width="48" height="48" rx="8" fill="#F5F5F5" stroke="#E0E0E0" stroke-width="1"/><path d="M24 28h16M24 36h12" stroke="#D9D9D9" stroke-width="2" stroke-linecap="round"/></svg><p class="empty-text">暂无数据</p></div></td></tr>
                                }
                                else
                                {
                                    @foreach (var item in detailDataSource)
                                    {
                                        <tr>
                                            @foreach (var col in CurrentDetailColumns.Where(c => c.Visible))
                                            {
                                                var wStyle = col.Width > 0 ? $"width:{col.Width}px" : "";
                                                <td style="@wStyle">@GetDetailCellValue(item, col.FieldKey)</td>
                                            }
                                            <td></td>
                                        </tr>
                                    }
                                }
                            </tbody>
