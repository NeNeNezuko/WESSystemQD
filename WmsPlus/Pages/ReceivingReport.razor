@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@inject HttpClient Http
@inject ILogger<ReceivingReport> _logger
@inject TokenProvider TokenProvider

<link rel="stylesheet" href="css/receiving-report.css" />

<div class="receiving-report-page" style="display:flex;flex-direction:column;flex:1 1 0%;overflow:hidden;">
    <!-- 顶部标题栏 -->
    <div class="page-header">
        <div class="header-left">
            <button class="favorite-btn @(isFavorited ? "favorited" : "")" @onclick="ToggleFavorite" title="收藏">
                <svg viewBox="0 0 24 24" width="24" height="24">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
                          fill="@((isFavorited ? "#FFD700" : "none"))"
                          stroke="@((isFavorited ? "#FFD700" : "#666666"))"
                          stroke-width="2"/>
                </svg>
            </button>
            <span class="page-title">收货单报表</span>
        </div>
        <div class="header-right">
            <button class="header-toolbar-btn" @onclick="HandleTypeConfig">
                <svg viewBox="0 0 16 16" width="14" height="14" fill="#666666">
                    <path d="M3 3h10v2H3V3zm0 4h7v2H3V7zm0 4h10v2H3v-2z" stroke="#666666" stroke-width="1" fill="none"/>
                </svg>
                <span>类型</span>
            </button>
            <button class="header-toolbar-btn" @onclick="HandleExport">
                <svg viewBox="0 0 16 16" width="14" height="14" fill="#666666">
                    <path d="M8 12V4m0 0L5 7m3-3l3 3" stroke="#666666" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M2 11v2a1 1 0 001 1h10a1 1 0 001-1v-2" stroke="#666666" stroke-width="1.5" fill="none" stroke-linecap="round"/>
                </svg>
                <span>导出Excel</span>
            </button>
            <button class="header-toolbar-btn" @onclick="HandlePrint">
                <svg viewBox="0 0 16 16" width="14" height="14" fill="#666666">
                    <path d="M4 2h8v3H4V2zM3 6h10v6H3V6z" stroke="#666666" stroke-width="1.2" fill="none"/>
                    <line x1="6" y1="13" x2="6" y2="15" stroke="#666666" stroke-width="1.2"/>
                    <line x1="10" y1="13" x2="10" y2="15" stroke="#666666" stroke-width="1.2"/>
                </svg>
                <span>打印</span>
            </button>
            <button class="header-toolbar-btn" @onclick="HandleColumnDesign">
                <svg viewBox="0 0 16 16" width="14" height="14" fill="#666666">
                    <path d="M2 3h12v2H2V3zm0 4h12v2H2V7zm0 4h12v2H2v-2z" stroke="#666666" stroke-width="1" fill="none"/>
                </svg>
                <span>类型设计</span>
            </button>
            <button class="collapse-btn-fixed @(isCollapsed ? "collapsed" : "")" @onclick="ToggleCollapse" title="@(isCollapsed ? "展开查询" : "收起查询")">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="#666666">
                    <rect x="3" y="6" width="18" height="2" rx="1"/>
                    <rect x="3" y="11" width="18" height="2" rx="1"/>
                    <rect x="3" y="16" width="18" height="2" rx="1"/>
                </svg>
            </button>
        </div>
    </div>

    <!-- 收藏成功提示 -->
    @if (showFavoriteSuccess)
    {
        <div class="favorite-success-toast">
            <div class="toast-content">
                <svg viewBox="0 0 16 16" width="16" height="16" fill="#52C41A">
                    <circle cx="8" cy="8" r="8"/>
                    <path d="M5 8l2 2 4-4" stroke="white" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>收藏成功</span>
            </div>
        </div>
    }

    <!-- 主内容区域 -->
    <div class="page-content">
        <!-- 左侧查询区域 -->
        <div class="query-panel @(isCollapsed ? "collapsed" : "")">
            <div class="query-header">
                <span class="query-title">查询</span>
                <button class="query-settings-btn" title="设置" @onclick="ToggleSettingsMenu">
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="#999999" stroke-width="2">
                        <circle cx="12" cy="12" r="3"/>
                        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/>
                    </svg>
                </button>
                @if (showSettingsMenu)
                {
                    <div class="settings-dropdown" @onclick:stopPropagation>
                        <div class="settings-dropdown-item" @onclick="BatchAddCondition">批次添加条件</div>
                        <div class="settings-dropdown-item" @onclick="AddSingleCondition">添加单一条件</div>
                        <div class="settings-dropdown-item" @onclick="CustomCondition">自定义条件</div>
                        <div class="settings-dropdown-item" @onclick="RemoveCondition">移除条件</div>
                        <div class="settings-dropdown-item" @onclick="SaveConditionValues">保存条件值</div>
                    </div>
                }
            </div>

            <div class="query-form">
                <!-- 收货日期 -->
                <DateRangeInput @bind-Value="query.DateRange" Label="制货日期" />

                <!-- 转入单号 起/止 -->
                <div class="form-item-fused">
                    <div class="fused-row">
                        <label class="form-label">转入单号 起</label>
                        <input type="text" class="fused-input" placeholder="" @bind="query.BilNoFrom" />
                    </div>
                    <div class="fused-divider"></div>
                    <div class="fused-row">
                        <label class="form-label">转入单号 止</label>
                        <input type="text" class="fused-input" placeholder="" @bind="query.BilNoTo" />
                    </div>
                </div>

                <!-- 单据号码 起/止 -->
                <div class="form-item-fused">
                    <div class="fused-row">
                        <label class="form-label">单据号码 起</label>
                        <input type="text" class="fused-input" placeholder="" @bind="query.ShNoFrom" />
                    </div>
                    <div class="fused-divider"></div>
                    <div class="fused-row">
                        <label class="form-label">单据号码 止</label>
                        <input type="text" class="fused-input" placeholder="" @bind="query.ShNoTo" />
                    </div>
                </div>

                <!-- 货品代号 起/止 -->
                <div class="form-item-fused">
                    <div class="fused-row">
                        <label class="form-label">货品代号 起</label>
                        <div class="fused-input-area">
                            <input type="text" class="fused-input" placeholder="" @bind="query.PrdNoFrom" />
                            <button class="fused-search-btn" title="选择货品" @onclick="OpenPrdFromSelector">
                                <svg viewBox="0 0 14 14" width="12" height="12" fill="none" stroke="#999999" stroke-width="1.5">
                                    <circle cx="6" cy="6" r="4"/>
                                    <line x1="9" y1="9" x2="13" y2="13"/>
                                </svg>
                            </button>
                        </div>
                    </div>
                    <div class="fused-divider"></div>
                    <div class="fused-row">
                        <label class="form-label">货品代号 止</label>
                        <div class="fused-input-area">
                            <input type="text" class="fused-input" placeholder="" @bind="query.PrdNoTo" />
                            <button class="fused-search-btn" title="选择货品" @onclick="OpenPrdToSelector">
                                <svg viewBox="0 0 14 14" width="12" height="12" fill="none" stroke="#999999" stroke-width="1.5">
                                    <circle cx="6" cy="6" r="4"/>
                                    <line x1="9" y1="9" x2="13" y2="13"/>
                                </svg>
                            </button>
                        </div>
                    </div>
                </div>

                <!-- 货品名称 + 模糊checkbox -->
                <div class="form-item">
                    <label class="form-label">货品名称</label>
                    <div style="display:flex;align-items:center;gap:8px;flex:1;">
                        <input type="text" class="form-input" placeholder="" @bind="query.PrdName" style="flex:1;" />
                        <label style="display:flex;align-items:center;cursor:pointer;font-size:13px;color:#666666;white-space:nowrap;">
                            <input type="checkbox" style="width:16px;height:16px;margin-right:4px;" checked="@query.PrdNameFuzzy" @onchange="@((ChangeEventArgs e) => query.PrdNameFuzzy = (bool)e.Value!)" />
                            模糊
                        </label>
                    </div>
                </div>

                <!-- 仓库 + 含下架checkbox -->
                <div class="form-item">
                    <label class="form-label">仓库</label>
                    <div style="display:flex;align-items:center;gap:8px;flex:1;">
                        <WarehouseCodeInput @bind-Value="query.Wh" style="flex:1;" />
                        <label style="display:flex;align-items:center;cursor:pointer;font-size:13px;color:#666666;white-space:nowrap;">
                            <input type="checkbox" style="width:16px;height:16px;margin-right:4px;" checked="@query.IncludeOffShelf" @onchange="@((ChangeEventArgs e) => query.IncludeOffShelf = (bool)e.Value!)" />
                            含下架
                        </label>
                    </div>
                </div>

                <!-- 查询按钮 -->
                <div class="form-item query-btn-wrapper">
                    <button class="query-submit-btn" @onclick="HandleSearch">
                        <svg viewBox="0 0 16 16" width="16" height="16" fill="white" stroke="white" stroke-width="1.5">
                            <circle cx="7" cy="7" r="5"/>
                            <line x1="11" y1="11" x2="15" y2="15"/>
                        </svg>
                        <span>查询</span>
                    </button>
                </div>
            </div>
        </div>

        <!-- 右侧数据表格区域 -->
        <div class="table-panel">
            <!-- 顶部工具栏：内层选项卡 -->
            <div class="table-toolbar">
                <div class="toolbar-left">
                    <!-- 内层选项卡：明细表 | 统计表 -->
                    <div class="inner-tab-bar-inline">
                        <div class="inner-tab-item @(activeInnerTab == "detail" ? "active" : "")" @onclick="SwitchToDetailTab">
                            明细表
                        </div>
                        <div class="inner-tab-item @(activeInnerTab == "summary" ? "active" : "")" @onclick="SwitchToSummaryTab">
                            统计表
                        </div>
                    </div>
                </div>
            </div>

            <!-- 数据表格 -->
            <div class="data-table-container">
                <table class="data-table">
                    <thead>
                        <tr>
                            @foreach (var col in columnConfigs.Where(c => c.Visible))
                            {
                                var widthStyle = col.Width > 0 ? $"width:{col.Width}px" : "";
                                if (col.Sortable)
                                {
                                    <th style="@widthStyle" class="sortable">
                                        @col.DisplayName
                                        <svg viewBox="0 0 12 12" width="10" height="10" fill="#999999">
                                            <path d="M6 3l3 3H9l-3-3-3 3H3z"/>
                                            <path d="M6 9l-3-3h3l3 3h-3z" opacity="0.3"/>
                                        </svg>
                                    </th>
                                }
                                else
                                {
                                    <th style="@widthStyle">@col.DisplayName</th>
                                }
                            }
                            <th class="col-action" style="display:flex;align-items:center;justify-content:space-between;white-space:nowrap;">
                                <span>操作</span>
                                <button class="column-settings-btn" title="栏位设置" @onclick="OpenColumnSettings">
                                    <svg viewBox="0 0 16 16" width="14" height="14" fill="#666666">
                                        <path d="M2 3h4v2H2V3zm0 4h4v2H2V7zm0 4h4v2H2v-2zm6-8h6v2H8V3zm0 4h6v2H8V7zm0 4h6v2H8v-2z"/>
                                    </svg>
                                </button>
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (detailDataSource.Count == 0)
                        {
                            <tr><td colspan="@(VisibleColumnCount + 1)" class="empty-data-cell"><div class="empty-data"><svg viewBox="0 0 64 64" width="80" height="80" fill="none"><rect x="8" y="8" width="48" height="48" rx="8" fill="#F5F5F5" stroke="#E0E0E0" stroke-width="1"/><path d="M24 28h16M24 36h12" stroke="#D9D9D9" stroke-width="2" stroke-linecap="round"/></svg><p class="empty-text">暂无数据</p></div></td></tr>
                        }
                        else
                        {
                            @foreach (var item in detailDataSource)
                            {
                                <tr>
                                    @foreach (var col in columnConfigs.Where(c => c.Visible))
                                    {
                                        var widthStyle = col.Width > 0 ? $"width:{col.Width}px" : "";
                                        <td style="@widthStyle">@GetCellValue(item, col.FieldKey)</td>
                                    }
                                    <td><button class="action-btn" title="操作"><svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="#1890FF" stroke-width="1.5"><circle cx="8" cy="3" r="1" fill="#1890FF"/><circle cx="8" cy="8" r="1" fill="#1890FF"/><circle cx="8" cy="13" r="1" fill="#1890FF"/></svg></button></td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            <!-- 底部统计栏 -->
            <div class="table-footer">
                <div class="footer-left">
                    <span class="group-label">分组统计字段：</span>
                    <label class="group-checkbox">
                        <input type="checkbox" checked="@groupByDate" @onchange="@((ChangeEventArgs e) => groupByDate = (bool)e.Value!)" />
                        制表日期
                    </label>
                    <label class="group-checkbox">
                        <input type="checkbox" checked="@groupByYear" @onchange="@((ChangeEventArgs e) => groupByYear = (bool)e.Value!)" />
                        制表日期-年
                    </label>
                    <label class="group-checkbox">
                        <input type="checkbox" checked="@groupByQuarter" @onchange="@((ChangeEventArgs e) => groupByQuarter = (bool)e.Value!)" />
                        制表日期-季
                    </label>
                    <label class="group-checkbox">
                        <input type="checkbox" checked="@groupByMonth" @onchange="@((ChangeEventArgs e) => groupByMonth = (bool)e.Value!)" />
                        制表日期-月
                    </label>
                    <label class="group-checkbox">
                        <input type="checkbox" checked="@groupByWeek" @onchange="@((ChangeEventArgs e) => groupByWeek = (bool)e.Value!)" />
                        制表日期-周
                    </label>
                    <label class="group-checkbox">
                        <input type="checkbox" checked="@groupByDay" @onchange="@((ChangeEventArgs e) => groupByDay = (bool)e.Value!)" />
                        货品代号
                    </label>
                    <label class="group-checkbox">
                        <input type="checkbox" checked="@groupByPrdNo" @onchange="@((ChangeEventArgs e) => groupByPrdNo = (bool)e.Value!)" />
                        仓库
                    </label>
                    <label class="group-checkbox">
                        <input type="checkbox" checked="@groupByWh" @onchange="@((ChangeEventArgs e) => groupByWh = (bool)e.Value!)" />
                        客户名称
                    </label>
                </div>
                <div class="footer-right">
                    <span class="record-count">共 @totalRecords 笔记录</span>
                    <button class="page-btn" @onclick="GoToFirstPage" disabled="@(currentPage <= 1)">
                        <svg viewBox="0 0 16 16" width="12" height="12" fill="#666666">
                            <path d="M10 12L6 8l4-4" stroke="#666666" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                            <path d="M13 12L9 8l4-4" stroke="#666666" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </button>
                    <button class="page-btn" @onclick="GoToPrevPage" disabled="@(currentPage <= 1)">
                        <svg viewBox="0 0 16 16" width="12" height="12" fill="#666666">
                            <path d="M10 12L6 8l4-4" stroke="#666666" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </button>
                    <button class="page-btn" @onclick="GoToNextPage" disabled="@(currentPage >= totalPages)">
                        <svg viewBox="0 0 16 16" width="12" height="12" fill="#666666">
                            <path d="M6 4l4 4-4 4" stroke="#666666" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </button>
                    <button class="page-btn" @onclick="GoToLastPage" disabled="@(currentPage >= totalPages)">
                        <svg viewBox="0 0 16 16" width="12" height="12" fill="#666666">
                            <path d="M6 4l4 4-4 4" stroke="#666666" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                            <path d="M3 4l4 4-4 4" stroke="#666666" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 导出对话框 -->
@if (showExportDialog)
{
    <div class="export-dialog-overlay" @onclick="CancelExport">
        <div class="export-dialog" @onclick:stopPropagation>
            <div class="export-dialog-header">
                <span>导出 Excel</span>
                <button class="export-dialog-close" @onclick="CancelExport">&times;</button>
            </div>
            <div class="export-dialog-body">
                <label class="export-label">文件名</label>
                <input type="text" class="export-filename-input" @bind="exportFileName" @bind:event="oninput" />
            </div>
            <div class="export-dialog-footer">
                <button class="export-btn-cancel" @onclick="CancelExport">取消</button>
                <button class="export-btn-confirm" @onclick="ConfirmExport">确认导出</button>
            </div>
        </div>
    </div>
}

<!-- 栏位设计对话框 -->
@if (showColumnSettingsDialog)
{
    <div class="column-settings-overlay" @onclick="CloseColumnSettings">
        <div class="column-settings-dialog" @onclick:stopPropagation>
            <div class="column-settings-header">
                <span>栏位设计</span>
                <button class="column-settings-close" @onclick="CloseColumnSettings">&times;</button>
            </div>
            <div class="column-settings-search">
                <input type="text" class="column-search-input" placeholder="搜索栏位原名..." @bind="columnSearchKeyword" @bind:event="oninput" />
            </div>
            <div class="column-settings-body">
                <table class="column-settings-table">
                    <thead>
                        <tr>
                            <th class="col-seq">项次</th>
                            <th class="col-visible">显示否</th>
                            <th class="col-original">原栏位名</th>
                            <th class="col-display">栏位标题</th>
                            <th class="col-width">宽度</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < FilteredColumnConfigs.Count; i++)
                        {
                            var col = FilteredColumnConfigs[i];
                            var idx = columnConfigs.IndexOf(col) + 1;
                            <tr>
                                <td class="col-seq">@idx</td>
                                <td class="col-visible">
                                    <label class="toggle-switch">
                                        <input type="checkbox" checked="@col.Visible" @onchange="@((ChangeEventArgs e) => col.Visible = (bool)e.Value!)" />
                                        <span class="toggle-slider"></span>
                                    </label>
                                </td>
                                <td class="col-original">@col.OriginalName</td>
                                <td class="col-display">
                                    <input type="text" class="col-title-input" value="@col.DisplayName"
                                           @onchange="@((ChangeEventArgs e) => col.DisplayName = e.Value?.ToString() ?? col.OriginalName)" />
                                </td>
                                <td class="col-width">
                                    <input type="number" class="col-width-input" value="@col.Width"
                                           min="0" max="500"
                                           @onchange="@((ChangeEventArgs e) => { if(int.TryParse(e.Value?.ToString(), out var w)) col.Width = w; })" />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="column-settings-footer">
                <div class="footer-left">
                    <button class="col-select-all" @onclick="SelectAllColumns">全选</button>
                    <button class="col-restore-default" @onclick="RestoreDefaultColumns">恢复默认</button>
                </div>
                <div class="footer-right">
                    <button class="col-btn-confirm" @onclick="ConfirmColumnSettings">确定</button>
                    <button class="col-btn-cancel" @onclick="CancelColumnSettings">取消</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- 货品选择器对话框 -->
@if (showProductDialog)
{
    <div class="prd-selector-overlay" @onclick="CloseProductSelector">
        <div class="prd-selector-dialog" @onclick:stopPropagation>
            <div class="prd-selector-header">
                <span>货品(PRDT)</span>
                <button class="prd-close-btn" @onclick="CloseProductSelector">&times;</button>
            </div>
            <div class="prd-selector-body">
                <div class="prd-left-panel">
                    <div class="prd-filter-title">过滤</div>
                    <input type="text" class="prd-search-input" placeholder="输入关键字查询" @bind="productSearchKeyword" @bind:event="oninput" @onkeyup="@((KeyboardEventArgs e) => { if(e.Key == "Enter") _ = SearchProduct(); })" />
                    <button class="prd-query-btn" @onclick="@(() => _ = SearchProduct())">查询</button>
                </div>
                <div class="prd-right-panel">
                    <table class="prd-data-table">
                        <thead>
                            <tr>
                                <th class="prd-col-action">操作</th>
                                <th style="width:50px">项次</th>
                                <th>货品代号</th>
                                <th>货品名称</th>
                                <th>规格</th>
                                <th>单位</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (productData.Count == 0)
                            {
                                <tr><td colspan="6" style="text-align:center;padding:30px;color:#999;">暂无数据</td></tr>
                            }
                            else
                            {
                                @for (int i = 0; i < productData.Count; i++)
                                {
                                    var item = productData[i];
                                    var rowIdx = (productPageIndex - 1) * productPageSize + i + 1;
                                    <tr>
                                        <td><button class="prd-select-btn" @onclick="() => SelectProduct(item)">选择</button></td>
                                        <td style="text-align:center">@rowIdx</td>
                                        <td>@item.PRD_NO</td>
                                        <td>@item.NAME</td>
                                        <td>@item.SNM</td>
                                        <td>@item.UT</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                    <div class="prd-pagination">
                        <span class="prd-total-info">共 @productTotalCount 笔记录</span>
                        <div class="prd-page-controls">
                            <button class="prd-page-btn" disabled="@(productPageIndex <= 1)" @onclick="async () => await GoToPrdPage(productPageIndex - 1)">&lt;</button>
                            <input type="number" class="prd-page-input" value="@productPageIndex" min="1" max="@PrdTotalPages"
                                   @onchange="async (ChangeEventArgs e) => { if(int.TryParse(e.Value?.ToString(), out var p)) await GoToPrdPage(p); }" />
                            <span>/ @PrdTotalPages</span>
                            <button class="prd-page-btn" disabled="@(productPageIndex >= PrdTotalPages)" @onclick="async () => await GoToPrdPage(productPageIndex + 1)">&gt;</button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="prd-selector-footer">
                <button class="prd-footer-cancel" @onclick="CloseProductSelector">取消</button>
            </div>
        </div>
    </div>
}


