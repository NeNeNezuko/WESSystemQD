    private async Task SearchProduct()
    {
        try
        {
            var url = $"http://localhost:5102/api/warehouse/prdsearch?keyword={Uri.EscapeDataString(productSearchKeyword ?? "")}&pageIndex={productPageIndex}&pageSize={productPageSize}";
            var jsonOptions = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var request = AuthHttpClient.CreateRequest(HttpMethod.Get, url, TokenProvider.Token);
            var responseMsg = await Http.SendAsync(request);

            if (responseMsg.IsSuccessStatusCode)
            {
                var json = await responseMsg.Content.ReadAsStringAsync();
                var result = System.Text.Json.JsonSerializer.Deserialize<PrdSearchResult>(json, jsonOptions);

                if (result != null)
                {
                    productData = result.Items ?? new List<PrdItem>();
                    productTotalCount = result.TotalCount;
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ReceivingReport] 查询货品数据失败: {ex.Message}");
        }
        StateHasChanged();
    }

    private void SelectProduct(PrdItem item)
    {
        if (activePrdSelector == "from")
            query.PrdNoFrom = item.PRD_NO;
        else if (activePrdSelector == "to")
            query.PrdNoTo = item.PRD_NO;

        showProductDialog = false;
        StateHasChanged();
    }

