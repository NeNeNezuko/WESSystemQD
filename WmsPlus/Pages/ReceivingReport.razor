    private async Task LoadData()
    {
        try
        {
            const string ApiBaseUrl = "http://localhost:5102";
            var url = $"{ApiBaseUrl}/api/ReceivingReport/search";
            var tabType = activeInnerTab == "detail" ? "detail" : "summary";

            // 构建查询参数
            if (!string.IsNullOrWhiteSpace(query.DateRange) && query.DateRange.Contains("\u2192"))
            {
                var parts = query.DateRange.Split("\u2192", StringSplitOptions.TrimEntries);
                if (parts.Length >= 2)
                {
                    url += $"?dateFrom={Uri.EscapeDataString(parts[0])}&dateTo={Uri.EscapeDataString(parts[1])}";
                }
            }
            if (!string.IsNullOrWhiteSpace(query.BilNoFrom))
                url += $"{(url.Contains("?") ? "&" : "?")}bilNoFrom={Uri.EscapeDataString(query.BilNoFrom)}";
            if (!string.IsNullOrWhiteSpace(query.BilNoTo))
                url += $"&bilNoTo={Uri.EscapeDataString(query.BilNoTo)}";
            if (!string.IsNullOrWhiteSpace(query.ShNoFrom))
                url += $"&shNoFrom={Uri.EscapeDataString(query.ShNoFrom)}";
            if (!string.IsNullOrWhiteSpace(query.ShNoTo))
                url += $"&shNoTo={Uri.EscapeDataString(query.ShNoTo)}";
            if (!string.IsNullOrWhiteSpace(query.PrdNoFrom))
                url += $"&prdNoFrom={Uri.EscapeDataString(query.PrdNoFrom)}";
            if (!string.IsNullOrWhiteSpace(query.PrdNoTo))
                url += $"&prdNoTo={Uri.EscapeDataString(query.PrdNoTo)}";
            if (!string.IsNullOrWhiteSpace(query.PrdName))
                url += $"&prdName={Uri.EscapeDataString(query.PrdName)}&prdNameFuzzy={query.PrdNameFuzzy.ToString().ToLower()}";
            if (!string.IsNullOrWhiteSpace(query.Wh))
                url += $"&wh={Uri.EscapeDataString(query.Wh)}&includeOffShelf={query.IncludeOffShelf.ToString().ToLower()}";

            // 分页参数（确保以 ? 或 & 正确连接）
            var separator = url.Contains("?") ? "&" : "?";
            url += $"{separator}page={currentPage}&pageSize={pageSize}&tabType={tabType}";

            var jsonOptions = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var request = AuthHttpClient.CreateRequest(HttpMethod.Get, url, TokenProvider.Token);
            var responseMsg = await Http.SendAsync(request);

            if (activeInnerTab == "detail")
            {
