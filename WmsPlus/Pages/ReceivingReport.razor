    {
        if (currentPage <= 1) return;
        currentPage--;
        await LoadData();
    }

    private async Task GoToNextPage()
    {
        if (currentPage >= totalPages) return;
        currentPage++;
        await LoadData();
    }

    private async Task GoToLastPage()
    {
        if (currentPage >= totalPages) return;
        currentPage = totalPages;
