    // ===== 明细选项卡切换 =====
    private void SwitchToProductTab()
    {
        activeDetailTab = "product";
        StateHasChanged();
    }

    private void SwitchToBarcodeTab()
    {
        activeDetailTab = "barcode";
        StateHasChanged();
    }

    // ===== 货品明细操作 =====
    private void AddProductRow()
    {
        productItemSeq++;
        productItems.Add(new InboundNoticeAddProductItem { ItemNo = productItemSeq });
        StateHasChanged();
    }

    // ===== 条码明细操作 =====
    private void AddBarcodeRow()
    {
        barcodeItemSeq++;
        barcodeItems.Add(new InboundNoticeAddBarcodeItem { ItemNo = barcodeItemSeq });
        StateHasChanged();
    }

    private void RemoveBarcodeRow(int itemNo)
    {
        barcodeItems.RemoveAll(x => x.ItemNo == itemNo);
        StateHasChanged();
    }
