        "StandardBoxQty" => item.StandardBoxQty?.ToString() ?? "",
        "TailBoxQty" => item.TailBoxQty?.ToString() ?? "",
        "LabelCount" => item.LabelCount?.ToString() ?? "",
        "PrintBarcode" => item.PrintBarcode,
        "CusNo" => item.CusNo,
        "SoNo" => item.SoNo,
        "NoPickFlag" => item.NoPickFlag,
        "SourceNo" => item.SourceNo,
        "ApplyDocType" => item.ApplyDocType,
        "ApplyNo" => item.ApplyNo,
        _ => ""
    };

