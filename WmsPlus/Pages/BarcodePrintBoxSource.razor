    private async Task HandleSearch() { await LoadData(); }
    private void HandleBatchPrint() { }

    private async Task LoadData()
    {
        try
        {
            var url = $"{ApiConfig.BaseUrl}/api/BarcodePrintBoxSource/search?";
            if (!string.IsNullOrWhiteSpace(query.SourceDoc)) url += ($"&sourceDoc={Uri.EscapeDataString(query.SourceDoc)}");
            if (!string.IsNullOrWhiteSpace(query.SourceNo)) url += ($"&sourceNo={Uri.EscapeDataString(query.SourceNo)}");
            if (!string.IsNullOrWhiteSpace(query.PrdNo)) url += ($"&prdNo={Uri.EscapeDataString(query.PrdNo)}");
            if (!string.IsNullOrWhiteSpace(query.CusName)) url += ($"&cusName={Uri.EscapeDataString(query.CusName)}");
            var jsonOptions = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var request = AuthHttpClient.CreateRequest(HttpMethod.Get, url, TokenProvider.Token);
            var responseMsg = await Http.SendAsync(request);
            var response = await responseMsg.Content.ReadFromJsonAsync<ApiResponse<List<BarcodePrintBoxSourceModel>>>(jsonOptions);
            if (response != null && response.Success && response.Data != null) dataSource = response.Data;
            else dataSource = new List<BarcodePrintBoxSourceModel>();
        }
        catch (Exception ex) { _logger?.LogError(ex, "加载依来源单打印箱条码数据失败"); dataSource = new List<BarcodePrintBoxSourceModel>(); }
        StateHasChanged();
    }

    // ===== 栏位配置 =====
    private class ColumnConfig
    {
        public string FieldKey { get; set; } = "";
        public string OriginalName { get; set; } = "";
        public string DisplayName { get; set; } = "";
        public bool Visible { get; set; } = true;
        public int Width { get; set; } = 0;
        public int DefaultWidth { get; set; } = 0;
        public bool Sortable { get; set; } = false;
    }

    private const string COLUMN_SETTINGS_KEY = "wms_column_settings_barcode_print_box_source";

    private void InitDefaultColumnConfigs()
    {
        defaultColumnConfigs = new List<ColumnConfig>
        {
            new() { FieldKey = "SeqNo", OriginalName = "项次", DisplayName = "项次", Visible = true, Width = 50, DefaultWidth = 50 },
            new() { FieldKey = "PrdNo", OriginalName = "货品代号", DisplayName = "货品代号", Visible = true, Width = 100, DefaultWidth = 100, Sortable = true },
