@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@inject HttpClient Http
@inject ILogger<BarcodePrintBoxSource> _logger
@inject TokenProvider TokenProvider

<link rel="stylesheet" href="css/barcode-print-box-source.css" />

<div class="barcode-print-box-source-page">
    <div class="page-header">
        <div class="header-left">
            <button class="favorite-btn @(isFavorited ? "favorited" : "")" @onclick="ToggleFavorite" title="收藏">
                <svg viewBox="0 0 24 24" width="24" height="24">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
                          fill="@((isFavorited ? "#FFD700" : "none"))"
                          stroke="@((isFavorited ? "#FFD700" : "#666666"))"
                          stroke-width="2"/>
                </svg>
            </button>
            <span class="page-title">依来源单打印箱条码</span>
        </div>
        <div class="header-center">
            <button class="collapse-btn-fixed @(isCollapsed ? "collapsed" : "")" @onclick="ToggleCollapse"
                    title="@(isCollapsed ? "展开查询" : "收起查询")">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="#666666">
                    <rect x="3" y="6" width="18" height="2" rx="1"/>
                    <rect x="3" y="11" width="18" height="2" rx="1"/>
                    <rect x="3" y="16" width="18" height="2" rx="1"/>
                </svg>
            </button>
</div>
<div class="header-right">
        
                    <!-- 内层选项卡 -->
                    <div class="inner-tab-bar-inline">
                        @foreach (var tab in innerTabs)
                        {
                            <div class="inner-tab-item @(tab.IsActive ? "active" : "")" @onclick="() => SwitchInnerTab(tab.Id)">
                                @tab.Title
                            </div>
                        }
                    </div>
                    <button class="header-action-btn primary" @onclick="HandleBatchPrint">批次打印</button>
                    <button class="header-action-btn" @onclick="HandleSearch">查询</button>
                </div>
    </div>

    @if (showFavoriteSuccess)
    {
        <div class="favorite-success-toast">
            <div class="toast-content">
                <svg viewBox="0 0 16 16" width="16" height="16" fill="#52C41A">
                    <circle cx="8" cy="8" r="8"/>
                    <path d="M5 8l2 2 4-4" stroke="white" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>收藏成功</span>
            </div>
        </div>
    }

    <div class="page-content">
        @* ===== 打印&查询选项卡内容 ===== *@
        <div style="display:@(innerTabs[0].IsActive ? "flex" : "none");flex-direction:column;flex:1;gap:0;overflow:hidden;">
        <div class="query-panel @(isCollapsed ? "collapsed" : "")">
            <div class="query-header">
                <span class="query-title">查询</span>
                <button class="query-settings-btn" title="设置" @onclick="ToggleSettingsMenu">
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="#999999" stroke-width="2">
                        <circle cx="12" cy="12" r="3"/>
                        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2.83 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/>
                    </svg>
                </button>
                @if (showSettingsMenu)
                {
                    <div class="settings-dropdown" @onclick:stopPropagation>
                        <div class="settings-dropdown-item" @onclick="BatchAddCondition">批次添加条件</div>
                        <div class="settings-dropdown-item" @onclick="AddSingleCondition">添加单一条件</div>
                        <div class="settings-dropdown-item" @onclick="CustomCondition">自定义条件</div>
                        <div class="settings-dropdown-item" @onclick="RemoveCondition">移除条件</div>
                        <div class="settings-dropdown-item" @onclick="SaveConditionValues">保存条件值</div>
                    </div>
                }
            </div>
            <div class="query-form">
                <div class="form-item">
                    <label class="form-label">来源单据</label>
                    <div class="select-wrapper">
                        <select class="form-select" @bind="query.SourceDoc">
                            <option value="">全部</option>
                            <option value="RK">入库通知单</option>
                            <option value="CK">出库通知单</option>
                            <option value="IC">调拨单</option>
                        </select>
                        <span class="select-arrow">
                            <svg viewBox="0 0 12 12" width="10" height="6" fill="#999999">
                                <path d="M1 2l5 5 5-5"/>
                            </svg>
                        </span>
                    </div>
                </div>
                <div class="form-item">
                    <label class="form-label">来源单号</label>
                    <input type="text" class="form-input" placeholder="" @bind="query.SourceNo" />
                </div>
                <div class="form-item">
                    <label class="form-label">货品代号</label>
                    <input type="text" class="form-input" placeholder="" @bind="query.PrdNo" />
                </div>
                <div class="form-item">
                    <label class="form-label">客户名称</label>
                    <input type="text" class="form-input" placeholder="" @bind="query.CusName" />
                </div>
                <div class="form-item">
                    <label class="form-label">模糊</label>
                    <div style="display:flex;align-items:center;padding-left:8px;flex:1;">
                        <input type="checkbox" style="width:16px;height:16px;" @bind="query.FuzzySearch" />
                    </div>
                </div>
                <div class="form-item query-btn-wrapper">
                    <button class="query-submit-btn" @onclick="HandleSearch">
                        <svg viewBox="0 0 16 16" width="16" height="16" fill="white" stroke="white" stroke-width="1.5">
                            <circle cx="7" cy="7" r="5"/>
                            <line x1="11" y1="11" x2="15" y2="15"/>
                        </svg>
                        <span>查询</span>
                    </button>
                </div>
            </div>
        </div>

        <div class="table-panel">
            <!-- 工具栏 -->
            

            <div class="data-table-container">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th class="col-checkbox">
                                <input type="checkbox" @onchange="ToggleSelectAll" checked="@isAllSelected" />
                            </th>
                            @foreach (var col in columnConfigs.Where(c => c.Visible))
                            {
                                var ws = col.Width > 0 ? $"width:{col.Width}px" : "";
                                if (col.Sortable)
                                {
                                    <th style="@ws" class="sortable">
                                        @col.DisplayName
                                        <svg viewBox="0 0 12 12" width="10" height="10" fill="#999999">
                                            <path d="M6 3l3 3H9l-3-3-3 3H3z"/>
                                            <path d="M6 9l-3-3h3l3 3h-3z" opacity="0.3"/>
                                        </svg>
                                    </th>
                                }
                                else
                                {
                                    <th style="@ws">@col.DisplayName</th>
                                }
                            }
                            <th class="col-action" style="display:flex;align-items:center;justify-content:space-between;white-space:nowrap;">
                                <span>操作</span>
                                <button class="column-settings-btn" title="栏位设置" @onclick="OpenColumnSettings">
                                    <svg viewBox="0 0 16 16" width="14" height="14" fill="#666666">
                                        <path d="M2 3h4v2H2V3zm0 4h4v2H2V7zm0 4h4v2H2v-2zm6-8h6v2H8V3zm0 4h6v2H8V7zm0 4h6v2H8v-2z"/>
                                    </svg>
                                </button>
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (dataSource.Count == 0)
                        {
                            <tr>
                                <td colspan="@(VisibleColumnCount + 2)" class="empty-data-cell">
                                    <div class="empty-data">
                                        <svg viewBox="0 0 64 64" width="80" height="80" fill="none">
                                            <rect x="8" y="8" width="48" height="48" rx="8" fill="#F5F5F5" stroke="#E0E0E0" stroke-width="1"/>
                                            <path d="M24 28h16M24 36h12" stroke="#D9D9D9" stroke-width="2" stroke-linecap="round"/>
                                        </svg>
                                        <p class="empty-text">暂无数据</p>
                                    </div>
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in dataSource)
                            {
                                <tr>
                                    <td class="col-checkbox">
                                        <div class="checkbox-cell">
                                            <input type="checkbox" checked="@selectedItems.Contains(item)"
                                                   @onchange="(e) => ToggleItemSelection(item, e)" />
                                        </div>
                                    </td>
                                    @foreach (var col in columnConfigs.Where(c => c.Visible))
                                    {
                                        var ws = col.Width > 0 ? $"width:{col.Width}px" : "";
                                        <td style="@ws">@GetCellValue(item, col.FieldKey)</td>
                                    }
                                    <td>
                                        <button class="action-btn" title="操作">
                                            <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="#1890FF" stroke-width="1.5">
                                                <circle cx="8" cy="3" r="1" fill="#1890FF"/>
                                                <circle cx="8" cy="8" r="1" fill="#1890FF"/>
                                                <circle cx="8" cy="13" r="1" fill="#1890FF"/>
                                            </svg>
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
            <!-- 表格底部栏 -->
            <div class="table-footer">
                <div class="footer-left">
                    <span class="footer-label">分页栏位字段：</span>
                    <div class="footer-checkboxes">
                        @foreach (var col in columnConfigs.Where(c => c.Visible))
                        {
                            <label class="footer-checkbox-item">
                                <input type="checkbox" checked />
                                <span>@col.DisplayName</span>
                            </label>
                        }
                    </div>
                </div>
                <div class="footer-right">
                    <span class="record-count">共 @dataSource.Count 条记录</span>
                    <div class="pagination-info"></div>
                </div>
            </div>
        </div>
    </div>

        @* ===== 参数设定选项卡内容 ===== *@
        <div style="display:@(innerTabs[1].IsActive ? "flex" : "none");flex-direction:column;flex:1;overflow-y:auto;padding:12px 16px;background-color:#ffffff;">
            @* 基本参数 *@
            <div class="param-section">
                <div class="param-section-title">基本参数</div>
                <div class="param-field-row">
                    <span class="param-help-icon" @onclick="ShowHelpStockRule" title="帮助说明">
                        <svg viewBox="0 0 16 16" width="14" height="14"><circle cx="8" cy="8" r="7" fill="#1890FF"/><text x="8" y="11.5" text-anchor="middle" fill="#ffffff" font-size="11" font-weight="bold">?</text></svg>
                    </span>
                    <label class="param-label">备货产生规则</label>
                    <div class="param-control">
                        <input type="text" class="param-text-input" placeholder="" readonly />
                        <button class="param-search-btn" title="搜索">
                            <svg viewBox="0 0 16 16" width="14" height="14" fill="#999999"><circle cx="6.5" cy="6.5" r="4.5"/><line x1="10" y1="10" x2="15" y2="15" stroke="#999999" stroke-width="1.5"/></svg>
                        </button>
                        <button class="param-radio-btn @(paramStockRule == "auto" ? "checked" : "")" @onclick="SetParamStockRuleAuto"></button>
                    </div>
                </div>
                <div class="param-field-row">
                    <span class="param-help-icon" @onclick="ShowHelpBatchRule" title="帮助说明">
                        <svg viewBox="0 0 16 16" width="14" height="14"><circle cx="8" cy="8" r="7" fill="#1890FF"/><text x="8" y="11.5" text-anchor="middle" fill="#ffffff" font-size="11" font-weight="bold">?</text></svg>
                    </span>
                    <label class="param-label">批号产生规则</label>
                    <div class="param-control">
                        <input type="text" class="param-text-input" value="批号编码规则-标准" readonly />
                        <button class="param-search-btn" title="搜索">
                            <svg viewBox="0 0 16 16" width="14" height="14" fill="#999999"><circle cx="6.5" cy="6.5" r="4.5"/><line x1="10" y1="10" x2="15" y2="15" stroke="#999999" stroke-width="1.5"/></svg>
                        </button>
                        <button class="param-radio-btn @(paramBatchRule == "standard" ? "checked" : "")" @onclick="SetParamBatchRuleStandard"></button>
                    </div>
                </div>
                <div class="param-field-row">
                    <span class="param-help-icon" @onclick="ShowHelpBatchMethod" title="帮助说明">
                        <svg viewBox="0 0 16 16" width="14" height="14"><circle cx="8" cy="8" r="7" fill="#1890FF"/><text x="8" y="11.5" text-anchor="middle" fill="#ffffff" font-size="11" font-weight="bold">?</text></svg>
                    </span>
                    <label class="param-label">批号产生方式</label>
                    <div class="param-control">
                        <input type="text" class="param-text-input" value="按商品主" readonly />
                        <button class="param-expand-btn" title="展开">
                            <svg viewBox="0 0 12 12" width="10" height="6" fill="#999999"><path d="M1 3l5 5 5-5"/></svg>
                        </button>
                    </div>
                </div>
                <div class="param-field-row">
                    <span class="param-help-icon" @onclick="ShowHelpGenDate" title="帮助说明">
                        <svg viewBox="0 0 16 16" width="14" height="14"><circle cx="8" cy="8" r="7" fill="#1890FF"/><text x="8" y="11.5" text-anchor="middle" fill="#ffffff" font-size="11" font-weight="bold">?</text></svg>
                    </span>
                    <label class="param-label">产生日期</label>
                    <div class="param-control">
                        <input type="text" class="param-text-input" value="当前日期" readonly />
                        <button class="param-expand-btn" title="展开">
                            <svg viewBox="0 0 12 12" width="10" height="6" fill="#999999"><path d="M1 3l5 5 5-5"/></svg>
                        </button>
                    </div>
                </div>
                <div class="param-field-row">
                    <span class="param-help-icon" @onclick="ShowHelpPreOrder" title="帮助说明">
                        <svg viewBox="0 0 16 16" width="14" height="14"><circle cx="8" cy="8" r="7" fill="#1890FF"/><text x="8" y="11.5" text-anchor="middle" fill="#ffffff" font-size="11" font-weight="bold">?</text></svg>
                    </span>
                    <label class="param-label">预订单产生的批效默认不参与与尾位</label>
                    <div class="param-control">
                        <label class="param-toggle-switch">
                            <input type="checkbox" checked="@paramPreOrderNotParticipate" @onchange="(e) => { paramPreOrderNotParticipate = (bool)e.Value!; StateHasChanged(); }" />
                            <span class="param-toggle-slider"></span>
                        </label>
                    </div>
                </div>
                <div class="param-field-row">
                    <span class="param-help-icon" @onclick="ShowHelpAllowEdit" title="帮助说明">
                        <svg viewBox="0 0 16 16" width="14" height="14"><circle cx="8" cy="8" r="7" fill="#1890FF"/><text x="8" y="11.5" text-anchor="middle" fill="#ffffff" font-size="11" font-weight="bold">?</text></svg>
                    </span>
                    <label class="param-label">允许编辑不参与参与配位标记</label>
                    <div class="param-control">
                        <label class="param-toggle-switch">
                            <input type="checkbox" checked="@paramAllowEditMark" @onchange="(e) => { paramAllowEditMark = (bool)e.Value!; StateHasChanged(); }" />
                            <span class="param-toggle-slider"></span>
                        </label>
                    </div>
                </div>
            </div>

            @* 打印参数 *@
            <div class="param-section">
                <div class="param-section-title">打印参数</div>
                <div class="param-field-row">
                    <span class="param-help-icon" @onclick="ShowHelpPrintSetting" title="帮助说明">
                        <svg viewBox="0 0 16 16" width="14" height="14"><circle cx="8" cy="8" r="7" fill="#1890FF"/><text x="8" y="11.5" text-anchor="middle" fill="#ffffff" font-size="11" font-weight="bold">?</text></svg>
                    </span>
                    <label class="param-label">打印设定</label>
                    <div class="param-control">
                        <input type="text" class="param-text-input" value="生成标签并打印" readonly />
                        <button class="param-expand-btn" title="展开">
                            <svg viewBox="0 0 12 12" width="10" height="6" fill="#999999"><path d="M1 3l5 5 5-5"/></svg>
                        </button>
                    </div>
                </div>
                <div class="param-field-row">
                    <span class="param-help-icon" @onclick="ShowHelpPrintSite" title="帮助说明">
                        <svg viewBox="0 0 16 16" width="14" height="14"><circle cx="8" cy="8" r="7" fill="#1890FF"/><text x="8" y="11.5" text-anchor="middle" fill="#ffffff" font-size="11" font-weight="bold">?</text></svg>
                    </span>
                    <label class="param-label">打印网点</label>
                    <div class="param-control">
                        <input type="text" class="param-text-input" readonly />
                        <button class="param-expand-btn" title="展开">
                            <svg viewBox="0 0 12 12" width="10" height="6" fill="#999999"><path d="M1 3l5 5 5-5"/></svg>
                        </button>
                    </div>
                </div>
                <div class="param-field-row">
                    <span class="param-help-icon" @onclick="ShowHelpPrinter" title="帮助说明">
                        <svg viewBox="0 0 16 16" width="14" height="14"><circle cx="8" cy="8" r="7" fill="#1890FF"/><text x="8" y="11.5" text-anchor="middle" fill="#ffffff" font-size="11" font-weight="bold">?</text></svg>
                    </span>
                    <label class="param-label">打印机</label>
                    <div class="param-control">
                        <input type="text" class="param-text-input" readonly />
                        <button class="param-expand-btn" title="展开">
                            <svg viewBox="0 0 12 12" width="10" height="6" fill="#999999"><path d="M1 3l5 5 5-5"/></svg>
                        </button>
                    </div>
                </div>
                <div class="param-field-row">
                    <span class="param-help-icon" @onclick="ShowHelpProductTemplate" title="帮助说明">
                        <svg viewBox="0 0 16 16" width="14" height="14"><circle cx="8" cy="8" r="7" fill="#1890FF"/><text x="8" y="11.5" text-anchor="middle" fill="#ffffff" font-size="11" font-weight="bold">?</text></svg>
                    </span>
                    <label class="param-label">依货品备套条码打印套版</label>
                    <div class="param-control">
                        <label class="param-toggle-switch">
                            <input type="checkbox" checked="@paramUseProductTemplate" @onchange="(e) => { paramUseProductTemplate = (bool)e.Value!; StateHasChanged(); }" />
                            <span class="param-toggle-slider"></span>
                        </label>
                    </div>
                </div>
                <div class="param-field-row">
                    <span class="param-help-icon" @onclick="ShowHelpTemplate" title="帮助说明">
                        <svg viewBox="0 0 16 16" width="14" height="14"><circle cx="8" cy="8" r="7" fill="#1890FF"/><text x="8" y="11.5" text-anchor="middle" fill="#ffffff" font-size="11" font-weight="bold">?</text></svg>
                    </span>
                    <label class="param-label">套版</label>
                    <div class="param-control">
                        <input type="text" class="param-text-input" placeholder="" readonly />
                        <button class="param-search-btn" title="搜索">
                            <svg viewBox="0 0 16 16" width="14" height="14" fill="#999999"><circle cx="6.5" cy="6.5" r="4.5"/><line x1="10" y1="10" x2="15" y2="15" stroke="#999999" stroke-width="1.5"/></svg>
                        </button>
                        <button class="param-radio-btn @(paramTemplate == "selected" ? "checked" : "")" @onclick="SetParamTemplateSelected"></button>
                    </div>
                </div>
                <div class="param-field-row">
                    <span class="param-help-icon" @onclick="ShowHelpPrintCopies" title="帮助说明">
                        <svg viewBox="0 0 16 16" width="14" height="14"><circle cx="8" cy="8" r="7" fill="#1890FF"/><text x="8" y="11.5" text-anchor="middle" fill="#ffffff" font-size="11" font-weight="bold">?</text></svg>
                    </span>
                    <label class="param-label">打印份数</label>
                    <div class="param-control">
                        <input type="number" class="param-number-input" @bind="paramPrintCopies" @bind:event="oninput" />
                        <button class="param-radio-btn @(paramPrintCopiesMode == "fixed" ? "checked" : "")" @onclick="SetParamPrintCopiesFixed"></button>
                    </div>
                </div>
                <div class="param-field-row">
                    <span class="param-help-icon" @onclick="ShowHelpLabelsPerBox" title="帮助说明">
                        <svg viewBox="0 0 16 16" width="14" height="14"><circle cx="8" cy="8" r="7" fill="#1890FF"/><text x="8" y="11.5" text-anchor="middle" fill="#ffffff" font-size="11" font-weight="bold">?</text></svg>
                    </span>
                    <label class="param-label">分组行印-每箱每签个数</label>
                    <div class="param-control">
                        <input type="number" class="param-number-input" @bind="paramLabelsPerBox" @bind:event="oninput" />
                        <button class="param-radio-btn @(paramLabelsPerBoxMode == "fixed" ? "checked" : "")" @onclick="SetParamLabelsPerBoxFixed"></button>
                    </div>
                </div>
            </div>
        </div>
    </div>

@if (showColumnSettingsDialog)
{
    <div class="column-settings-overlay" @onclick="CloseColumnSettings">
        <div class="column-settings-dialog" @onclick:stopPropagation>
            <div class="column-settings-header">
                <span>栏位设计</span>
                <button class="column-settings-close" @onclick="CloseColumnSettings">&times;</button>
            </div>
            <div class="column-settings-search">
                <input type="text" class="column-search-input" placeholder="搜索栏位原名..." @bind="columnSearchKeyword" @bind:event="oninput" />
            </div>
            <div class="column-settings-body">
                <table class="column-settings-table">
                    <thead>
                        <tr>
                            <th class="col-seq">项次</th>
                            <th class="col-visible">显示否</th>
                            <th class="col-original">原栏位名</th>
                            <th class="col-display">栏位标题</th>
                            <th class="col-width">宽度</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < FilteredColumnConfigs.Count; i++)
                        {
                            var col = FilteredColumnConfigs[i];
                            var idx = columnConfigs.IndexOf(col) + 1;
                            <tr>
                                <td class="col-seq">@idx</td>
                                <td class="col-visible">
                                    <label class="toggle-switch">
                                        <input type="checkbox" checked="@col.Visible" @onchange="@((ChangeEventArgs e) => col.Visible = (bool)e.Value!)" />
                                        <span class="toggle-slider"></span>
                                    </label>
                                </td>
                                <td class="col-original">@col.OriginalName</td>
                                <td class="col-display">
                                    <input type="text" class="col-title-input" value="@col.DisplayName"
                                           @onchange="@((ChangeEventArgs e) => col.DisplayName = e.Value?.ToString() ?? col.OriginalName)" />
                                </td>
                                <td class="col-width">
                                    <input type="number" class="col-width-input" value="@col.Width" min="0" max="500"
                                           @onchange="@((ChangeEventArgs e) => { if (int.TryParse(e.Value?.ToString(), out var w)) col.Width = w; })" />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="column-settings-footer">
                <div class="footer-left">
                    <button class="col-select-all" @onclick="SelectAllColumns">全选</button>
                    <button class="col-restore-default" @onclick="RestoreDefaultColumns">恢复默认</button>
                </div>
                <div class="footer-right">
                    <button class="col-btn-confirm" @onclick="ConfirmColumnSettings">确定</button>
                    <button class="col-btn-cancel" @onclick="CancelColumnSettings">取消</button>
                </div>
            </div>
        </div>
    </div>
}

