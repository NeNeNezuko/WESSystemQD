@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@inject HttpClient Http
@inject ILogger<BarcodePrintProductSource> _logger
@inject TokenProvider TokenProvider

<link rel="stylesheet" href="css/barcode-print-product-source.css" />

<div class="barcode-print-product-source-page" style="display:flex;flex-direction:column;flex:1 1 0%;overflow:hidden;">
    <div class="page-header">
        <div class="header-left">
            <button class="favorite-btn @(isFavorited ? "favorited" : "")" @onclick="ToggleFavorite" title="收藏">
                <svg viewBox="0 0 24 24" width="24" height="24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill="@((isFavorited ? "#FFD700" : "none"))" stroke="@((isFavorited ? "#FFD700" : "#666666"))" stroke-width="2"/></svg>
            </button>
            <span class="page-title">依来源单打印货品条码</span>
        </div>
        <div class="header-right">
            <button class="collapse-btn-fixed @(isCollapsed ? "collapsed" : "")" @onclick="ToggleCollapse" title="@(isCollapsed ? "展开查询" : "收起查询")">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="#666666"><rect x="3" y="6" width="18" height="2" rx="1"/><rect x="3" y="11" width="18" height="2" rx="1"/><rect x="3" y="16" width="18" height="2" rx="1"/></svg>
            </button>
        </div>
    </div>
    @if (showFavoriteSuccess) { <div class="favorite-success-toast"><div class="toast-content"><svg viewBox="0 0 16 16" width="16" height="16" fill="#52C41A"><circle cx="8" cy="8" r="8"/><path d="M5 8l2 2 4-4" stroke="white" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg><span>收藏成功</span></div></div> }

    <div class="page-content">
        <div class="query-panel @(isCollapsed ? "collapsed" : "")">
            <div class="query-header">
                <span class="query-title">查询</span>
                <button class="query-settings-btn" title="设置" @onclick="ToggleSettingsMenu">
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="#999999" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2.83 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
                </button>
                @if (showSettingsMenu)
                {
                    <div class="settings-dropdown" @onclick:stopPropagation>
                        <div class="settings-dropdown-item" @onclick="BatchAddCondition">批次添加条件</div>
                        <div class="settings-dropdown-item" @onclick="AddSingleCondition">添加单一条件</div>
                        <div class="settings-dropdown-item" @onclick="CustomCondition">自定义条件</div>
                        <div class="settings-dropdown-item" @onclick="RemoveCondition">移除条件</div>
                        <div class="settings-dropdown-item" @onclick="SaveConditionValues">保存条件值</div>
                    </div>
                }
            </div>
            <div class="query-form">
                <div class="form-item">
                    <label class="form-label">来源单据</label>
                    <div class="select-wrapper">
                        <select class="form-select" @bind="query.SourceDoc">
                            <option value="">全部</option>
                            <option value="RK">入库通知单</option>
                            <option value="CK">出库通知单</option>
                            <option value="IC">调拨单</option>
                            <option value="PD">盘点单</option>
                        </select>
                        <span class="select-arrow"><svg viewBox="0 0 12 12" width="10" height="6" fill="#999999"><path d="M1 2l5 5 5-5"/></svg></span>
                    </div>
                </div>
                <div class="form-item"><label class="form-label">来源单号</label><input type="text" class="form-input" placeholder="" @bind="query.SourceNo" /></div>
                <div class="form-item"><label class="form-label">货品代号</label><input type="text" class="form-input" placeholder="" @bind="query.PrdNo" /></div>
                <div class="form-item"><label class="form-label">客户名称</label><input type="text" class="form-input" placeholder="" @bind="query.CusName" /></div>
                <div class="form-item">
                    <label class="form-label">模糊</label>
                    <div style="display:flex;align-items:center;padding-left:8px;flex:1;">
                        <input type="checkbox" style="width:16px;height:16px;" @bind="query.FuzzySearch" />
                    </div>
                </div>
                <div class="form-item query-btn-wrapper"><button class="query-submit-btn" @onclick="HandleSearch"><svg viewBox="0 0 16 16" width="16" height="16" fill="white" stroke="white" stroke-width="1.5"><circle cx="7" cy="7" r="5"/><line x1="11" y1="11" x2="15" y2="15"/></svg><span>查询</span></button></div>
            </div>
        </div>

        <div class="table-panel">
            <!-- 工具栏 -->
            <div class="table-toolbar">
                <div class="toolbar-left">
                    <!-- 内层选项卡：打印&查询 / 参数设定 -->
                    <div class="inner-tab-bar-inline">
                        <div class="inner-tab-item @(activeInnerTabId == "print-query" ? "active" : "")" @onclick="SwitchToPrintQueryTab">打印&amp;查询</div>
                        <div class="inner-tab-item @(activeInnerTabId == "param-setting" ? "active" : "")" @onclick="SwitchToParamSettingTab">参数设定</div>
                    </div>
                    <button class="toolbar-btn primary-btn" @onclick="HandleBatchPrint">批次打印</button>
                    <button class="toolbar-btn export-btn" @onclick="HandleSearch">查询</button>
                </div>
            </div>

            <div class="data-table-container">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th class="col-checkbox"><input type="checkbox" @onchange="ToggleSelectAll" checked="@isAllSelected" /></th>
                            @foreach (var col in columnConfigs.Where(c => c.Visible))
                            {
                                var ws = col.Width > 0 ? $"width:{col.Width}px" : "";
                                if (col.Sortable) { <th style="@ws" class="sortable">@col.DisplayName<svg viewBox="0 0 12 12" width="10" height="10" fill="#999999"><path d="M6 3l3 3H9l-3-3-3 3H3z"/><path d="M6 9l-3-3h3l3 3h-3z" opacity="0.3"/></svg></th> }
                                else { <th style="@ws">@col.DisplayName</th> }
                            }
                            <th class="col-action" style="display:flex;align-items:center;justify-content:space-between;white-space:nowrap;"><span>操作</span><button class="column-settings-btn" title="栏位设置" @onclick="OpenColumnSettings"><svg viewBox="0 0 16 16" width="14" height="14" fill="#666666"><path d="M2 3h4v2H2V3zm0 4h4v2H2V7zm0 4h4v2H2v-2zm6-8h6v2H8V3zm0 4h6v2H8V7zm0 4h6v2H8v-2z"/></svg></button></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (dataSource.Count == 0)
                        { <tr><td colspan="@(VisibleColumnCount + 2)" class="empty-data-cell"><div class="empty-data"><svg viewBox="0 0 64 64" width="80" height="80" fill="none"><rect x="8" y="8" width="48" height="48" rx="8" fill="#F5F5F5" stroke="#E0E0E0" stroke-width="1"/><path d="M24 28h16M24 36h12" stroke="#D9D9D9" stroke-width="2" stroke-linecap="round"/></svg><p class="empty-text">暂无数据</p></div></td></tr> }
                        else
                        {
                            @foreach (var item in dataSource)
                            {
                                <tr>
                                    <td class="col-checkbox"><div class="checkbox-cell"><input type="checkbox" checked="@selectedItems.Contains(item)" @onchange="(e) => ToggleItemSelection(item, e)" /></div></td>
                                    @foreach (var col in columnConfigs.Where(c => c.Visible))
                                    { var colWs = col.Width > 0 ? $"width:{col.Width}px" : ""; <td style="@colWs">@GetCellValue(item, col.FieldKey)</td> }
                                    <td><button class="action-btn" title="操作"><svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="#1890FF" stroke-width="1.5"><circle cx="8" cy="3" r="1" fill="#1890FF"/><circle cx="8" cy="8" r="1" fill="#1890FF"/><circle cx="8" cy="13" r="1" fill="#1890FF"/></svg></button></td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
            <!-- 表格底部栏 -->
            <div class="table-footer">
                <div class="footer-left">
                    <span class="footer-label">分页栏位字段：</span>
                    <div class="footer-checkboxes">
                        @foreach (var col in columnConfigs.Where(c => c.Visible))
                        {
                            <label class="footer-checkbox-item">
                                <input type="checkbox" checked />
                                <span>@col.DisplayName</span>
                            </label>
                        }
                    </div>
                </div>
                <div class="footer-right">
                    <span class="record-count">共 @dataSource.Count 条记录</span>
                    <div class="pagination-info"></div>
                </div>
            </div>
        </div>
    </div>
</div>

@if (showColumnSettingsDialog)
{
    <div class="column-settings-overlay" @onclick="CloseColumnSettings">
        <div class="column-settings-dialog" @onclick:stopPropagation>
            <div class="column-settings-header"><span>栏位设计</span><button class="column-settings-close" @onclick="CloseColumnSettings">&times;</button></div>
            <div class="column-settings-search"><input type="text" class="column-search-input" placeholder="搜索栏位原名..." @bind="columnSearchKeyword" @bind:event="oninput" /></div>
            <div class="column-settings-body">
                <table class="column-settings-table">
                    <thead><tr><th class="col-seq">项次</th><th class="col-visible">显示否</th><th class="col-original">原栏位名</th><th class="col-display">栏位标题</th><th class="col-width">宽度</th></tr></thead>
                    <tbody>
                        @for (int i = 0; i < FilteredColumnConfigs.Count; i++)
                        { var fCol = FilteredColumnConfigs[i]; var fIdx = columnConfigs.IndexOf(fCol) + 1;
                        <tr><td class="col-seq">@fIdx</td><td class="col-visible"><label class="toggle-switch"><input type="checkbox" checked="@fCol.Visible" @onchange="@((ChangeEventArgs e) => fCol.Visible = (bool)e.Value!)" /><span class="toggle-slider"></span></label></td><td class="col-original">@fCol.OriginalName</td><td class="col-display"><input type="text" class="col-title-input" value="@fCol.DisplayName" @onchange="@((ChangeEventArgs e) => fCol.DisplayName = e.Value?.ToString() ?? fCol.OriginalName)" /></td><td class="col-width"><input type="number" class="col-width-input" value="@fCol.Width" min="0" max="500" @onchange="@((ChangeEventArgs e) => { if(int.TryParse(e.Value?.ToString(), out var w)) fCol.Width = w; })" /></td></tr>}
                    </tbody>
                </table>
            </div>
            <div class="column-settings-footer">
                <div class="footer-left"><button class="col-select-all" @onclick="SelectAllColumns">全选</button><button class="col-restore-default" @onclick="RestoreDefaultColumns">恢复默认</button></div>
                <div class="footer-right"><button class="col-btn-confirm" @onclick="ConfirmColumnSettings">确定</button><button class="col-btn-cancel" @onclick="CancelColumnSettings">取消</button></div>
            </div>
        </div>
    </div>
}

@code {
    private bool isFavorited = false;
    private bool showFavoriteSuccess = false;
    private bool isCollapsed = false;
    private bool showSettingsMenu = false;
    private bool showColumnSettingsDialog = false;
    private string columnSearchKeyword = "";
    private string activeInnerTabId = "print-query";
    private List<ColumnConfig> columnConfigs = new();
    private List<ColumnConfig> defaultColumnConfigs = new();
    private BarcodePrintProductSourceQuery query = new();
    private List<BarcodePrintProductSourceModel> dataSource = new();
    private HashSet<BarcodePrintProductSourceModel> selectedItems = new();
    private bool isAllSelected = false;

    [CascadingParameter(Name = "OnFavoriteChanged")] public Action? OnFavoriteChanged { get; set; }

    protected override async Task OnInitializedAsync()
    {
        InitDefaultColumnConfigs();
        await LoadColumnSettings();
        await LoadFavoriteStatus();
        await LoadData();
    }

    // ===== 内层选项卡 =====
    private void SwitchInnerTab(string tabId)
    {
        activeInnerTabId = tabId;
        StateHasChanged();
    }

    private void SwitchToPrintQueryTab() => SwitchInnerTab("print-query");
    private void SwitchToParamSettingTab() => SwitchInnerTab("param-setting");

    // ===== 折叠方法 =====
    private void ToggleCollapse() { isCollapsed = !isCollapsed; StateHasChanged(); }

    // ===== 设置菜单方法 =====
    private void ToggleSettingsMenu() { showSettingsMenu = !showSettingsMenu; StateHasChanged(); }
    private void BatchAddCondition() { showSettingsMenu = false; StateHasChanged(); }
    private void AddSingleCondition() { showSettingsMenu = false; StateHasChanged(); }
    private void CustomCondition() { showSettingsMenu = false; StateHasChanged(); }
    private void RemoveCondition() { showSettingsMenu = false; StateHasChanged(); }
    private void SaveConditionValues() { showSettingsMenu = false; StateHasChanged(); }

    // ===== 收藏功能 =====
    private async Task LoadFavoriteStatus() { try { var r = await JS.InvokeAsync<string>("localStorage.getItem", "wms_favorite_barcode_print_product_source"); isFavorited = r == "true"; } catch { } }

    private async Task ToggleFavorite()
    {
        isFavorited = !isFavorited;
        try { await JS.InvokeVoidAsync("localStorage.setItem", "wms_favorite_barcode_print_product_source", isFavorited.ToString().ToLower()); } catch { }
        OnFavoriteChanged?.Invoke();
        if (isFavorited) { showFavoriteSuccess = true; StateHasChanged(); await Task.Delay(2000); showFavoriteSuccess = false; }
        StateHasChanged();
    }

    // ===== 选择相关 =====
    private void ToggleSelectAll(ChangeEventArgs e)
    {
        var isChecked = (bool)(e.Value ?? false);
        isAllSelected = isChecked;
        if (isChecked) selectedItems = new HashSet<BarcodePrintProductSourceModel>(dataSource);
        else selectedItems.Clear();
        StateHasChanged();
    }

    private void ToggleItemSelection(BarcodePrintProductSourceModel item, ChangeEventArgs e)
    {
        var isChecked = (bool)(e.Value ?? false);
        if (isChecked) selectedItems.Add(item); else selectedItems.Remove(item);
        isAllSelected = selectedItems.Count == dataSource.Count && dataSource.Count > 0;
        StateHasChanged();
    }

    // ===== 查询与操作 =====
    private async Task HandleSearch() { await LoadData(); }
    private void HandleBatchPrint() { }

    private async Task LoadData()
    {
        try
        {
            var url = $"{ApiConfig.BaseUrl}/api/BarcodePrintProductSource/search?";
            if (!string.IsNullOrWhiteSpace(query.SourceDoc)) url += $"&sourceDoc={Uri.EscapeDataString(query.SourceDoc)}";
            if (!string.IsNullOrWhiteSpace(query.SourceNo)) url += $"&sourceNo={Uri.EscapeDataString(query.SourceNo)}";
            if (!string.IsNullOrWhiteSpace(query.PrdNo)) url += $"&prdNo={Uri.EscapeDataString(query.PrdNo)}";
            if (!string.IsNullOrWhiteSpace(query.CusName)) url += $"&cusName={Uri.EscapeDataString(query.CusName)}";
            var jsonOptions = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var request = AuthHttpClient.CreateRequest(HttpMethod.Get, url, TokenProvider.Token);
            var responseMsg = await Http.SendAsync(request);
            var response = await responseMsg.Content.ReadFromJsonAsync<ApiResponse<List<BarcodePrintProductSourceModel>>>(jsonOptions);
            if (response != null && response.Success && response.Data != null) dataSource = response.Data;
            else dataSource = new List<BarcodePrintProductSourceModel>();
        }
        catch (Exception ex) { _logger?.LogError(ex, "加载依来源单打印货品条码数据失败"); dataSource = new List<BarcodePrintProductSourceModel>(); }
        StateHasChanged();
    }

    // ===== 栏位配置 =====
    private class ColumnConfig
    {
        public string FieldKey { get; set; } = "";
        public string OriginalName { get; set; } = "";
        public string DisplayName { get; set; } = "";
        public bool Visible { get; set; } = true;
        public int Width { get; set; } = 0;
        public int DefaultWidth { get; set; } = 0;
        public bool Sortable { get; set; } = false;
    }

    private const string COLUMN_SETTINGS_KEY = "wms_column_settings_barcode_print_product_source";

    private void InitDefaultColumnConfigs()
    {
        defaultColumnConfigs = new List<ColumnConfig>
        {
            new() { FieldKey = "SeqNo", OriginalName = "项次", DisplayName = "项次", Visible = true, Width = 50, DefaultWidth = 50 },
            new() { FieldKey = "PrdNo", OriginalName = "货品代号", DisplayName = "货品代号", Visible = true, Width = 100, DefaultWidth = 100, Sortable = true },
            new() { FieldKey = "PrdName", OriginalName = "货品名称", DisplayName = "货品名称", Visible = true, Width = 120, DefaultWidth = 120 },
            new() { FieldKey = "BatNo", OriginalName = "批号", DisplayName = "批号", Visible = true, Width = 80, DefaultWidth = 80 },
            new() { FieldKey = "OrigQty", OriginalName = "原单数量", DisplayName = "原单数量", Visible = true, Width = 70, DefaultWidth = 70 },
            new() { FieldKey = "PrintedQty", OriginalName = "已打印数量", DisplayName = "已打印数量", Visible = true, Width = 75, DefaultWidth = 75 },
            new() { FieldKey = "LabelCount", OriginalName = "标签个数", DisplayName = "标签个数", Visible = true, Width = 70, DefaultWidth = 70 },
            new() { FieldKey = "PrintBarcode", OriginalName = "打印条码", DisplayName = "打印条码", Visible = true, Width = 110, DefaultWidth = 110 },
            new() { FieldKey = "CusNo", OriginalName = "客户代号", DisplayName = "客户代号", Visible = true, Width = 80, DefaultWidth = 80 },
            new() { FieldKey = "SoNo", OriginalName = "受订单号", DisplayName = "受订单号", Visible = true, Width = 95, DefaultWidth = 95 },
            new() { FieldKey = "NoPickFlag", OriginalName = "不能参与配位标记", DisplayName = "不能参与配位标记", Visible = true, Width = 120, DefaultWidth = 120 },
            new() { FieldKey = "SourceNo", OriginalName = "来源单号", DisplayName = "来源单号", Visible = true, Width = 100, DefaultWidth = 100 }
        };
        columnConfigs = defaultColumnConfigs.Select(c => new ColumnConfig
        {
            FieldKey = c.FieldKey,
            OriginalName = c.OriginalName,
            DisplayName = c.DisplayName,
            Visible = c.Visible,
            Width = c.Width,
            DefaultWidth = c.DefaultWidth,
            Sortable = c.Sortable
        }).ToList();
    }

    private async Task LoadColumnSettings()
    {
        try
        {
            var json = await JS.InvokeAsync<string>("localStorage.getItem", COLUMN_SETTINGS_KEY);
            if (!string.IsNullOrWhiteSpace(json))
            {
                var opts = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
                var saved = System.Text.Json.JsonSerializer.Deserialize<List<ColumnConfig>>(json, opts);
                if (saved != null && saved.Count > 0)
                {
                    foreach (var col in columnConfigs)
                    {
                        var sc = saved.FirstOrDefault(s => s.FieldKey == col.FieldKey);
                        if (sc != null)
                        {
                            col.Visible = sc.Visible;
                            col.DisplayName = !string.IsNullOrWhiteSpace(sc.DisplayName) ? sc.DisplayName : col.OriginalName;
                            col.Width = sc.Width >= 0 ? sc.Width : col.DefaultWidth;
                        }
                    }
                }
            }
        }
        catch { }
    }

    private async Task SaveColumnSettings() { try { await JS.InvokeVoidAsync("localStorage.setItem", COLUMN_SETTINGS_KEY, System.Text.Json.JsonSerializer.Serialize(columnConfigs)); } catch { } }

    private void OpenColumnSettings() { columnSearchKeyword = ""; showColumnSettingsDialog = true; StateHasChanged(); }
    private void CloseColumnSettings() { showColumnSettingsDialog = false; StateHasChanged(); }
    private void ConfirmColumnSettings() { showColumnSettingsDialog = false; _ = SaveColumnSettings(); StateHasChanged(); }
    private void CancelColumnSettings() { showColumnSettingsDialog = false; _ = LoadColumnSettings(); StateHasChanged(); }
    private void SelectAllColumns() { foreach (var col in columnConfigs) col.Visible = true; StateHasChanged(); }

    private void RestoreDefaultColumns()
    {
        for (int i = 0; i < columnConfigs.Count && i < defaultColumnConfigs.Count; i++)
        {
            columnConfigs[i].Visible = defaultColumnConfigs[i].Visible;
            columnConfigs[i].DisplayName = defaultColumnConfigs[i].DisplayName;
            columnConfigs[i].Width = defaultColumnConfigs[i].Width;
        }
        StateHasChanged();
    }

    private List<ColumnConfig> FilteredColumnConfigs =>
        string.IsNullOrWhiteSpace(columnSearchKeyword)
            ? columnConfigs
            : columnConfigs.Where(c => c.OriginalName.Contains(columnSearchKeyword, StringComparison.OrdinalIgnoreCase) ||
                                       c.FieldKey.Contains(columnSearchKeyword, StringComparison.OrdinalIgnoreCase)).ToList();

    private int VisibleColumnCount => columnConfigs.Count(c => c.Visible);

    private object GetCellValue(BarcodePrintProductSourceModel item, string fieldKey) => fieldKey switch
    {
        "SeqNo" => item.SeqNo,
        "PrdNo" => item.PrdNo,
        "PrdName" => item.PrdName,
        "BatNo" => item.BatNo,
        "OrigQty" => item.OrigQty?.ToString() ?? "",
        "PrintedQty" => item.PrintedQty?.ToString() ?? "",
        "LabelCount" => item.LabelCount?.ToString() ?? "",
        "PrintBarcode" => item.PrintBarcode,
        "CusNo" => item.CusNo,
        "SoNo" => item.SoNo,
        "NoPickFlag" => item.NoPickFlag,
        "SourceNo" => item.SourceNo,
        _ => ""
    };

    // ===== API响应模型 =====
    private class ApiResponse<T>
    {
        public bool Success { get; set; }
        public string Message { get; set; } = "";
        public T? Data { get; set; }
        public int Total { get; set; }
    }
}
