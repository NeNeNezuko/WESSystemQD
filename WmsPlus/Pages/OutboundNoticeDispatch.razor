    // ===== 数据加载 =====
    private async Task LoadData()
    {
        try
        {
            

            // 构建来源单据类别参数
            var sourceTypes = BuildSourceTypesParam();

            // 解析预计出货日期范围
            var today = DateTime.Today;
            var estDateFromStr = "";
            var estDateToStr = "";
            if (!string.IsNullOrWhiteSpace(query.EstDateRange) && query.EstDateRange.Contains("→"))
            {
                var parts = query.EstDateRange.Split("→", StringSplitOptions.TrimEntries);
                if (parts.Length >= 2)
                {
                    estDateFromStr = parts[0];
                    estDateToStr = parts[1];
                }
            }

            // 解析单据日期范围
            var dateFromStr = today.ToString("yyyy-MM-dd");
            var dateToStr = today.ToString("yyyy-MM-dd");
            if (!string.IsNullOrWhiteSpace(query.DateRange) && query.DateRange.Contains("→"))
            {
                var parts = query.DateRange.Split("→", StringSplitOptions.TrimEntries);
                if (parts.Length >= 2)
                {
                    dateFromStr = parts[0];
                    dateToStr = parts[1];
                }
            }

            var url = $"{ApiConfig.BaseUrl}/api/OutboundNoticeDispatch/search?sourceTypes={Uri.EscapeDataString(sourceTypes)}";
            if (!string.IsNullOrWhiteSpace(estDateFromStr))
                url += $"&estDateFrom={estDateFromStr}";
            if (!string.IsNullOrWhiteSpace(estDateToStr))
                url += $"&estDateTo={estDateToStr}";
            url += $"&dateFrom={dateFromStr}&dateTo={dateToStr}";
            if (!string.IsNullOrWhiteSpace(query.DocumentNumber))
                url += $"&documentNumber={Uri.EscapeDataString(query.DocumentNumber)}";
            if (!string.IsNullOrWhiteSpace(query.WarehouseCode))
                url += $"&warehouseCode={Uri.EscapeDataString(query.WarehouseCode)}";
            if (!string.IsNullOrWhiteSpace(query.BusinessType))
                url += $"&businessType={Uri.EscapeDataString(query.BusinessType)}";
            if (!string.IsNullOrWhiteSpace(query.ErpOrderNo))
                url += $"&erpOrderNo={Uri.EscapeDataString(query.ErpOrderNo)}";
            if (!string.IsNullOrWhiteSpace(query.BizOrderNo))
                url += $"&bizOrderNo={Uri.EscapeDataString(query.BizOrderNo)}";
            if (!string.IsNullOrWhiteSpace(query.DispatchStatus) && query.DispatchStatus != "全部")
                url += $"&dispatchStatus={Uri.EscapeDataString(query.DispatchStatus)}";
            if (!string.IsNullOrWhiteSpace(query.PickCloseStatus) && query.PickCloseStatus != "全部")
                url += $"&pickCloseStatus={Uri.EscapeDataString(query.PickCloseStatus)}";

            var jsonOptions = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var request = AuthHttpClient.CreateRequest(HttpMethod.Get, url, TokenProvider.Token);
            var responseMsg = await Http.SendAsync(request);
            var response = await responseMsg.Content.ReadFromJsonAsync<ApiResponse<DispatchSearchResult>>(jsonOptions);

            if (response != null && response.Success && response.Data != null)
            {
                mainDataSource = response.Data.MainList ?? new List<OutboundNoticeDispatchModel>();
                detailDataSource = response.Data.DetailList ?? new List<OutboundNoticeDispatchDetailModel>();
            }
            else
            {
                mainDataSource = new List<OutboundNoticeDispatchModel>();
                detailDataSource = new List<OutboundNoticeDispatchDetailModel>();
            }
        }
        catch (Exception ex)
        {
            _logger?.LogError(ex, "加载出库通知单派工数据失败");
            mainDataSource = new List<OutboundNoticeDispatchModel>();
            detailDataSource = new List<OutboundNoticeDispatchDetailModel>();
        }
        StateHasChanged();
    }

    /// <summary>根据Checkbox状态构建来源单据类别参数</summary>
    private string BuildSourceTypesParam()
    {
        var types = new List<string>();
        if (includeOutboundNotice) types.Add("出库通知单");
        if (includeTransferNotice) types.Add("调拨通知单");
        return string.Join(",", types);
    }

    private async Task ExportToExcel()
    {
        var visibleCols = mainColumnConfigs.Where(c => c.Visible).ToList();
        var headers = visibleCols.Select(c => c.DisplayName).ToArray();
        var rows = new List<object[]>();
        rows.Add(headers);
        foreach (var item in mainDataSource)
        {
            var row = new object[visibleCols.Count];
            for (int i = 0; i < visibleCols.Count; i++)
                row[i] = GetMainCellValue(item, visibleCols[i].FieldKey);
            rows.Add(row);
        }
        var fileName = string.IsNullOrWhiteSpace(exportFileName) ? $"出库通知单派工_{DateTime.Now:yyyyMMddHHmmss}" : exportFileName;
        if (!fileName.EndsWith(".xlsx", StringComparison.OrdinalIgnoreCase)) fileName += ".xlsx";
        await JS.InvokeVoidAsync("exportToExcel", rows, fileName);
    }

