        "Unit" => item.Unit,
        "Qty" => item.Qty,
        "PlannedDeductionQty" => item.PlannedDeductionQty,
        "ReturnedQty" => item.ReturnedQty,
        "PickedQty" => item.PickedQty,
        "OutboundQty" => item.OutboundQty,
