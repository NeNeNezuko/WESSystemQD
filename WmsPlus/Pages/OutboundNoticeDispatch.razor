@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@inject HttpClient Http
@inject ILogger<OutboundNoticeDispatch> _logger
@inject TokenProvider TokenProvider

<link rel="stylesheet" href="css/outbound-notice-dispatch.css" />

<div class="dispatch-page" style="display:flex;flex-direction:column;flex:1 1 0%;overflow:hidden;">
    <!-- 顶部标题栏 -->
    <div class="page-header">
        <div class="header-left">
            <button class="favorite-btn @(isFavorited ? "favorited" : "")" @onclick="ToggleFavorite" title="收藏">
                <svg viewBox="0 0 24 24" width="24" height="24">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
                          fill="@((isFavorited ? "#FFD700" : "none"))"
                          stroke="@((isFavorited ? "#FFD700" : "#666666"))"
                          stroke-width="2"/>
                </svg>
            </button>
            <span class="page-title">出库通知单派工</span>
        </div>
        <div class="header-right">
            <button class="collapse-btn-fixed @(isCollapsed ? "collapsed" : "")" @onclick="ToggleCollapse" title="@(isCollapsed ? "展开查询" : "收起查询")">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="#666666">
                    <rect x="3" y="6" width="18" height="2" rx="1"/>
                    <rect x="3" y="11" width="18" height="2" rx="1"/>
                    <rect x="3" y="16" width="18" height="2" rx="1"/>
                </svg>
            </button>
        </div>
    </div>

    <!-- 收藏成功提示 -->
    @if (showFavoriteSuccess)
    {
        <div class="favorite-success-toast">
            <div class="toast-content">
                <svg viewBox="0 0 16 16" width="16" height="16" fill="#52C41A">
                    <circle cx="8" cy="8" r="8"/>
                    <path d="M5 8l2 2 4-4" stroke="white" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>收藏成功</span>
            </div>
        </div>
    }

    <!-- 主内容区域 -->
    <div class="page-content">
        <!-- 左侧查询区域 -->
        <div class="query-panel @(isCollapsed ? "collapsed" : "")">
            <div class="query-header">
                <span class="query-title">查询</span>
                <button class="query-settings-btn" title="设置" @onclick="ToggleSettingsMenu">
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="#999999" stroke-width="2">
                        <circle cx="12" cy="12" r="3"/>
                        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2.83 2.83 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/>
                    </svg>
                </button>
                @if (showSettingsMenu)
                {
                    <div class="settings-dropdown" @onclick:stopPropagation>
                        <div class="settings-dropdown-item" @onclick="BatchAddCondition">批次添加条件</div>
                        <div class="settings-dropdown-item" @onclick="AddSingleCondition">添加单一条件</div>
                        <div class="settings-dropdown-item" @onclick="CustomCondition">自定义条件</div>
                        <div class="settings-dropdown-item" @onclick="RemoveCondition">移除条件</div>
                        <div class="settings-dropdown-item" @onclick="SaveConditionValues">保存条件值</div>
                    </div>
                }
            </div>

            <div class="query-form">
                <!-- 来源单据类别（Checkbox多选） -->
                <div class="source-type-group">
                    <span class="source-type-label">来源单据类别</span>
                    <div class="source-type-options">
                        <label class="source-type-checkbox">
                            <input type="checkbox" checked="@includeOutboundNotice" @onchange="@((ChangeEventArgs e) => includeOutboundNotice = (bool)e.Value!)" />
                            <span>出库通知单</span>
                        </label>
                        <label class="source-type-checkbox">
                            <input type="checkbox" checked="@includeTransferNotice" @onchange="@((ChangeEventArgs e) => includeTransferNotice = (bool)e.Value!)" />
                            <span>调拨通知单</span>
                        </label>
                    </div>
                </div>

                <!-- 预计出货日期 -->
                <DateRangeInput @bind-Value="query.EstDateRange" Label="预计出货日期" />

                <!-- 单据日期 -->
                <DateRangeInput @bind-Value="query.DateRange" />

                <!-- 仓库代号 -->
                <WarehouseCodeInput @bind-Value="query.WarehouseCode" />

                <!-- 业务类型 -->
                <BizTypeInput @bind-Value="query.BusinessType" />

                <!-- ERP申请单号 -->
                <div class="form-item">
                    <label class="form-label">ERP申请单号</label>
                    <input type="text" class="form-input" placeholder="" @bind="query.ErpOrderNo" />
                </div>

                <!-- 单据号码 -->
                <div class="form-item">
                    <label class="form-label">单据号码</label>
                    <input type="text" class="form-input" placeholder="" @bind="query.DocumentNumber" />
                </div>

                <!-- 业务单号 -->
                <div class="form-item">
                    <label class="form-label">业务单号</label>
                    <input type="text" class="form-input" placeholder="" @bind="query.BizOrderNo" />
                </div>

                <!-- 派工状态 -->
                <div class="form-item">
                    <label class="form-label">派工状态</label>
                    <div class="select-wrapper">
                        <select class="form-select" @bind="query.DispatchStatus">
                            <option value="全部">全部</option>
                            <option value="未派工">未派工</option>
                            <option value="已派工">已派工</option>
                        </select>
                        <svg class="select-arrow" viewBox="0 0 12 12" width="10" height="10" fill="#999999">
                            <path d="M2 4l4 4 4-4"/>
                        </svg>
                    </div>
                </div>

                <!-- 拣货结案标记 -->
                <div class="form-item">
                    <label class="form-label">拣货结案</label>
                    <div class="select-wrapper">
                        <select class="form-select" @bind="query.PickCloseStatus">
                            <option value="全部">全部</option>
                            <option value="未派工">未派工</option>
                            <option value="已派工">已派工</option>
                        </select>
                        <svg class="select-arrow" viewBox="0 0 12 12" width="10" height="10" fill="#999999">
                            <path d="M2 4l4 4 4-4"/>
                        </svg>
                    </div>
                </div>

                <!-- 查询按钮 -->
                <div class="form-item query-btn-wrapper">
                    <button class="query-submit-btn" @onclick="HandleSearch">
                        <svg viewBox="0 0 16 16" width="16" height="16" fill="white" stroke="white" stroke-width="1.5">
                            <circle cx="7" cy="7" r="5"/>
                            <line x1="11" y1="11" x2="15" y2="15"/>
                        </svg>
                        <span>查询</span>
                    </button>
                </div>
            </div>
        </div>

        <!-- 右侧数据表格区域（双表格布局） -->
        <div class="table-panel">
            <!-- 工具栏 -->
            <div class="table-toolbar">
                <div class="toolbar-left">
                    <button class="toolbar-btn" disabled @onclick="HandleAssignPicker" title="指定拣货员">
                        <svg viewBox="0 0 16 16" width="14" height="14" fill="#666666">
                            <path d="M8 2a3 3 0 100 6 3 3 0 000-6zM4 10c-2 0-4 1-4 3v1h16v-1c0-2-2-3-4-3H4z" stroke="#666666" stroke-width="1.2" fill="none"/>
                        </svg>
                        <span>指定拣货员</span>
                    </button>
                    <button class="toolbar-btn" disabled @onclick="HandleDispatch" title="派工">
                        <svg viewBox="0 0 16 16" width="14" height="14" fill="#666666">
                            <path d="M2 8h12M8 2v12" stroke="#666666" stroke-width="1.5" stroke-linecap="round"/>
                        </svg>
                        <span>派工</span>
                    </button>
                    <button class="toolbar-btn" disabled @onclick="HandleCancelDispatch" title="取消派工">
                        <svg viewBox="0 0 16 16" width="14" height="14" fill="#666666">
                            <path d="M4 4l8 8M12 4l-8 8" stroke="#666666" stroke-width="1.5" stroke-linecap="round"/>
                        </svg>
                        <span>取消派工</span>
                    </button>
                    <button class="toolbar-btn primary-btn" @onclick="HandleBatchPriority" title="批量变更优先级">
                        <svg viewBox="0 0 16 16" width="14" height="14" fill="white">
                            <path d="M8 3v6m0 0l-2-2m2 2l2-2" stroke="white" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                            <path d="M3 13h10" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
                        </svg>
                        <span>批量变更优先级</span>
                    </button>
                </div>
            </div>

            <!-- 双表格容器 -->
            <div class="dual-table-container">
                <!-- ===== 主表格：通知单 ===== -->
                <div class="main-table-section">
                    <div class="section-header">
                        <div class="section-header-bar"></div>
                        <span class="section-header-title">通知单</span>
                    </div>
                    <div class="data-table-container">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th style="width:35px"><input type="checkbox" @onchange="ToggleSelectAll" checked="@IsAllSelected" /></th>
                                    @foreach (var col in mainColumnConfigs.Where(c => c.Visible))
                                    {
                                        var widthStyle = col.Width > 0 ? $"width:{col.Width}px" : "";
                                        if (col.Sortable)
                                        {
                                            <th style="@widthStyle" class="sortable">
                                                @col.DisplayName
                                                <svg viewBox="0 0 12 12" width="10" height="10" fill="#999999">
                                                    <path d="M6 3l3 3H9l-3-3-3 3H3z"/>
                                                    <path d="M6 9l-3-3h3l3 3h-3z" opacity="0.3"/>
                                                </svg>
                                            </th>
                                        }
                                        else
                                        {
                                            <th style="@widthStyle">@col.DisplayName</th>
                                        }
                                    }
                                    <th class="col-action" style="display:flex;align-items:center;justify-content:space-between;white-space:nowrap;">
                                        <span>操作</span>
                                        <button class="column-settings-btn" title="主表栏位设置" @onclick="OpenMainColumnSettings">
                                            <svg viewBox="0 0 16 16" width="14" height="14" fill="#666666">
                                                <path d="M2 3h4v2H2V3zm0 4h4v2H2V7zm0 4h4v2H2v-2zm6-8h6v2H8V3zm0 4h6v2H8V7zm0 4h6v2H8v-2z"/>
                                            </svg>
                                        </button>
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (mainDataSource.Count == 0)
                                {
                                    <tr><td colspan="@(MainVisibleColumnCount + 1)" class="empty-data-cell"><div class="empty-data"><svg viewBox="0 0 64 64" width="80" height="80" fill="none"><rect x="8" y="8" width="48" height="48" rx="8" fill="#F5F5F5" stroke="#E0E0E0" stroke-width="1"/><path d="M24 28h16M24 36h12" stroke="#D9D9D9" stroke-width="2" stroke-linecap="round"/></svg><p class="empty-text">暂无数据</p></div></td></tr>
                                }
                                else
                                {
                                    @foreach (var item in mainDataSource)
                                    {
                                        <tr>
                                            <td style="width:35px;text-align:center;"><input type="checkbox" checked="@item.IsSelected" @onchange="@((ChangeEventArgs e) => item.IsSelected = (bool)e.Value!)" /></td>
                                            @foreach (var col in mainColumnConfigs.Where(c => c.Visible))
                                            {
                                                var widthStyle = col.Width > 0 ? $"width:{col.Width}px" : "";
                                                <td style="@widthStyle">@GetMainCellValue(item, col.FieldKey)</td>
                                            }
                                            <td><button class="action-btn" title="操作"><svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="#1890FF" stroke-width="1.5"><circle cx="8" cy="3" r="1" fill="#1890FF"/><circle cx="8" cy="8" r="1" fill="#1890FF"/><circle cx="8" cy="13" r="1" fill="#1890FF"/></svg></button></td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="table-footer-info">
                        <span>共 @mainDataSource.Count 笔记录</span>
                    </div>
                </div>

                <!-- ===== 明细表格：通知单单据明细 ===== -->
                <div class="detail-table-section">
                    <div class="section-header">
                        <div class="section-header-bar"></div>
                        <span class="section-header-title">通知单明细</span>
                    </div>
                    <div class="data-table-container">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    @foreach (var col in detailColumnConfigs.Where(c => c.Visible))
                                    {
                                        var widthStyle = col.Width > 0 ? $"width:{col.Width}px" : "";
                                        if (col.Sortable)
                                        {
                                            <th style="@widthStyle" class="sortable">
                                                @col.DisplayName
                                                <svg viewBox="0 0 12 12" width="10" height="10" fill="#999999">
                                                    <path d="M6 3l3 3H9l-3-3-3 3H3z"/>
                                                    <path d="M6 9l-3-3h3l3 3h-3z" opacity="0.3"/>
                                                </svg>
                                            </th>
                                        }
                                        else
                                        {
                                            <th style="@widthStyle">@col.DisplayName</th>
                                        }
                                    }
                                    <th class="col-action" style="display:flex;align-items:center;justify-content:space-between;white-space:nowrap;">
                                        <span>操作</span>
                                        <button class="column-settings-btn" title="明细栏位设置" @onclick="OpenDetailColumnSettings">
                                            <svg viewBox="0 0 16 16" width="14" height="14" fill="#666666">
                                                <path d="M2 3h4v2H2V3zm0 4h4v2H2V7zm0 4h4v2H2v-2zm6-8h6v2H8V3zm0 4h6v2H8V7zm0 4h6v2H8v-2z"/>
                                            </svg>
                                        </button>
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (detailDataSource.Count == 0)
                                {
                                    <tr><td colspan="@(DetailVisibleColumnCount + 1)" class="empty-data-cell"><div class="empty-data"><svg viewBox="0 0 64 64" width="80" height="80" fill="none"><rect x="8" y="8" width="48" height="48" rx="8" fill="#F5F5F5" stroke="#E0E0E0" stroke-width="1"/><path d="M24 28h16M24 36h12" stroke="#D9D9D9" stroke-width="2" stroke-linecap="round"/></svg><p class="empty-text">暂无数据</p></div></td></tr>
                                }
                                else
                                {
                                    @foreach (var item in detailDataSource)
                                    {
                                        <tr>
                                            @foreach (var col in detailColumnConfigs.Where(c => c.Visible))
                                            {
                                                var widthStyle = col.Width > 0 ? $"width:{col.Width}px" : "";
                                                <td style="@widthStyle">@GetDetailCellValue(item, col.FieldKey)</td>
                                            }
                                            <td><button class="action-btn" title="操作"><svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="#1890FF" stroke-width="1.5"><circle cx="8" cy="3" r="1" fill="#1890FF"/><circle cx="8" cy="8" r="1" fill="#1890FF"/><circle cx="8" cy="13" r="1" fill="#1890FF"/></svg></button></td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 导出对话框 -->
@if (showExportDialog)
{
    <div class="export-dialog-overlay" @onclick="CancelExport">
        <div class="export-dialog" @onclick:stopPropagation>
            <div class="export-dialog-header">
                <span>导出 Excel</span>
                <button class="export-dialog-close" @onclick="CancelExport">&times;</button>
            </div>
            <div class="export-dialog-body">
                <label class="export-label">文件名</label>
                <input type="text" class="export-filename-input" @bind="exportFileName" @bind:event="oninput" />
            </div>
            <div class="export-dialog-footer">
                <button class="export-btn-cancel" @onclick="CancelExport">取消</button>
                <button class="export-btn-confirm" @onclick="ConfirmExport">确认导出</button>
            </div>
        </div>
    </div>
}

<!-- 主表格栏位设计对话框 -->
@if (showMainColumnSettingsDialog)
{
    <div class="column-settings-overlay" @onclick="CloseMainColumnSettings">
        <div class="column-settings-dialog" @onclick:stopPropagation>
            <div class="column-settings-header">
                <span>主表栏位设计</span>
                <button class="column-settings-close" @onclick="CloseMainColumnSettings">&times;</button>
            </div>
            <div class="column-settings-search">
                <input type="text" class="column-search-input" placeholder="搜索栏位原名..." @bind="mainColumnSearchKeyword" @bind:event="oninput" />
            </div>
            <div class="column-settings-body">
                <table class="column-settings-table">
                    <thead>
                        <tr>
                            <th class="col-seq">项次</th>
                            <th class="col-visible">显示否</th>
                            <th class="col-original">原栏位名</th>
                            <th class="col-display">栏位标题</th>
                            <th class="col-width">宽度</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < FilteredMainColumnConfigs.Count; i++)
                        {
                            var col = FilteredMainColumnConfigs[i];
                            var idx = mainColumnConfigs.IndexOf(col) + 1;
                            <tr>
                                <td class="col-seq">@idx</td>
                                <td class="col-visible">
                                    <label class="toggle-switch">
                                        <input type="checkbox" checked="@col.Visible" @onchange="@((ChangeEventArgs e) => col.Visible = (bool)e.Value!)" />
                                        <span class="toggle-slider"></span>
                                    </label>
                                </td>
                                <td class="col-original">@col.OriginalName</td>
                                <td class="col-display">
                                    <input type="text" class="col-title-input" value="@col.DisplayName"
                                           @onchange="@((ChangeEventArgs e) => col.DisplayName = e.Value?.ToString() ?? col.OriginalName)" />
                                </td>
                                <td class="col-width">
                                    <input type="number" class="col-width-input" value="@col.Width"
                                           min="0" max="500"
                                           @onchange="@((ChangeEventArgs e) => { if(int.TryParse(e.Value?.ToString(), out var w)) col.Width = w; })" />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="column-settings-footer">
                <div class="footer-left">
                    <button class="col-select-all" @onclick="SelectAllMainColumns">全选</button>
                    <button class="col-restore-default" @onclick="RestoreDefaultMainColumns">恢复默认</button>
                </div>
                <div class="footer-right">
                    <button class="col-btn-confirm" @onclick="ConfirmMainColumnSettings">确定</button>
                    <button class="col-btn-cancel" @onclick="CancelMainColumnSettings">取消</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- 明细表格栏位设计对话框 -->
@if (showDetailColumnSettingsDialog)
{
    <div class="column-settings-overlay" @onclick="CloseDetailColumnSettings">
        <div class="column-settings-dialog" @onclick:stopPropagation>
            <div class="column-settings-header">
                <span>明细栏位设计</span>
                <button class="column-settings-close" @onclick="CloseDetailColumnSettings">&times;</button>
            </div>
            <div class="column-settings-search">
                <input type="text" class="column-search-input" placeholder="搜索栏位原名..." @bind="detailColumnSearchKeyword" @bind:event="oninput" />
            </div>
            <div class="column-settings-body">
                <table class="column-settings-table">
                    <thead>
                        <tr>
                            <th class="col-seq">项次</th>
                            <th class="col-visible">显示否</th>
                            <th class="col-original">原栏位名</th>
                            <th class="col-display">栏位标题</th>
                            <th class="col-width">宽度</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < FilteredDetailColumnConfigs.Count; i++)
                        {
                            var col = FilteredDetailColumnConfigs[i];
                            var idx = detailColumnConfigs.IndexOf(col) + 1;
                            <tr>
                                <td class="col-seq">@idx</td>
                                <td class="col-visible">
                                    <label class="toggle-switch">
                                        <input type="checkbox" checked="@col.Visible" @onchange="@((ChangeEventArgs e) => col.Visible = (bool)e.Value!)" />
                                        <span class="toggle-slider"></span>
                                    </label>
                                </td>
                                <td class="col-original">@col.OriginalName</td>
                                <td class="col-display">
                                    <input type="text" class="col-title-input" value="@col.DisplayName"
                                           @onchange="@((ChangeEventArgs e) => col.DisplayName = e.Value?.ToString() ?? col.OriginalName)" />
                                </td>
                                <td class="col-width">
                                    <input type="number" class="col-width-input" value="@col.Width"
                                           min="0" max="500"
                                           @onchange="@((ChangeEventArgs e) => { if(int.TryParse(e.Value?.ToString(), out var w)) col.Width = w; })" />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="column-settings-footer">
                <div class="footer-left">
                    <button class="col-select-all" @onclick="SelectAllDetailColumns">全选</button>
                    <button class="col-restore-default" @onclick="RestoreDefaultDetailColumns">恢复默认</button>
                </div>
                <div class="footer-right">
                    <button class="col-btn-confirm" @onclick="ConfirmDetailColumnSettings">确定</button>
                    <button class="col-btn-cancel" @onclick="CancelDetailColumnSettings">取消</button>
                </div>
            </div>
        </div>
    </div>
}


@code {
    // ===== 状态变量 =====
    private bool isFavorited = false;
    private bool showFavoriteSuccess = false;
    private bool isCollapsed = false;
    private bool showSettingsMenu = false;
    private bool showExportDialog = false;
    private string exportFileName = "";

    // 来源单据类别 Checkbox 状态
    private bool includeOutboundNotice = true;
    private bool includeTransferNotice = true;

    // 栏位设置对话框状态
    private bool showMainColumnSettingsDialog = false;
    private bool showDetailColumnSettingsDialog = false;
    private string mainColumnSearchKeyword = "";
    private string detailColumnSearchKeyword = "";

    // 查询与数据
    private OutboundNoticeDispatchQuery query = new();
    private List<OutboundNoticeDispatchModel> mainDataSource = new();
