    {
        "ItemNo" => item.ItemNo,
        "Priority" => item.Priority > 0 ? item.Priority : "",
        "BillType" => "",          // TODO: 业务类型字段来源待确认
        "DocumentDate" => item.DocumentDate.ToString("yyyy-MM-dd"),
        "DocumentNumber" => item.DocumentNumber,
        "ErpOrderNo" => item.ErpOrderNo,
        "EstDeliveryDate" => item.EstDeliveryDate.HasValue ? item.EstDeliveryDate.Value.ToString("yyyy-MM-dd") : "",
        "CustomerName" => item.CustomerName,
        "HandlerName" => item.HandlerName,
        "BillCategory" => item.BillCategory,
        "CustomerCode" => item.CustomerCode,
        "IsClosed" => item.IsClosed ? "是" : "否",
        "DispatchStatus" => item.DispatchStatus,
        "PickerName" => item.PickerName,
        "Remark" => item.Remark,
        _ => ""
    };

