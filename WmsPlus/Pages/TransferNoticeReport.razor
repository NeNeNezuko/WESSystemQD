@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@inject HttpClient Http
@inject ILogger<TransferNoticeReport> _logger
@inject TokenProvider TokenProvider

<link rel="stylesheet" href="css/transfer-notice-report.css" />

<div class="transfer-notice-report-page" style="display:flex;flex-direction:column;flex:1 1 0%;overflow:hidden;">
    <!-- 顶部标题栏 -->
    <div class="page-header">
        <div class="header-left">
            <button class="favorite-btn @(isFavorited ? "favorited" : "")" @onclick="ToggleFavorite" title="收藏">
                <svg viewBox="0 0 24 24" width="24" height="24">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
                          fill="@((isFavorited ? "#FFD700" : "none"))"
                          stroke="@((isFavorited ? "#FFD700" : "#666666"))"
                          stroke-width="2"/>
                </svg>
            </button>
            <span class="page-title">调拨通知单报表</span>
        </div>
        <div class="header-right">
            <button class="collapse-btn-fixed @(isCollapsed ? "collapsed" : "")" @onclick="ToggleCollapse" title="@(isCollapsed ? "展开查询" : "收起查询")">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="#666666">
                    <rect x="3" y="6" width="18" height="2" rx="1"/>
                    <rect x="3" y="11" width="18" height="2" rx="1"/>
                    <rect x="3" y="16" width="18" height="2" rx="1"/>
                </svg>
            </button>
        </div>
    </div>

    <!-- 收藏成功提示 -->
    @if (showFavoriteSuccess)
    {
        <div class="favorite-success-toast">
            <div class="toast-content">
                <svg viewBox="0 0 16 16" width="16" height="16" fill="#52C41A">
                    <circle cx="8" cy="8" r="8"/>
                    <path d="M5 8l2 2 4-4" stroke="white" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>收藏成功</span>
            </div>
        </div>
    }

    <!-- 主内容区域 -->
    <div class="page-content">
        <!-- 左侧查询区域 -->
        <div class="query-panel @(isCollapsed ? "collapsed" : "")">
            <div class="query-header">
                <span class="query-title">查询</span>
                <button class="query-settings-btn" title="设置" @onclick="ToggleSettingsMenu">
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="#999999" stroke-width="2">
                        <circle cx="12" cy="12" r="3"/>
                        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/>
                    </svg>
                </button>
                @if (showSettingsMenu)
                {
                    <div class="settings-dropdown" @onclick:stopPropagation>
                        <div class="settings-dropdown-item" @onclick="BatchAddCondition">批次添加条件</div>
                        <div class="settings-dropdown-item" @onclick="AddSingleCondition">添加单一条件</div>
                        <div class="settings-dropdown-item" @onclick="CustomCondition">自定义条件</div>
                        <div class="settings-dropdown-item" @onclick="RemoveCondition">移除条件</div>
                        <div class="settings-dropdown-item" @onclick="SaveConditionValues">保存条件值</div>
                    </div>
                }
            </div>

            <div class="query-form">
                <DateRangeInput @bind-Value="query.DateRange" />

                <div class="form-item">
                    <label class="form-label">通知单号</label>
                    <input type="text" class="form-input" placeholder="" @bind="query.NoticeNumber" />
                </div>

                <div class="form-item">
                    <label class="form-label">部门名称</label>
                    <input type="text" class="form-input" placeholder="" @bind="query.DepName" />
                </div>

                <div class="form-item-fused">
                    <div class="fused-row">
                        <label class="form-label">货品代号 起</label>
                        <input type="text" class="fused-input" @bind="query.PrdNoFrom" />
                    </div>
                    <div class="fused-divider"></div>
                    <div class="fused-row">
                        <label class="form-label">货品代号 止</label>
                        <input type="text" class="fused-input" @bind="query.PrdNoTo" />
                    </div>
                </div>

                <div class="form-item-fused">
                    <div class="fused-row">
                        <label class="form-label">货品名称 起</label>
                        <input type="text" class="fused-input" @bind="query.PrdNameFrom" />
                    </div>
                    <div class="fused-divider"></div>
                    <div class="fused-row">
                        <label class="form-label">货品名称 止</label>
                        <input type="text" class="fused-input" @bind="query.PrdNameTo" />
                    </div>
                </div>

                <WarehouseCodeInput @bind-Value="query.WhOut" />

                <WarehouseCodeInput @bind-Value="query.WhIn" />

                <div class="form-item">
                    <label class="form-label">ERP申请单号</label>
                    <input type="text" class="form-input" placeholder="" @bind="query.ErpApplyNo" />
                </div>

                <div class="form-item">
                    <label class="form-label">业务单号</label>
                    <input type="text" class="form-input" placeholder="" @bind="query.BizNo" />
                </div>

                <div class="form-item">
                    <label class="form-label">第三方系统单号</label>
                    <input type="text" class="form-input" placeholder="" @bind="query.ThirdPartyNo" />
                </div>

                <div class="form-item">
                    <label class="form-label">波次结案</label>
                    <select class="form-input" @bind="query.ClsIdBc">
                        <option value="">全部</option>
                        <option value="Y">是</option>
                        <option value="N">否</option>
                    </select>
                </div>

                <div class="form-item">
                    <label class="form-label">拣货结案</label>
                    <select class="form-input" @bind="query.ClsIdPk">
                        <option value="">全部</option>
                        <option value="Y">是</option>
                        <option value="N">否</option>
                    </select>
                </div>

                <div class="form-item">
                    <label class="form-label">出库结案</label>
                    <select class="form-input" @bind="query.ClsIdCk">
                        <option value="">全部</option>
                        <option value="Y">是</option>
                        <option value="N">否</option>
                    </select>
                </div>

                <div class="form-item query-btn-wrapper">
                    <button class="query-submit-btn" @onclick="HandleSearch">
                        <svg viewBox="0 0 16 16" width="16" height="16" fill="white" stroke="white" stroke-width="1.5">
                            <circle cx="7" cy="7" r="5"/><line x1="11" y1="11" x2="15" y2="15"/>
                        </svg>
                        <span>查询</span>
                    </button>
                </div>
            </div>
        </div>

        <!-- 右侧数据表格区域 -->
        <div class="table-panel">
            <div class="table-toolbar">
                <div class="toolbar-left">
                    <!-- 内层选项卡：明细表 | 统计表 -->
                    <div class="inner-tab-bar-inline">
                        <div class="inner-tab-item @(activeInnerTab == "detail" ? "active" : "")" @onclick="SwitchToDetailTab">明细表</div>
                        <div class="inner-tab-item @(activeInnerTab == "summary" ? "active" : "")" @onclick="SwitchToSummaryTab">统计表</div>
                    </div>
                    <button class="toolbar-btn export-btn" @onclick="HandleExport">
                        <svg viewBox="0 0 16 16" width="14" height="14" fill="#666666">
                            <path d="M8 12V4m0 0L5 7m3-3l3 3" stroke="#666666" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                            <path d="M2 11v2a1 1 0 001 1h10a1 1 0 001-1v-2" stroke="#666666" stroke-width="1.5" fill="none" stroke-linecap="round"/>
                        </svg>
                        <span>导出</span>
                    </button>
                </div>
            </div>

            <div class="data-table-container">
                <table class="data-table">
                    <thead>
                        <tr>
                            @foreach (var col in columnConfigs.Where(c => c.Visible))
                            {
                                var widthStyle = col.Width > 0 ? $"width:{col.Width}px" : "";
                                if (col.Sortable)
                                {
                                    <th style="@widthStyle" class="sortable">
                                        @col.DisplayName
                                        <svg viewBox="0 0 12 12" width="10" height="10" fill="#999999">
                                            <path d="M6 3l3 3H9l-3-3-3 3H3z"/><path d="M6 9l-3-3h3l3 3h-3z" opacity="0.3"/>
                                        </svg>
                                    </th>
                                }
                                else
                                {
                                    <th style="@widthStyle">@col.DisplayName</th>
                                }
                            }
                            <th class="col-action" style="display:flex;align-items:center;justify-content:space-between;white-space:nowrap;">
                                <span>操作</span>
                                <button class="column-settings-btn" title="栏位设置" @onclick="OpenColumnSettings">
                                    <svg viewBox="0 0 16 16" width="14" height="14" fill="#666666"><path d="M2 3h4v2H2V3zm0 4h4v2H2V7zm0 4h4v2H2v-2zm6-8h6v2H8V3zm0 4h6v2H8V7zm0 4h6v2H8v-2z"/></svg>
                                </button>
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (dataSource.Count == 0)
                        {
                            <tr><td colspan="@(VisibleColumnCount + 1)" class="empty-data-cell"><div class="empty-data"><svg viewBox="0 0 64 64" width="80" height="80" fill="none"><rect x="8" y="8" width="48" height="48" rx="8" fill="#F5F5F5" stroke="#E0E0E0" stroke-width="1"/><path d="M24 28h16M24 36h12" stroke="#D9D9D9" stroke-width="2" stroke-linecap="round"/></svg><p class="empty-text">暂无数据</p></div></td></tr>
                        }
                        else
                        {
                            @foreach (var item in dataSource)
                            {
                                <tr>
                                    @foreach (var col in columnConfigs.Where(c => c.Visible))
                                    {
                                        var widthStyle = col.Width > 0 ? $"width:{col.Width}px" : "";
                                        <td style="@widthStyle">@GetCellValue(item, col.FieldKey)</td>
                                    }
                                    <td><button class="action-btn" title="操作"><svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="#1890FF" stroke-width="1.5"><circle cx="8" cy="3" r="1" fill="#1890FF"/><circle cx="8" cy="8" r="1" fill="#1890FF"/><circle cx="8" cy="13" r="1" fill="#1890FF"/></svg></button></td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
            <!-- 表格底部栏 -->
            <div class="table-footer">
                <div class="footer-left">
                    <span class="footer-label">分页栏位字段：</span>
                    <div class="footer-checkboxes">
                        @foreach (var col in columnConfigs.Where(c => c.Visible))
                        {
                            <label class="footer-checkbox-item">
                                <input type="checkbox" checked />
                                <span>@col.DisplayName</span>
                            </label>
                        }
                    </div>
                </div>
                <div class="footer-right">
                    <span class="record-count">共 @dataSource.Count 条记录</span>
                    <div class="pagination-info"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 导出对话框 -->
@if (showExportDialog)
{
    <div class="export-dialog-overlay" @onclick="CancelExport">
        <div class="export-dialog" @onclick:stopPropagation>
            <div class="export-dialog-header"><span>导出 Excel</span><button class="export-dialog-close" @onclick="CancelExport">&times;</button></div>
            <div class="export-dialog-body">
                <label class="export-label">文件名</label>
                <input type="text" class="export-filename-input" @bind="exportFileName" @bind:event="oninput" />
            </div>
            <div class="export-dialog-footer">
                <button class="export-btn-cancel" @onclick="CancelExport">取消</button>
                <button class="export-btn-confirm" @onclick="ConfirmExport">确认导出</button>
            </div>
        </div>
    </div>
}

<!-- 栏位设计对话框 -->
@if (showColumnSettingsDialog)
{
    <div class="column-settings-overlay" @onclick="CloseColumnSettings">
        <div class="column-settings-dialog" @onclick:stopPropagation>
            <div class="column-settings-header"><span>栏位设计</span><button class="column-settings-close" @onclick="CloseColumnSettings">&times;</button></div>
            <div class="column-settings-search">
                <input type="text" class="column-search-input" placeholder="搜索栏位原名..." @bind="columnSearchKeyword" @bind:event="oninput" />
            </div>
            <div class="column-settings-body">
                <table class="column-settings-table">
                    <thead><tr><th class="col-seq">项次</th><th class="col-visible">显示否</th><th class="col-original">原栏位名</th><th class="col-display">栏位标题</th><th class="col-width">宽度</th></tr></thead>
                    <tbody>
                        @for (int i = 0; i < FilteredColumnConfigs.Count; i++)
                        {
                            var col = FilteredColumnConfigs[i];
                            var idx = columnConfigs.IndexOf(col) + 1;
                            <tr>
                                <td class="col-seq">@idx</td>
                                <td class="col-visible">
                                    <label class="toggle-switch">
                                        <input type="checkbox" checked="@col.Visible" @onchange="@((ChangeEventArgs e) => col.Visible = (bool)e.Value!)" />
                                        <span class="toggle-slider"></span>
                                    </label>
                                </td>
                                <td class="col-original">@col.OriginalName</td>
                                <td class="col-display">
                                    <input type="text" class="col-title-input" value="@col.DisplayName"
                                           @onchange="@((ChangeEventArgs e) => col.DisplayName = e.Value?.ToString() ?? col.OriginalName)" />
                                </td>
                                <td class="col-width">
                                    <input type="number" class="col-width-input" value="@col.Width" min="0" max="500"
                                           @onchange="@((ChangeEventArgs e) => { if(int.TryParse(e.Value?.ToString(), out var w)) col.Width = w; })" />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="column-settings-footer">
                <div class="footer-left">
                    <button class="col-select-all" @onclick="SelectAllColumns">全选</button>
                    <button class="col-restore-default" @onclick="RestoreDefaultColumns">恢复默认</button>
                </div>
                <div class="footer-right">
                    <button class="col-btn-confirm" @onclick="ConfirmColumnSettings">确定</button>
                    <button class="col-btn-cancel" @onclick="CancelColumnSettings">取消</button>
                </div>
            </div>
        </div>
    </div>
}


@code {
    private bool isFavorited = false;
    private bool showFavoriteSuccess = false;
    private bool isCollapsed = false;
    private bool showSettingsMenu = false;
    private bool showExportDialog = false;
    private string exportFileName = "";
    private bool showColumnSettingsDialog = false;
    private string columnSearchKeyword = "";
    private string activeInnerTab = "detail";
    private List<ColumnConfig> columnConfigs = new();
    private List<ColumnConfig> defaultColumnConfigs = new();
    private TransferNoticeReportQuery query = new();
    private List<TransferNoticeReportModel> dataSource = new();

    [CascadingParameter(Name = "OnFavoriteChanged")] public Action? OnFavoriteChanged { get; set; }

    protected override async Task OnInitializedAsync()
    {
        InitDefaultColumnConfigs();
        await LoadColumnSettings();
        await LoadFavoriteStatus();
        await LoadData();
    }

    private void SwitchInnerTab(string tab)
    {
        activeInnerTab = tab;
        InitDefaultColumnConfigs();
        _ = LoadData();
        StateHasChanged();
    }
    private void SwitchToDetailTab() => SwitchInnerTab("detail");
    private void SwitchToSummaryTab() => SwitchInnerTab("summary");

    private void ToggleCollapse() { isCollapsed = !isCollapsed; StateHasChanged(); }
    private void ToggleSettingsMenu() { showSettingsMenu = !showSettingsMenu; StateHasChanged(); }
    private void BatchAddCondition() { showSettingsMenu = false; StateHasChanged(); }
    private void AddSingleCondition() { showSettingsMenu = false; StateHasChanged(); }
    private void CustomCondition() { showSettingsMenu = false; StateHasChanged(); }
    private void RemoveCondition() { showSettingsMenu = false; StateHasChanged(); }
    private void SaveConditionValues() { showSettingsMenu = false; StateHasChanged(); }

    private async Task LoadFavoriteStatus()
    {
        try { var r = await JS.InvokeAsync<string>("localStorage.getItem", "wms_favorite_transfer_notice_report"); isFavorited = r == "true"; }
        catch { isFavorited = false; }
    }

    private async Task ToggleFavorite()
    {
        isFavorited = !isFavorited;
        try { await JS.InvokeVoidAsync("localStorage.setItem", "wms_favorite_transfer_notice_report", isFavorited.ToString().ToLower()); } catch { }
        OnFavoriteChanged?.Invoke();
        if (isFavorited) { showFavoriteSuccess = true; StateHasChanged(); await Task.Delay(2000); showFavoriteSuccess = false; }
        StateHasChanged();
    }

    private async Task HandleSearch() { await LoadData(); }

    private async Task HandleExport()
    {
        if (dataSource.Count == 0) { await JS.InvokeVoidAsync("alert", "暂无数据可导出"); return; }
        exportFileName = $"调拨通知单报表_{DateTime.Now:yyyyMMddHHmmss}";
        showExportDialog = true;
        StateHasChanged();
    }

    private void CancelExport() { showExportDialog = false; StateHasChanged(); }

    private async Task ConfirmExport()
    {
        showExportDialog = false;
        try { await ExportToExcel(); } catch (Exception ex) { await JS.InvokeVoidAsync("alert", $"导出失败: {ex.Message}"); }
    }

    private async Task LoadData()
    {
        try
        {
            var today = DateTime.Today;
            var dateFromStr = today.ToString("yyyy-MM-dd");
            var dateToStr = today.ToString("yyyy-MM-dd");
            if (!string.IsNullOrWhiteSpace(query.DateRange) && query.DateRange.Contains("\u2192"))
            {
                var parts = query.DateRange.Split("\u2192", StringSplitOptions.TrimEntries);
                if (parts.Length >= 2) { dateFromStr = parts[0]; dateToStr = parts[1]; }
            }
            var viewType = activeInnerTab == "summary" ? "summary" : "detail";
            var url = $"{ApiConfig.BaseUrl}/api/TransferNoticeReport/search?dateFrom={dateFromStr}&dateTo={dateToStr}&viewType={viewType}";
            if (!string.IsNullOrWhiteSpace(query.NoticeNumber)) url += $"&noticeNumber={Uri.EscapeDataString(query.NoticeNumber)}";
            if (!string.IsNullOrWhiteSpace(query.DepName)) url += $"&depName={Uri.EscapeDataString(query.DepName)}";
            if (!string.IsNullOrWhiteSpace(query.PrdNoFrom)) url += $"&prdNoFrom={Uri.EscapeDataString(query.PrdNoFrom)}";
            if (!string.IsNullOrWhiteSpace(query.PrdNoTo)) url += $"&prdNoTo={Uri.EscapeDataString(query.PrdNoTo)}";
            if (!string.IsNullOrWhiteSpace(query.PrdNameFrom)) url += $"&prdNameFrom={Uri.EscapeDataString(query.PrdNameFrom)}";
            if (!string.IsNullOrWhiteSpace(query.PrdNameTo)) url += $"&prdNameTo={Uri.EscapeDataString(query.PrdNameTo)}";
            if (!string.IsNullOrWhiteSpace(query.WhOut)) url += $"&whOut={Uri.EscapeDataString(query.WhOut)}";
            if (!string.IsNullOrWhiteSpace(query.WhIn)) url += $"&whIn={Uri.EscapeDataString(query.WhIn)}";
            if (!string.IsNullOrWhiteSpace(query.ErpApplyNo)) url += $"&erpApplyNo={Uri.EscapeDataString(query.ErpApplyNo)}";
            if (!string.IsNullOrWhiteSpace(query.BizNo)) url += $"&bizNo={Uri.EscapeDataString(query.BizNo)}";
            if (!string.IsNullOrWhiteSpace(query.ThirdPartyNo)) url += $"&thirdPartyNo={Uri.EscapeDataString(query.ThirdPartyNo)}";
            if (!string.IsNullOrWhiteSpace(query.ClsIdBc)) url += $"&clsIdBc={Uri.EscapeDataString(query.ClsIdBc)}";
            if (!string.IsNullOrWhiteSpace(query.ClsIdPk)) url += $"&clsIdPk={Uri.EscapeDataString(query.ClsIdPk)}";
            if (!string.IsNullOrWhiteSpace(query.ClsIdCk)) url += $"&clsIdCk={Uri.EscapeDataString(query.ClsIdCk)}";

            var jsonOptions = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var request = AuthHttpClient.CreateRequest(HttpMethod.Get, url, TokenProvider.Token);
            var responseMsg = await Http.SendAsync(request);
            var response = await responseMsg.Content.ReadFromJsonAsync<ApiResponse<List<TransferNoticeReportModel>>>(jsonOptions);
            if (response != null && response.Success && response.Data != null) { dataSource = response.Data; }
            else { dataSource = new List<TransferNoticeReportModel>(); }
        }
        catch (Exception ex)
        {
            _logger?.LogError(ex, "加载调拨通知单报表数据失败");
            dataSource = new List<TransferNoticeReportModel>();
        }
        StateHasChanged();
    }

    private async Task ExportToExcel()
    {
        var visibleCols = columnConfigs.Where(c => c.Visible).ToList();
        var headers = visibleCols.Select(c => c.DisplayName).ToArray();
        var rows = new List<object[]>();
        rows.Add(headers);
        foreach (var item in dataSource)
        {
            var row = new object[visibleCols.Count];
            for (int i = 0; i < visibleCols.Count; i++) row[i] = GetCellValue(item, visibleCols[i].FieldKey);
            rows.Add(row);
        }
        var fileName = string.IsNullOrWhiteSpace(exportFileName) ? $"调拨通知单报表_{DateTime.Now:yyyyMMddHHmmss}" : exportFileName;
        if (!fileName.EndsWith(".xlsx", StringComparison.OrdinalIgnoreCase)) fileName += ".xlsx";
        await JS.InvokeVoidAsync("exportToExcel", rows, fileName);
    }

    // ===== 栏位配置 =====
    private class ColumnConfig
    {
        public string FieldKey { get; set; } = "";
        public string OriginalName { get; set; } = "";
        public string DisplayName { get; set; } = "";
        public bool Visible { get; set; } = true;
        public int Width { get; set; } = 0;
        public int DefaultWidth { get; set; } = 0;
        public bool Sortable { get; set; } = false;
    }

    private const string COLUMN_SETTINGS_KEY_DETAIL = "wms_column_settings_transfer_notice_detail";
    private const string COLUMN_SETTINGS_KEY_SUMMARY = "wms_column_settings_transfer_notice_summary";
    private string CurrentColumnSettingsKey => activeInnerTab == "summary" ? COLUMN_SETTINGS_KEY_SUMMARY : COLUMN_SETTINGS_KEY_DETAIL;

    private void InitDefaultColumnConfigs()
    {
        if (activeInnerTab == "summary")
        {
            defaultColumnConfigs = new List<ColumnConfig>
            {
                new() { FieldKey = "TZ_NO", OriginalName = "通知单号", DisplayName = "通知单号", Visible = true, Width = 110, DefaultWidth = 110, Sortable = true },
                new() { FieldKey = "TZ_DD", OriginalName = "单据日期", DisplayName = "单据日期", Visible = true, Width = 90, DefaultWidth = 90, Sortable = true },
                new() { FieldKey = "DEP", OriginalName = "部门代号", DisplayName = "部门代号", Visible = true, Width = 75, DefaultWidth = 75 },
                new() { FieldKey = "WH1", OriginalName = "出货仓库", DisplayName = "出货仓库", Visible = true, Width = 80, DefaultWidth = 80, Sortable = true },
                new() { FieldKey = "WH2", OriginalName = "入货仓库", DisplayName = "入货仓库", Visible = true, Width = 80, DefaultWidth = 80, Sortable = true },
                new() { FieldKey = "SAL_NO", OriginalName = "业务员", DisplayName = "业务员", Visible = true, Width = 70, DefaultWidth = 70 },
                new() { FieldKey = "EST_DD", OriginalName = "预计日期", DisplayName = "预计日期", Visible = true, Width = 90, DefaultWidth = 90, Sortable = true },
                new() { FieldKey = "AREA_SH", OriginalName = "调拨区域", DisplayName = "调拨区域", Visible = true, Width = 80, DefaultWidth = 80 },
                new() { FieldKey = "CLS_ID_BC", OriginalName = "波次结案", DisplayName = "波次结案", Visible = true, Width = 70, DefaultWidth = 70 },
                new() { FieldKey = "CLS_ID_CK", OriginalName = "出库结案", DisplayName = "出库结案", Visible = true, Width = 70, DefaultWidth = 70 },
                new() { FieldKey = "TYPE_ID", OriginalName = "类型", DisplayName = "类型", Visible = true, Width = 60, DefaultWidth = 60 },
                new() { FieldKey = "SYS_DATE", OriginalName = "录入时间", DisplayName = "录入时间", Visible = true, Width = 145, DefaultWidth = 145, Sortable = true }
            };
        }
        else
        {
            defaultColumnConfigs = new List<ColumnConfig>
            {
                new() { FieldKey = "ItemNo", OriginalName = "项次", DisplayName = "项次", Visible = true, Width = 45, DefaultWidth = 45 },
                new() { FieldKey = "TZ_NO", OriginalName = "通知单号", DisplayName = "通知单号", Visible = true, Width = 110, DefaultWidth = 110, Sortable = true },
                new() { FieldKey = "TZ_DD", OriginalName = "单据日期", DisplayName = "单据日期", Visible = true, Width = 90, DefaultWidth = 90, Sortable = true },
