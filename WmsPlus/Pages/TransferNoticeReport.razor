                new() { FieldKey = "REM", OriginalName = "备注", DisplayName = "备注", Visible = false, Width = 80, DefaultWidth = 80 }
            };
        }
        columnConfigs = defaultColumnConfigs.Select(c => new ColumnConfig
        {
            FieldKey = c.FieldKey, OriginalName = c.OriginalName, DisplayName = c.DisplayName,
            Visible = c.Visible, Width = c.Width, DefaultWidth = c.DefaultWidth, Sortable = c.Sortable
        }).ToList();
    }

    private async Task LoadColumnSettings()
    {
        try
        {
            var json = await JS.InvokeAsync<string>("localStorage.getItem", CurrentColumnSettingsKey);
            if (!string.IsNullOrWhiteSpace(json))
            {
                var options = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
                var saved = System.Text.Json.JsonSerializer.Deserialize<List<ColumnConfig>>(json, options);
                if (saved != null && saved.Count > 0)
                {
                    foreach (var col in columnConfigs)
                    {
                        var savedCol = saved.FirstOrDefault(s => s.FieldKey == col.FieldKey);
                        if (savedCol != null)
                        {
                            col.Visible = savedCol.Visible;
                            col.DisplayName = !string.IsNullOrWhiteSpace(savedCol.DisplayName) ? savedCol.DisplayName : col.OriginalName;
                            col.Width = savedCol.Width >= 0 ? savedCol.Width : col.DefaultWidth;
                        }
                    }
                }
            }
        }
        catch { }
    }

    private async Task SaveColumnSettings()
    {
        try { var json = System.Text.Json.JsonSerializer.Serialize(columnConfigs); await JS.InvokeVoidAsync("localStorage.setItem", CurrentColumnSettingsKey, json); }
        catch { }
    }

    private void OpenColumnSettings() { columnSearchKeyword = ""; showColumnSettingsDialog = true; StateHasChanged(); }
    private void CloseColumnSettings() { showColumnSettingsDialog = false; StateHasChanged(); }
    private void ConfirmColumnSettings() { showColumnSettingsDialog = false; _ = SaveColumnSettings(); StateHasChanged(); }
    private void CancelColumnSettings() { showColumnSettingsDialog = false; _ = LoadColumnSettings(); StateHasChanged(); }
    private void SelectAllColumns() { foreach (var col in columnConfigs) col.Visible = true; StateHasChanged(); }

    private void RestoreDefaultColumns()
    {
        for (int i = 0; i < columnConfigs.Count && i < defaultColumnConfigs.Count; i++)
        {
            columnConfigs[i].Visible = defaultColumnConfigs[i].Visible;
            columnConfigs[i].DisplayName = defaultColumnConfigs[i].DisplayName;
            columnConfigs[i].Width = defaultColumnConfigs[i].Width;
        }
        StateHasChanged();
    }

    private List<ColumnConfig> FilteredColumnConfigs =>
        string.IsNullOrWhiteSpace(columnSearchKeyword)
            ? columnConfigs
            : columnConfigs.Where(c => c.OriginalName.Contains(columnSearchKeyword, StringComparison.OrdinalIgnoreCase) ||
                                       c.FieldKey.Contains(columnSearchKeyword, StringComparison.OrdinalIgnoreCase)).ToList();

    private int VisibleColumnCount => columnConfigs.Count(c => c.Visible);

    private object GetCellValue(TransferNoticeReportModel item, string fieldKey) => fieldKey switch
    {
        "ItemNo" => item.ItemNo,
        "TZ_NO" => item.TZ_NO,
        "TZ_DD" => item.TZ_DD?.ToString("yyyy-MM-dd"),
        "DEP" => item.DEP,
        "WH1" => item.WH1,
        "WH2" => item.WH2,
        "PRD_NO" => item.PRD_NO,
        "PRD_NAME" => item.PRD_NAME,
        "QTY" => item.QTY,
        "REM" => item.REM,
        "SAL_NO" => item.SAL_NO,
        "EST_DD" => item.EST_DD?.ToString("yyyy-MM-dd"),
        "AREA_SH" => item.AREA_SH,
        "CLS_ID_BC" => item.CLS_ID_BC == "Y" ? "是" : (item.CLS_ID_BC == "N" ? "否" : item.CLS_ID_BC),
        "CLS_ID_CK" => item.CLS_ID_CK == "Y" ? "是" : (item.CLS_ID_CK == "N" ? "否" : item.CLS_ID_CK),
        "TYPE_ID" => item.TYPE_ID,
        "SYS_DATE" => item.SYS_DATE?.ToString("yyyy-MM-dd HH:mm:ss"),
        _ => ""
    };

    private class ApiResponse<T>
    {
        public bool Success { get; set; }
        public string Message { get; set; } = "";
        public T? Data { get; set; }
        public int Total { get; set; }
    }
