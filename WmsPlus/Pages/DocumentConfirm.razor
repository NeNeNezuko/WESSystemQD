@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@inject HttpClient Http
@inject ILogger<DocumentConfirm> _logger
@inject TokenProvider TokenProvider

<link rel="stylesheet" href="css/document-confirm.css" />

<div class="document-confirm-page" style="display:flex;flex-direction:column;flex:1 1 0%;overflow:hidden;">
    <!-- 顶部标题栏 -->
    <div class="page-header">
        <div class="header-left">
            <button class="favorite-btn @(isFavorited ? "favorited" : "")" @onclick="ToggleFavorite" title="收藏">
                <svg viewBox="0 0 24 24" width="24" height="24">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
                          fill="@((isFavorited ? "#FFD700" : "none"))"
                          stroke="@((isFavorited ? "#FFD700" : "#666666"))"
                          stroke-width="2"/>
                </svg>
            </button>
            <span class="page-title">单据确认作业</span>
        </div>
        <div class="header-right">
            <button class="collapse-btn-fixed @(isCollapsed ? "collapsed" : "")" @onclick="ToggleCollapse" title="@(isCollapsed ? "展开查询" : "收起查询")">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="#666666">
                    <rect x="3" y="6" width="18" height="2" rx="1"/>
                    <rect x="3" y="11" width="18" height="2" rx="1"/>
                    <rect x="3" y="16" width="18" height="2" rx="1"/>
                </svg>
            </button>
        </div>
    </div>

    <!-- 收藏成功提示 -->
    @if (showFavoriteSuccess)
    {
        <div class="favorite-success-toast">
            <div class="toast-content">
                <svg viewBox="0 0 16 16" width="16" height="16" fill="#52C41A">
                    <circle cx="8" cy="8" r="8"/>
                    <path d="M5 8l2 2 4-4" stroke="white" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>收藏成功</span>
            </div>
        </div>
    }

    <!-- 内层选项卡：待确认 / 已确认 -->
    <div class="inner-tab-bar">
        <div class="inner-tab-item @(activeInnerTab == "pending" ? "active" : "")" @onclick="SwitchToPendingTab">
            待确认
        </div>
        <div class="inner-tab-item @(activeInnerTab == "confirmed" ? "active" : "")" @onclick="SwitchToConfirmedTab">
            已确认
        </div>
    </div>

    <!-- 主内容区域 -->
    <div class="page-content">
        <!-- 左侧查询区域 -->
        <div class="query-panel @(isCollapsed ? "collapsed" : "")">
            <div class="query-header">
                <span class="query-title">查询</span>
                <button class="query-settings-btn" title="设置" @onclick="ToggleSettingsMenu">
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="#999999" stroke-width="2">
                        <circle cx="12" cy="12" r="3"/>
                        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/>
                    </svg>
                </button>
                @if (showSettingsMenu)
                {
                    <div class="settings-dropdown" @onclick:stopPropagation>
                        <div class="settings-dropdown-item" @onclick="BatchAddCondition">批次添加条件</div>
                        <div class="settings-dropdown-item" @onclick="AddSingleCondition">添加单一条件</div>
                        <div class="settings-dropdown-item" @onclick="CustomCondition">自定义条件</div>
                        <div class="settings-dropdown-item" @onclick="RemoveCondition">移除条件</div>
                        <div class="settings-dropdown-item" @onclick="SaveConditionValues">保存条件值</div>
                    </div>
                }
            </div>

            <div class="query-form">
                <!-- 单据别 -->
                <div class="form-item">
                    <label class="form-label">单据别</label>
                    <div class="select-wrapper">
                        <select class="form-select" @bind="query.DocType" @bind:after="OnDocTypeChanged">
                            <option value="PD">盘点单</option>
                            <option value="YN">盘盈单</option>
                            <option value="KU">盘亏单</option>
                        </select>
                        <svg class="select-arrow" viewBox="0 0 12 12" width="10" height="10" fill="#999999">
                            <path d="M2 4l4 4 4-4"/>
                        </svg>
                    </div>
                </div>

                <!-- 单据日期 -->
                <DateRangeInput @bind-Value="query.DateRange" />

                <!-- 仓库代号 -->
                <WarehouseCodeInput @bind-Value="query.WarehouseCode" />

                <!-- 起止货品（融合式单边框）-->
                <div class="form-item-fused">
                    <div class="fused-row">
                        <ProductCodeInput @bind-Value="query.PrdNoFrom" Label="货品代号 起" />
                    </div>
                    <div class="fused-divider"></div>
                    <div class="fused-row">
                        <ProductCodeInput @bind-Value="query.PrdNoTo" Label="货品代号 止" />
                    </div>
                </div>

                <!-- 查询按钮 -->
                <div class="form-item query-btn-wrapper">
                    <button class="query-submit-btn" @onclick="HandleSearch">
                        <svg viewBox="0 0 16 16" width="16" height="16" fill="white" stroke="white" stroke-width="1.5">
                            <circle cx="7" cy="7" r="5"/>
                            <line x1="11" y1="11" x2="15" y2="15"/>
                        </svg>
                        <span>查询</span>
                    </button>
                </div>
            </div>
        </div>

        <!-- 右侧数据表格区域 -->
        <div class="table-panel">
            <!-- 工具栏：根据内层选项卡显示不同按钮 -->
            <div class="table-toolbar">
                <div class="toolbar-left">
                    @if (activeInnerTab == "pending")
                    {
                        <button class="toolbar-btn primary-btn" @onclick="HandleConfirm">
                            <svg viewBox="0 0 16 16" width="14" height="14" fill="white">
                                <path d="M13.854 3.646a.5.5 0 0 1 0 .708l-7 7a.5.5 0 0 1-.708 0l-3.5-3.5a.5.5 0 1 1 .708-.708L6.5 10.293l6.646-6.647a.5.5 0 0 1 .708 0z" stroke="white" stroke-width="0.5"/>
                            </svg>
                            <span>确认</span>
                        </button>
                    }
                    else
                    {
                        <button class="toolbar-btn primary-btn" @onclick="HandleUnconfirm">
                            <svg viewBox="0 0 16 16" width="14" height="14" fill="white">
                                <path d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708z" stroke="white" stroke-width="0.5"/>
                            </svg>
                            <span>反确认</span>
                        </button>
                    }
                    <button class="toolbar-btn export-btn" @onclick="HandleExport">
                        <svg viewBox="0 0 16 16" width="14" height="14" fill="#666666">
                            <path d="M8 12V4m0 0L5 7m3-3l3 3" stroke="#666666" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                            <path d="M2 11v2a1 1 0 001 1h10a1 1 0 001-1v-2" stroke="#666666" stroke-width="1.5" fill="none" stroke-linecap="round"/>
                        </svg>
                        <span>导出</span>
                    </button>
                </div>
            </div>

            <!-- 数据表格 -->
            <div class="data-table-container">
                <table class="data-table">
                    <thead>
                        <tr>
                            @foreach (var col in columnConfigs.Where(c => c.Visible))
                            {
                                var widthStyle = col.Width > 0 ? $"width:{col.Width}px" : "";
                                if (col.Sortable)
                                {
                                    <th style="@widthStyle" class="sortable">
                                        @col.DisplayName
                                        <svg viewBox="0 0 12 12" width="10" height="10" fill="#999999">
                                            <path d="M6 3l3 3H9l-3-3-3 3H3z"/>
                                            <path d="M6 9l-3-3h3l3 3h-3z" opacity="0.3"/>
                                        </svg>
                                    </th>
                                }
                                else
                                {
                                    <th style="@widthStyle">@col.DisplayName</th>
                                }
                            }
                            <th class="col-action" style="display:flex;align-items:center;justify-content:space-between;white-space:nowrap;">
                                <span>操作</span>
                                <button class="column-settings-btn" title="栏位设置" @onclick="OpenColumnSettings">
                                    <svg viewBox="0 0 16 16" width="14" height="14" fill="#666666">
                                        <path d="M2 3h4v2H2V3zm0 4h4v2H2V7zm0 4h4v2H2v-2zm6-8h6v2H8V3zm0 4h6v2H8V7zm0 4h6v2H8v-2z"/>
                                    </svg>
                                </button>
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (dataSource.Count == 0)
                        {
                            <tr><td colspan="@(VisibleColumnCount + 1)" class="empty-data-cell"><div class="empty-data"><svg viewBox="0 0 64 64" width="80" height="80" fill="none"><rect x="8" y="8" width="48" height="48" rx="8" fill="#F5F5F5" stroke="#E0E0E0" stroke-width="1"/><path d="M24 28h16M24 36h12" stroke="#D9D9D9" stroke-width="2" stroke-linecap="round"/></svg><p class="empty-text">暂无数据</p></div></td></tr>
                        }
                        else
                        {
                            @foreach (var item in dataSource)
                            {
                                <tr>
                                    @foreach (var col in columnConfigs.Where(c => c.Visible))
                                    {
                                        var widthStyle = col.Width > 0 ? $"width:{col.Width}px" : "";
                                        <td style="@widthStyle">@GetCellValue(item, col.FieldKey)</td>
                                    }
                                    <td><button class="action-btn" title="操作"><svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="#1890FF" stroke-width="1.5"><circle cx="8" cy="3" r="1" fill="#1890FF"/><circle cx="8" cy="8" r="1" fill="#1890FF"/><circle cx="8" cy="13" r="1" fill="#1890FF"/></svg></button></td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- 导出对话框 -->
@if (showExportDialog)
{
    <div class="export-dialog-overlay" @onclick="CancelExport">
        <div class="export-dialog" @onclick:stopPropagation>
            <div class="export-dialog-header">
                <span>导出 Excel</span>
                <button class="export-dialog-close" @onclick="CancelExport">&times;</button>
            </div>
            <div class="export-dialog-body">
                <label class="export-label">文件名</label>
                <input type="text" class="export-filename-input" @bind="exportFileName" @bind:event="oninput" />
            </div>
            <div class="export-dialog-footer">
                <button class="export-btn-cancel" @onclick="CancelExport">取消</button>
                <button class="export-btn-confirm" @onclick="ConfirmExport">确认导出</button>
            </div>
        </div>
    </div>
}

<!-- 栏位设计对话框 -->
@if (showColumnSettingsDialog)
{
    <div class="column-settings-overlay" @onclick="CloseColumnSettings">
        <div class="column-settings-dialog" @onclick:stopPropagation>
            <div class="column-settings-header">
                <span>栏位设计</span>
                <button class="column-settings-close" @onclick="CloseColumnSettings">&times;</button>
            </div>
            <div class="column-settings-search">
                <input type="text" class="column-search-input" placeholder="搜索栏位原名..." @bind="columnSearchKeyword" @bind:event="oninput" />
            </div>
            <div class="column-settings-body">
                <table class="column-settings-table">
                    <thead>
                        <tr>
                            <th class="col-seq">项次</th>
                            <th class="col-visible">显示否</th>
                            <th class="col-original">原栏位名</th>
                            <th class="col-display">栏位标题</th>
                            <th class="col-width">宽度</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < FilteredColumnConfigs.Count; i++)
                        {
                            var col = FilteredColumnConfigs[i];
                            var idx = columnConfigs.IndexOf(col) + 1;
                            <tr>
                                <td class="col-seq">@idx</td>
                                <td class="col-visible">
                                    <label class="toggle-switch">
                                        <input type="checkbox" checked="@col.Visible" @onchange="@((ChangeEventArgs e) => col.Visible = (bool)e.Value!)" />
                                        <span class="toggle-slider"></span>
                                    </label>
                                </td>
                                <td class="col-original">@col.OriginalName</td>
                                <td class="col-display">
                                    <input type="text" class="col-title-input" value="@col.DisplayName"
                                           @onchange="@((ChangeEventArgs e) => col.DisplayName = e.Value?.ToString() ?? col.OriginalName)" />
                                </td>
                                <td class="col-width">
                                    <input type="number" class="col-width-input" value="@col.Width"
                                           min="0" max="500"
                                           @onchange="@((ChangeEventArgs e) => { if(int.TryParse(e.Value?.ToString(), out var w)) col.Width = w; })" />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="column-settings-footer">
                <div class="footer-left">
                    <button class="col-select-all" @onclick="SelectAllColumns">全选</button>
                    <button class="col-restore-default" @onclick="RestoreDefaultColumns">恢复默认</button>
                </div>
                <div class="footer-right">
                    <button class="col-btn-confirm" @onclick="ConfirmColumnSettings">确定</button>
                    <button class="col-btn-cancel" @onclick="CancelColumnSettings">取消</button>
                </div>
            </div>
        </div>
    </div>
}


@code {
    // ===== 状态变量 =====
    private bool isFavorited = false;
    private bool showFavoriteSuccess = false;
    private bool isCollapsed = false;
    private bool showSettingsMenu = false;
    private bool showExportDialog = false;
    private string exportFileName = "";
    private bool showColumnSettingsDialog = false;
    private string columnSearchKeyword = "";
    private string activeInnerTab = "pending";  // 内层选项卡：pending(待确认) / confirmed(已确认)
    private List<ColumnConfig> columnConfigs = new();
    private List<ColumnConfig> defaultColumnConfigs = new();
    private DocumentConfirmQuery query = new();
    private List<DocumentConfirmModel> dataSource = new();

    [CascadingParameter(Name = "OnFavoriteChanged")] public Action? OnFavoriteChanged { get; set; }

    protected override async Task OnInitializedAsync()
    {
        InitDefaultColumnConfigs();
        await LoadColumnSettings();
        await LoadFavoriteStatus();
        await LoadData();
    }

    // ===== 内层选项卡切换 =====
    private void SwitchInnerTab(string tab)
    {
        activeInnerTab = tab;
        _ = LoadData();  // 切换选项卡时重新加载数据
        StateHasChanged();
    }

    private void SwitchToPendingTab() => SwitchInnerTab("pending");
    private void SwitchToConfirmedTab() => SwitchInnerTab("confirmed");

    // ===== 单据别变更时重新加载 =====
    private async Task OnDocTypeChanged()
    {
        await LoadData();
    }

    // ===== 折叠/展开 =====
    private void ToggleCollapse()
    {
        isCollapsed = !isCollapsed;
        StateHasChanged();
    }

    // ===== 设置菜单方法 =====
    private void ToggleSettingsMenu()
    {
        showSettingsMenu = !showSettingsMenu;
        StateHasChanged();
    }

    private void BatchAddCondition() { showSettingsMenu = false; StateHasChanged(); }
    private void AddSingleCondition() { showSettingsMenu = false; StateHasChanged(); }
    private void CustomCondition() { showSettingsMenu = false; StateHasChanged(); }
    private void RemoveCondition() { showSettingsMenu = false; StateHasChanged(); }
    private void SaveConditionValues() { showSettingsMenu = false; StateHasChanged(); }

    // ===== 收藏功能 =====
    private async Task LoadFavoriteStatus()
    {
        try { var r = await JS.InvokeAsync<string>("localStorage.getItem", "wms_favorite_document_confirm"); isFavorited = r == "true"; }
        catch { isFavorited = false; }
    }

    private async Task ToggleFavorite()
    {
        isFavorited = !isFavorited;
        try { await JS.InvokeVoidAsync("localStorage.setItem", "wms_favorite_document_confirm", isFavorited.ToString().ToLower()); } catch { }
        OnFavoriteChanged?.Invoke();
        if (isFavorited)
        {
            showFavoriteSuccess = true; StateHasChanged(); await Task.Delay(2000); showFavoriteSuccess = false;
        }
        StateHasChanged();
    }

    // ===== 查询操作 =====
    private async Task HandleSearch() { await LoadData(); }

    // ===== 确认/反确认（占位） =====
    private void HandleConfirm() { /* TODO: 实现确认逻辑 */ }

    private void HandleUnconfirm() { /* TODO: 实现反确认逻辑 */ }

    // ===== 导出 =====
    private async Task HandleExport()
    {
        if (dataSource.Count == 0) { await JS.InvokeVoidAsync("alert", "暂无数据可导出"); return; }
        exportFileName = $"单据确认作业_{DateTime.Now:yyyyMMddHHmmss}";
        showExportDialog = true;
        StateHasChanged();
    }

    private void CancelExport()
    {
        showExportDialog = false;
        StateHasChanged();
    }

    private async Task ConfirmExport()
    {
        showExportDialog = false;
        try { await ExportToExcel(); } catch (Exception ex) { await JS.InvokeVoidAsync("alert", $"导出失败: {ex.Message}"); }
    }

    // ===== 数据加载 =====
    private async Task LoadData()
    {
        try
        {
            const string ApiBaseUrl = "http://localhost:5102";
            var today = DateTime.Today;
            var dateFromStr = today.ToString("yyyy-MM-dd");
            var dateToStr = today.ToString("yyyy-MM-dd");
            if (!string.IsNullOrWhiteSpace(query.DateRange) && query.DateRange.Contains("\u2192"))
            {
                var parts = query.DateRange.Split("\u2192", StringSplitOptions.TrimEntries);
                if (parts.Length >= 2)
                {
                    dateFromStr = parts[0];
                    dateToStr = parts[1];
                }
            }
            var confirmStatus = activeInnerTab == "confirmed" ? "confirmed" : "pending";
            var url = $"{ApiBaseUrl}/api/DocumentConfirm/search?docType={Uri.EscapeDataString(query.DocType)}&dateFrom={dateFromStr}&dateTo={dateToStr}&confirmStatus={confirmStatus}";
            if (!string.IsNullOrWhiteSpace(query.WarehouseCode))
                url += $"&warehouseCode={Uri.EscapeDataString(query.WarehouseCode)}";
            if (!string.IsNullOrWhiteSpace(query.PrdNoFrom))
                url += $"&prdNoFrom={Uri.EscapeDataString(query.PrdNoFrom)}";
            if (!string.IsNullOrWhiteSpace(query.PrdNoTo))
                url += $"&prdNoTo={Uri.EscapeDataString(query.PrdNoTo)}";

            var jsonOptions = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var request = AuthHttpClient.CreateRequest(HttpMethod.Get, url, TokenProvider.Token);
            var responseMsg = await Http.SendAsync(request);
            var response = await responseMsg.Content.ReadFromJsonAsync<ApiResponse<List<DocumentConfirmModel>>>(jsonOptions);
            if (response != null && response.Success && response.Data != null)
            {
                dataSource = response.Data;
            }
            else
            {
                dataSource = new List<DocumentConfirmModel>();
            }
        }
        catch (Exception ex)
        {
            _logger?.LogError(ex, "加载单据确认作业数据失败");
            dataSource = new List<DocumentConfirmModel>();
        }
        StateHasChanged();
    }

    // ===== Excel导出 =====
    private async Task ExportToExcel()
    {
        var visibleCols = columnConfigs.Where(c => c.Visible).ToList();
        var headers = visibleCols.Select(c => c.DisplayName).ToArray();
        var rows = new List<object[]>();
        rows.Add(headers);
        foreach (var item in dataSource)
        {
            var row = new object[visibleCols.Count];
            for (int i = 0; i < visibleCols.Count; i++)
                row[i] = GetCellValue(item, visibleCols[i].FieldKey);
            rows.Add(row);
        }
        var fileName = string.IsNullOrWhiteSpace(exportFileName) ? $"单据确认作业_{DateTime.Now:yyyyMMddHHmmss}" : exportFileName;
        if (!fileName.EndsWith(".xlsx", StringComparison.OrdinalIgnoreCase)) fileName += ".xlsx";
        await JS.InvokeVoidAsync("exportToExcel", rows, fileName);
    }

    // ===== 栏位配置 =====
    private class ColumnConfig
    {
        public string FieldKey { get; set; } = "";
        public string OriginalName { get; set; } = "";
        public string DisplayName { get; set; } = "";
        public bool Visible { get; set; } = true;
        public int Width { get; set; } = 0;
        public int DefaultWidth { get; set; } = 0;
        public bool Sortable { get; set; } = false;
    }

    private const string COLUMN_SETTINGS_KEY = "wms_column_settings_document_confirm";

    private void InitDefaultColumnConfigs()
    {
        defaultColumnConfigs = new List<ColumnConfig>
        {
            new() { FieldKey = "DocumentDate", OriginalName = "单据日期", DisplayName = "单据日期", Visible = true, Width = 90, DefaultWidth = 90, Sortable = true },
            new() { FieldKey = "DocumentNumber", OriginalName = "单据号码", DisplayName = "单据号码", Visible = true, Width = 120, DefaultWidth = 120, Sortable = true },
            new() { FieldKey = "WarehouseCode", OriginalName = "仓库代号", DisplayName = "仓库代号", Visible = true, Width = 80, DefaultWidth = 80, Sortable = true },
            new() { FieldKey = "WarehouseName", OriginalName = "仓库名称", DisplayName = "仓库名称", Visible = true, Width = 100, DefaultWidth = 100 },
            new() { FieldKey = "CreatorCode", OriginalName = "制单人代号", DisplayName = "制单人代号", Visible = true, Width = 90, DefaultWidth = 90 },
            new() { FieldKey = "CreatorName", OriginalName = "制单人名称", DisplayName = "制单人名称", Visible = true, Width = 90, DefaultWidth = 90 },
            new() { FieldKey = "CreateTime", OriginalName = "制单时间", DisplayName = "制单时间", Visible = true, Width = 140, DefaultWidth = 140, Sortable = true },
            new() { FieldKey = "ConfirmStatus", OriginalName = "确认状态", DisplayName = "确认状态", Visible = true, Width = 75, DefaultWidth = 75 },
            new() { FieldKey = "ConfirmUser", OriginalName = "确认人", DisplayName = "确认人", Visible = true, Width = 80, DefaultWidth = 80 },
            new() { FieldKey = "ConfirmTime", OriginalName = "确认时间", DisplayName = "确认时间", Visible = true, Width = 140, DefaultWidth = 140 }
        };
        columnConfigs = defaultColumnConfigs.Select(c => new ColumnConfig
        {
            FieldKey = c.FieldKey,
            OriginalName = c.OriginalName,
            DisplayName = c.DisplayName,
            Visible = c.Visible,
            Width = c.Width,
            DefaultWidth = c.DefaultWidth,
            Sortable = c.Sortable
        }).ToList();
    }

    private async Task LoadColumnSettings()
    {
        try
        {
            var json = await JS.InvokeAsync<string>("localStorage.getItem", COLUMN_SETTINGS_KEY);
            if (!string.IsNullOrWhiteSpace(json))
            {
                var options = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
                var saved = System.Text.Json.JsonSerializer.Deserialize<List<ColumnConfig>>(json, options);
                if (saved != null && saved.Count > 0)
                {
                    foreach (var col in columnConfigs)
                    {
                        var savedCol = saved.FirstOrDefault(s => s.FieldKey == col.FieldKey);
                        if (savedCol != null)
                        {
                            col.Visible = savedCol.Visible;
                            col.DisplayName = !string.IsNullOrWhiteSpace(savedCol.DisplayName) ? savedCol.DisplayName : col.OriginalName;
                            col.Width = savedCol.Width >= 0 ? savedCol.Width : col.DefaultWidth;
                        }
                    }
                }
            }
        }
        catch { }
    }

    private async Task SaveColumnSettings()
    {
        try
        {
            var json = System.Text.Json.JsonSerializer.Serialize(columnConfigs);
            await JS.InvokeVoidAsync("localStorage.setItem", COLUMN_SETTINGS_KEY, json);
        }
        catch { }
    }

    private void OpenColumnSettings()
    {
        columnSearchKeyword = "";
        showColumnSettingsDialog = true;
        StateHasChanged();
    }

    private void CloseColumnSettings()
    {
        showColumnSettingsDialog = false;
        StateHasChanged();
    }

    private void ConfirmColumnSettings()
    {
        showColumnSettingsDialog = false;
        _ = SaveColumnSettings();
        StateHasChanged();
    }

    private void CancelColumnSettings()
    {
        showColumnSettingsDialog = false;
        _ = LoadColumnSettings();
        StateHasChanged();
    }

    private void SelectAllColumns()
    {
        foreach (var col in columnConfigs)
            col.Visible = true;
        StateHasChanged();
    }

    private void RestoreDefaultColumns()
    {
        for (int i = 0; i < columnConfigs.Count && i < defaultColumnConfigs.Count; i++)
        {
            columnConfigs[i].Visible = defaultColumnConfigs[i].Visible;
            columnConfigs[i].DisplayName = defaultColumnConfigs[i].DisplayName;
            columnConfigs[i].Width = defaultColumnConfigs[i].Width;
        }
        StateHasChanged();
    }

    private List<ColumnConfig> FilteredColumnConfigs =>
        string.IsNullOrWhiteSpace(columnSearchKeyword)
            ? columnConfigs
            : columnConfigs.Where(c => c.OriginalName.Contains(columnSearchKeyword, StringComparison.OrdinalIgnoreCase) ||
                                       c.FieldKey.Contains(columnSearchKeyword, StringComparison.OrdinalIgnoreCase)).ToList();

    private int VisibleColumnCount => columnConfigs.Count(c => c.Visible);

    // 获取单元格渲染值
    private object GetCellValue(DocumentConfirmModel item, string fieldKey) => fieldKey switch
    {
        "DocumentDate" => item.DocumentDate.ToString("yyyy-MM-dd"),
        "DocumentNumber" => item.DocumentNumber,
        "WarehouseCode" => item.WarehouseCode,
        "WarehouseName" => item.WarehouseName,
        "CreatorCode" => item.CreatorCode,
        "CreatorName" => item.CreatorName,
        "CreateTime" => item.CreateTime.ToString("yyyy-MM-dd HH:mm:ss"),
        "ConfirmStatus" => item.ConfirmStatus,
        "ConfirmUser" => item.ConfirmUser,
        "ConfirmTime" => item.ConfirmTime.HasValue ? item.ConfirmTime.Value.ToString("yyyy-MM-dd HH:mm:ss") : "",
        _ => ""
    };

    // ===== API响应模型 =====
    private class ApiResponse<T>
    {
        public bool Success { get; set; }
        public string Message { get; set; } = "";
        public T? Data { get; set; }
        public int Total { get; set; }
    }
}
