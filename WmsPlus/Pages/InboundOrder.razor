@inject IJSRuntime JS

<link rel="stylesheet" href="css/inbound-order.css" />

<div class="inbound-order-page" style="display:flex;flex-direction:column;flex:1 1 0%;overflow:hidden;">
    <!-- 页面头部 -->
    <div class="page-header">
        <div class="header-left">
            <button class="favorite-btn @(isFavorited ? "favorited" : "")" @onclick="ToggleFavorite" title="收藏">
                <svg viewBox="0 0 24 24" width="24" height="24">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
                          fill="@((isFavorited ? "#FFD700" : "none"))"
                          stroke="@((isFavorited ? "#FFD700" : "#666666"))"
                          stroke-width="2"/>
                </svg>
            </button>
            <span class="page-title">入库单/查询</span>
        </div>
        <div class="header-center">
            <button class="collapse-btn-fixed @(isCollapsed ? "collapsed" : "")" @onclick="ToggleCollapse" title="@(isCollapsed ? "展开查询" : "收起查询")">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="#666666">
                    <rect x="3" y="6" width="18" height="2" rx="1"/>
                    <rect x="3" y="11" width="18" height="2" rx="1"/>
                    <rect x="3" y="16" width="18" height="2" rx="1"/>
                </svg>
            </button>
        </div>
        <div class="header-right">
            <button class="header-action-btn primary">
                <svg viewBox="0 0 16 16" width="12" height="12" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="8" y1="3" x2="8" y2="13"/><line x1="3" y1="8" x2="13" y2="8"/></svg>
                新增
            </button>
            <button class="header-action-btn">
                <svg viewBox="0 0 16 16" width="12" height="12" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8 3v7M5 7l3 3 3-3"/><path d="M3 12h10"/></svg>
                导出
            </button>
        </div>
    </div>

    @if (showFavoriteSuccess)
    {
        <div class="favorite-success-toast">
            <div class="toast-content">
                <svg viewBox="0 0 20 20" width="16" height="16" fill="#52C41A"><circle cx="10" cy="10" r="10"/><path d="M6 10l3 3 5-6" stroke="white" stroke-width="1.5" fill="none"/></svg>
                <span>收藏成功！已添加到工作台常用功能</span>
            </div>
        </div>
    }

    <!-- 主内容区 -->
    <div class="page-content">
        <!-- 左侧查询区域 -->
        <div class="query-panel @(isCollapsed ? "collapsed" : "")">
            <div class="query-header">
                <span class="query-title">查询</span>
                <button class="query-settings-btn" title="设置" @onclick="ToggleSettingsMenu">
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="#999999" stroke-width="2">
                        <circle cx="12" cy="12" r="3"/>
                        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/>
                    </svg>
                </button>
                @if (showSettingsMenu)
                {
                    <div class="settings-dropdown" @onclick:stopPropagation>
                        <div class="settings-dropdown-item" @onclick="BatchAddCondition">批次添加条件</div>
                        <div class="settings-dropdown-item" @onclick="AddSingleCondition">添加单一条件</div>
                        <div class="settings-dropdown-item" @onclick="CustomCondition">自定义条件</div>
                        <div class="settings-dropdown-item" @onclick="RemoveCondition">移除条件</div>
                        <div class="settings-dropdown-item" @onclick="SaveConditionValues">保存条件值</div>
                    </div>
                }
            </div>

            <div class="query-form">
                <!-- 单据日期 - 日期范围选择器 -->
                <DateRangeInput @bind-Value="query.DateRange" />

                <div class="form-item">
                    <label class="form-label">单据号码</label>
                    <div class="input-with-search">
                        <input type="text" class="form-input" placeholder="" @bind="query.OrderNumber" />
                        <button class="search-icon-btn" title="搜索">
                            <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="#999" stroke-width="1.5"><circle cx="6.5" cy="6.5" r="4.5"/><line x1="10" y1="10" x2="14.5" y2="14.5"/></svg>
                        </button>
                    </div>
                </div>

                <DeptCodeInput @bind-Value="query.DeptCode" />

                <WarehouseCodeInput @bind-Value="query.WarehouseCode" />

                <div class="form-item">
                    <label class="form-label">厂商代号</label>
                    <div class="input-with-search">
                        <input type="text" class="form-input" placeholder="" @bind="query.VendorCode" />
                        <button class="search-icon-btn" title="搜索">
                            <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="#999" stroke-width="1.5"><circle cx="6.5" cy="6.5" r="4.5"/><line x1="10" y1="10" x2="14.5" y2="14.5"/></svg>
                        </button>
                    </div>
                </div>

                <div class="query-btn-wrapper">
                    <button class="query-submit-btn" @onclick="HandleQuery">
                        <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="7" cy="7" r="4.5"/><line x1="11" y1="11" x2="15" y2="15"/></svg>
                        查询
                    </button>
                </div>
            </div>
        </div>

        <!-- 右侧表格区域 -->
        <div class="table-panel">
            <div class="data-table-container">
                @if (dataSource.Count > 0)
                {
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th class="col-item-no sortable">项次</th>
                                <th class="col-date sortable">入库日期</th>
                                <th class="col-doc-no sortable">入库单号</th>
                                <th class="col-dept-code sortable">部门代号</th>
                                <th class="col-dept-name sortable">部门名称</th>
                                <th class="col-wh-code sortable">仓库代号</th>
                                <th class="col-wh-name sortable">仓库名称</th>
                                <th class="col-vendor-code sortable">厂商代号</th>
                                <th class="col-vendor-name sortable">厂商名称</th>
                                <th class="col-transfer-in-id sortable">转入ID</th>
                                <th class="col-transfer-in-no sortable">转入单号</th>
                                <th class="col-action">操作</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in dataSource)
                            {
                                <tr>
                                    <td>@item.ItemNo</td>
                                    <td>@item.InboundDate.ToString("yyyy-MM-dd")</td>
                                    <td>@item.OrderNumber</td>
                                    <td>@item.DeptCode</td>
                                    <td>@item.DeptName</td>
                                    <td>@item.WarehouseCode</td>
                                    <td>@item.WarehouseName</td>
                                    <td>@item.VendorCode</td>
                                    <td>@item.VendorName</td>
                                    <td>@item.TransferInId</td>
                                    <td>@item.TransferInOrderNumber</td>
                                    <td>
                                        <button class="query-link-btn" @onclick="() => HandleEdit(item.OrderNumber)">查询</button>
                                        <button class="action-btn" title="查看"><svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="#1890ff" stroke-width="1.5"><path d="M2 8s3-4.5 6-4.5S14 8 14 8s-3 4.5-6 4.5S2 8 2 8z"/><circle cx="8" cy="8" r="1.5"/></svg></button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th class="col-item-no">项次</th>
                                <th class="col-date">入库日期</th>
                                <th class="col-doc-no">入库单号</th>
                                <th class="col-dept-code">部门代号</th>
                                <th class="col-dept-name">部门名称</th>
                                <th class="col-wh-code">仓库代号</th>
                                <th class="col-wh-name">仓库名称</th>
                                <th class="col-vendor-code">厂商代号</th>
                                <th class="col-vendor-name">厂商名称</th>
                                <th class="col-transfer-in-id">转入ID</th>
                                <th class="col-transfer-in-no">转入单号</th>
                                <th class="col-action">操作</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td colspan="12" class="empty-data-cell">
                                    <div class="empty-data">
                                        <svg viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg">
                                            <rect x="8" y="12" width="48" height="40" rx="4" fill="#f5f5f5" stroke="#e8e8e8" stroke-width="1.5"/>
                                            <path d="M18 28 L26 36 L44 18" stroke="#d9d9d9" stroke-width="2" fill="none" opacity="0.5"/>
                                            <rect x="16" y="20" width="32" height="2" rx="1" fill="#e8e8e8"/>
                                            <rect x="16" y="26" width="24" height="2" rx="1" fill="#e8e8e8"/>
                                            <rect x="16" y="32" width="28" height="2" rx="1" fill="#e8e8e8"/>
                                        </svg>
                                        <p class="empty-text">暂无数据</p>
                                    </div>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private bool isFavorited = false;
    private bool showFavoriteSuccess = false;
    private bool isCollapsed = false;
    private bool showSettingsMenu = false;
    private InboundOrderQuery query = new();
    private List<InboundOrderModel> dataSource = new();


    [CascadingParameter(Name = "OnFavoriteChanged")] public Action? OnFavoriteChanged { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadFavoriteStatus();
        await LoadData();
    }

    // ===== 原有功能方法 =====
    private void ToggleCollapse()
    {
        isCollapsed = !isCollapsed;
        StateHasChanged();
    }

    // ===== 设置菜单方法 =====
    private void ToggleSettingsMenu()
    {
        showSettingsMenu = !showSettingsMenu;
        StateHasChanged();
    }

    private void BatchAddCondition() { showSettingsMenu = false; StateHasChanged(); }
    private void AddSingleCondition() { showSettingsMenu = false; StateHasChanged(); }
    private void CustomCondition() { showSettingsMenu = false; StateHasChanged(); }
    private void RemoveCondition() { showSettingsMenu = false; StateHasChanged(); }
    private void SaveConditionValues() { showSettingsMenu = false; StateHasChanged(); }

    private async Task ToggleFavorite()
    {
        isFavorited = !isFavorited;
        try
        {
            await JS.InvokeVoidAsync("localStorage.setItem", "wms_favorite_inbound_order", isFavorited.ToString().ToLower());
        }
        catch { }

        OnFavoriteChanged?.Invoke();

        if (isFavorited)
        {
            showFavoriteSuccess = true;
            StateHasChanged();
            await Task.Delay(2000);
            showFavoriteSuccess = false;
            StateHasChanged();
        }
    }

    private async Task LoadFavoriteStatus()
    {
        try
        {
            var result = await JS.InvokeAsync<string>("localStorage.getItem", "wms_favorite_inbound_order");
            isFavorited = result == "true";
        }
        catch { isFavorited = false; }
    }

    private async Task LoadData()
    {
        await Task.Delay(100);
        dataSource = new List<InboundOrderModel>();
    }

    private async Task HandleQuery()
    {
        await LoadData();
    }

    private void HandleEdit(string orderNumber)
    {
        // TODO: 打开入库单查询/编辑页面
    }
}
