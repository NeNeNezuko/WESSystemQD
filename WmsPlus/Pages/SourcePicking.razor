    }

    private void RestoreCurrentDefaultColumns()
    {
        var defaults = currentEditingColumnType switch
        {
            "batch" => defaultBatchColumnConfigs,
            "pick-main" => defaultPickMainColumnConfigs,
            "pick-detail" => defaultPickDetailColumnConfigs,
            _ => defaultBatchColumnConfigs
        };
        var target = CurrentEditingColumns;
        for (int i = 0; i < target.Count && i < defaults.Count; i++)
        {
            target[i].Visible = defaults[i].Visible;
            target[i].DisplayName = defaults[i].DisplayName;
            target[i].Width = defaults[i].Width;
        }
        StateHasChanged();
    }

