@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@inject HttpClient Http
@inject ILogger<SourcePicking> _logger
@inject TokenProvider TokenProvider

<link rel="stylesheet" href="css/source-picking.css" />

<div class="source-picking-page">
    <!-- 顶部标题栏 -->
    <div class="page-header">
        <div class="header-left">
            <button class="favorite-btn @(isFavorited ? "favorited" : "")" @onclick="ToggleFavorite" title="收藏">
                <svg viewBox="0 0 24 24" width="24" height="24">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
                          fill="@((isFavorited ? "#FFD700" : "none"))"
                          stroke="@((isFavorited ? "#FFD700" : "#666666"))"
                          stroke-width="2"/>
                </svg>
            </button>
            <span class="page-title">依来源单配货</span>
        </div>
        <div class="header-right">
            <button class="collapse-btn-fixed @(isCollapsed ? "collapsed" : "")" @onclick="ToggleCollapse" title="@(isCollapsed ? "展开查询" : "收起查询")">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="#666666">
                    <rect x="3" y="6" width="18" height="2" rx="1"/>
                    <rect x="3" y="11" width="18" height="2" rx="1"/>
                    <rect x="3" y="16" width="18" height="2" rx="1"/>
                </svg>
            </button>
        </div>
    </div>

    <!-- 收藏成功提示 -->
    @if (showFavoriteSuccess)
    {
        <div class="favorite-success-toast">
            <div class="toast-content">
                <svg viewBox="0 0 16 16" width="16" height="16" fill="#52C41A">
                    <circle cx="8" cy="8" r="8"/>
                    <path d="M5 8l2 2 4-4" stroke="white" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>收藏成功</span>
            </div>
        </div>
    }

    <!-- 主内容区域 -->
    <div class="page-content">
        <!-- 左侧查询区域（两Tab共用容器，内容随Tab切换） -->
        <div class="query-panel @(isCollapsed ? "collapsed" : "")">
            <div class="query-header">
                <span class="query-title">查询</span>
                <button class="query-settings-btn" title="设置" @onclick="ToggleSettingsMenu">
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="#999999" stroke-width="2">
                        <circle cx="12" cy="12" r="3"/>
                        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2.83 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2.83 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/>
                    </svg>
                </button>
                @if (showSettingsMenu)
                {
                    <div class="settings-dropdown" @onclick:stopPropagation>
                        <div class="settings-dropdown-item" @onclick="BatchAddCondition">批次添加条件</div>
                        <div class="settings-dropdown-item" @onclick="AddSingleCondition">添加单一条件</div>
                        <div class="settings-dropdown-item" @onclick="CustomCondition">自定义条件</div>
                        <div class="settings-dropdown-item" @onclick="RemoveCondition">移除条件</div>
                        <div class="settings-dropdown-item" @onclick="SaveConditionValues">保存条件值</div>
                    </div>
                }
            </div>

            <div class="query-form">
                @if (activeInnerTabId == "batch-shelving")
                {
                    <!-- ====== Tab1: 批量上架 查询条件 ====== -->
                    <WarehouseCodeInput @bind-Value="batchQuery.WarehouseCode" />

                    <DateRangeInput @bind-Value="batchQuery.DateRange" />

                    <div class="form-item">
                        <label class="form-label">单据号码</label>
                        <input type="text" class="form-input" placeholder="" @bind="batchQuery.DocumentNumber" />
                    </div>

                    <BizTypeInput @bind-Value="batchQuery.BusinessType" />

                    <DeptCodeInput @bind-Value="batchQuery.DeptCode" />

                    <CustomerCodeInput @bind-Value="batchQuery.CustomerCode" />

                    <div class="form-item">
                        <label class="form-label">业务单号</label>
                        <input type="text" class="form-input" placeholder="" @bind="batchQuery.BusinessOrderNumber" />
                    </div>

                    <div class="form-item">
                        <label class="form-label">ERP申请单号</label>
                        <input type="text" class="form-input" placeholder="" @bind="batchQuery.ErpApplyOrderNumber" />
                    </div>

                    <div class="form-item">
                        <label class="form-label">收货点</label>
                        <input type="text" class="form-input" placeholder="" @bind="batchQuery.ReceivePoint" />
                    </div>

                    <!-- 起止货品 -->
                    <div class="form-item">
                        <label class="form-label">起止货品</label>
                        <div style="display:flex;align-items:center;flex:1;gap:4px;padding:0 6px;">
                            <input type="text" style="width:45%;font-size:11px;border:none;outline:none;" placeholder="" @bind="batchQuery.ProductFrom" />
                            <span style="color:#999;font-size:11px;">~</span>
                            <input type="text" style="width:45%;font-size:11px;border:none;outline:none;" placeholder="" @bind="batchQuery.ProductTo" />
                            <svg viewBox="0 0 16 16" width="13" height="13" fill="#999999" style="cursor:pointer;flex-shrink:0;">
                                <circle cx="7" cy="7" r="5"/><line x1="11" y1="11" x2="15" y2="15" stroke="#999999" stroke-width="1.5"/>
                            </svg>
                        </div>
                    </div>

                    <!-- 不手唤已下架任务量 Toggle -->
                    <div class="form-item toggle-row">
                        <span class="toggle-row-label">不手唤已下架任务量</span>
                        <label class="mini-toggle-switch">
                            <input type="checkbox" @bind="batchQuery.ExcludeShelvedTasks" />
                            <span class="mini-toggle-slider"></span>
                        </label>
                    </div>

                    <!-- 家源单据到 Checkbox组 -->
                    <div class="form-item" style="height:auto;min-height:30px;align-items:center;flex-direction:column;gap:4px;">
                        <label class="form-label" style="width:100%;">家源单据到</label>
                        <div class="checkbox-group">
                            <label class="checkbox-label"><input type="checkbox" checked="@batchQuery.SourceNoticeOutbound" @onchange="(e) => batchQuery.SourceNoticeOutbound = (bool)e.Value!" /> 出库通知单</label>
                            <label class="checkbox-label"><input type="checkbox" checked="@batchQuery.SourceTransferNotice" @onchange="(e) => batchQuery.SourceTransferNotice = (bool)e.Value!" /> 调拨通知单</label>
                        </div>
                    </div>
                }
                else if (activeInnerTabId == "direct-pick-task")
                {
                    <!-- ====== Tab2: 直接拣货任务单 查询条件 ====== -->
                    <DateRangeInput @bind-Value="pickQuery.DateRange" />

                    <div class="form-item">
                        <label class="form-label">单据号码</label>
                        <input type="text" class="form-input" placeholder="" @bind="pickQuery.DocumentNumber" />
                    </div>

                    <BizTypeInput @bind-Value="pickQuery.BusinessType" />

                    <WarehouseCodeInput @bind-Value="pickQuery.WarehouseCode" />

                    <div class="form-item">
                        <label class="form-label">申请单号</label>
                        <input type="text" class="form-input" placeholder="" @bind="pickQuery.ApplyOrderNumber" />
                    </div>

                    <div class="form-item">
                        <label class="form-label">通知单号</label>
                        <input type="text" class="form-input" placeholder="" @bind="pickQuery.NoticeNumber" />
                    </div>

                    <div class="form-item">
                        <label class="form-label">业务单号</label>
                        <input type="text" class="form-input" placeholder="" @bind="pickQuery.BusinessOrderNumber" />
                    </div>

                    <!-- 打印标签列示 -->
                    <div class="form-item">
                        <label class="form-label">打印标签</label>
                        <div class="select-wrapper">
                            <select class="form-select" @bind="pickQuery.PrintLabelType">
                                <option value="全部">全部</option>
                                <option value="已打印">已打印</option>
                                <option value="未打印">未打印</option>
                            </select>
                            <svg class="select-arrow" viewBox="0 0 12 12" width="10" height="10" fill="#999999">
                                <path d="M2 4l4 4 4-4"/>
                            </svg>
                        </div>
                    </div>
                }

                <!-- 查询按钮（两Tab共用） -->
                <div class="form-item query-btn-wrapper">
                    <button class="query-submit-btn" @onclick="HandleSearch">
                        <svg viewBox="0 0 16 16" width="16" height="16" fill="white" stroke="white" stroke-width="1.5">
                            <circle cx="7" cy="7" r="5"/>
                            <line x1="11" y1="11" x2="15" y2="15"/>
                        </svg>
                        <span>查询</span>
                    </button>
                </div>
            </div>
        </div>

        <!-- 右侧数据表格区域 -->
        <div class="table-panel">
            <!-- 工具栏 -->
            <div class="table-toolbar">
                <div class="toolbar-left">
                    <!-- 内层选项卡 -->
                    <div class="inner-tab-bar-inline">
                        @foreach (var tab in innerTabs)
                        {
                            <div class="inner-tab-item @(tab.IsActive ? "active" : "")" @onclick="() => SwitchInnerTab(tab.Id)">
                                @tab.Title
                            </div>
                        }
                    </div>
                    @if (activeInnerTabId == "batch-shelving")
                    {
                        <button class="toolbar-btn export-btn" @onclick="HandleConfigDownload">配置下载</button>
                        <button class="toolbar-btn primary-btn" @onclick="HandleBatchExport">导出</button>
                    }
                    else if (activeInnerTabId == "direct-pick-task")
                    {
                        <button class="toolbar-btn export-btn" @onclick="HandlePrint">打印</button>
                        <button class="toolbar-btn primary-btn" @onclick="HandleAddNew">新增</button>
                    }
                </div>
            </div>

            @if (activeInnerTabId == "batch-shelving")
            {
                <!-- ====== Tab1: 批量上架 表格 ====== -->
                <div class="data-table-container">
                    <table class="data-table">
                        <thead>
                            <tr>
                                @foreach (var col in batchColumnConfigs.Where(c => c.Visible))
                                {
                                    var widthStyle = col.Width > 0 ? $"width:{col.Width}px" : "";
                                    if (col.Sortable)
                                    {
                                        <th style="@widthStyle" class="sortable">
                                            @col.DisplayName
                                            <svg viewBox="0 0 12 12" width="10" height="10" fill="#999999">
                                                <path d="M6 3l3 3H9l-3-3-3 3H3z"/>
                                                <path d="M6 9l-3-3h3l3 3h-3z" opacity="0.3"/>
                                            </svg>
                                        </th>
                                    }
                                    else
                                    {
                                        <th style="@widthStyle">@col.DisplayName</th>
                                    }
                                }
                                <th class="col-action" style="display:flex;align-items:center;justify-content:space-between;white-space:nowrap;">
                                    <span>操作</span>
                                    <button class="column-settings-btn" title="栏位设置" @onclick="OpenBatchColumnSettings">
                                        <svg viewBox="0 0 16 16" width="14" height="14" fill="#666666">
                                            <path d="M2 3h4v2H2V3zm0 4h4v2H2V7zm0 4h4v2H2v-2zm6-8h6v2H8V3zm0 4h6v2H8V7zm0 4h6v2H8v-2z"/>
                                        </svg>
                                    </button>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (batchDataSource.Count == 0)
                            {
                                <tr><td colspan="@(BatchVisibleCount + 1)" class="empty-data-cell"><div class="empty-data"><svg viewBox="0 0 64 64" width="80" height="80" fill="none"><rect x="8" y="8" width="48" height="48" rx="8" fill="#F5F5F5" stroke="#E0E0E0" stroke-width="1"/><path d="M24 28h16M24 36h12" stroke="#D9D9D9" stroke-width="2" stroke-linecap="round"/></svg><p class="empty-text">暂无数据</p></div></td></tr>
                            }
                            else
                            {
                                @foreach (var item in batchDataSource)
                                {
                                    var idx = batchDataSource.IndexOf(item) + 1;
                                    <tr>
                                        <td>@idx</td>
                                        @foreach (var col in batchColumnConfigs.Where(c => c.Visible).Skip(1))
                                        {
                                            var wStyle = col.Width > 0 ? $"width:{col.Width}px" : "";
                                            <td style="@wStyle">@GetBatchCellValue(item, col.FieldKey)</td>
                                        }
                                        <td><button class="action-btn" title="操作"><svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="#1890FF" stroke-width="1.5"><circle cx="8" cy="3" r="1" fill="#1890FF"/><circle cx="8" cy="8" r="1" fill="#1890FF"/><circle cx="8" cy="13" r="1" fill="#1890FF"/></svg></button></td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <!-- ====== Tab2: 直接拣货任务单 双表格布局 ====== -->

                <!-- 上方：主表格（MF_XJRW表头数据） -->
                <div class="data-table-container" style="flex:1;overflow:auto;">
                    <table class="data-table">
                        <thead>
                            <tr>
                                @foreach (var col in pickMainColumnConfigs.Where(c => c.Visible))
                                {
                                    var widthStyle = col.Width > 0 ? $"width:{col.Width}px" : "";
                                    if (col.Sortable)
                                    {
                                        <th style="@widthStyle" class="sortable">
                                            @col.DisplayName
                                            <svg viewBox="0 0 12 12" width="10" height="10" fill="#999999">
                                                <path d="M6 3l3 3H9l-3-3-3 3H3z"/>
                                                <path d="M6 9l-3-3h3l3 3h-3z" opacity="0.3"/>
                                            </svg>
                                        </th>
                                    }
                                    else
                                    {
                                        <th style="@widthStyle">@col.DisplayName</th>
                                    }
                                }
                                <th class="col-action" style="display:flex;align-items:center;justify-content:space-between;white-space:nowrap;">
                                    <span>操作</span>
                                    <button class="column-settings-btn" title="栏位设置" @onclick="OpenPickMainColumnSettings">
                                        <svg viewBox="0 0 16 16" width="14" height="14" fill="#666666">
                                            <path d="M2 3h4v2H2V3zm0 4h4v2H2V7zm0 4h4v2H2v-2zm6-8h6v2H8V3zm0 4h6v2H8V7zm0 4h6v2H8v-2z"/>
                                        </svg>
                                    </button>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (pickMainDataSource.Count == 0)
                            {
                                <tr><td colspan="@(PickMainVisibleCount + 1)" class="empty-data-cell"><div class="empty-data"><svg viewBox="0 0 64 64" width="80" height="80" fill="none"><rect x="8" y="8" width="48" height="48" rx="8" fill="#F5F5F5" stroke="#E0E0E0" stroke-width="1"/><path d="M24 28h16M24 36h12" stroke="#D9D9D9" stroke-width="2" stroke-linecap="round"/></svg><p class="empty-text">暂无数据</p></div></td></tr>
                            }
                            else
                            {
                                @foreach (var item in pickMainDataSource)
                                {
                                    <tr>
                                        @foreach (var col in pickMainColumnConfigs.Where(c => c.Visible))
                                        {
                                            var wStyle = col.Width > 0 ? $"width:{col.Width}px" : "";
                                            <td style="@wStyle">@GetPickMainCellValue(item, col.FieldKey)</td>
                                        }
                                        <td><button class="action-btn" title="操作"><svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="#1890FF" stroke-width="1.5"><circle cx="8" cy="3" r="1" fill="#1890FF"/><circle cx="8" cy="8" r="1" fill="#1890FF"/><circle cx="8" cy="13" r="1" fill="#1890FF"/></svg></button></td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>

                <!-- 下方：明细表格标题 -->
                <div class="detail-section-title">直接拣货任务单明细</div>

                <!-- 下方：明细表格（TF_XJRW表身数据） -->
                <div class="data-table-container" style="max-height:280px;overflow:auto;">
                    <table class="data-table">
                        <thead>
                            <tr>
                                @foreach (var col in pickDetailColumnConfigs.Where(c => c.Visible))
                                {
                                    var widthStyle = col.Width > 0 ? $"width:{col.Width}px" : "";
                                    <th style="@widthStyle">@col.DisplayName</th>
                                }
                                <th class="col-action" style="display:flex;align-items:center;justify-content:space-between;white-space:nowrap;">
                                    <span>操作</span>
                                    <button class="column-settings-btn" title="栏位设置" @onclick="OpenPickDetailColumnSettings">
                                        <svg viewBox="0 0 16 16" width="14" height="14" fill="#666666">
                                            <path d="M2 3h4v2H2V3zm0 4h4v2H2V7zm0 4h4v2H2v-2zm6-8h6v2H8V3zm0 4h6v2H8V7zm0 4h6v2H8v-2z"/>
                                        </svg>
                                    </button>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (pickDetailDataSource.Count == 0)
                            {
                                <tr><td colspan="@(PickDetailVisibleCount + 1)" class="empty-data-cell"><div class="empty-data"><svg viewBox="0 0 64 64" width="80" height="80" fill="none"><rect x="8" y="8" width="48" height="48" rx="8" fill="#F5F5F5" stroke="#E0E0E0" stroke-width="1"/><path d="M24 28h16M24 36h12" stroke="#D9D9D9" stroke-width="2" stroke-linecap="round"/></svg><p class="empty-text">暂无数据</p></div></td></tr>
                            }
                            else
                            {
                                @foreach (var item in pickDetailDataSource)
                                {
                                    <tr>
                                        @foreach (var col in pickDetailColumnConfigs.Where(c => c.Visible))
                                        {
                                            var wStyle = col.Width > 0 ? $"width:{col.Width}px" : "";
                                            <td style="@wStyle">@GetPickDetailCellValue(item, col.FieldKey)</td>
                                        }
                                        <td><button class="action-btn" title="操作"><svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="#1890FF" stroke-width="1.5"><circle cx="8" cy="3" r="1" fill="#1890FF"/><circle cx="8" cy="8" r="1" fill="#1890FF"/><circle cx="8" cy="13" r="1" fill="#1890FF"/></svg></button></td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<!-- 导出对话框 -->
@if (showExportDialog)
{
    <div class="export-dialog-overlay" @onclick="CancelExport">
        <div class="export-dialog" @onclick:stopPropagation>
            <div class="export-dialog-header">
                <span>导出 Excel</span>
                <button class="export-dialog-close" @onclick="CancelExport">&times;</button>
            </div>
            <div class="export-dialog-body">
                <label class="export-label">文件名</label>
                <input type="text" class="export-filename-input" @bind="exportFileName" @bind:event="oninput" />
            </div>
            <div class="export-dialog-footer">
                <button class="export-btn-cancel" @onclick="CancelExport">取消</button>
                <button class="export-btn-confirm" @onclick="ConfirmExport">确认导出</button>
            </div>
        </div>
    </div>
}

<!-- 栏位设计对话框 -->
@if (showColumnSettingsDialog)
{
    <div class="column-settings-overlay" @onclick="CloseColumnSettings">
        <div class="column-settings-dialog" @onclick:stopPropagation>
            <div class="column-settings-header">
                <span>栏位设计</span>
                <button class="column-settings-close" @onclick="CloseColumnSettings">&times;</button>
            </div>
            <div class="column-settings-search">
                <input type="text" class="column-search-input" placeholder="搜索栏位原名..." @bind="columnSearchKeyword" @bind:event="oninput" />
            </div>
            <div class="column-settings-body">
                <table class="column-settings-table">
                    <thead>
                        <tr>
                            <th class="col-seq">项次</th>
                            <th class="col-visible">显示否</th>
                            <th class="col-original">原栏位名</th>
                            <th class="col-display">栏位标题</th>
                            <th class="col-width">宽度</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < FilteredCurrentColumns.Count; i++)
                        {
                            var col = FilteredCurrentColumns[i];
                            var idx = CurrentEditingColumns.IndexOf(col) + 1;
                            <tr>
                                <td class="col-seq">@idx</td>
                                <td class="col-visible">
                                    <label class="toggle-switch">
                                        <input type="checkbox" checked="@col.Visible" @onchange="@((ChangeEventArgs e) => col.Visible = (bool)e.Value!)" />
                                        <span class="toggle-slider"></span>
                                    </label>
                                </td>
                                <td class="col-original">@col.OriginalName</td>
                                <td class="col-display">
                                    <input type="text" class="col-title-input" value="@col.DisplayName"
                                           @onchange="@((ChangeEventArgs e) => col.DisplayName = e.Value?.ToString() ?? col.OriginalName)" />
                                </td>
                                <td class="col-width">
                                    <input type="number" class="col-width-input" value="@col.Width"
                                           min="0" max="500"
                                           @onchange="@((ChangeEventArgs e) => { if(int.TryParse(e.Value?.ToString(), out var w)) col.Width = w; })" />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="column-settings-footer">
                <div class="footer-left">
                    <button class="col-select-all" @onclick="SelectAllCurrentColumns">全选</button>
                    <button class="col-restore-default" @onclick="RestoreCurrentDefaultColumns">恢复默认</button>
                </div>
                <div class="footer-right">
                    <button class="col-btn-confirm" @onclick="ConfirmColumnSettings">确定</button>
                    <button class="col-btn-cancel" @onclick="CancelColumnSettings">取消</button>
                </div>
            </div>
        </div>
    </div>
}


@code {
    // ====== 状态变量 ======
    private bool isFavorited = false;
    private bool showFavoriteSuccess = false;
    private bool isCollapsed = false;
    private bool showSettingsMenu = false;
    private bool showExportDialog = false;
    private string exportFileName = "";
    private bool showColumnSettingsDialog = false;
    private string columnSearchKeyword = "";

    // 当前正在编辑的栏位配置类型
    private string currentEditingColumnType = "batch"; // batch | pick-main | pick-detail

    // ====== 内层选项卡 ======
    private List<InnerTab> innerTabs = new()
    {
