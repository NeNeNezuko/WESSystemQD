    private List<ColumnConfig> CloneColumnConfigs(List<ColumnConfig> source)
    {
        return source.Select(c => new ColumnConfig
        {
            FieldKey = c.FieldKey,
            OriginalName = c.OriginalName,
            DisplayName = c.DisplayName,
            Visible = c.Visible,
            Width = c.Width,
            DefaultWidth = c.DefaultWidth,
            Sortable = c.Sortable
        }).ToList();
    }

    private async Task LoadAllColumnSettings()
    {
        await LoadSingleColumnSettings(BATCH_COLUMN_KEY, batchColumnConfigs, defaultBatchColumnConfigs);
        await LoadSingleColumnSettings(PICK_MAIN_COLUMN_KEY, pickMainColumnConfigs, defaultPickMainColumnConfigs);
        await LoadSingleColumnSettings(PICK_DETAIL_COLUMN_KEY, pickDetailColumnConfigs, defaultPickDetailColumnConfigs);
    }

    private async Task LoadSingleColumnSettings(string key, List<ColumnConfig> configs, List<ColumnConfig> defaults)
    {
        try
        {
            var json = await JS.InvokeAsync<string>("localStorage.getItem", key);
            if (!string.IsNullOrWhiteSpace(json))
            {
                var opts = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
                var saved = System.Text.Json.JsonSerializer.Deserialize<List<ColumnConfig>>(json, opts);
                if (saved != null && saved.Count > 0)
                {
                    foreach (var col in configs)
                    {
                        var s = saved.FirstOrDefault(sc => sc.FieldKey == col.FieldKey);
                        if (s != null)
                        {
                            col.Visible = s.Visible;
                            col.DisplayName = !string.IsNullOrWhiteSpace(s.DisplayName) ? s.DisplayName : col.OriginalName;
                            col.Width = s.Width >= 0 ? s.Width : col.DefaultWidth;
                        }
                    }
                }
            }
        }
        catch { }
    }

    private async Task SaveCurrentColumnSettings()
    {
        try
        {
            var key = currentEditingColumnType switch
            {
                "batch" => BATCH_COLUMN_KEY,
                "pick-main" => PICK_MAIN_COLUMN_KEY,
                "pick-detail" => PICK_DETAIL_COLUMN_KEY,
                _ => BATCH_COLUMN_KEY
            };
            var json = System.Text.Json.JsonSerializer.Serialize(CurrentEditingColumns);
            await JS.InvokeVoidAsync("localStorage.setItem", key, json);
        }
        catch { }
    }

    // 当前编辑中的栏位配置列表
    private List<ColumnConfig> CurrentEditingColumns => currentEditingColumnType switch
    {
        "batch" => batchColumnConfigs,
        "pick-main" => pickMainColumnConfigs,
        "pick-detail" => pickDetailColumnConfigs,
        _ => batchColumnConfigs
    };

    private List<ColumnConfig> FilteredCurrentColumns =>
        string.IsNullOrWhiteSpace(columnSearchKeyword)
            ? CurrentEditingColumns
            : CurrentEditingColumns.Where(c => c.OriginalName.Contains(columnSearchKeyword, StringComparison.OrdinalIgnoreCase) ||
                                               c.FieldKey.Contains(columnSearchKeyword, StringComparison.OrdinalIgnoreCase)).ToList();

