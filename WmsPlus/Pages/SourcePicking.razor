    private async Task LoadData()
    {
        try
        {
            const string ApiBaseUrl = "http://localhost:5102";
            var jsonOptions = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };

            if (activeInnerTabId == "batch-shelving")
            {
                await LoadBatchData(ApiBaseUrl, jsonOptions);
            }
            else
            {
                await LoadPickData(ApiBaseUrl, jsonOptions);
            }
        }
        catch (Exception ex)
        {
            _logger?.LogError(ex, "加载依来源单配货数据失败");
            batchDataSource = new List<BatchShelvingModel>();
            pickMainDataSource = new List<SourcePickMainModel>();
            pickDetailDataSource = new List<SourcePickDetailModel>();
        }
        StateHasChanged();
    }

    private async Task LoadBatchData(string apiBase, System.Text.Json.JsonSerializerOptions opts)
    {
        var today = DateTime.Today;
        var dateFromStr = today.ToString("yyyy-MM-dd");
        var dateToStr = today.ToString("yyyy-MM-dd");
        if (!string.IsNullOrWhiteSpace(batchQuery.DateRange) && batchQuery.DateRange.Contains("→"))
        {
            var parts = batchQuery.DateRange.Split("→", StringSplitOptions.TrimEntries);
            if (parts.Length >= 2) { dateFromStr = parts[0]; dateToStr = parts[1]; }
        }
        var url = $"{apiBase}/api/SourcePicking/batch-search?dateFrom={dateFromStr}&dateTo={dateToStr}";
        if (!string.IsNullOrWhiteSpace(batchQuery.WarehouseCode))
            url += $"&warehouseCode={Uri.EscapeDataString(batchQuery.WarehouseCode)}";
        if (!string.IsNullOrWhiteSpace(batchQuery.DocumentNumber))
            url += $"&documentNumber={Uri.EscapeDataString(batchQuery.DocumentNumber)}";
        if (!string.IsNullOrWhiteSpace(batchQuery.BusinessType))
            url += $"&businessType={Uri.EscapeDataString(batchQuery.BusinessType)}";
        if (!string.IsNullOrWhiteSpace(batchQuery.DeptCode))
            url += $"&deptCode={Uri.EscapeDataString(batchQuery.DeptCode)}";
        if (!string.IsNullOrWhiteSpace(batchQuery.CustomerCode))
            url += $"&customerCode={Uri.EscapeDataString(batchQuery.CustomerCode)}";
        if (!string.IsNullOrWhiteSpace(batchQuery.BusinessOrderNumber))
            url += $"&businessOrderNumber={Uri.EscapeDataString(batchQuery.BusinessOrderNumber)}";
        if (!string.IsNullOrWhiteSpace(batchQuery.ErpApplyOrderNumber))
            url += $"&erpApplyOrderNumber={Uri.EscapeDataString(batchQuery.ErpApplyOrderNumber)}";
        if (!string.IsNullOrWhiteSpace(batchQuery.ReceivePoint))
            url += $"&receivePoint={Uri.EscapeDataString(batchQuery.ReceivePoint)}";

        var request = AuthHttpClient.CreateRequest(HttpMethod.Get, url, TokenProvider.Token);
        var responseMsg = await Http.SendAsync(request);
        var response = await responseMsg.Content.ReadFromJsonAsync<ApiResponse<List<BatchShelvingModel>>>(opts);
        batchDataSource = (response != null && response.Success && response.Data != null) ? response.Data : new List<BatchShelvingModel>();
    }

    private async Task LoadPickData(string apiBase, System.Text.Json.JsonSerializerOptions opts)
    {
        var today = DateTime.Today;
        var dateFromStr = today.ToString("yyyy-MM-dd");
        var dateToStr = today.ToString("yyyy-MM-dd");
        if (!string.IsNullOrWhiteSpace(pickQuery.DateRange) && pickQuery.DateRange.Contains("→"))
        {
            var parts = pickQuery.DateRange.Split("→", StringSplitOptions.TrimEntries);
            if (parts.Length >= 2) { dateFromStr = parts[0]; dateToStr = parts[1]; }
        }
        var url = $"{apiBase}/api/SourcePicking/pick-search?dateFrom={dateFromStr}&dateTo={dateToStr}";
        if (!string.IsNullOrWhiteSpace(pickQuery.DocumentNumber))
            url += $"&documentNumber={Uri.EscapeDataString(pickQuery.DocumentNumber)}";
        if (!string.IsNullOrWhiteSpace(pickQuery.BusinessType))
            url += $"&businessType={Uri.EscapeDataString(pickQuery.BusinessType)}";
        if (!string.IsNullOrWhiteSpace(pickQuery.WarehouseCode))
            url += $"&warehouseCode={Uri.EscapeDataString(pickQuery.WarehouseCode)}";
        if (!string.IsNullOrWhiteSpace(pickQuery.ApplyOrderNumber))
            url += $"&applyOrderNumber={Uri.EscapeDataString(pickQuery.ApplyOrderNumber)}";
        if (!string.IsNullOrWhiteSpace(pickQuery.NoticeNumber))
            url += $"&noticeNumber={Uri.EscapeDataString(pickQuery.NoticeNumber)}";
        if (!string.IsNullOrWhiteSpace(pickQuery.BusinessOrderNumber))
            url += $"&businessOrderNumber={Uri.EscapeDataString(pickQuery.BusinessOrderNumber)}";

        var request = AuthHttpClient.CreateRequest(HttpMethod.Get, url, TokenProvider.Token);
        var responseMsg = await Http.SendAsync(request);
        var response = await responseMsg.Content.ReadFromJsonAsync<ApiResponse<PickSearchResult>>(opts);
        if (response != null && response.Success && response.Data != null)
        {
            pickMainDataSource = response.Data.MainList ?? new List<SourcePickMainModel>();
                pickDetailDataSource = response.Data.DetailList ?? new List<SourcePickDetailModel>();
        }
        else
        {
            pickMainDataSource = new List<SourcePickMainModel>();
            pickDetailDataSource = new List<SourcePickDetailModel>();
        }
    }

    // ====== 导出 ======
    private async Task HandleBatchExport()
    {
        if (batchDataSource.Count == 0) { await JS.InvokeVoidAsync("alert", "暂无数据可导出"); return; }
        exportFileName = $"批量上架_{DateTime.Now:yyyyMMddHHmmss}";
        showExportDialog = true;
        StateHasChanged();
    }

    private void CancelExport() { showExportDialog = false; StateHasChanged(); }

    private async Task ConfirmExport()
    {
        showExportDialog = false;
        try { await ExportToExcel(); } catch (Exception ex) { await JS.InvokeVoidAsync("alert", $"导出失败: {ex.Message}"); }
    }

    private async Task ExportToExcel()
    {
        var visibleCols = batchColumnConfigs.Where(c => c.Visible).ToList();
        var headers = visibleCols.Select(c => c.DisplayName).ToArray();
        var rows = new List<object[]>();
        rows.Add(headers);
        foreach (var item in batchDataSource)
        {
            var row = new object[visibleCols.Count];
            for (int i = 0; i < visibleCols.Count; i++)
                row[i] = GetBatchCellValue(item, visibleCols[i].FieldKey);
            rows.Add(row);
        }
        var fileName = string.IsNullOrWhiteSpace(exportFileName) ? $"批量上架_{DateTime.Now:yyyyMMddHHmmss}" : exportFileName;
        if (!fileName.EndsWith(".xlsx", StringComparison.OrdinalIgnoreCase)) fileName += ".xlsx";
        await JS.InvokeVoidAsync("exportToExcel", rows, fileName);
    }

