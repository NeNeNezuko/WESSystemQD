                    <span class="placeholder-text">即将开发 - 自动生成直接储任务单配置</span>
                </div>
            </div>

            <!-- 底部留白 -->
            <div style="height: 40px;"></div>
        </div>
    </div>
</div>

@code {
    // ========== 内部模型类 ==========
    public record NavItem(string Id, string Title);

    public class SystemFormData
    {
        public string CompanyCode { get; set; } = "GZD1";
        public string CompanyName { get; set; } = "天津渤海化学试剂测试账套";
        public string? CompanyEnName { get; set; }
        public string? CompanyAddress { get; set; }
        public string? Phone { get; set; }
        public DateTime? StartDate { get; set; } = new DateTime(2024, 1, 1);
    }

    // ========== 收藏功能 ==========
    private const string FAVORITE_KEY = "wms_favorite_system_setting";
    private bool isFavorited = false;
    private bool showToast = false;

    // ========== 导航相关 ==========
    private string activeNavId = "company";
    private ElementReference contentRef;

    // ========== 表单数据 ==========
    private SystemFormData formData = new();

    // --- 公司资料 ---
    private string dateFormat = "yyyy-MM-dd";
    private int decimalPlaces = 2;
    private bool hideTrailingZero = false;

    // --- 密码策略 ---
    private string pwdValidDays = "";
    private string pwdContentLimit = "";
    private string pwdMinLength = "";

    // --- 系统设定 ---
    private bool useSerialNo = true;
    private bool allowReuseSerial = false;
    private string defaultCkBizType = "";
    private string rkIgnoreBizType = "";
    private string rkDateSource = "";
    private string bizTypePriority = "";
    private string checkDeviceMode = "";
    private string sunlikeSuffix = "";
    private string suffixDateQty = "";
    private string printLabelOrder = "";

    // --- 货品特征 ---
    private bool enableProductMark = false;
    private string markInclude = "";
    private bool markPositionControl = true;
    private string markDefineMethod = "";
    private string markSeparator = "";
    private bool enableMarkByProduct = false;

    // --- 电子标签 ---
    private int rfidReadTime = 3;
    private int rfidBarcodeTime = 10;
    private bool allowReuseBoxCode = false;

    // --- 应用储位管理 ---
    private bool enableStorageLocation = true;
    private string storageBasis = "2";
    private string storageOrder = "2";

    // --- 扫描设定 ---
    private bool scanProductRule = false;
    private int scanHotkey = 3;

    // --- 集整库存服务 ---
    private int inventoryExecTime = 3;
    private int inventoryInterval = 45;

    // --- 前端设定（前缀参数）---
    private string prefixLabel = "前缀码";
    private string[] prefixItems = new string[20];

    // --- 货品二维码组成 ---
    private bool enableQrCode = false;
    private string qrSeparator = "";
    private string qrBarcodeSegment = "";
    private string qrCkDocSegment = "";
    private string qrCkItmSegment = "";
    private string qrRkDocSegment = "";
    private string qrDataSegment = "";
    private string qrDefaultParse = "";

    // --- 信息加密处理 ---
    private bool encCustomerName = true;
    private bool encVendorName = true;
    private bool encReceiveInfo = false;

    // --- 对接ERP系统 ---
    private bool enableErpConnect = false;
    private string erpApiUrl = "";
    private bool enableSunlikeApi = false;
    private string sunlikeUrl = "";
    private string sunlikeAccount = "";
    private string sunlikeCompany = "";
    private string sunlikeOrderMode = "";
    private DateTime? sunlikeStartDate = new DateTime(2024, 1, 1);
    private int sunlikePastDays = 0;

    // ========== 导航项定义 ==========
    private List<NavItem> NavItems => new()
    {
        new("company", "公司资料"),
        new("password", "密码策略"),
        new("system", "系统设定"),
        new("product-mark", "货品特征"),
        new("rfid", "电子标签"),
        new("storage-location", "应用储位管理"),
        new("scan", "扫描设定"),
        new("inventory-service", "集整库存服务"),
        new("frontend", "前端设定"),
        new("qrcode", "货品二维码组成"),
        new("encrypt", "信息加密处理"),
        new("erp", "对接ERP系统"),
        new("other-system", "与其他系统对接"),
        new("api-setting", "API接口设置"),
        new("visual-params", "可视化仓储视图参数"),
        new("no-restrict", "无忌接入送单服务"),
        new("auto-generate", "自动生成或次单"),
        new("auto-storage-task", "自动生成直接储任务单"),
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadFavoriteStatus();
        await LoadSettings();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await SetupScrollObserver();
        }
    }

    // ========== 收藏功能 ==========
    private async Task LoadFavoriteStatus()
    {
        try
        {
            var result = await JSRuntime.InvokeAsync<string>("localStorage.getItem", FAVORITE_KEY);
            isFavorited = result == "true";
        }
        catch { }
    }

    private async Task ToggleFavorite()
    {
        isFavorited = !isFavorited;
        try
        {
            await JSRuntime.InvokeVoidAsync("localStorage.setItem", FAVORITE_KEY, isFavorited.ToString().ToLower());
        }
        catch { }

        if (isFavorited)
        {
            showToast = true;
            StateHasChanged();
            await Task.Delay(2000);
            showToast = false;
            StateHasChanged();
        }
    }

    // ========== 数据加载 ==========
    private async Task LoadSettings()
    {
        try
        {
            var http = HttpClientFactory.CreateClient();
            var token = await GetToken();
            var request = new HttpRequestMessage(HttpMethod.Get,
                $"http://localhost:5102/api/SystemSetting/all");
            if (!string.IsNullOrEmpty(token))
                request.Headers.Add("Authorization", $"Bearer {token}");

            var response = await http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                var json = await response.Content.ReadAsStringAsync();
                // 解析并填充表单数据（后续对接实际数据）
            }
        }
        catch { /* 静默处理 */ }
    }

    private async Task<string?> GetToken()
    {
        try
        {
            return await JSRuntime.InvokeAsync<string>("localStorage.getItem", "wms_token");
        }
        catch { return null; }
    }

    // ========== 导航滚动 ==========
    private async Task ScrollToSection(string navId)
    {
        activeNavId = navId;
        StateHasChanged();
        await Task.Delay(50);
        await JSRuntime.InvokeVoidAsync("eval",
            $"document.getElementById('sec-{navId}')?.scrollIntoView({{ behavior: 'smooth', block: 'start' }})");
    }

    private async void HandleContentScroll(EventArgs e)
    {
        _ = SetupScrollObserver();
    }

    private async Task SetupScrollObserver()
    {
        try
        {
            var sectionIds = string.Join(",", NavItems.Select(n => $"'sec-{n.Id}'"));
            var dotNetRef = DotNetObjectReference.Create(this);
            await JSRuntime.InvokeVoidAsync("eval", $@"
                (function() {{
                    const dotNet = {dotNetRef};
                    const observer = new IntersectionObserver((entries) => {{
                        entries.forEach(entry => {{
                            if (entry.isIntersecting) {{
                                const navId = entry.target.getAttribute('data-nav');
                                if (navId) {{
                                    dotNet.invokeMethodAsync('UpdateActiveNav', navId);
                                }}
                            }}
                        }});
                    }}, {{ rootMargin: '-80px 0px -60% 0px', threshold: 0 }});
                    [{sectionIds}].forEach(id => {{
                        const el = document.getElementById(id);
                        if (el) observer.observe(el);
                    }});
                }})();
            ");
        }
        catch { }
    }

    [JSInvokable]
    public async Task UpdateActiveNav(string navId)
    {
        if (activeNavId != navId)
        {
            activeNavId = navId;
            await InvokeAsync(StateHasChanged);
        }
    }

    // ========== 保存（UI占位）==========
    private async Task HandleSave()
    {
        await JSRuntime.InvokeVoidAsync("alert", "保存功能开发中...");
    }
}
