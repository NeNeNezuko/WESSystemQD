@using Microsoft.AspNetCore.Components.Web
@inject IJSRuntime JS
@inject ILogger<SystemSetting> _logger

<link rel="stylesheet" href="css/system-setting.css" />

<div class="system-setting-page">
    <!-- 顶部标题栏 -->
    <div class="page-header">
        <div class="header-left">
            <span class="page-title">系统设定</span>
        </div>
        <div class="header-right">
            <button class="save-btn" @onclick="SaveSettings">保存</button>
        </div>
    </div>

    <!-- 主内容区 -->
    <div class="page-body">
        <!-- 左侧导航栏（16项，按参考图正确顺序）-->
        <div class="nav-sidebar">
            <div class="nav-title">导航</div>
            @foreach (var nav in NavItems)
            {
                <div class="nav-item @(activeNavId == nav.Id ? "active" : "")"
                     @onclick="() => ScrollToSection(nav.Id)"
                     data-nav-id="@nav.Id">
                    @nav.Title
                </div>
            }
        </div>

        <!-- 右侧内容区（可滚动长表单）-->
        <div class="content-area" @ref="contentAreaRef" @onscroll="HandleScroll">

            @* ========== 1. 公司资料 ========== *@
            <div class="setting-section" id="section-company">
                <div class="section-title">公司资料</div>
                @FieldRow("公司代号", "company-code", @<input type="text" readonly value="@Model.CompanyCode" />)
                @FieldRow("公司名称", "company-name", @<input type="text" @bind="Model.CompanyName" />)
                @FieldRow("英文名称", "company-name-en", @<input type="text" @bind="Model.CompanyNameEn" />)
                @FieldRow("公司地址", "company-address", @<input type="text" @bind="Model.CompanyAddress" />)
                @FieldRow("电话", "company-phone", @<input type="text" @bind="Model.CompanyPhone" />)
                @FieldRow("开帐日期", "open-date", @<input type="date" @bind="Model.OpenDate" />)
                @FieldRow("日期格式", "date-format", @<input type="text" @bind="Model.DateFormat" />)
                @FieldRow("小数位数", "decimal-places", @<input type="number" @bind="Model.DecimalPlaces" />)
                @FieldRow("小数位后零不显示", "hide-trailing-zero",
                    @<label class="toggle-switch"><input type="checkbox" @bind="Model.HideTrailingZero" /><span class="toggle-slider"></span></label>)
            </div>

            @* ========== 2. 密码策略 ========== *@
            <div class="setting-section" id="section-password">
                <div class="section-title">密码策略</div>
                @FieldRow("有效期", "password-valid-period", @<input type="text" @bind="Model.PasswordValidPeriod" />)
                @FieldRow("内部限制", "password-inner-limit",
                    @<select @bind="Model.PasswordInnerLimit">
                        <option value="无限制">无限制</option>
                        <option value="30天">30天</option>
                        <option value="60天">60天</option>
                        <option value="90天">90天</option>
                        <option value="180天">180天</option>
                    </select>)
                @FieldRow("最小长度", "password-min-length",
                    @<input type="number" min="1" max="15" placeholder="只输入入1~15的数字" @bind="Model.PasswordMinLength" />)
            </div>

            @* ========== 3. 系统设定 ========== *@
            <div class="setting-section" id="section-system">
                <div class="section-title">系统设定</div>
                @FieldRow("货品使用序列号", "product-use-serial-no",
                    @<label class="toggle-switch"><input type="checkbox" @bind="Model.ProductUseSerialNo" /><span class="toggle-slider"></span></label>)
                @FieldRow("已出库序号允许重复使用", "allow-serial-reuse",
                    @<label class="toggle-switch"><input type="checkbox" @bind="Model.AllowSerialReuse" /><span class="toggle-slider"></span></label>)
                @FieldRow("默认出库业务类型", "default-out-biz-type",
                    @<text><input type="text" placeholder="销货出库/退货运回出库/暂估退回出库/托工退回出库/生产领料..." @bind="Model.DefaultOutBizType" /><button class="input-action" type="button" title="搜索">Q</button></text>)
                @FieldRow("入库时不够触发入库日的业务类型", "in-trigger-biz-type",
                    @<text><input type="text" @bind="Model.InTriggerBizType" /><button class="input-action" type="button" title="搜索">Q</button></text>)
                @FieldRow("不够触发入库日的前提", "in-trigger-precondition",
                    @<text><input type="text" @bind="Model.InTriggerPrecondition" /><button class="input-action" type="button" title="搜索">Q</button></text>)
                @FieldRow("按业务类型设定料号优先规则", "biz-type-priority-rule",
                    @<text><input type="text" @bind="Model.BizTypePriorityRule" /><button class="input-action" type="button" title="搜索">Q</button></text>)
                @FieldRow("检验单据是否SUNLIKE系统", "sunlike-check", @<input type="text" @bind="Model.SunlikeCheck" />)
                @FieldRow("系统关闭后是否提醒和确认", "close-reminder-confirm",
                    @<select @bind="Model.CloseReminderConfirm">
                        <option value="当前系统日期">当前系统日期</option>
                        <option value="不提醒">不提醒</option>
                        <option value="强制确认">强制确认</option>
                    </select>)
                @FieldRow("货品盘点打印探取数据来源", "inventory-print-source",
                    @<select @bind="Model.InventoryPrintSource">
                        <option value="验收品">验收品</option>
                        <option value="库存品">库存品</option>
                        <option value="全部">全部</option>
                    </select>)
            </div>

            @* ========== 4. 启用储位管理 ========== *@
            <div class="setting-section" id="section-storage-location">
                <div class="section-title">启用储位管理</div>
                @FieldRow("指定执行时间点", "storage-exec-time-point", @<input type="number" @bind="Model.StorageExecTimePoint" />)
                @FieldRow("计算期间天数", "storage-calc-days", @<input type="number" @bind="Model.StorageCalcDays" />)
            </div>

            @* ========== 5. 扫描设定 ========== *@
            <div class="setting-section" id="section-scan-setting">
                <div class="section-title">扫描设定</div>
                @FieldRow("扫描临时输入员是否有需", "scan-temp-input-required",
                    @<label class="toggle-switch"><input type="checkbox" @bind="Model.ScanTempInputRequired" /><span class="toggle-slider"></span></label>)
                @FieldRow("多号码模式切换快捷键设置", "scan-multi-mode-hotkey", @<input type="number" @bind="Model.ScanMultiModeHotkey" />)
            </div>

            @* ========== 6. 重整库存服务 (占位) ========== *@
            <div class="setting-section" id="section-restock-service">
                <div class="section-title">重整库存服务</div>
                <div class="placeholder-section">
                    <p class="placeholder-text">功能开发中...</p>
                </div>
            </div>

            @* ========== 7. 前缀设定 ========== *@
            <div class="setting-section" id="section-prefix-setting">
                <div class="section-title">前缀设定</div>
                <table class="prefix-table">
                    <tbody>
                        @for (int i = 0; i < Model.PrefixItems.Count; i++)
                        {
                            var item = Model.PrefixItems[i];
                            <tr>
                                <td>@item.Label</td>
                                <td>
                                    <div class="prefix-value-wrap">
                                        <input type="text" class="prefix-input" readonly value="@item.Value" />
                                        <button class="prefix-more-btn" type="button" title="更多操作">...</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @* ========== 8. 货品二维码组成 ========== *@
            <div class="setting-section" id="section-qrcode-setting">
                <div class="section-title">货品二维码组成</div>
                @FieldRow("应用货品二维码(外部条码)", "qrcode-external-barcode",
                    @<label class="toggle-switch"><input type="checkbox" @bind="Model.QrcodeIncludeExternalBarcode" /><span class="toggle-slider"></span></label>)
                @FieldRow("二维码分段分隔编码", "qrcode-separator", @<input type="text" @bind="Model.QrcodeSeparator" />)
                @FieldRow("条列信息所在分段", "qrcode-info-section", @<input type="text" @bind="Model.QrcodeInfoSection" />)
                @FieldRow("出库业务单据所在分段", "out-biz-type-section", @<input type="text" @bind="Model.OutBizTypeSection" />)
                @FieldRow("入库业务单据所在分段", "in-biz-type-section", @<input type="text" @bind="Model.InBizTypeSection" />)
                @FieldRow("数据存在分段", "data-exist-section", @<input type="text" @bind="Model.DataExistSection" />)
                @FieldRow("拆解每码信息无前缀时默认以条类型", "default-barcode-type",
                    @<select @bind="Model.DefaultBarcodeTypeWithoutPrefix">
                        <option value="制">制[条码固定定]</option>
                        <option value="固定">固定</option>
                    </select>)
            </div>

            @* ========== 9. 信息加密处理 ========== *@
            <div class="setting-section" id="section-encrypt">
                <div class="section-title">信息加密处理</div>
                @FieldRow("信息加密处理", "encrypt-processing",
                    @<div class="checkbox-group">
                        <label><input type="checkbox" @bind="Model.EncryptCustomerName" /> 客户名称</label>
                        <label><input type="checkbox" @bind="Model.EncryptVendorName" /> 厂商名称</label>
                        <label><input type="checkbox" @bind="Model.EncryptReceiveInfo" /> 收货信息</label>
                    </div>)
            </div>

            @* ========== 10. 对接ERP系统 ========== *@
            <div class="setting-section" id="section-erp-integration">
                <div class="section-title">对接ERP系统</div>
                @FieldRow("启用ERP系统对接", "enable-erp-integration",
                    @<label class="toggle-switch"><input type="checkbox" @bind="Model.EnableErpIntegration" /><span class="toggle-slider"></span></label>)
                @FieldRow("AI-WMS PLUS接口Url", "erp-api-url", @<input type="text" @bind="Model.ErpApiUrl" />)

                <div class="sub-section-title">Sunlike系统</div>
                @FieldRow("启用Sunlike ERP API", "enable-sunlike-api",
                    @<label class="toggle-switch"><input type="checkbox" @bind="Model.EnableSunlikeApi" /><span class="toggle-slider"></span></label>)
                @FieldRow("接口Url", "sunlike-url",
                    @<text><input type="text" @bind="Model.SunlikeUrl" /><button class="test-btn" type="button">测试</button></text>)
                @FieldRow("Sunlike帐套代号", "sunlike-account-code", @<input type="text" @bind="Model.SunlikeAccountCode" />)
                @FieldRow("基因公司", "sunlike-company", @<input type="text" @bind="Model.SunlikeCompany" />)
                @FieldRow("遵期产生方式", "sunlike-produce-mode", @<input type="text" placeholder="ERP传递账套" @bind="Model.SunlikeProduceMode" />)
                @FieldRow("启用日期", "sunlike-enable-date", @<input type="date" @bind="Model.SunlikeEnableDate" />)
                @FieldRow("允许挂起获取申请单的天数", "sunlike-allow-pending-days", @<input type="number" @bind="Model.SunlikeAllowPendingDays" />)

                <div class="sub-section-title">TB/企业系统</div>
                @FieldRow("启用TB企业架API", "enable-tb-enterprise-api",
                    @<label class="toggle-switch"><input type="checkbox" @bind="Model.EnableTbEnterpriseApi" /><span class="toggle-slider"></span></label>)
                @FieldRow("接口Url", "tb-url", @<input type="text" @bind="Model.TbUrl" />)
                @FieldRow("TB企业架帐套代号", "tb-account-code", @<input type="text" @bind="Model.TbAccountCode" />)
                @FieldRow("ERP购入人数值", "tb-erp-buyer-value", @<input type="text" placeholder="按到ERP购入人" @bind="Model.TbErpBuyerValue" />)
                @FieldRow("生效ERP购入制单人", "tb-effective-buyer", @<input type="text" readonly placeholder="" />)

                <div class="sub-section-title">金蝶星空</div>
                @FieldRow("启用金蝶API", "enable-kingdee-api",
                    @<label class="toggle-switch"><input type="checkbox" @bind="Model.EnableKingdeeApi" /><span class="toggle-slider"></span></label>)
                @FieldRow("接口Url", "kingdee-url",
                    @<text><input type="text" @bind="Model.KingdeeUrl" /><button class="test-btn" type="button">测试</button></text>)
                @FieldRow("应用ID", "kingdee-app-id", @<input type="text" @bind="Model.KingdeeAppId" />)
                @FieldRow("应用密钥", "kingdee-app-secret", @<input type="text" @bind="Model.KingdeeAppSecret" />)
                @FieldRow("账套ID", "kingdee-ledger-id", @<input type="text" @bind="Model.KingdeeLedgerId" />)
                @FieldRow("用户名", "kingdee-username", @<input type="text" @bind="Model.KingdeeUsername" />)
                @FieldRow("电租编码", "kingdee-tenant-code", @<input type="text" @bind="Model.KingdeeTenantCode" />)
                @FieldRow("WMS仓库", "kingdee-wms-wh",
                    @<text><input type="text" @bind="Model.KingdeeWmsWarehouse" /><button class="input-action" type="button" title="搜索">Q</button></text>)
                @FieldRow("默认从制库代人号", "kingdee-default-from-user", @<input type="text" @bind="Model.KingdeeDefaultFromUser" />)
                @FieldRow("默认从门代号", "kingdee-default-from-door", @<input type="text" @bind="Model.KingdeeDefaultFromDoor" />)
                @FieldRow("启用日期", "kingdee-enable-date", @<input type="date" @bind="Model.KingdeeEnableDate" />)
                @FieldRow("单据日期取(近X天)", "kingdee-order-date-range", @<input type="number" @bind="Model.KingdeeOrderDateRange" />)
                @FieldRow("获取生产订单行订单类型", "kingdee-production-order-type",
                    @<text><input type="text" @bind="Model.KingdeeProductionOrderType" /><button class="input-action" type="button" title="搜索">Q</button></text>)
                @FieldRow("接送单据不自动提交单据控制", "kingdee-inbound-no-auto-submit",
                    @<text><input type="text" @bind="Model.KingdeeInboundNotAutoSubmit" /><button class="input-action" type="button" title="搜索">Q</button></text>)
                @FieldRow("推送单据不自动结单单据控制", "kingdee-outbound-not-auto-submit",
                    @<text><input type="text" @bind="Model.KingdeeOutboundNotAutoSubmit" /><button class="input-action" type="button" title="搜索">Q</button></text>)
            </div>

            @* ========== 11. 与其他系统对接 ========== *@
            <div class="setting-section" id="section-other-systems">
                <div class="section-title">与其他系统对接</div>
                <div class="sub-section-title">MES系统</div>
                @FieldRow("启用MES API", "enable-mes-api",
                    @<label class="toggle-switch"><input type="checkbox" @bind="Model.EnableMesApi" /><span class="toggle-slider"></span></label>)
                @FieldRow("接口Url", "mes-url", @<input type="text" @bind="Model.MesUrl" />)
                @FieldRow("MES帐套代号", "mes-account-code", @<input type="text" @bind="Model.MesAccountCode" />)

                <div class="sub-section-title">与PTL电子标签对接</div>
                @FieldRow("启用PTL电子标签对接", "enable-ptl-tag-integration",
                    @<label class="toggle-switch"><input type="checkbox" @bind="Model.EnablePtlTagIntegration" /><span class="toggle-slider"></span></label>)
            </div>

            @* ========== 12. API接口设置 ========== *@
            <div class="setting-section" id="section-api-setting">
                <div class="section-title">API接口设置</div>
                @FieldRow("允许外部访问的日志名称", "external-log-name",
                    @<text><input type="text" placeholder="多个以|符号开隔" @bind="Model.ExternalLogName" /><button class="input-action" type="button" title="搜索">Q</button></text>)
                @FieldRow("允许部设读取端口", "external-read-port",
                    @<text><input type="text" @bind="Model.ExternalReadPort" /><button class="input-action" type="button" title="搜索">Q</button></text>)
            </div>

            @* ========== 13. 可视化仓储视图参数 ========== *@
            <div class="setting-section" id="section-storage-map">
                <div class="section-title">可视化仓储视图参数</div>

                <div class="sub-section-title">储位异示</div>
                @FieldRow("储图排果显示样式", "storage-map-display-style", @<input type="text" placeholder="1:完整置数结果" @bind="Model.StorageMapDisplayStyle" />)
                @FieldRow("并载定时刷新间隔", "storage-map-auto-refresh",
                    @<label class="toggle-switch"><input type="checkbox" @bind="Model.StorageMapAutoRefreshToggle" /><span class="toggle-slider"></span></label>)
                @FieldRow("刷新时间(秒)", "storage-map-refresh-seconds", @<input type="number" @bind="Model.StorageMapRefreshSeconds" />)

                <div class="sub-section-title">仓储营查</div>
                @FieldRow("显示在储信息", "show-storage-info",
                    @<label class="toggle-switch"><input type="checkbox" @bind="Model.ShowStorageInfo" /><span class="toggle-slider"></span></label>)
                @FieldRow("显示入库信息", "show-inbound-info",
                    @<label class="toggle-switch"><input type="checkbox" @bind="Model.ShowInboundInfo" /><span class="toggle-slider"></span></label>)
                @FieldRow("显示库存信息", "show-inventory-info",
                    @<label class="toggle-switch"><input type="checkbox" @bind="Model.ShowInventoryInfo" /><span class="toggle-slider"></span></label>)

                <div class="sub-section-title">储缺设定</div>
                @FieldRow("储位信息显示项", "storage-info-display-items",
                    @<text><input type="text" @bind="Model.StorageInfoDisplayItems" /><button class="input-action" type="button">...</button></text>)
                @FieldRow("容器条码使用状态(混装+最近盘存日期)", "container-barcode-status-items",
                    @<text><input type="text" @bind="Model.ContainerBarcodeStatusItems" /><button class="input-action" type="button">...</button></text>)
                @FieldRow("货品代码+品类名称+货品特征+其号", "product-code-category-items",
                    @<text><input type="text" @bind="Model.ProductCodeCategoryItems" /><button class="input-action" type="button">...</button></text>)

                <div class="sub-section-title">异常管理</div>
                @FieldRow("显示异常信息", "show-exception-info",
                    @<label class="toggle-switch"><input type="checkbox" @bind="Model.ShowExceptionInfo" /><span class="toggle-slider"></span></label>)

                <div class="sub-section-title">功能链理</div>
                @FieldRow("动态链理储位显示项", "dynamic-storage-display-items",
                    @<text><input type="text" @bind="Model.DynamicStorageDisplayItems" /><button class="input-action" type="button">...</button></text>)
            </div>

            @* ========== 14. 汇总推进入库单服务 ========== *@
            <div class="setting-section" id="section-summary-service">
                <div class="section-title">汇总推进入库单服务</div>
                @FieldRow("启用入库汇总单", "enable-inbound-summary",
                    @<text><input type="text" value="@Model.EnableInboundSummary.ToString()" readonly /><button class="input-action" type="button">...</button></text>)
                @FieldRow("入库单汇总合并条件", "inbound-summary-condition",
                    @<select @bind="Model.InboundSummaryCondition">
                        <option value="">请选择</option>
                        <option value="单版日期+申单位ID+申单编号号+&quot;厂代号&quot;+部门">单版日期+申单位ID+申单编号号+"厂代号"+部门</option>
                    </select>)
            </div>

            @* ========== 15. 自动生成波次单 ========== *@
            <div class="setting-section" id="section-auto-wave">
                <div class="section-title">自动生成波次单</div>
                @FieldRow("自动产生主波次单", "auto-generate-main-wave",
                    @<label class="toggle-switch"><input type="checkbox" @bind="Model.AutoGenerateMainWave" /><span class="toggle-slider"></span></label>)
                @FieldRow("自动产生波次次的仓库", "auto-wave-warehouse",
                    @<text><input type="text" @bind="Model.AutoWaveWarehouse" /><button class="input-action" type="button" title="搜索">Q</button></text>)
                @FieldRow("默认制单人", "auto-wave-default-user",
                    @<text><input type="text" @bind="Model.AutoWaveDefaultUser" /><button class="input-action" type="button" title="搜索">Q</button></text>)
                @FieldRow("每天执行账数", "auto-wave-daily-count", @<input type="number" @bind="Model.AutoWaveDailyCount" />)
                @FieldRow("单据日期取(近X天)", "auto-wave-date-range-days", @<input type="number" @bind="Model.AutoWaveDateRangeDays" />)
                @FieldRow("业务类型范围", "auto-wave-biz-types",
                    @<text><input type="text" @bind="Model.AutoWaveBizTypes" /><button class="input-action" type="button" title="搜索">Q</button></text>)
            </div>

            @* ========== 16. 自动生成直接拣货任务单 ========== *@
            <div class="setting-section" id="section-auto-pick-task">
                <div class="section-title">自动生成直接拣货任务单</div>
                @FieldRow("自动产生直接拣货任务单", "auto-generate-pick-task",
                    @<label class="toggle-switch"><input type="checkbox" @bind="Model.AutoGeneratePickTask" /><span class="toggle-slider"></span></label>)
                @FieldRow("自动产生直接拣货任务单的仓库", "auto-pick-warehouse",
                    @<text><input type="text" @bind="Model.AutoPickWarehouse" /><button class="input-action" type="button" title="搜索">Q</button></text>)
                @FieldRow("默认制单人", "auto-pick-default-user",
                    @<text><input type="text" @bind="Model.AutoPickDefaultUser" /><button class="input-action" type="button" title="搜索">Q</button></text>)
                @FieldRow("编次执行账数", "auto-pick-daily-count", @<input type="number" @bind="Model.AutoPickDailyCount" />)
                @FieldRow("单据日期取(近X天)", "auto-pick-date-range-days", @<input type="number" @bind="Model.AutoPickDateRangeDays" />)
                @FieldRow("业务类型范围", "auto-pick-biz-types",
                    @<text><input type="text" @bind="Model.AutoPickBizTypes" /><button class="input-action" type="button" title="搜索">Q</button></text>)
            </div>

            @* 功能按钮显示项（无独立导航，附在最后） *@
            <div class="setting-section" id="section-function-buttons">
                <div class="section-title">功能按钮显示项</div>
                @FieldRow("功能按钮显示项", "function-button-display",
                    @<text><input type="text" @bind="Model.FunctionButtonDisplay" /><button class="input-action" type="button">...</button></text>)
            </div>

            <div style="height: 40px;"></div>
        </div>
    </div>
</div>

@* ===== 帮助弹窗 ===== *@
@if (showHelpModal)
{
    <div class="help-modal-overlay" @onclick="CloseHelpModal">
        <div class="help-modal" @onclick:stopPropagation>
            <div class="help-modal-header">
                <div class="help-modal-title">
                    <span class="help-modal-icon"></span>
                    <span>帮助->@(currentHelpTitle ?? "字段说明")</span>
                </div>
                <button class="help-modal-close" @onclick="CloseHelpModal">&times;</button>
            </div>
            <div class="help-modal-body">
                <div class="help-field-name">【@(currentHelpTitle ?? "字段名")】</div>
                <div>一、说明：@(currentHelpDesc ?? "说明内容待补充...")</div>
                <div style="margin-top:8px;">二、缺省值：缺省值待补充...</div>
                <div style="margin-top:8px;">三、使用条件：</div>
                <div style="margin-top:12px;">四、使用说明：</div>
                <div style="padding-left:16px; color:#666;">
                    <div>1、待补充详细说明</div>
                    <div>2、只读栏位，生成后不可修改</div>
                </div>
            </div>
            <div class="help-modal-footer">
                <button class="btn-online-help" type="button">
                    <span style="font-size:14px;">?</span> 在线帮助
                </button>
                <button class="btn-cancel" type="button" @onclick="CloseHelpModal">
                    &otimes; 取消
                </button>
            </div>
        </div>
    </div>
}

@code {
    private SystemSettingModel Model { get; set; } = new();
    private string activeNavId = "company";

    // 导航项 - 按参考图正确顺序，共16项
    private List<NavItem> NavItems { get; set; } = new()
    {
        new("company", "公司资料"),
        new("password", "密码策略"),
        new("system", "系统设定"),
        new("storage-location", "启用储位管理"),
        new("scan-setting", "扫描设定"),
        new("restock-service", "重整库存服务"),
        new("prefix-setting", "前缀设定"),
        new("qrcode-setting", "货品二维码组成"),
        new("encrypt", "信息加密处理"),
        new("erp-integration", "对接ERP系统"),
        new("other-systems", "与其他系统对接"),
        new("api-setting", "API接口设置"),
        new("storage-map", "可视化仓储视图参数"),
        new("summary-service", "汇总推进入库单服务"),
        new("auto-wave", "自动生成波次单"),
        new("auto-pick-task", "自动生成直接拣货任务单"),
    };

    // 帮助弹窗状态
    private bool showHelpModal;
    private string? currentHelpTitle;
    private string? currentHelpDesc;

    private DotNetObjectReference<SystemSetting>? dotNetRef;
    private bool jsInitialized;
    private ElementReference contentAreaRef;

    // ===== 字段行渲染方法：蓝色问号图标 + 标签 + 输入控件 =====
    private RenderFragment FieldRow(string label, string fieldId, RenderFragment content) => @<div class="form-row">
        <div class="help-icon" @onclick="() => OpenHelpModal(fieldId, label)" title="点击查看帮助"></div>
        <div class="row-label">@label</div>
        <div class="row-input-wrap">@content</div>
    </div>;

    protected override void OnInitialized()
    {
        base.OnInitialized();
        InitPrefixData();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            dotNetRef = DotNetObjectReference.Create(this);
            await InitScrollSpy();
        }
    }

    private void InitPrefixData()
    {
        Model.PrefixItems = new List<PrefixSettingItem>
        {
            new() { Label = "未使用前缀的条码默认类型", Value = "" },
            new() { Label = "仓库代号前缀", Value = "$WHN" },
            new() { Label = "储位代号前缀", Value = "$CW" },
            new() { Label = "工作台前缀", Value = "$GCT" },
            new() { Label = "客户/厂商代号前缀", Value = "$CUS" },
            new() { Label = "业务员代号前缀", Value = "$SAL" },
            new() { Label = "部门代号前缀", Value = "$DEP" },
            new() { Label = "货品前缀前缀", Value = "#PRQ" },
            new() { Label = "条码前缀", Value = "#BC" },
            new() { Label = "程序列前缀", Value = "#BB" },
            new() { Label = "序列号前缀", Value = "#BR" },
            new() { Label = "程序列前缀", Value = "#BS" },
            new() { Label = "机装前缀", Value = "#FPG" },
            new() { Label = "机装前缀", Value = "#FH" },
        };
    }

    // 点击导航 -> 滚动
    private async Task ScrollToSection(string navId)
    {
        activeNavId = navId;
        var sectionId = $"section-{navId}";
        try { await JS.InvokeVoidAsync("scrollToElement", contentAreaRef, sectionId); }
        catch (Exception ex) { _logger.LogError(ex, "滚动失败: {SectionId}", sectionId); }
    }

    // 打开帮助弹窗
    private void OpenHelpModal(string fieldId, string fieldLabel)
    {
        currentHelpTitle = fieldLabel;
        currentHelpDesc = null; // 后续可按 fieldId 映射具体说明
        showHelpModal = true;
    }

    // 关闭帮助弹窗
    private void CloseHelpModal()
    {
        showHelpModal = false;
        currentHelpTitle = null;
        currentHelpDesc = null;
    }

    // Scroll Spy 初始化
    private async Task InitScrollSpy()
    {
        if (jsInitialized) return;
        try { await JS.InvokeVoidAsync("initSystemSettingScrollSpy", contentAreaRef, dotNetRef, NavItems.Select(n => n.Id).ToArray()); jsInitialized = true; }
        catch (Exception ex) { _logger.LogError(ex, "初始化 scroll spy 失败"); }
    }

    [JSInvokable]
    public Task OnActiveNavChanged(string navId)
    {
        if (activeNavId != navId) { activeNavId = navId; StateHasChanged(); }
        return Task.CompletedTask;
    }

    private async Task SaveSettings() { _logger.LogInformation("用户点击了保存按钮"); }

    private async Task HandleScroll(EventArgs e) { if (!jsInitialized) { await DetectActiveSection(); } }

    private async Task DetectActiveSection()
    {
        try { var result = await JS.InvokeAsync<string>("detectActiveSection", contentAreaRef, NavItems.Select(n => n.Id).ToArray()); if (!string.IsNullOrEmpty(result) && activeNavId != result) { activeNavId = result; StateHasChanged(); } } catch { /* 忽略 */ }
    }

    public async ValueTask DisposeAsync()
    {
        if (jsInitialized) { try { await JS.InvokeVoidAsync("destroySystemSettingScrollSpy"); } catch { } }
        dotNetRef?.Dispose();
    }
}
