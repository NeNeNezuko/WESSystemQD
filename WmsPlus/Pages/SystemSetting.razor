                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">集团公司</span>
                    <div class="row-input-wrap">
                        <input type="text" @bind="sunlikeCompany" placeholder="" />
                        <button class="input-action" title="清空">&#8857;</button>
                    </div>
                </div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">避即单产生方式</span>
                    <div class="row-input-wrap">
                        <select @bind="sunlikeOrderMode">
                            <option value="">ERP推送进销存</option>
                            <option value="1">WMS主动拉取</option>
                            <option value="2">双向同步</option>
                        </select>
                        <button class="input-action" title="展开">&#9660;</button>
                    </div>
                </div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">启用日期</span>
                    <div class="row-input-wrap">
                        <input type="date" @bind="sunlikeStartDate" />
                        <button class="input-action" title="清空">&#8857;</button>
                    </div>
                </div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">允许往日获取申请单的天数</span>
                    <div class="row-input-wrap">
                        <input type="number" @bind="sunlikePastDays" />
                        <button class="input-action" title="清空">&#8857;</button>
                    </div>
                </div>
            </div>

            <!-- ====== Section 13-17: 占位区域 ====== -->
            <div class="setting-section" id="sec-other-system" data-nav="other-system">
                <div class="section-title">与其他系统对接</div>
                <div class="placeholder-section">
                    <span class="placeholder-text">即将开发 - 与其他系统对接设置项</span>
                </div>
            </div>

            <div class="setting-section" id="sec-api-setting" data-nav="api-setting">
                <div class="section-title">API接口设置</div>
                <div class="placeholder-section">
                    <span class="placeholder-text">即将开发 - API接口配置项</span>
                </div>
            </div>

            <div class="setting-section" id="sec-visual-params" data-nav="visual-params">
                <div class="section-title">可视化仓储视图参数</div>
                <div class="placeholder-section">
                    <span class="placeholder-text">即将开发 - 可视化仓储视图参数配置</span>
                </div>
            </div>

            <div class="setting-section" id="sec-no-restrict" data-nav="no-restrict">
                <div class="section-title">无忌接入送单服务</div>
                <div class="placeholder-section">
                    <span class="placeholder-text">即将开发 - 无忌接入送单服务配置</span>
                </div>
            </div>

            <div class="setting-section" id="sec-auto-generate" data-nav="auto-generate">
                <div class="section-title">自动生成或次单</div>
                <div class="placeholder-section">
                    <span class="placeholder-text">即将开发 - 自动生成或次单配置</span>
                </div>
            </div>

            <div class="setting-section" id="sec-auto-storage-task" data-nav="auto-storage-task">
                <div class="section-title">自动生成直接储任务单</div>
