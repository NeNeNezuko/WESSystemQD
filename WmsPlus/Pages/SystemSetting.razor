@page "/system-setting"
@using Microsoft.AspNetCore.Components.Web
@using System.Net.Http
@inject IHttpClientFactory HttpClientFactory
@inject IJSRuntime JSRuntime
@inject NavigationManager NavManager

<link rel="stylesheet" href="css/system-setting.css" />

<div class="system-setting-page">
    <!-- 顶部标题栏 -->
    <div class="page-header">
        <div class="header-left">
            <button class="favorite-btn @(isFavorited ? "favorited" : "")" @onclick="ToggleFavorite" title="收藏">
                @(isFavorited ? "★" : "☆")
            </button>
            <span class="page-title">系统设定</span>
        </div>
        <div class="header-right">
            <button class="save-btn" @onclick="HandleSave">保存</button>
        </div>
    </div>

    <!-- 收藏成功提示 -->
    <div class="toast @(showToast ? "show" : "")">收藏成功</div>

    <!-- 主内容区：左侧导航 + 右侧设置内容 -->
    <div class="page-body">
        <!-- 左侧导航栏 -->
        <div class="nav-sidebar">
            <div class="nav-title">导航</div>
            @foreach (var nav in NavItems)
            {
                <div class="nav-item @(activeNavId == nav.Id ? "active" : "")"
                     @onclick="() => ScrollToSection(nav.Id)">
                    @nav.Title
                </div>
            }
        </div>

        <!-- 右侧内容区（滚动） -->
        <div class="content-area" @onscroll="HandleContentScroll" @ref="contentRef">

            <!-- ====== Section 1: 公司资料 ====== -->
            <div class="setting-section" id="sec-company" data-nav="company">
                <div class="section-title">公司资料</div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">公司代号</span>
                    <div class="row-input-wrap">
                        <input type="text" @bind="formData.CompanyCode" placeholder="" />
                        <button class="input-action" title="清空">&#8857;</button>
                    </div>
                </div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">公司名称</span>
                    <div class="row-input-wrap">
                        <input type="text" @bind="formData.CompanyName" placeholder="" />
                        <button class="input-action" title="清空">&#8857;</button>
                    </div>
                </div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">英文名称</span>
                    <div class="row-input-wrap">
                        <input type="text" @bind="formData.CompanyEnName" placeholder="" />
                        <button class="input-action" title="清空">&#8857;</button>
                    </div>
                </div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">公司地址</span>
                    <div class="row-input-wrap">
                        <input type="text" @bind="formData.CompanyAddress" placeholder="" />
                        <button class="input-action" title="清空">&#8857;</button>
                    </div>
                </div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">电话</span>
                    <div class="row-input-wrap">
                        <input type="text" @bind="formData.Phone" placeholder="" />
                        <button class="input-action" title="清空">&#8857;</button>
                    </div>
                </div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">开始日期</span>
                    <div class="row-input-wrap">
                        <input type="date" @bind="formData.StartDate" />
                        <button class="input-action" title="清空">&#8857;</button>
                    </div>
                </div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">日期格式</span>
                    <div class="row-input-wrap">
                        <input type="text" @bind="dateFormat" placeholder="yyyy-MM-dd" />
                        <button class="input-action" title="清空">&#8857;</button>
                    </div>
                </div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">小数位</span>
                    <div class="row-input-wrap">
                        <input type="number" @bind="decimalPlaces" />
                        <button class="input-action" title="清空">&#8857;</button>
                    </div>
                </div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">数位后加0不显示</span>
                    <label class="toggle-switch">
                        <input type="checkbox" @bind="hideTrailingZero" />
                        <span class="toggle-slider"></span>
                    </label>
                </div>
            </div>

            <!-- ====== Section 2: 密码策略 ====== -->
            <div class="setting-section" id="sec-password" data-nav="password">
                <div class="section-title">密码策略</div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">有效期</span>
                    <div class="row-input-wrap">
                        <input type="text" @bind="pwdValidDays" placeholder="" />
                        <button class="input-action" title="清空">&#8857;</button>
                    </div>
                </div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">内容限制</span>
                    <div class="row-input-wrap">
                        <select @bind="pwdContentLimit">
                            <option value="">无限制</option>
                            <option value="1">必须包含数字</option>
                            <option value="2">必须包含字母</option>
                            <option value="3">必须包含特殊字符</option>
                        </select>
                        <button class="input-action" title="展开">&#9660;</button>
                    </div>
                </div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">最小长度</span>
                    <div class="row-input-wrap">
                        <input type="text" @bind="pwdMinLength" placeholder="[已输入至1前(数字)]" />
                        <button class="input-action" title="清空">&#8857;</button>
                    </div>
                </div>
            </div>

            <!-- ====== Section 3: 系统设定 ====== -->
            <div class="setting-section" id="sec-system" data-nav="system">
                <div class="section-title">系统设定</div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">货品使用序列号</span>
                    <label class="toggle-switch">
                        <input type="checkbox" @bind="useSerialNo" />
                        <span class="toggle-slider"></span>
                    </label>
                </div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">已出库序号允许重复使用</span>
                    <label class="toggle-switch">
                        <input type="checkbox" @bind="allowReuseSerial" />
                        <span class="toggle-slider"></span>
                    </label>
                </div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">默认出库业务类型</span>
                    <div class="row-input-wrap">
                        <input type="text" @bind="defaultCkBizType" placeholder="" readonly />
                        <button class="input-action" title="search">&#128269;</button>
                    </div>
                </div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">入库时不对影响输入入库目的业务类型</span>
                    <div class="row-input-wrap">
                        <input type="text" @bind="rkIgnoreBizType" placeholder="" />
                        <button class="input-action" title="search">&#128269;</button>
                    </div>
                </div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">不影响输入入库日期的来源</span>
                    <div class="row-input-wrap">
                        <input type="text" @bind="rkDateSource" placeholder="" />
                        <button class="input-action" title="search">&#128269;</button>
                    </div>
                </div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">批业类型设定默认优先级</span>
                    <div class="row-input-wrap">
                        <input type="text" @bind="bizTypePriority" placeholder="" />
                        <button class="input-action" title="search">&#128269;</button>
                    </div>
                </div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">检查来设备</span>
                    <div class="row-input-wrap">
                        <select @bind="checkDeviceMode">
                            <option value="">在WMS系统检验</option>
                            <option value="1">跳过检验</option>
                            <option value="2">在PDA端检验</option>
                        </select>
                        <button class="input-action" title="展开">&#9660;</button>
                    </div>
                </div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">系统表头后缀SUNLIKE系统</span>
                    <div class="row-input-wrap">
                        <input type="text" @bind="sunlikeSuffix" placeholder="" />
                        <button class="input-action" title="清空">&#8857;</button>
                    </div>
                </div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">系统表头后缀日期和数量</span>
                    <div class="row-input-wrap">
                        <select @bind="suffixDateQty">
                            <option value="">当前系统日期</option>
                            <option value="1">单据日期</option>
                            <option value="2">不添加后缀</option>
                        </select>
                        <button class="input-action" title="展开">&#9660;</button>
                    </div>
                </div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">货品打印标签频值次序</span>
                    <div class="row-input-wrap">
                        <select @bind="printLabelOrder">
                            <option value="">货品</option>
                            <option value="1">批号</option>
                            <option value="2">储位</option>
                        </select>
                        <button class="input-action" title="展开">...</button>
                    </div>
                </div>
            </div>

            <!-- ====== Section 4: 货品特征 ====== -->
            <div class="setting-section" id="sec-product-mark" data-nav="product-mark">
                <div class="section-title">货品特征</div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">货品启用特征</span>
                    <label class="toggle-switch">
                        <input type="checkbox" @bind="enableProductMark" />
                        <span class="toggle-slider"></span>
                    </label>
                </div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">特征含</span>
                    <div class="row-input-wrap">
                        <input type="text" @bind="markInclude" placeholder="" />
                        <button class="input-action" title="清空">&#8857;</button>
                    </div>
                </div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">特征输入受位置编码控制</span>
                    <label class="toggle-switch">
                        <input type="checkbox" @bind="markPositionControl" />
                        <span class="toggle-slider"></span>
                    </label>
                </div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">特征分段说明定义方式</span>
                    <div class="row-input-wrap">
                        <select @bind="markDefineMethod">
                            <option value="">单相固定长度的分段方式</option>
                            <option value="1">可变长度分段</option>
                            <option value="2">分隔符分段</option>
                        </select>
                        <button class="input-action" title="展开">&#9660;</button>
                    </div>
                </div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">特征分段分隔符</span>
                    <div class="row-input-wrap">
                        <input type="text" @bind="markSeparator" placeholder="" />
                        <button class="input-action" title="清空">&#8857;</button>
                    </div>
                </div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">按货品启用特征</span>
                    <label class="toggle-switch">
                        <input type="checkbox" @bind="enableMarkByProduct" />
                        <span class="toggle-slider"></span>
                    </label>
                </div>
            </div>

            <!-- ====== Section 5: 电子标签 ====== -->
            <div class="setting-section" id="sec-rfid" data-nav="rfid">
                <div class="section-title">电子标签</div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">RFID 就采时长（秒）</span>
                    <div class="row-input-wrap">
                        <input type="number" @bind="rfidReadTime" />
                        <button class="input-action" title="清空">&#8857;</button>
                    </div>
                </div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">RFID采集货品条码时长（秒）</span>
                    <div class="row-input-wrap">
                        <input type="number" @bind="rfidBarcodeTime" />
                        <button class="input-action" title="清空">&#8857;</button>
                    </div>
                </div>
                <div class="sub-section-title">其他标签</div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">已出库箱码允许重复使用</span>
                    <label class="toggle-switch">
                        <input type="checkbox" @bind="allowReuseBoxCode" />
                        <span class="toggle-slider"></span>
                    </label>
                </div>
            </div>

            <!-- ====== Section 6: 应用储位管理 ====== -->
            <div class="setting-section" id="sec-storage-location" data-nav="storage-location">
                <div class="section-title">应用储位管理</div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">启用储位管理</span>
                    <label class="toggle-switch">
                        <input type="checkbox" @bind="enableStorageLocation" />
                        <span class="toggle-slider"></span>
                    </label>
                </div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">货品储位管理的依据</span>
                    <div class="row-input-wrap">
                        <select @bind="storageBasis">
                            <option value="2" selected>2.依货品设定(储存性质)</option>
                            <option value="1">1.依中类设定</option>
                            <option value="3">3.依储存性设定</option>
                        </select>
                        <button class="input-action" title="展开">&#9660;</button>
                    </div>
                </div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">储存顺序依据</span>
                    <div class="row-input-wrap">
                        <select @bind="storageOrder">
                            <option value="2" selected>2.中类依据排序/依储性属性与顺序</option>
                            <option value="1">1.依货品编码顺序</option>
                        </select>
                        <button class="input-action" title="展开">&#9660;</button>
                    </div>
                </div>
            </div>

            <!-- ====== Section 7: 扫描设定 ====== -->
            <div class="setting-section" id="sec-scan" data-nav="scan">
                <div class="section-title">扫描设定</div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">扫描时输入货品有效规则</span>
                    <label class="toggle-switch">
                        <input type="checkbox" @bind="scanProductRule" />
                        <span class="toggle-slider"></span>
                    </label>
                </div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">条列模式切换快捷键设置</span>
                    <div class="row-input-wrap">
                        <input type="number" @bind="scanHotkey" />
                        <button class="input-action" title="清空">&#8857;</button>
                    </div>
                </div>
            </div>

            <!-- ====== Section 8: 集整库存服务 ====== -->
            <div class="setting-section" id="sec-inventory-service" data-nav="inventory-service">
                <div class="section-title">集整库存服务</div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">排定执行时间点</span>
                    <div class="row-input-wrap">
                        <input type="number" @bind="inventoryExecTime" />
                        <button class="input-action" title="清空">&#8857;</button>
                    </div>
                </div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">计算间隔天数</span>
                    <div class="row-input-wrap">
                        <input type="number" @bind="inventoryInterval" />
                        <button class="input-action" title="清空">&#8857;</button>
                    </div>
                </div>
            </div>

            <!-- ====== Section 9: 前端设定 ====== -->
            <div class="setting-section" id="sec-frontend" data-nav="frontend">
                <div class="section-title">前端设定</div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">未使用前端的利系默认类型</span>
                    <div class="row-input-wrap">
                        <input type="text" @bind="prefixItems[0]" placeholder="" />
                        <button class="input-action" title="清空">&#8857;</button>
                    </div>
                </div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">前置码</span>
                    <div class="row-input-wrap">
                        <input type="text" value="@(prefixLabel)" readonly style="background:#fafafa;color:#8c8c8s;" />
                    </div>
                </div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">仓库代号前缀</span>
                    <div class="row-input-wrap">
                        <input type="text" @bind="prefixItems[1]" placeholder="@@WMS" />
                        <button class="input-action" title="清空">&#8857;</button>
                    </div>
                </div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">储位代号前缀</span>
                    <div class="row-input-wrap">
                        <input type="text" @bind="prefixItems[2]" placeholder="@@BCW" />
                        <button class="input-action" title="清空">&#8857;</button>
                    </div>
                </div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">工作台前缀</span>
                    <div class="row-input-wrap">
                        <input type="text" @bind="prefixItems[3]" placeholder="@@BCZF" />
                        <button class="input-action" title="清空">&#8857;</button>
                    </div>
                </div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">客户/厂商代号前缀</span>
                    <div class="row-input-wrap">
                        <input type="text" @bind="prefixItems[4]" placeholder="@@BCUS" />
                        <button class="input-action" title="清空">&#8857;</button>
                    </div>
                </div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">业务代号前缀</span>
                    <div class="row-input-wrap">
                        <input type="text" @bind="prefixItems[5]" placeholder="@@B4AL" />
                        <button class="input-action" title="清空">&#8857;</button>
                    </div>
                </div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">部门代号前缀</span>
                    <div class="row-input-wrap">
                        <input type="text" @bind="prefixItems[6]" placeholder="@@BDEP" />
                        <button class="input-action" title="清空">&#8857;</button>
                    </div>
                </div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">物流备前缀</span>
                    <div class="row-input-wrap">
                        <input type="text" @bind="prefixItems[7]" placeholder="@@BHQ" />
                        <button class="input-action" title="清空">&#8857;</button>
                    </div>
                </div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">条码前缀</span>
                    <div class="row-input-wrap">
                        <input type="text" @bind="prefixItems[8]" placeholder="@@BBG" />
                        <button class="input-action" title="清空">&#8857;</button>
                    </div>
                </div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">序列号前缀</span>
                    <div class="row-input-wrap">
                        <input type="text" @bind="prefixItems[9]" placeholder="@@BSB" />
                        <button class="input-action" title="清空">&#8857;</button>
                    </div>
                </div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">库存区分前缀</span>
                    <div class="row-input-wrap">
                        <input type="text" @bind="prefixItems[10]" placeholder="@@BSY" />
                        <button class="input-action" title="清空">&#8857;</button>
                    </div>
                </div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">器器分区前缀</span>
                    <div class="row-input-wrap">
                        <input type="text" @bind="prefixItems[11]" placeholder="@@BPQG" />
                        <button class="input-action" title="清空">&#8857;</button>
                    </div>
                </div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">包装码前缀</span>
                    <div class="row-input-wrap">
                        <input type="text" @bind="prefixItems[12]" placeholder="@@BPAG" />
                        <button class="input-action" title="清空">&#8857;</button>
                    </div>
                </div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">架装货位前缀</span>
                    <div class="row-input-wrap">
                        <input type="text" @bind="prefixItems[13]" placeholder="@@BHJ" />
                        <button class="input-action" title="清空">&#8857;</button>
                    </div>
                </div>
            </div>

            <!-- ====== Section 10: 货品二维码组成 ====== -->
            <div class="setting-section" id="sec-qrcode" data-nav="qrcode">
                <div class="section-title">货品二维码组成</div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">启用货品二维码(外部条码)</span>
                    <label class="toggle-switch">
                        <input type="checkbox" @bind="enableQrCode" />
                        <span class="toggle-slider"></span>
                    </label>
                </div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">二维码分段的间隔符</span>
                    <div class="row-input-wrap">
                        <input type="text" @bind="qrSeparator" placeholder="" />
                        <button class="input-action" title="清空">&#8857;</button>
                    </div>
                </div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">条码信息所在分段</span>
                    <div class="row-input-wrap">
                        <input type="text" @bind="qrBarcodeSegment" placeholder="" />
                        <button class="input-action" title="清空">&#8857;</button>
                    </div>
                </div>
                <div class="form-row">
                    <div class="row-marker"></div>
                    <span class="row-label">出库业务单据所在分段</span>
                    <div class="row-input-wrap">
                        <input type="text" @bind="qrCkDocSegment" placeholder="" />
