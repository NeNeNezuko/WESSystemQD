@code {
    private OutboundNoticeAddHeader header = new();
    private List<OutboundNoticeAddProductItem> productItems = new();
    private List<OutboundNoticeAddBarcodeItem> barcodeItems = new();
    private string activeDetailTab = "product";
    private int productItemSeq = 0;
    private int barcodeItemSeq = 0;

    // ===== 客户选择器状态 =====
    private bool showVendorDialog = false;
    private string vendorSearchKeyword = "";
    private List<VendorItem> vendorData = new();
    private int vendorPageIndex = 1;
    private int vendorPageSize = 10;
    private int vendorTotalCount = 0;

    // ===== 仓库选择器状态 =====
    private bool showWarehouseDialog = false;
    private string warehouseSearchKeyword = "";
    private List<WarehouseItem> warehouseData = new();
    private int warehousePageIndex = 1;
    private int warehousePageSize = 10;
    private int warehouseTotalCount = 0;
    private OutboundNoticeAddProductItem? currentRowForWh = null;
    private bool isWarehouseForHeader = false;

    [CascadingParameter(Name = "OpenTabCallback")] public Action<string, string>? OpenTab { get; set; }
    [CascadingParameter(Name = "OnFavoriteChanged")] public Action? NotifyFavoriteChanged { get; set; }

    // ===== 收藏功能 =====
    private bool isFavorited = false;
    private bool showFavoriteSuccess = false;
    private const string FAVORITE_KEY = "wms_favorite_outbound_notice_add";

    protected override async Task OnInitializedAsync()
    {
        try { var r = await JS.InvokeAsync<string>("localStorage.getItem", FAVORITE_KEY); isFavorited = r == "true"; } catch { }

        await LoadNextDocumentNo();
    }

    private async Task LoadNextDocumentNo()
    {
        try
        {
            var url = $"{ApiConfig.BaseUrl}/api/OutboundNotice/next-no";
            var request = AuthHttpClient.CreateRequest(HttpMethod.Get, url, TokenProvider.Token);
            var responseMsg = await Http.SendAsync(request);
            if (responseMsg.IsSuccessStatusCode)
            {
                var json = await responseMsg.Content.ReadAsStringAsync();
                var jsonOptions = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
                var result = System.Text.Json.JsonSerializer.Deserialize<NextNoResult>(json, jsonOptions);
                if (result != null && result.Success && !string.IsNullOrWhiteSpace(result.Data))
                {
                    header.DocumentNumber = result.Data;
                    return;
                }
            }
        }
        catch (Exception ex)
        {
            _logger?.LogError(ex, "获取出库通知单单号失败");
        }
        header.DocumentNumber = $"UP{DateTime.Now:yyyyMMdd}000001";
    }

    private class NextNoResult
    {
        public bool Success { get; set; }
        public string? Data { get; set; }
        public string? Message { get; set; }
    }

    private async Task ToggleFavorite()
    {
        isFavorited = !isFavorited;
        try { await JS.InvokeVoidAsync("localStorage.setItem", FAVORITE_KEY, isFavorited.ToString().ToLower()); } catch { }
        NotifyFavoriteChanged?.Invoke();
        showFavoriteSuccess = true;
        StateHasChanged();
        await Task.Delay(1500);
        showFavoriteSuccess = false;
        StateHasChanged();
    }

    // ===== 工具栏按钮事件 =====
    private async Task HandleSave()
    {
        if (string.IsNullOrWhiteSpace(header.DocumentNumber))
        {
            await JS.InvokeVoidAsync("alert", "单据号码不能为空");
            return;
        }
        if (string.IsNullOrWhiteSpace(header.WarehouseCode))
        {
            await JS.InvokeVoidAsync("alert", "仓库代号不能为空");
            return;
        }

        try
        {
            var payload = new
            {
                Header = new
                {
                    TZ_NO = header.DocumentNumber,
                    TZ_DD = header.DocumentDate,
                    DEP = header.OperatorCode ?? "",
                    BIL_TYPE = header.BusinessType ?? "",
                    CUS_NO = header.CustomerCode ?? "",
                    CUS_NAME = header.CustomerName ?? "",
                    WH = header.WarehouseCode ?? "",
                    APPLY_NO = header.ApplyOrderNo ?? "",
                    EXPECT_DD = header.ExpectedDate,
                    PRIORITY = header.Priority,
                    REM = header.Remark ?? "",
                    USR = header.OperatorCode ?? ""
                },
                Details = productItems.Select((p, idx) => new
                {
                    ITM = idx + 1,
                    PRD_NO = p.PrdNo ?? "",
                    PRD_NAME = p.PrdName ?? "",
                    BAT_NO = p.BatchNo ?? "",
                    WH = p.WhCode ?? "",
                    UNIT = p.UnitName ?? "",
                    QTY = p.Qty,
                    REM = ""
                }).ToList()
            };

            var url = $"{ApiConfig.BaseUrl}/api/OutboundNotice/save";
            var jsonOptions = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var json = System.Text.Json.JsonSerializer.Serialize(payload, jsonOptions);
            var content = new StringContent(json, System.Text.Encoding.UTF8, "application/json");
            var request = AuthHttpClient.CreateRequest(HttpMethod.Post, url, TokenProvider.Token);
            request.Content = content;

            var responseMsg = await Http.SendAsync(request);
            var respJson = await responseMsg.Content.ReadAsStringAsync();
            var result = System.Text.Json.JsonSerializer.Deserialize<NextNoResult>(respJson, jsonOptions);

            if (responseMsg.IsSuccessStatusCode && result != null && result.Success)
            {
                await JS.InvokeVoidAsync("alert", $"保存成功！单据号码：{header.DocumentNumber}");
                await HandleAddNew();
            }
            else
            {
                var msg = result?.Message ?? "保存失败";
                await JS.InvokeVoidAsync("alert", msg);
            }
        }
        catch (Exception ex)
        {
            _logger?.LogError(ex, "保存出库通知单失败");
            await JS.InvokeVoidAsync("alert", $"保存异常：{ex.Message}");
        }
    }

    private async Task HandleAddNew()
    {
        header = new OutboundNoticeAddHeader();
        productItems = new();
        barcodeItems = new();
        activeDetailTab = "product";
        productItemSeq = 0;
        barcodeItemSeq = 0;
        await LoadNextDocumentNo();
        StateHasChanged();
    }
    private void HandleDelete() { /* TODO: 删除功能 */ }
    private void HandlePrint() { /* TODO: 打印功能 */ }
    private void HandleColumnSettings() { /* TODO: 栏位设置功能 */ }
    private void HandleQuery() { /* TODO: 查询功能 */ }

    // ===== 客户选择器方法 =====
    private async Task OpenVendorSelector()
    {
        vendorSearchKeyword = "";
        vendorPageIndex = 1;
        await SearchVendor();
        showVendorDialog = true;
        StateHasChanged();
    }

    private void CloseVendorSelector()
    {
        showVendorDialog = false;
        StateHasChanged();
    }

    private async Task SearchVendor()
    {
        try
        {
            var url = $"{ApiConfig.BaseUrl}/api/warehouse/customersearch?keyword={Uri.EscapeDataString(vendorSearchKeyword ?? "")}&pageIndex={vendorPageIndex}&pageSize={vendorPageSize}";
            var jsonOptions = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var request = AuthHttpClient.CreateRequest(HttpMethod.Get, url, TokenProvider.Token);
            var responseMsg = await Http.SendAsync(request);
            if (responseMsg.IsSuccessStatusCode)
            {
                var json = await responseMsg.Content.ReadAsStringAsync();
                var result = System.Text.Json.JsonSerializer.Deserialize<VendorSearchResult>(json, jsonOptions);
                if (result != null)
                {
                    vendorData = result.Items ?? new List<VendorItem>();
                    vendorTotalCount = result.TotalCount;
                }
            }
        }
        catch (Exception ex)
        {
            _logger?.LogError(ex, "客户选择器查询失败");
        }
        StateHasChanged();
    }

    private void SelectVendor(VendorItem item)
    {
        header.CustomerCode = item.CUS_NO;
        header.CustomerName = item.CUS_NAME;
        showVendorDialog = false;
        StateHasChanged();
    }

    private int VendorTotalPages => vendorPageSize > 0 ? (int)Math.Ceiling((double)vendorTotalCount / vendorPageSize) : 1;

    private async Task GoToVendorPage(int page)
    {
        if (page >= 1 && page <= VendorTotalPages)
        {
            vendorPageIndex = page;
            await SearchVendor();
        }
    }

    // ===== 仓库选择器方法 =====
    private async Task OpenHeaderWarehouseSelector()
    {
        isWarehouseForHeader = true;
        currentRowForWh = null;
        await OpenWarehouseSelectorCommon();
    }

    private async Task OpenRowWarehouseSelector(OutboundNoticeAddProductItem row)
    {
        isWarehouseForHeader = false;
        currentRowForWh = row;
        await OpenWarehouseSelectorCommon();
    }

    private async Task OpenWarehouseSelectorCommon()
    {
        warehouseSearchKeyword = "";
        warehousePageIndex = 1;
        await SearchWarehouse();
        showWarehouseDialog = true;
        StateHasChanged();
    }

    private void CloseWarehouseSelector()
    {
        showWarehouseDialog = false;
        StateHasChanged();
    }

    private async Task SearchWarehouse()
    {
        try
        {
            var url = $"{ApiConfig.BaseUrl}/api/warehouse/search?keyword={Uri.EscapeDataString(warehouseSearchKeyword ?? "")}&pageIndex={warehousePageIndex}&pageSize={warehousePageSize}";
            var jsonOptions = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var request = AuthHttpClient.CreateRequest(HttpMethod.Get, url, TokenProvider.Token);
            var responseMsg = await Http.SendAsync(request);
            if (responseMsg.IsSuccessStatusCode)
            {
                var json = await responseMsg.Content.ReadAsStringAsync();
                var result = System.Text.Json.JsonSerializer.Deserialize<WarehouseSearchResult>(json, jsonOptions);
                if (result != null)
                {
                    warehouseData = result.Items ?? new List<WarehouseItem>();
                    warehouseTotalCount = result.TotalCount;
                }
            }
        }
        catch (Exception ex)
        {
            _logger?.LogError(ex, "仓库选择器查询失败");
        }
        StateHasChanged();
    }

    private void SelectWarehouse(WarehouseItem item)
    {
        if (isWarehouseForHeader)
        {
            header.WarehouseCode = item.WH;
            header.WarehouseName = item.NAME ?? "";
        }
        else if (currentRowForWh != null)
        {
            currentRowForWh.WhCode = item.WH;
        }
        showWarehouseDialog = false;
        StateHasChanged();
    }

    private int WarehouseTotalPages => warehousePageSize > 0 ? (int)Math.Ceiling((double)warehouseTotalCount / warehousePageSize) : 1;

    private async Task GoToWarehousePage(int page)
    {
        if (page >= 1 && page <= WarehouseTotalPages)
        {
            warehousePageIndex = page;
            await SearchWarehouse();
        }
    }

    // ===== 底部操作栏按钮事件 =====
    private void HandleDocInfo() { /* TODO: 单据资讯功能 */ }
    private void HandleExcelImport() { /* TODO: Excel导入功能 */ }
    private void HandleSplit() { /* TODO: 拆分功能 */ }
    private void HandleMore() { /* TODO: 更多功能 */ }

    // ===== 明细选项卡切换 =====
    private void SwitchToProductTab()
    {
        activeDetailTab = "product";
        StateHasChanged();
    }

    private void SwitchToBarcodeTab()
    {
        activeDetailTab = "barcode";
        StateHasChanged();
    }

    // ===== 货品明细操作 =====
    private void AddProductRow()
    {
        productItemSeq++;
        productItems.Add(new OutboundNoticeAddProductItem { ItemNo = productItemSeq, WhCode = header.WarehouseCode });
        StateHasChanged();
    }

    private void OnProductSelected(OutboundNoticeAddProductItem row, ProductCodeAutocomplete.AutoProductItem product)
    {
        row.PrdName = product.NAME;
        row.UnitName = product.UT;
        StateHasChanged();
    }

    // ===== 条码明细操作 =====
    private void AddBarcodeRow()
    {
        barcodeItemSeq++;
        barcodeItems.Add(new OutboundNoticeAddBarcodeItem { ItemNo = barcodeItemSeq });
        StateHasChanged();
    }

    private void RemoveBarcodeRow(int itemNo)
    {
        barcodeItems.RemoveAll(x => x.ItemNo == itemNo);
        StateHasChanged();
    }

    // ===== 客户数据模型 =====
    public class VendorItem
    {
        public string CUS_NO { get; set; } = "";
        public string CUS_NAME { get; set; } = "";
    }

    private class VendorSearchResult
    {
        public List<VendorItem>? Items { get; set; }
        public int TotalCount { get; set; }
    }

    // ===== 仓库数据模型 =====
    public class WarehouseItem
    {
        public string WH { get; set; } = "";
        public string? NAME { get; set; }
    }

    private class WarehouseSearchResult
    {
        public List<WarehouseItem>? Items { get; set; }
        public int TotalCount { get; set; }
    }
}
