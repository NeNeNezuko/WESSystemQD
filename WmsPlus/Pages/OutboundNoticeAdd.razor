@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@inject HttpClient Http
@inject ILogger<OutboundNoticeAdd> _logger
@inject TokenProvider TokenProvider

<link rel="stylesheet" href="css/inbound-notice-add.css" />

<div class="inbound-notice-add-page">
    <!-- 页面标题栏 -->
    <div class="page-header">
        <div class="header-left">
            <button class="favorite-btn @(isFavorited ? "favorited" : "")" @onclick="ToggleFavorite" title="收藏">
                <svg viewBox="0 0 24 24" width="24" height="24">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
                          fill="@((isFavorited ? "#FFD700" : "none"))"
                          stroke="@((isFavorited ? "#FFD700" : "#666666"))"
                          stroke-width="2"/>
                </svg>
            </button>
            <span class="page-title">出库通知单-新增</span>
        </div>
        <div class="header-right">
            <button class="header-action-btn primary" @onclick="HandleSave">
                <svg viewBox="0 0 16 16" width="14" height="14" fill="white">
                    <path d="M13.78 4.22a.75.75 0 010 1.06l-7.25 7.25a.75.75 0 01-1.06 0L2.22 8.28a.75.75 0 011.06-1.06L6 9.94l6.72-6.72a.75.75 0 011.06 0z"/>
                </svg>
                <span>保存</span>
            </button>
            <button class="header-action-btn primary" @onclick="HandleAddNew">
                <svg viewBox="0 0 16 16" width="14" height="14" fill="white">
                    <path d="M8 3v10M3 8h10" stroke="white" stroke-width="2" stroke-linecap="round"/>
                </svg>
                <span>新增</span>
            </button>
            <button class="header-action-btn" @onclick="HandleDelete">
                <svg viewBox="0 0 16 16" width="14" height="14" fill="#666666">
                    <path d="M5.5 4h5l.5.5v9l-.5.5h-5L5 13.5v-9l.5-.5zM6 5v8h4V5H6z M4 3.5V4h1v-.5a.5.5 0 00-.5-.5h-1a.5.5 0 00-.5.5zm8 0V4h1v-.5a.5.5 0 00-.5-.5h-1a.5.5 0 00-.5.5z"/>
                </svg>
                <span>删除</span>
            </button>
            <button class="header-action-btn" @onclick="HandlePrint">
                <svg viewBox="0 0 16 16" width="14" height="14" fill="#666666">
                    <path d="M5 2h6v2H5V2zm7 2h1a2 2 0 012 2v2h-2V6a1 1 0 00-1-1H4a1 1 0 00-1 1v2H1V6a2 2 0 012-2h1V2a1 1 0 011-1h6a1 1 0 011 1v2zM1 11h14v2a1 1 0 01-1 1H2a1 1 0 01-1-1v-2zm3-3h8v3H4V8z"/>
                </svg>
                <span>打印</span>
            </button>
            <button class="header-action-btn" @onclick="HandleColumnSettings">
                <svg viewBox="0 0 16 16" width="14" height="14" fill="#666666">
                    <path d="M2 3h4v2H2V3zm0 4h4v2H2V7zm0 4h4v2H2v-2zm6-8h6v2H8V3zm0 4h6v2H8V7zm0 4h6v2H8v-2z"/>
                </svg>
                <span>栏位</span>
            </button>
            <button class="header-action-btn" @onclick="HandleQuery">
                <svg viewBox="0 0 16 16" width="14" height="14" fill="#666666">
                    <circle cx="7" cy="7" r="5"/>
                    <line x1="11" y1="11" x2="15" y2="15" stroke="#666666" stroke-width="1.5"/>
                </svg>
                <span>查询</span>
            </button>
        </div>
    </div>

    @if (showFavoriteSuccess)
    {
        <div class="favorite-success-toast">
            <div class="toast-content">
                <svg viewBox="0 0 16 16" width="16" height="16" fill="#52C41A">
                    <circle cx="8" cy="8" r="8"/>
                    <path d="M5 8l2 2 4-4" stroke="white" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>收藏成功</span>
            </div>
        </div>
    }

    <!-- 表单区域 - 3列布局 -->
    <div class="form-area">
        <div class="form-grid-3col">
            <!-- ===== 第1列（左侧）===== -->
            <!-- 单据日期 -->
            <div class="form-item-add">
                <label class="form-label-add">单据日期</label>
                <input type="date" class="form-input-add" @bind="header.DocumentDate" @bind:format="yyyy-MM-dd" />
            </div>

            <!-- 客户代号* -->
            <div class="form-item-add">
                <label class="form-label-add"><span class="required-mark">*</span>客户代号</label>
                <input type="text" class="form-input-add" placeholder="" @bind="header.CustomerCode" />
                <div class="input-search-icon" title="选择客户" style="cursor:pointer;" @onclick="OpenVendorSelector">
                    <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="#999999" stroke-width="1.5">
                        <circle cx="7" cy="7" r="5"/><line x1="11" y1="11" x2="15" y2="15" stroke="#999999" stroke-width="1.5"/>
                    </svg>
                </div>
            </div>

            <!-- 仓库代号* -->
            <div class="form-item-add">
                <label class="form-label-add"><span class="required-mark">*</span>仓库代号</label>
                <input type="text" class="form-input-add" placeholder="" @bind="header.WarehouseCode" />
                <div class="input-search-icon" title="搜索" style="cursor:pointer;" @onclick="OpenHeaderWarehouseSelector">
                    <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="#999999" stroke-width="1.5">
                        <circle cx="7" cy="7" r="5"/><line x1="11" y1="11" x2="15" y2="15" stroke="#999999" stroke-width="1.5"/>
                    </svg>
                </div>
            </div>

            <!-- 申请单号 -->
            <div class="form-item-add">
                <label class="form-label-add">申请单号</label>
                <input type="text" class="form-input-add" placeholder="" @bind="header.ApplyOrderNo" />
            </div>

            <!-- ERP存单据生成方式 -->
            <div class="form-item-add">
                <label class="form-label-add">ERP存单据生成方式</label>
                <input type="text" class="form-input-add" placeholder="" @bind="header.ErpGenerateMode" />
            </div>

            <!-- 出库单据 checkbox -->
            <div class="checkbox-wrapper">
                <input type="checkbox" id="chkOutboundOrder" @bind="header.IsOutboundOrder" />
                <label for="chkOutboundOrder">出库单据</label>
            </div>

            <!-- ===== 第2列（中间）===== -->
            <!-- 单据号码（只读） -->
            <div class="form-item-add">
                <label class="form-label-add">单据号码</label>
                <input type="text" class="form-input-add" readonly value="@header.DocumentNumber" />
            </div>

            <!-- 单据类别 -->
            <div class="form-item-add">
                <label class="form-label-add">单据类别</label>
                <input type="text" class="form-input-add" placeholder="" @bind="header.DocCategoryCode" />
                <div class="input-search-icon" title="搜索">
                    <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="#999999" stroke-width="1.5">
                        <circle cx="7" cy="7" r="5"/><line x1="11" y1="11" x2="15" y2="15" stroke="#999999" stroke-width="1.5"/>
                    </svg>
                </div>
            </div>

            <!-- 经办人 -->
            <div class="form-item-add">
                <label class="form-label-add">经办人</label>
                <input type="text" class="form-input-add" placeholder="" @bind="header.OperatorCode" />
                <div class="input-search-icon" title="搜索">
                    <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="#999999" stroke-width="1.5">
                        <circle cx="7" cy="7" r="5"/><line x1="11" y1="11" x2="15" y2="15" stroke="#999999" stroke-width="1.5"/>
                    </svg>
                </div>
            </div>

            <!-- 预计出库日期 -->
            <div class="form-item-add">
                <label class="form-label-add">预计出库日期</label>
                <input type="date" class="form-input-add" @bind="header.ExpectedDate" @bind:format="yyyy-MM-dd" />
            </div>

            <!-- 优先级 -->
            <div class="form-item-add">
                <label class="form-label-add">优先级</label>
                <input type="number" class="form-input-add" @bind="header.Priority" />
            </div>

            <!-- 备注 -->
            <div class="form-textarea-wrapper">
                <label class="form-label-add">备注</label>
                <textarea class="form-textarea-add" placeholder="" @bind="header.Remark"></textarea>
            </div>

            <!-- ===== 第3列（右侧）===== -->
            <!-- 业务类型* -->
            <div class="form-item-add">
                <label class="form-label-add"><span class="required-mark">*</span>业务类型</label>
                <CkTypeInput @bind-Value="header.BusinessType" SingleSelect="true" HideLabel="true" />
            </div>

            <!-- 外部系统标识 -->
            <div class="form-item-add">
                <label class="form-label-add">外部系统标识</label>
                <input type="text" class="form-input-add" placeholder="" @bind="header.ExternalSystemId" />
            </div>

            <!-- 外部系统单号 -->
            <div class="form-item-add">
                <label class="form-label-add">外部系统单号</label>
                <input type="text" class="form-input-add" placeholder="" @bind="header.ExternalSystemOrderNo" />
            </div>

            <!-- 来源单号 -->
            <div class="form-item-add">
                <label class="form-label-add">来源单号</label>
                <input type="text" class="form-input-add" placeholder="" @bind="header.SourceOrderNo" />
            </div>

            <!-- 生成ERP出库单据则 checkbox -->
            <div class="checkbox-wrapper">
                <input type="checkbox" id="chkGenerateErpOut" @bind="header.GenerateErpOutbound" />
                <label for="chkGenerateErpOut">生成ERP出库单据则</label>
            </div>
        </div>
    </div>

    <!-- 底部操作栏 -->
    <div class="action-bar">
        <button class="action-btn" @onclick="HandleDocInfo">单据资讯</button>
        <button class="action-btn" @onclick="HandleExcelImport">Excel导入</button>
        <button class="action-btn" @onclick="HandleSplit">拆分</button>
        <button class="action-btn" @onclick="HandleMore">更多...</button>
    </div>

    <!-- 明细区域 -->
    <div class="detail-area">
        <div class="detail-tabs">
            <div class="detail-tab-item @(activeDetailTab == "product" ? "active" : "")" @onclick="SwitchToProductTab">
                <svg class="detail-tab-icon" viewBox="0 0 16 16" fill="currentColor">
                    <path d="M2 3h5v5H2V3zm7 0h5v5H9V3zM2 9h5v5H2V9zm7 0h5v5H9V9z"/>
                </svg>
                <span>货品信息</span>
            </div>
            <div class="detail-tab-item @(activeDetailTab == "barcode" ? "active" : "")" @onclick="SwitchToBarcodeTab">
                <svg class="detail-tab-icon" viewBox="0 0 16 16" fill="currentColor">
                    <path d="M2 2h2v12H2V2zm3 0h1v12H5V2zm2 0h2v12H7V2zm3 0h1v12h-1V2zm2 0h2v12h-2V2z"/>
                </svg>
                <span>条码明细</span>
            </div>
        </div>

        <div class="detail-table-container">
            @if (activeDetailTab == "product")
            {
                <table class="data-table" style="width:100%;border-collapse:collapse;table-layout:fixed;">
                    <thead>
                        <tr style="position:sticky;top:0;z-index:1;">
                            <th style="width:36px;background:#fafafa;font-size:11px;text-align:center;border-bottom:1px solid #e8e8e8;padding:6px 4px;">
                                <svg viewBox="0 0 16 16" width="14" height="14" fill="#1890ff"><path d="M8 3v10M3 8h10" stroke="#1890ff" stroke-width="2" stroke-linecap="round"/></svg>
                            </th>
                            <th style="width:100px;background:#fafafa;font-size:11px;text-align:center;border-bottom:1px solid #e8e8e8;padding:6px 4px;">货品代号</th>
                            <th style="width:120px;background:#fafafa;font-size:11px;text-align:center;border-bottom:1px solid #e8e8e8;padding:6px 4px;">货品名称</th>
                            <th style="width:80px;background:#fafafa;font-size:11px;text-align:center;border-bottom:1px solid #e8e8e8;padding:6px 4px;">仓库代号</th>
                            <th style="width:80px;background:#fafafa;font-size:11px;text-align:center;border-bottom:1px solid #e8e8e8;padding:6px 4px;">单位名称</th>
                            <th style="width:70px;background:#fafafa;font-size:11px;text-align:center;border-bottom:1px solid #e8e8e8;padding:6px 4px;">数量</th>
                            <th style="width:90px;background:#fafafa;font-size:11px;text-align:center;border-bottom:1px solid #e8e8e8;padding:6px 4px;">批号</th>
                            <th style="width:70px;background:#fafafa;font-size:11px;text-align:center;border-bottom:1px solid #e8e8e8;padding:6px 4px;">已拣数量</th>
                            <th style="width:110px;background:#fafafa;font-size:11px;text-align:center;border-bottom:1px solid #e8e8e8;padding:6px 4px;">外部系统单号</th>
                            <th style="width:100px;background:#fafafa;font-size:11px;text-align:center;border-bottom:1px solid #e8e8e8;padding:6px 4px;">ERP申请单号</th>
                            <th style="width:100px;background:#fafafa;font-size:11px;text-align:center;border-bottom:1px solid #e8e8e8;padding:6px 4px;">业务单号</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (productItems.Count == 0)
                        {
                            <tr>
                                <td colspan="11" style="text-align:center;padding:40px 0;">
                                    <div style="display:inline-flex;flex-direction:column;align-items:center;gap:8px;">
                                        <svg viewBox="0 0 64 64" width="80" height="80" fill="none">
                                            <rect x="8" y="8" width="48" height="48" rx="8" fill="#F5F5F5" stroke="#E0E0E0" stroke-width="1"/>
                                            <path d="M24 28h16M24 36h12" stroke="#D9D9D9" stroke-width="2" stroke-linecap="round"/>
                                        </svg>
                                        <p style="font-size:12px;color:#999999;margin:0;">暂无数据</p>
                                    </div>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in productItems)
                            {
                                <tr style="border-bottom:1px solid #f0f0f0;" onmouseover="this.style.background='#fafafa'" onmouseout="this.style.background='#ffffff'">
                                    <td style="text-align:center;padding:3px 4px;font-size:11px;">@item.ItemNo</td>
                                    <td style="padding:2px 3px;">
                                        <div class="td-input-group">
                                            <ProductCodeAutocomplete @bind-Value="item.PrdNo" ProductSelected="@((p) => OnProductSelected(item, p))" />
                                        </div>
                                    </td>
                                    <td style="padding:2px 3px;">
                                        <input type="text" class="td-input" @bind="item.PrdName" />
                                    </td>
                                    <td style="padding:2px 3px;">
                                        <div class="td-input-group">
                                            <input type="text" class="td-input" placeholder="" @bind="item.WhCode" />
                                            <span class="td-search-icon" style="cursor:pointer;" @onclick="() => OpenRowWarehouseSelector(item)">
                                                <svg viewBox="0 0 16 16" width="12" height="12" fill="#999999"><circle cx="7" cy="7" r="5"/><line x1="11" y1="11" x2="15" y2="15" stroke="#999999" stroke-width="1.5"/></svg>
                                            </span>
                                        </div>
                                    </td>
                                    <td style="padding:2px 3px;">
                                        <input type="text" class="td-input" @bind="item.UnitName" readonly />
                                    </td>
                                    <td style="padding:2px 3px;">
                                        <input type="number" class="td-input td-num-input" step="0.01" min="0" @bind="item.Qty" @bind:event="oninput" />
                                    </td>
                                    <td style="padding:2px 3px;">
                                        <input type="text" class="td-input" placeholder="" @bind="item.BatchNo" />
                                    </td>
                                    <td style="padding:2px 3px;">
                                        <input type="number" class="td-input td-num-input" step="0.01" min="0" @bind="item.PickedQty" readonly />
                                    </td>
                                    <td style="padding:2px 3px;">
                                        <input type="text" class="td-input" @bind="item.ExtSysOrderNo" />
                                    </td>
                                    <td style="padding:2px 3px;">
                                        <input type="text" class="td-input" @bind="item.ErpApplyNo" />
                                    </td>
                                    <td style="padding:2px 3px;">
                                        <input type="text" class="td-input" @bind="item.BizOrderNo" />
                                    </td>
                                </tr>
                            }
                        }
                        <tr>
                            <td colspan="11" class="add-row-btn-cell" style="background:#fff;cursor:pointer;">
                                <button class="add-row-btn" @onclick="AddProductRow">
                                    <svg viewBox="0 0 16 16" width="12" height="12" fill="#1890ff"><path d="M8 3v10M3 8h10" stroke="#1890ff" stroke-width="2" stroke-linecap="round"/></svg>
                                    新增行
                                </button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            }
            else
            {
                <table class="data-table" style="width:100%;border-collapse:collapse;table-layout:fixed;">
                    <thead>
                        <tr style="position:sticky;top:0;z-index:1;">
                            <th style="width:80px;background:#fafafa;font-size:11px;text-align:center;border-bottom:1px solid #e8e8e8;padding:6px 4px;">条码类型</th>
                            <th style="width:140px;background:#fafafa;font-size:11px;text-align:center;border-bottom:1px solid #e8e8e8;padding:6px 4px;">条码</th>
                            <th style="width:70px;background:#fafafa;font-size:11px;text-align:center;border-bottom:1px solid #e8e8e8;padding:6px 4px;">扫描数量</th>
                            <th style="width:70px;background:#fafafa;font-size:11px;text-align:center;border-bottom:1px solid #e8e8e8;padding:6px 4px;">实品数量</th>
                            <th style="width:120px;background:#fafafa;font-size:11px;text-align:center;border-bottom:1px solid #e8e8e8;padding:6px 4px;">容器条码</th>
                            <th style="width:70px;background:#fafafa;font-size:11px;text-align:center;border-bottom:1px solid #e8e8e8;padding:6px 4px;">原箱数量</th>
                            <th style="width:110px;background:#fafafa;font-size:11px;text-align:center;border-bottom:1px solid #e8e8e8;padding:6px 4px;">箱码条码标签</th>
                            <th style="width:110px;background:#fafafa;font-size:11px;text-align:center;border-bottom:1px solid #e8e8e8;padding:6px 4px;">容器部件标签</th>
                            <th style="width:60px;background:#fafafa;font-size:11px;text-align:center;border-bottom:1px solid #e8e8e8;padding:6px 4px;">操作</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (barcodeItems.Count == 0)
                        {
                            <tr>
                                <td colspan="9" style="text-align:center;padding:40px 0;">
                                    <div style="display:inline-flex;flex-direction:column;align-items:center;gap:8px;">
                                        <svg viewBox="0 0 64 64" width="80" height="80" fill="none">
                                            <rect x="8" y="8" width="48" height="48" rx="8" fill="#F5F5F5" stroke="#E0E0E0" stroke-width="1"/>
                                            <path d="M24 28h16M24 36h12" stroke="#D9D9D9" stroke-width="2" stroke-linecap="round"/>
                                        </svg>
                                        <p style="font-size:12px;color:#999999;margin:0;">暂无数据</p>
                                    </div>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in barcodeItems)
                            {
                                <tr style="border-bottom:1px solid #f0f0f0;" onmouseover="this.style.background='#fafafa'" onmouseout="this.style.background='#ffffff'">
                                    <td style="padding:2px 3px;"><input type="text" class="td-input" @bind="item.BarcodeType" /></td>
                                    <td style="padding:2px 3px;"><input type="text" class="td-input" @bind="item.Barcode" /></td>
                                    <td style="padding:2px 3px;"><input type="number" class="td-input td-num-input" step="0.01" min="0" @bind="item.ScanQty" @bind:event="oninput" /></td>
                                    <td style="padding:2px 3px;"><input type="number" class="td-input td-num-input" step="0.01" min="0" @bind="item.ActualQty" @bind:event="oninput" /></td>
                                    <td style="padding:2px 3px;"><input type="text" class="td-input" @bind="item.ContainerBarcode" /></td>
                                    <td style="padding:2px 3px;"><input type="number" class="td-input td-num-input" step="0.01" min="0" @bind="item.BoxQty" @bind:event="oninput" /></td>
                                    <td style="padding:2px 3px;"><input type="text" class="td-input" @bind="item.BoxLabelTag" /></td>
                                    <td style="padding:2px 3px;"><input type="text" class="td-input" @bind="item.ContainerPartLabel" /></td>
                                    <td style="text-align:center;padding:3px 4px;font-size:11px;">
                                        <button class="row-action-btn" @onclick="() => RemoveBarcodeRow(item.ItemNo)">删除</button>
                                    </td>
                                </tr>
                            }
                        }
                        <tr>
                            <td colspan="9" class="add-row-btn-cell" style="background:#fff;cursor:pointer;">
                                <button class="add-row-btn" @onclick="AddBarcodeRow">
                                    <svg viewBox="0 0 16 16" width="12" height="12" fill="#1890ff"><path d="M8 3v10M3 8h10" stroke="#1890ff" stroke-width="2" stroke-linecap="round"/></svg>
                                    新增行
                                </button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>

<!-- 客户选择器对话框 -->
@if (showVendorDialog)
{
    <div class="vendor-selector-overlay" @onclick="CloseVendorSelector">
        <div class="vendor-selector-dialog" @onclick:stopPropagation>
            <div class="vendor-selector-header">
                <span>客户资料(CUST)</span>
                <button class="vendor-close-btn" @onclick="CloseVendorSelector">&times;</button>
            </div>
            <div class="vendor-selector-body">
                <div class="vendor-left-panel">
                    <div class="vendor-filter-title">过滤</div>
                    <input type="text" class="vendor-search-input" placeholder="输入关键字查询" @bind="vendorSearchKeyword" @bind:event="oninput" @onkeyup="@((KeyboardEventArgs e) => { if(e.Key == "Enter") _ = SearchVendor(); })" />
                    <button class="vendor-query-btn" @onclick="@(() => _ = SearchVendor())">查询</button>
                </div>
                <div class="vendor-right-panel">
                    <table class="vendor-data-table">
                        <thead>
                            <tr>
                                <th style="width:60px">操作</th>
                                <th style="width:100px">客户代号</th>
                                <th>客户名称</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (vendorData.Count == 0)
                            {
                                <tr><td colspan="3" style="text-align:center;padding:30px;color:#999;">暂无数据</td></tr>
                            }
                            else
                            {
                                @for (int i = 0; i < vendorData.Count; i++)
                                {
                                    var item = vendorData[i];
                                    <tr>
                                        <td><button class="vendor-select-btn" @onclick="() => SelectVendor(item)">选择</button></td>
                                        <td>@item.CUS_NO</td>
                                        <td>@item.CUS_NAME</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                    <div class="vendor-pagination">
                        <span class="vendor-total-info">共 @vendorTotalCount 笔记录</span>
                        <div class="vendor-page-controls">
                            <button class="vendor-page-btn" disabled="@(vendorPageIndex <= 1)" @onclick="async () => await GoToVendorPage(vendorPageIndex - 1)">&lt;</button>
                            <input type="number" class="vendor-page-input" value="@vendorPageIndex" min="1" max="@VendorTotalPages"
                                   @onchange="async (ChangeEventArgs e) => { if(int.TryParse(e.Value?.ToString(), out var p)) await GoToVendorPage(p); }" />
                            <span>/ @VendorTotalPages</span>
                            <button class="vendor-page-btn" disabled="@(vendorPageIndex >= VendorTotalPages)" @onclick="async () => await GoToVendorPage(vendorPageIndex + 1)">&gt;</button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="vendor-selector-footer">
                <button class="vendor-footer-cancel" @onclick="CloseVendorSelector">取消</button>
            </div>
        </div>
    </div>
}

