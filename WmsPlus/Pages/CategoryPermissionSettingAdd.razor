    // ===== 加载编辑数据 =====
    private async Task LoadEditData()
    {
        if (string.IsNullOrEmpty(EditRoleNo)) return;
        try
        {
            var url = $"{ApiConfig.BaseUrl}/api/CategoryPermissionSetting/{Uri.EscapeDataString(EditRoleNo)}";
            var jsonOptions = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var request = AuthHttpClient.CreateRequest(HttpMethod.Get, url, TokenProvider.Token);
            var responseMsg = await Http.SendAsync(request);
            var result = await responseMsg.Content.ReadFromJsonAsync<CpsApiResponse<CpsDetailDto>>(jsonOptions);
            if (result != null && result.Success && result.Data != null)
            {
                var info = result.Data.RoleInfo;
                roleForm.RoleNo = info.RoleNo;
                roleForm.Name = info.Name;
                roleForm.Dep = info.Dep;
                roleForm.CompNo = info.CompNo;
                roleForm.TypeId = info.TypeId;
                roleForm.Rem = info.Rem;
                roleForm.DeproNo = ""; // 从权限行中取
                publicFlag = info.PublicId == "T";
                roleForm.PublicId = info.PublicId;
                subFlag = info.SubId == "Y";
                roleForm.SubId = info.SubId;

                // 回填权限数据
                foreach (var p in result.Data.Permissions)
                {
                    var gRow = GeneralPermRows.FirstOrDefault(r => r.Pgm == p.Pgm);
                    if (gRow != null)
                    {
                        gRow.Qry = p.Qry ?? "";
                        gRow.Upd = p.Upd ?? "";
                        gRow.Del = p.Del ?? "";
                        gRow.Prn = p.Prn ?? "";
                        gRow.LockDoc = ""; // 锁单字段暂无对应
                        gRow.Ins = p.Ins ?? "";
                        gRow.Property = p.Property ?? "";
                        gRow.Fld = p.Fld ?? "";
                        gRow.Ept = p.Ept ?? "";
                        gRow.Qty = p.Qty ?? "";
                        gRow.DeproNo = p.DeproNo ?? "";
                    }
                    var aRow = AdvancedPermRows.FirstOrDefault(r => r.Pgm == p.Pgm);
                    if (aRow != null)
                    {
                        aRow.AllowId = (p.AllowId ?? "") == "Y";
                        aRow.DeproNo = p.DeproNo ?? "";
                        aRow.QueryRangeDeproNo = p.DeproNo ?? "";
                    }
                }
            }
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "加载角色详情失败");
        }
    }

