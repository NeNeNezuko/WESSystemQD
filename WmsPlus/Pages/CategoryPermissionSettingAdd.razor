    // ===== 将树结构扁平化为线性列表 =====
    private void RebuildFlatTree()
    {
        flatTreeCache = new List<FlatTreeItem>();
        foreach (var node in treeNodes)
        {
            FlattenNode(node, 0);
        }
    }

    private void FlattenNode(TreeNodeData node, int depth)
    {
        var hasChildren = node.Children != null && node.Children.Count > 0;
        flatTreeCache.Add(new FlatTreeItem
        {
            Key = node.Key,
            Title = node.Title,
            Depth = depth,
            HasChildren = hasChildren,
            IsExpanded = node.IsExpanded,
            SourceNode = node
        });
        if (node.IsExpanded && hasChildren)
        {
            foreach (var child in node.Children)
            {
                FlattenNode(child, depth + 1);
            }
        }
    }

