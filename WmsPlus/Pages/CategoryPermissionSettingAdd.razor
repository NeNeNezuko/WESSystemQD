    // ===== 批量操作 =====
    private void SetAllPermissions()
    {
        foreach (var r in GeneralPermRows) { r.Qry = "Y"; r.Upd = "Y"; r.Del = "Y"; r.Prn = "Y"; r.LockDoc = ""; r.Ins = "Y"; r.Property = "Y"; r.Fld = "Y"; r.Ept = "Y"; r.Qty = "W"; }
        foreach (var r in AdvancedPermRows) { r.AllowId = true; }
        foreach (var r in PdaPermRows) { r.Qry = "Y"; r.Upd = "Y"; r.Del = "Y"; r.Prn = "Y"; r.LockDoc = ""; r.Ins = "Y"; r.Property = "Y"; r.Fld = "Y"; r.Ept = "Y"; r.Qty = "W"; }
        StateHasChanged();
    }
    private void ClearAllPermissions()
    {
        foreach (var r in GeneralPermRows) { r.Qry = ""; r.Upd = ""; r.Del = ""; r.Prn = ""; r.LockDoc = ""; r.Ins = ""; r.Property = ""; r.Fld = ""; r.Ept = ""; r.Qty = ""; }
        foreach (var r in AdvancedPermRows) { r.AllowId = false; }
        foreach (var r in PdaPermRows) { r.Qry = ""; r.Upd = ""; r.Del = ""; r.Prn = ""; r.LockDoc = ""; r.Ins = ""; r.Property = ""; r.Fld = ""; r.Ept = ""; r.Qty = ""; }
        StateHasChanged();
    }

    // ===== 保存 =====
    private async Task HandleSave()
    {
        if (string.IsNullOrWhiteSpace(roleForm.RoleNo))
        { await JS.InvokeVoidAsync("alert", "请输入类别代号"); return; }
        if (string.IsNullOrWhiteSpace(roleForm.Name))
        { await JS.InvokeVoidAsync("alert", "请输入类别名称"); return; }

        try
        {
            var permissions = GeneralPermRows.Select(r => new CpsPermRowDto
            {
                Pgm = r.Pgm,
                TypeId = "",
                CompNo = roleForm.CompNo,
                DeproNo = r.DeproNo,
                Qry = r.Qry ?? "",
                Ins = r.Ins ?? "",
                Upd = r.Upd ?? "",
                Del = r.Del ?? "",
                Prn = r.Prn ?? "",
                Qty = r.Qty ?? "",
                Fld = r.Fld ?? "",
                Property = r.Property ?? "",
                AllowId = "",
                Ept = r.Ept ?? ""
            }).ToList();

            var request = new CpsCreateRequest
            {
                RoleInfo = new CpsRoleDto
                {
                    RoleNo = roleForm.RoleNo,
                    Name = roleForm.Name,
                    Dep = roleForm.Dep,
                    DeproNo = roleForm.DeproNo,
                    CompNo = roleForm.CompNo,
                    TypeId = roleForm.TypeId,
                    PublicId = roleForm.PublicId,
                    SubId = roleForm.SubId,
                    Rem = roleForm.Rem
                },
                Permissions = permissions,
                Usr = "ADMIN"
            };

            var url = IsEditMode
                ? $"{ApiConfig.BaseUrl}/api/CategoryPermissionSetting/{Uri.EscapeDataString(roleForm.RoleNo)}"
                : $"{ApiConfig.BaseUrl}/api/CategoryPermissionSetting";

            var method = IsEditMode ? HttpMethod.Put : HttpMethod.Post;
            var jsonOptions = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var httpRequest = AuthHttpClient.CreateRequest(method, url, TokenProvider.Token);
            httpRequest.Content = new StringContent(
                System.Text.Json.JsonSerializer.Serialize(request, new System.Text.Json.JsonSerializerOptions { WriteIndented = false }),
                System.Text.Encoding.UTF8);
            httpRequest.Content.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue("application/json");
            var responseMsg = await Http.SendAsync(httpRequest);
            var result = await responseMsg.Content.ReadFromJsonAsync<CpsApiResponse<string>>(jsonOptions);

            if (result != null && result.Success)
            {
                await JS.InvokeVoidAsync("alert", IsEditMode ? "更新成功！" : "新增成功！");
            }
            else
            {
                await JS.InvokeVoidAsync("alert", $"操作失败: {result?.Message ?? "未知错误"}");
            }
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "保存失败");
            await JS.InvokeVoidAsync("alert", $"保存失败: {ex.Message}");
        }
    }

    private async Task HandleSaveAndNew()
    {
        await HandleSave();
        roleForm = new RoleFormData();
        publicFlag = false;
        subFlag = false;
        ClearAllPermissions();
        StateHasChanged();
    }

