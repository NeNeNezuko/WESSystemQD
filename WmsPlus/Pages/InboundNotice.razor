    private async Task SearchBizType()
    {
        try
        {
            var url = $"http://localhost:5102/api/warehouse/rktypesearch?keyword={Uri.EscapeDataString(bizTypeSearchKeyword ?? "")}&pageIndex={bizTypePageIndex}&pageSize={bizTypePageSize}";
            Console.WriteLine($"[BizType] Request URL: {url}");

            var response = await Http.GetAsync(url);
            if (response.IsSuccessStatusCode)
            {
                var json = await response.Content.ReadAsStringAsync();
                var result = System.Text.Json.JsonSerializer.Deserialize<BizTypeSearchResult>(json, new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                if (result != null)
                {
                    bizTypeData = result.Items ?? new List<BizTypeItem>();
                    bizTypeTotalCount = result.TotalCount;
                    Console.WriteLine($"[BizType] Items count: {bizTypeData.Count}, Total: {bizTypeTotalCount}");
                }
            }
            else
            {
                var errBody = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"[BizType] API error: {response.StatusCode} - {errBody}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[BizType] Exception: {ex.Message}");
        }
        StateHasChanged();
    }

    private void ToggleBizTypeSelect(BizTypeItem item)
    {
        var existing = selectedBizTypes.FirstOrDefault(s => s.tYPE_ID == item.tYPE_ID);
        if (existing != null)
        {
            selectedBizTypes.Remove(existing);
        }
        else
        {
            selectedBizTypes.Add(new BizTypeItem { tYPE_ID = item.tYPE_ID, nAME = item.nAME });
        }
        StateHasChanged();
    }

    private void SelectAllBizType(ChangeEventArgs e)
    {
        bool selectAll = (bool)e.Value!;
        if (selectAll)
        {
            foreach (var item in bizTypeData)
            {
                if (!selectedBizTypes.Any(s => s.tYPE_ID == item.tYPE_ID))
                {
                    selectedBizTypes.Add(new BizTypeItem { tYPE_ID = item.tYPE_ID, nAME = item.nAME });
                }
            }
        }
        else
        {
            foreach (var item in bizTypeData)
            {
                selectedBizTypes.RemoveAll(s => s.tYPE_ID == item.tYPE_ID);
            }
        }
        StateHasChanged();
    }

    private void RemoveBizTypeTag(string rkType)
    {
        selectedBizTypes.RemoveAll(s => s.tYPE_ID == rkType);
        query.BusinessType = string.Join(",", selectedBizTypes.Select(s => s.tYPE_ID));
        StateHasChanged();
    }

    private void ClearBizTypeSelection()
    {
        selectedBizTypes.Clear();
        StateHasChanged();
    }

    private void ConfirmBizTypeSelection()
    {
        query.BusinessType = string.Join(",", selectedBizTypes.Select(s => s.tYPE_ID));
        showBizTypeDialog = false;
        StateHasChanged();
    }

    private async Task GoToBizTypePage(int page)
    {
        if (page < 1 || page > BizTypeTotalPages) return;
        bizTypePageIndex = page;
        await SearchBizType();
    }
