    private async Task HandleSearch() { await LoadData(); }
    private void HandleAddNew() { }

    private async Task HandleExport()
    {
        if (dataSource.Count == 0) { await JS.InvokeVoidAsync("alert", "暂无数据可导出"); return; }
        exportFileName = $"入库通知单_{DateTime.Now:yyyyMMddHHmmss}";
        showExportDialog = true;
        StateHasChanged();
    }

    private void CancelExport()
    {
        showExportDialog = false;
        StateHasChanged();
    }

    private async Task ConfirmExport()
    {
        showExportDialog = false;
        try { await ExportToExcel(); } catch (Exception ex) { await JS.InvokeVoidAsync("alert", $"导出失败: {ex.Message}"); }
    }

    private async Task LoadData()
    {
        try
        {
            const string ApiBaseUrl = "http://localhost:5102";
            var url = $"{ApiBaseUrl}/api/InboundNotice/search?dateFrom={query.DateFrom:yyyy-MM-dd}&dateTo={query.DateTo:yyyy-MM-dd}";
            if (!string.IsNullOrWhiteSpace(query.DocumentNumber))
                url += $"&documentNumber={Uri.EscapeDataString(query.DocumentNumber)}";
            if (!string.IsNullOrWhiteSpace(query.WarehouseCode))
                url += $"&warehouseCode={Uri.EscapeDataString(query.WarehouseCode)}";
            if (!string.IsNullOrWhiteSpace(query.VendorCode))
                url += $"&vendorCode={Uri.EscapeDataString(query.VendorCode)}";
            if (!string.IsNullOrWhiteSpace(query.CloseStatus) && query.CloseStatus != "全部")
                url += $"&closeStatus={Uri.EscapeDataString(query.CloseStatus)}";
            if (!string.IsNullOrWhiteSpace(query.BusinessType))
                url += $"&businessType={Uri.EscapeDataString(query.BusinessType)}";

            var jsonOptions = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var request = AuthHttpClient.CreateRequest(HttpMethod.Get, url, TokenProvider.Token);
            var responseMsg = await Http.SendAsync(request);
            var response = await responseMsg.Content.ReadFromJsonAsync<ApiResponse<List<InboundNoticeModel>>>(jsonOptions);
            if (response != null && response.Success && response.Data != null)
            {
                dataSource = response.Data;
            }
            else
            {
                dataSource = new List<InboundNoticeModel>();
            }
        }
        catch (Exception ex)
        {
            _logger?.LogError(ex, "加载入库通知单数据失败");
            dataSource = new List<InboundNoticeModel>();
        }
        StateHasChanged();
    }

    private async Task ExportToExcel()
    {
        var visibleCols = columnConfigs.Where(c => c.Visible).ToList();
        var headers = visibleCols.Select(c => c.DisplayName).ToArray();
        var rows = new List<object[]>();
        rows.Add(headers);
        foreach (var item in dataSource)
        {
            var row = new object[visibleCols.Count];
            for (int i = 0; i < visibleCols.Count; i++)
                row[i] = GetCellValue(item, visibleCols[i].FieldKey);
            rows.Add(row);
        }
        var fileName = string.IsNullOrWhiteSpace(exportFileName) ? $"入库通知单_{DateTime.Now:yyyyMMddHHmmss}" : exportFileName;
        if (!fileName.EndsWith(".xlsx", StringComparison.OrdinalIgnoreCase)) fileName += ".xlsx";
        await JS.InvokeVoidAsync("exportToExcel", rows, fileName);
    }

    // ===== 栏位配置 =====
    private class ColumnConfig
    {
        public string FieldKey { get; set; } = "";
        public string OriginalName { get; set; } = "";
        public string DisplayName { get; set; } = "";
        public bool Visible { get; set; } = true;
        public int Width { get; set; } = 0;
        public int DefaultWidth { get; set; } = 0;
        public bool Sortable { get; set; } = false;
    }

    private const string COLUMN_SETTINGS_KEY = "wms_column_settings_inbound_notice";

    private void InitDefaultColumnConfigs()
    {
        defaultColumnConfigs = new List<ColumnConfig>
        {
            new() { FieldKey = "ItemNo", OriginalName = "项次", DisplayName = "项次", Visible = true, Width = 45, DefaultWidth = 45 },
            new() { FieldKey = "DocumentDate", OriginalName = "单据日期", DisplayName = "单据日期", Visible = true, Width = 85, DefaultWidth = 85, Sortable = true },
            new() { FieldKey = "DocumentNumber", OriginalName = "单据号码", DisplayName = "单据号码", Visible = true, Width = 100, DefaultWidth = 100, Sortable = true },
            new() { FieldKey = "WarehouseCode", OriginalName = "仓库代号", DisplayName = "仓库代号", Visible = true, Width = 70, DefaultWidth = 70, Sortable = true },
            new() { FieldKey = "WarehouseName", OriginalName = "仓库名称", DisplayName = "仓库名称", Visible = true, Width = 90, DefaultWidth = 90 },
            new() { FieldKey = "VendorCode", OriginalName = "厂商代号", DisplayName = "厂商代号", Visible = true, Width = 70, DefaultWidth = 70, Sortable = true },
            new() { FieldKey = "VendorName", OriginalName = "厂商名称", DisplayName = "厂商名称", Visible = true, Width = 90, DefaultWidth = 90 },
            new() { FieldKey = "ApplyOrderNumber", OriginalName = "申请单号(笔)", DisplayName = "申请单号(笔)", Visible = true, Width = 95, DefaultWidth = 95 },
            new() { FieldKey = "OrderNumber", OriginalName = "单据号码", DisplayName = "单据号码", Visible = true, Width = 95, DefaultWidth = 95 },
            new() { FieldKey = "IsClosed", OriginalName = "结案否", DisplayName = "结案否", Visible = true, Width = 55, DefaultWidth = 55, Sortable = true },
            new() { FieldKey = "PrdNo", OriginalName = "料号/品号", DisplayName = "料号/品号", Visible = false, Width = 100, DefaultWidth = 100 },
            new() { FieldKey = "PrdName", OriginalName = "品名", DisplayName = "品名", Visible = false, Width = 120, DefaultWidth = 120 },
            new() { FieldKey = "PrdSpec", OriginalName = "规格型号", DisplayName = "规格型号", Visible = false, Width = 100, DefaultWidth = 100 },
            new() { FieldKey = "Qty", OriginalName = "数量", DisplayName = "数量", Visible = false, Width = 60, DefaultWidth = 60 },
            new() { FieldKey = "Unit", OriginalName = "单位", DisplayName = "单位", Visible = false, Width = 50, DefaultWidth = 50 }
        };
        columnConfigs = defaultColumnConfigs.Select(c => new ColumnConfig
        {
            FieldKey = c.FieldKey,
            OriginalName = c.OriginalName,
            DisplayName = c.DisplayName,
            Visible = c.Visible,
            Width = c.Width,
            DefaultWidth = c.DefaultWidth,
            Sortable = c.Sortable
        }).ToList();
    }

    private async Task LoadColumnSettings()
    {
        try
        {
            var json = await JS.InvokeAsync<string>("localStorage.getItem", COLUMN_SETTINGS_KEY);
            if (!string.IsNullOrWhiteSpace(json))
            {
                var options = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
                var saved = System.Text.Json.JsonSerializer.Deserialize<List<ColumnConfig>>(json, options);
                if (saved != null && saved.Count > 0)
                {
                    foreach (var col in columnConfigs)
                    {
                        var savedCol = saved.FirstOrDefault(s => s.FieldKey == col.FieldKey);
                        if (savedCol != null)
                        {
                            col.Visible = savedCol.Visible;
                            col.DisplayName = !string.IsNullOrWhiteSpace(savedCol.DisplayName) ? savedCol.DisplayName : col.OriginalName;
                            col.Width = savedCol.Width >= 0 ? savedCol.Width : col.DefaultWidth;
                        }
                    }
                }
            }
        }
        catch { }
    }

    private async Task SaveColumnSettings()
    {
        try
        {
            var json = System.Text.Json.JsonSerializer.Serialize(columnConfigs);
            await JS.InvokeVoidAsync("localStorage.setItem", COLUMN_SETTINGS_KEY, json);
        }
        catch { }
    }

    private void OpenColumnSettings()
    {
