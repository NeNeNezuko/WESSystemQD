@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@inject HttpClient Http
@inject ILogger<InboundNotice> _logger
@inject TokenProvider TokenProvider

<link rel="stylesheet" href="css/inbound-notice.css" />
<style>
.wh-col-action { width: 70px !important; min-width: 70px !important; }
</style>

<div class="inbound-notice-page" style="display:flex;flex-direction:column;flex:1 1 0%;overflow:hidden;">
    <!-- 顶部标题栏 -->
    <div class="page-header">
        <div class="header-left">
            <button class="favorite-btn @(isFavorited ? "favorited" : "")" @onclick="ToggleFavorite" title="收藏">
                <svg viewBox="0 0 24 24" width="24" height="24">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
                          fill="@((isFavorited ? "#FFD700" : "none"))"
                          stroke="@((isFavorited ? "#FFD700" : "#666666"))"
                          stroke-width="2"/>
                </svg>
            </button>
            <span class="page-title">入库通知单/查询</span>
        </div>
        <div class="header-right">
            <button class="collapse-btn-fixed @(isCollapsed ? "collapsed" : "")" @onclick="ToggleCollapse" title="@(isCollapsed ? "展开查询" : "收起查询")">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="#666666">
                    <rect x="3" y="6" width="18" height="2" rx="1"/>
                    <rect x="3" y="11" width="18" height="2" rx="1"/>
                    <rect x="3" y="16" width="18" height="2" rx="1"/>
                </svg>
            </button>
        </div>
    </div>

    <!-- 收藏成功提示 -->
    @if (showFavoriteSuccess)
    {
        <div class="favorite-success-toast">
            <div class="toast-content">
                <svg viewBox="0 0 16 16" width="16" height="16" fill="#52C41A">
                    <circle cx="8" cy="8" r="8"/>
                    <path d="M5 8l2 2 4-4" stroke="white" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>收藏成功</span>
            </div>
        </div>
    }

    <!-- 主内容区域 -->
    <div class="page-content">
        <!-- 左侧查询区域 -->
        <div class="query-panel @(isCollapsed ? "collapsed" : "")">
            <div class="query-header">
                <span class="query-title">查询</span>
                <button class="query-settings-btn" title="设置" @onclick="ToggleSettingsMenu">
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="#999999" stroke-width="2">
                        <circle cx="12" cy="12" r="3"/>
                        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/>
                    </svg>
                </button>
                @if (showSettingsMenu)
                {
                    <div class="settings-dropdown" @onclick:stopPropagation>
                        <div class="settings-dropdown-item" @onclick="BatchAddCondition">批次添加条件</div>
                        <div class="settings-dropdown-item" @onclick="AddSingleCondition">添加单一条件</div>
                        <div class="settings-dropdown-item" @onclick="CustomCondition">自定义条件</div>
                        <div class="settings-dropdown-item" @onclick="RemoveCondition">移除条件</div>
                        <div class="settings-dropdown-item" @onclick="SaveConditionValues">保存条件值</div>
                    </div>
                }
            </div>

            <div class="query-form">
                <!-- 单据日期 - 双月历范围选择器 -->
                <div class="form-item">
                    <label class="form-label">单据日期</label>
                    <div class="date-picker-trigger" @onclick="ToggleDatePicker" @ref="datePickerTriggerRef">
                        <span class="date-display-text">@DateDisplayText</span>
                        <svg class="date-picker-icon" viewBox="0 0 16 16" width="12" height="12" fill="#999999">
                            <rect x="2" y="3" width="12" height="11" rx="2" stroke="#999999" stroke-width="1.2" fill="none"/>
                            <line x1="2" y1="6" x2="14" y2="6" stroke="#999999" stroke-width="1.2"/>
                            <line x1="5" y1="1" x2="5" y2="4" stroke="#999999" stroke-width="1.2" stroke-linecap="round"/>
                            <line x1="11" y1="1" x2="11" y2="4" stroke="#999999" stroke-width="1.2" stroke-linecap="round"/>
                        </svg>
                    </div><!-- date-picker-trigger -->

                    <!-- 日历弹出层 -->
                    @if (ShowCalendar)
                    {
                        <div class="datepicker-dropdown" @onclick:stopPropagation @ref="datePickerDropdownRef">
                            <div class="datepicker-popup-dual">
                                <div class="dp-header-dual">
                                    <button class="dp-nav" @onclick="GoPrevYear" title="上一年">&#171;</button>
                                    <button class="dp-nav" @onclick="GoPrevMonth" title="上一月">&#8249;</button>
                                    <span class="dp-title-dual">@ViewYear 年 @ViewMonth 月</span>
                                    <span class="dp-title-sep"></span>
                                    @{
                                        var nextM = ViewMonth + 1;
                                        var nextY = ViewYear;
                                        if (nextM > 12) { nextM = 1; nextY++; }
                                    }
                                    <span class="dp-title-dual">@nextY 年 @nextM 月</span>
                                    <button class="dp-nav" @onclick="GoNextMonth" title="下一月">&#8250;</button>
                                    <button class="dp-nav" @onclick="GoNextYear" title="下一年">&#187;</button>
                                </div>
                                <div class="dp-months-row">
                                    <div class="dp-month-block">
                                        <div class="dp-week-row">
                                            <span class="dp-week">一</span><span class="dp-week">二</span><span class="dp-week">三</span><span class="dp-week">四</span><span class="dp-week">五</span><span class="dp-week">六</span><span class="dp-week">日</span>
                                        </div>
                                        <div class="dp-grid">
                                            @for (int idx = 0; idx < LeftCalendarCells.Count; idx++)
                                            {
                                                var cell = LeftCalendarCells[idx];
                                                <button class="dp-cell @(cell.IsSelected ? "dp-sel" : "") @(cell.IsInRange ? "dp-range" : "") @(cell.IsToday && !cell.IsSelected ? "dp-today" : "") @(!cell.IsCurrentMonth ? "dp-gray" : "")"
                                                        @onclick="@(() => PickDate(cell.Year, cell.Month, cell.Day))">
                                                    @cell.Day
                                                </button>
                                            }
                                        </div>
                                    </div>
                                    <div class="dp-month-block">
                                        <div class="dp-week-row">
                                            <span class="dp-week">一</span><span class="dp-week">二</span><span class="dp-week">三</span><span class="dp-week">四</span><span class="dp-week">五</span><span class="dp-week">六</span><span class="dp-week">日</span>
                                        </div>
                                        <div class="dp-grid">
                                            @for (int idx = 0; idx < RightCalendarCells.Count; idx++)
                                            {
                                                var cell = RightCalendarCells[idx];
                                                <button class="dp-cell @(cell.IsSelected ? "dp-sel" : "") @(cell.IsInRange ? "dp-range" : "") @(cell.IsToday && !cell.IsSelected ? "dp-today" : "") @(!cell.IsCurrentMonth ? "dp-gray" : "")"
                                                        @onclick="@(() => PickDate(cell.Year, cell.Month, cell.Day))">
                                                    @cell.Day
                                                </button>
                                            }
                                        </div>
                                    </div>
                                </div>
                                <div class="dp-shortcuts-row">
                                    <button class="dp-qbtn" @onclick="QYesterday">昨天</button>
                                    <button class="dp-qbtn" @onclick="QLastWeek">上周</button>
                                    <button class="dp-qbtn" @onclick="QLastMonth">上月</button>
                                    <button class="dp-qbtn" @onclick="QLastYear">上年</button>
                                </div>
                                <div class="dp-shortcuts-row">
                                    <button class="dp-qbtn dp-qbtn-primary" @onclick="QToday">今日</button>
                                    <button class="dp-qbtn" @onclick="QThisWeek">本周</button>
                                    <button class="dp-qbtn" @onclick="QThisMonth">本月</button>
                                    <button class="dp-qbtn" @onclick="QThisQuarter">本季</button>
                                    <button class="dp-qbtn" @onclick="QThisYear">本年</button>
                                </div>
                            </div>
                        </div>
                    }
                </div><!-- form-item -->

                <!-- 单据号码 -->
                <div class="form-item">
                    <label class="form-label">单据号码</label>
                    <input type="text" class="form-input" placeholder="" @bind="query.DocumentNumber" />
                </div>

                <!-- 仓库代号 -->
                <div class="form-item">
                    <label class="form-label">仓库代号</label>
                    <div class="input-with-search">
                        <input type="text" class="form-input" placeholder="" @bind="query.WarehouseCode" />
                        <button class="search-icon-btn" title="选择仓库" @onclick="OpenWarehouseSelector">
                            <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="#999999" stroke-width="1.5">
                                <circle cx="7" cy="7" r="5"/>
                                <line x1="11" y1="11" x2="15" y2="15"/>
                            </svg>
                        </button>
                    </div>
                </div>

                <!-- 厂商代号 -->
                <div class="form-item">
                    <label class="form-label">厂商代号</label>
                    <input type="text" class="form-input" placeholder="" @bind="query.VendorCode" />
                </div>

                <!-- 结案列示 -->
                <div class="form-item">
                    <label class="form-label">结案列示</label>
                    <div class="select-wrapper">
                        <select class="form-select" @bind="query.CloseStatus">
                            <option value="全部">全部</option>
                            <option value="已结案">已结案</option>
                            <option value="未结案">未结案</option>
                        </select>
                        <svg class="select-arrow" viewBox="0 0 12 12" width="10" height="10" fill="#999999">
                            <path d="M2 4l4 4 4-4"/>
                        </svg>
                    </div>
                </div>

                <!-- 申请单号 -->
                <div class="form-item">
                    <label class="form-label">申请单号</label>
                    <input type="text" class="form-input" placeholder="" @bind="query.ApplyOrderNumber" />
                </div>

                <!-- 业务类型 -->
                <div class="form-item" style="flex-direction:column;align-items:stretch;height:auto;padding-bottom:4px;">
                    <div style="display:flex;flex-direction:row;align-items:stretch;height:30px;">
                        <label class="form-label" style="border-radius:2px 0 0 2px;">业务类型</label>
                        <div class="input-with-search" style="flex:1;">
                            <input type="text" class="form-input" placeholder="" value="@query.BusinessType" readonly />
                            <button class="search-icon-btn" title="选择业务类型" @onclick="OpenBizTypeSelector">
                                <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="#999999" stroke-width="1.5">
                                    <circle cx="7" cy="7" r="5"/>
                                    <line x1="11" y1="11" x2="15" y2="15"/>
                                </svg>
                            </button>
                        </div>
                    </div>
                    @if (selectedBizTypes.Count > 0)
                    {
                        <div class="biz-type-tags-area">
                            @foreach (var tag in selectedBizTypes)
                            {
                                <span class="biz-type-tag">@tag.tYPE_ID @tag.nAME<button class="biz-type-tag-close" @onclick="() => RemoveBizTypeTag(tag.tYPE_ID)">&times;</button></span>
                            }
                        </div>
                    }
                </div>

                <!-- 查询按钮 -->
                <div class="form-item query-btn-wrapper">
                    <button class="query-submit-btn" @onclick="HandleSearch">
                        <svg viewBox="0 0 16 16" width="16" height="16" fill="white" stroke="white" stroke-width="1.5">
                            <circle cx="7" cy="7" r="5"/>
                            <line x1="11" y1="11" x2="15" y2="15"/>
                        </svg>
                        <span>查询</span>
                    </button>
                </div>
            </div>
        </div>

        <!-- 右侧数据表格区域 -->
        <div class="table-panel">
            <!-- 工具栏 -->
            <div class="table-toolbar">
                <div class="toolbar-left">
                    <button class="toolbar-btn primary-btn" @onclick="HandleAddNew">
                        <svg viewBox="0 0 16 16" width="14" height="14" fill="white">
                            <path d="M8 3v10M3 8h10" stroke="white" stroke-width="2" stroke-linecap="round"/>
                        </svg>
                        <span>新增</span>
                    </button>
                    <button class="toolbar-btn export-btn" @onclick="HandleExport">
                        <svg viewBox="0 0 16 16" width="14" height="14" fill="#666666">
                            <path d="M8 12V4m0 0L5 7m3-3l3 3" stroke="#666666" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                            <path d="M2 11v2a1 1 0 001 1h10a1 1 0 001-1v-2" stroke="#666666" stroke-width="1.5" fill="none" stroke-linecap="round"/>
                        </svg>
                        <span>导出</span>
                    </button>
                </div>
            </div>

            <!-- 数据表格 -->
            <div class="data-table-container">
                <table class="data-table">
                    <thead>
                        <tr>
                            @foreach (var col in columnConfigs.Where(c => c.Visible))
                            {
                                var widthStyle = col.Width > 0 ? $"width:{col.Width}px" : "";
                                if (col.Sortable)
                                {
                                    <th style="@widthStyle" class="sortable">
                                        @col.DisplayName
                                        <svg viewBox="0 0 12 12" width="10" height="10" fill="#999999">
                                            <path d="M6 3l3 3H9l-3-3-3 3H3z"/>
                                            <path d="M6 9l-3-3h3l3 3h-3z" opacity="0.3"/>
                                        </svg>
                                    </th>
                                }
                                else
                                {
                                    <th style="@widthStyle">@col.DisplayName</th>
                                }
                            }
                            <th class="col-action" style="display:flex;align-items:center;justify-content:space-between;white-space:nowrap;">
                                <span>操作</span>
                                <button class="column-settings-btn" title="栏位设置" @onclick="OpenColumnSettings">
                                    <svg viewBox="0 0 16 16" width="14" height="14" fill="#666666">
                                        <path d="M2 3h4v2H2V3zm0 4h4v2H2V7zm0 4h4v2H2v-2zm6-8h6v2H8V3zm0 4h6v2H8V7zm0 4h6v2H8v-2z"/>
                                    </svg>
                                </button>
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (dataSource.Count == 0)
                        {
                            <tr><td colspan="@(VisibleColumnCount + 1)" class="empty-data-cell"><div class="empty-data"><svg viewBox="0 0 64 64" width="80" height="80" fill="none"><rect x="8" y="8" width="48" height="48" rx="8" fill="#F5F5F5" stroke="#E0E0E0" stroke-width="1"/><path d="M24 28h16M24 36h12" stroke="#D9D9D9" stroke-width="2" stroke-linecap="round"/></svg><p class="empty-text">暂无数据</p></div></td></tr>
                        }
                        else
                        {
                            @foreach (var item in dataSource)
                            {
                                <tr>
                                    @foreach (var col in columnConfigs.Where(c => c.Visible))
                                    {
                                        var widthStyle = col.Width > 0 ? $"width:{col.Width}px" : "";
                                        <td style="@widthStyle">@GetCellValue(item, col.FieldKey)</td>
                                    }
                                    <td><button class="action-btn" title="操作"><svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="#1890FF" stroke-width="1.5"><circle cx="8" cy="3" r="1" fill="#1890FF"/><circle cx="8" cy="8" r="1" fill="#1890FF"/><circle cx="8" cy="13" r="1" fill="#1890FF"/></svg></button></td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- 导出对话框 -->
@if (showExportDialog)
{
    <div class="export-dialog-overlay" @onclick="CancelExport">
        <div class="export-dialog" @onclick:stopPropagation>
            <div class="export-dialog-header">
                <span>导出 Excel</span>
                <button class="export-dialog-close" @onclick="CancelExport">&times;</button>
            </div>
            <div class="export-dialog-body">
                <label class="export-label">文件名</label>
                <input type="text" class="export-filename-input" @bind="exportFileName" @bind:event="oninput" />
            </div>
            <div class="export-dialog-footer">
                <button class="export-btn-cancel" @onclick="CancelExport">取消</button>
                <button class="export-btn-confirm" @onclick="ConfirmExport">确认导出</button>
            </div>
        </div>
    </div>
}

<!-- 栏位设计对话框 -->
@if (showColumnSettingsDialog)
{
    <div class="column-settings-overlay" @onclick="CloseColumnSettings">
        <div class="column-settings-dialog" @onclick:stopPropagation>
            <div class="column-settings-header">
                <span>栏位设计</span>
                <button class="column-settings-close" @onclick="CloseColumnSettings">&times;</button>
            </div>
            <div class="column-settings-search">
                <input type="text" class="column-search-input" placeholder="搜索栏位原名..." @bind="columnSearchKeyword" @bind:event="oninput" />
            </div>
            <div class="column-settings-body">
                <table class="column-settings-table">
                    <thead>
                        <tr>
                            <th class="col-seq">项次</th>
                            <th class="col-visible">显示否</th>
                            <th class="col-original">原栏位名</th>
                            <th class="col-display">栏位标题</th>
                            <th class="col-width">宽度</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < FilteredColumnConfigs.Count; i++)
                        {
                            var col = FilteredColumnConfigs[i];
                            var idx = columnConfigs.IndexOf(col) + 1;
                            <tr>
                                <td class="col-seq">@idx</td>
                                <td class="col-visible">
                                    <label class="toggle-switch">
                                        <input type="checkbox" checked="@col.Visible" @onchange="@((ChangeEventArgs e) => col.Visible = (bool)e.Value!)" />
                                        <span class="toggle-slider"></span>
                                    </label>
                                </td>
                                <td class="col-original">@col.OriginalName</td>
                                <td class="col-display">
                                    <input type="text" class="col-title-input" value="@col.DisplayName"
                                           @onchange="@((ChangeEventArgs e) => col.DisplayName = e.Value?.ToString() ?? col.OriginalName)" />
                                </td>
                                <td class="col-width">
                                    <input type="number" class="col-width-input" value="@col.Width"
                                           min="0" max="500"
                                           @onchange="@((ChangeEventArgs e) => { if(int.TryParse(e.Value?.ToString(), out var w)) col.Width = w; })" />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="column-settings-footer">
                <div class="footer-left">
                    <button class="col-select-all" @onclick="SelectAllColumns">全选</button>
                    <button class="col-restore-default" @onclick="RestoreDefaultColumns">恢复默认</button>
                </div>
                <div class="footer-right">
                    <button class="col-btn-confirm" @onclick="ConfirmColumnSettings">确定</button>
                    <button class="col-btn-cancel" @onclick="CancelColumnSettings">取消</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- 仓库选择器对话框 -->
@if (showWarehouseDialog)
{
    <div class="wh-selector-overlay" @onclick="CloseWarehouseSelector">
        <div class="wh-selector-dialog" @onclick:stopPropagation>
            <!-- 头部 -->
            <div class="wh-selector-header">
                <span>仓库(MY_WH)</span>
                <button class="wh-close-btn" @onclick="CloseWarehouseSelector">&times;</button>
            </div>
            <!-- 主体：左右分栏 -->
            <div class="wh-selector-body">
                <!-- 左侧面板：过滤区 -->
                <div class="wh-left-panel">
                    <div class="wh-filter-title">过滤</div>
                    <input type="text" class="wh-search-input" placeholder="输入关键字查询" @bind="warehouseSearchKeyword" @bind:event="oninput" @onkeyup="@((KeyboardEventArgs e) => { if(e.Key == "Enter") _ = SearchWarehouse(); })" />
                    <button class="wh-query-btn" @onclick="@(() => _ = SearchWarehouse())">查询</button>
                </div>
                <!-- 右侧区域：数据表格 -->
                <div class="wh-right-panel">
                    <table class="wh-data-table">
                        <thead>
                            <tr>
                                <th class="wh-col-action">
                                    操作
                                    <button class="column-settings-btn" title="栏位设置" @onclick="OpenWhColumnSettings">
                                        <svg viewBox="0 0 16 16" width="14" height="14" fill="#666666">
                                            <path d="M2 3h4v2H2V3zm0 4h4v2H2V7zm0 4h4v2H8v-2zm6-8h6v2H8V3zm0 4h6v2H8V7zm0 4h6v2H8v-2z"/>
                                        </svg>
                                    </button>
                                </th>
                                <th style="width:50px">项次</th>
                                @foreach (var col in whColumnConfigs.Where(c => c.Visible))
                                {
                                    var wStyle = col.Width > 0 ? $"width:{col.Width}px" : "";
                                    <th style="@wStyle">@col.DisplayName</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @if (warehouseData.Count == 0)
                            {
                                <tr><td colspan="@(WhVisibleColumnCount + 2)" style="text-align:center;padding:30px;color:#999;">暂无数据</td></tr>
                            }
                            else
                            {
                                @for (int i = 0; i < warehouseData.Count; i++)
                                {
                                    var item = warehouseData[i];
                                    var rowIdx = (warehousePageIndex - 1) * warehousePageSize + i + 1;
                                    <tr>
                                        <td><button class="wh-select-btn" @onclick="() => SelectWarehouse(item)">选择</button></td>
                                        <td style="text-align:center">@rowIdx</td>
                                        @foreach (var col in whColumnConfigs.Where(c => c.Visible))
                                        {
                                            var cw = col.Width > 0 ? $"width:{col.Width}px" : "";
                                            <td style="@cw">@GetWhCellValue(item, col.FieldKey)</td>
                                        }
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                    <!-- 分页 -->
                    <div class="wh-pagination">
                        <span class="wh-total-info">共 @warehouseTotalCount 笔记录</span>
                        <div class="wh-page-controls">
