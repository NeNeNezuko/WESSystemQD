    private async Task SearchWarehouse()
    {
        try
        {
            var url = $"http://localhost:5102/api/warehouse/search?keyword={Uri.EscapeDataString(warehouseSearchKeyword ?? "")}&pageIndex={warehousePageIndex}&pageSize={warehousePageSize}";
            Console.WriteLine($"[Warehouse] Request URL: {url}");
            
            var response = await Http.GetAsync(url);
            Console.WriteLine($"[Warehouse] Response Status: {response.StatusCode}");
            
            if (response.IsSuccessStatusCode)
            {
                var json = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"[Warehouse] Response JSON: {json}");
                
                var result = System.Text.Json.JsonSerializer.Deserialize<WarehouseSearchResult>(json, new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                Console.WriteLine($"[Warehouse] Deserialized result: {(result != null ? "not null" : "null")}");
                
                if (result != null)
                {
                    warehouseData = result.Items ?? new List<WarehouseItem>();
                    warehouseTotalCount = result.TotalCount;
                    Console.WriteLine($"[Warehouse] Items count: {warehouseData.Count}, Total: {warehouseTotalCount}");
                }
            }
            else
            {
                var errBody = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"[Warehouse] API error: {response.StatusCode} - {errBody}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Warehouse] Exception: {ex.Message}");
            Console.WriteLine($"[Warehouse] Exception Stack: {ex.StackTrace}");
        }
        StateHasChanged();
    }

    private void SelectWarehouse(WarehouseItem item)
