@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@inject HttpClient Http
@inject ILogger<InboundNotice> _logger
@inject TokenProvider TokenProvider

<link rel="stylesheet" href="css/inbound-notice.css" />

<div class="inbound-notice-page" style="display:flex;flex-direction:column;flex:1 1 0%;overflow:hidden;">
    <!-- 顶部标题栏 -->
    <div class="page-header">
        <div class="header-left">
            <button class="favorite-btn @(isFavorited ? "favorited" : "")" @onclick="ToggleFavorite" title="收藏">
                <svg viewBox="0 0 24 24" width="24" height="24">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
                          fill="@((isFavorited ? "#FFD700" : "none"))"
                          stroke="@((isFavorited ? "#FFD700" : "#666666"))"
                          stroke-width="2"/>
                </svg>
            </button>
            <span class="page-title">入库通知单/查询</span>
        </div>
        <div class="header-right">
            <button class="collapse-btn-fixed @(isCollapsed ? "collapsed" : "")" @onclick="ToggleCollapse" title="@(isCollapsed ? "展开查询" : "收起查询")">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="#666666">
                    <rect x="3" y="6" width="18" height="2" rx="1"/>
                    <rect x="3" y="11" width="18" height="2" rx="1"/>
                    <rect x="3" y="16" width="18" height="2" rx="1"/>
                </svg>
            </button>
        </div>
    </div>

    <!-- 收藏成功提示 -->
    @if (showFavoriteSuccess)
    {
        <div class="favorite-success-toast">
            <div class="toast-content">
                <svg viewBox="0 0 16 16" width="16" height="16" fill="#52C41A">
                    <circle cx="8" cy="8" r="8"/>
                    <path d="M5 8l2 2 4-4" stroke="white" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>收藏成功</span>
            </div>
        </div>
    }

    <!-- 主内容区域 -->
    <div class="page-content">
        <!-- 左侧查询区域 -->
        <div class="query-panel @(isCollapsed ? "collapsed" : "")">
            <div class="query-header">
                <span class="query-title">查询</span>
                <button class="query-settings-btn" title="设置" @onclick="ToggleSettingsMenu">
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="#999999" stroke-width="2">
                        <circle cx="12" cy="12" r="3"/>
                        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/>
                    </svg>
                </button>
                @if (showSettingsMenu)
                {
                    <div class="settings-dropdown" @onclick:stopPropagation>
                        <div class="settings-dropdown-item" @onclick="BatchAddCondition">批次添加条件</div>
                        <div class="settings-dropdown-item" @onclick="AddSingleCondition">添加单一条件</div>
                        <div class="settings-dropdown-item" @onclick="CustomCondition">自定义条件</div>
                        <div class="settings-dropdown-item" @onclick="RemoveCondition">移除条件</div>
                        <div class="settings-dropdown-item" @onclick="SaveConditionValues">保存条件值</div>
                    </div>
                }
            </div>

            <div class="query-form">
                <!-- 单据日期 - 双月历范围选择器 -->
                <div class="form-item">
                    <label class="form-label">单据日期</label>
                    <div class="date-picker-trigger" @onclick="ToggleDatePicker" @ref="datePickerTriggerRef">
                        <span class="date-display-text">@DateDisplayText</span>
                        <svg class="date-picker-icon" viewBox="0 0 16 16" width="12" height="12" fill="#999999">
                            <rect x="2" y="3" width="12" height="11" rx="2" stroke="#999999" stroke-width="1.2" fill="none"/>
                            <line x1="2" y1="6" x2="14" y2="6" stroke="#999999" stroke-width="1.2"/>
                            <line x1="5" y1="1" x2="5" y2="4" stroke="#999999" stroke-width="1.2" stroke-linecap="round"/>
                            <line x1="11" y1="1" x2="11" y2="4" stroke="#999999" stroke-width="1.2" stroke-linecap="round"/>
                        </svg>
                    </div><!-- date-picker-trigger -->

                    <!-- 日历弹出层 -->
                    @if (ShowCalendar)
                    {
                        <div class="datepicker-dropdown" @onclick:stopPropagation @ref="datePickerDropdownRef">
                            <div class="datepicker-popup-dual">
                                <div class="dp-header-dual">
                                    <button class="dp-nav" @onclick="GoPrevYear" title="上一年">&#171;</button>
                                    <button class="dp-nav" @onclick="GoPrevMonth" title="上一月">&#8249;</button>
                                    <span class="dp-title-dual">@ViewYear 年 @ViewMonth 月</span>
                                    <span class="dp-title-sep"></span>
                                    @{
                                        var nextM = ViewMonth + 1;
                                        var nextY = ViewYear;
                                        if (nextM > 12) { nextM = 1; nextY++; }
                                    }
                                    <span class="dp-title-dual">@nextY 年 @nextM 月</span>
                                    <button class="dp-nav" @onclick="GoNextMonth" title="下一月">&#8250;</button>
                                    <button class="dp-nav" @onclick="GoNextYear" title="下一年">&#187;</button>
                                </div>
                                <div class="dp-months-row">
                                    <div class="dp-month-block">
                                        <div class="dp-week-row">
                                            <span class="dp-week">一</span><span class="dp-week">二</span><span class="dp-week">三</span><span class="dp-week">四</span><span class="dp-week">五</span><span class="dp-week">六</span><span class="dp-week">日</span>
                                        </div>
                                        <div class="dp-grid">
                                            @for (int idx = 0; idx < LeftCalendarCells.Count; idx++)
                                            {
                                                var cell = LeftCalendarCells[idx];
                                                <button class="dp-cell @(cell.IsSelected ? "dp-sel" : "") @(cell.IsInRange ? "dp-range" : "") @(cell.IsToday && !cell.IsSelected ? "dp-today" : "") @(!cell.IsCurrentMonth ? "dp-gray" : "")"
                                                        @onclick="@(() => PickDate(cell.Year, cell.Month, cell.Day))">
                                                    @cell.Day
                                                </button>
                                            }
                                        </div>
                                    </div>
                                    <div class="dp-month-block">
                                        <div class="dp-week-row">
                                            <span class="dp-week">一</span><span class="dp-week">二</span><span class="dp-week">三</span><span class="dp-week">四</span><span class="dp-week">五</span><span class="dp-week">六</span><span class="dp-week">日</span>
                                        </div>
                                        <div class="dp-grid">
                                            @for (int idx = 0; idx < RightCalendarCells.Count; idx++)
                                            {
                                                var cell = RightCalendarCells[idx];
                                                <button class="dp-cell @(cell.IsSelected ? "dp-sel" : "") @(cell.IsInRange ? "dp-range" : "") @(cell.IsToday && !cell.IsSelected ? "dp-today" : "") @(!cell.IsCurrentMonth ? "dp-gray" : "")"
                                                        @onclick="@(() => PickDate(cell.Year, cell.Month, cell.Day))">
                                                    @cell.Day
                                                </button>
                                            }
                                        </div>
                                    </div>
                                </div>
                                <div class="dp-shortcuts-row">
                                    <button class="dp-qbtn" @onclick="QYesterday">昨天</button>
                                    <button class="dp-qbtn" @onclick="QLastWeek">上周</button>
                                    <button class="dp-qbtn" @onclick="QLastMonth">上月</button>
                                    <button class="dp-qbtn" @onclick="QLastYear">上年</button>
                                </div>
                                <div class="dp-shortcuts-row">
                                    <button class="dp-qbtn dp-qbtn-primary" @onclick="QToday">今日</button>
                                    <button class="dp-qbtn" @onclick="QThisWeek">本周</button>
                                    <button class="dp-qbtn" @onclick="QThisMonth">本月</button>
                                    <button class="dp-qbtn" @onclick="QThisQuarter">本季</button>
                                    <button class="dp-qbtn" @onclick="QThisYear">本年</button>
                                </div>
                            </div>
                        </div>
                    }
                </div><!-- form-item -->

                <!-- 单据号码 -->
                <div class="form-item">
                    <label class="form-label">单据号码</label>
                    <input type="text" class="form-input" placeholder="" @bind="query.DocumentNumber" />
                </div>

                <!-- 仓库代号 -->
                <div class="form-item">
                    <label class="form-label">仓库代号</label>
                    <div class="input-with-search">
                        <input type="text" class="form-input" placeholder="" @bind="query.WarehouseCode" />
                        <button class="search-icon-btn" title="搜索">
                            <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="#999999" stroke-width="1.5">
                                <circle cx="7" cy="7" r="5"/>
                                <line x1="11" y1="11" x2="15" y2="15"/>
                            </svg>
                        </button>
                    </div>
                </div>

                <!-- 厂商代号 -->
                <div class="form-item">
                    <label class="form-label">厂商代号</label>
                    <input type="text" class="form-input" placeholder="" @bind="query.VendorCode" />
                </div>

                <!-- 结案列示 -->
                <div class="form-item">
                    <label class="form-label">结案列示</label>
                    <div class="select-wrapper">
                        <select class="form-select" @bind="query.CloseStatus">
                            <option value="全部">全部</option>
                            <option value="已结案">已结案</option>
                            <option value="未结案">未结案</option>
                        </select>
                        <svg class="select-arrow" viewBox="0 0 12 12" width="10" height="10" fill="#999999">
                            <path d="M2 4l4 4 4-4"/>
                        </svg>
                    </div>
                </div>

                <!-- 申请单号 -->
                <div class="form-item">
                    <label class="form-label">申请单号</label>
                    <input type="text" class="form-input" placeholder="" @bind="query.ApplyOrderNumber" />
                </div>

                <!-- 业务类型 -->
                <div class="form-item">
                    <label class="form-label">业务类型</label>
                    <div class="input-with-search">
                        <input type="text" class="form-input" placeholder="" @bind="query.BusinessType" />
                        <button class="search-icon-btn" title="搜索">
                            <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="#999999" stroke-width="1.5">
                                <circle cx="7" cy="7" r="5"/>
                                <line x1="11" y1="11" x2="15" y2="15"/>
                            </svg>
                        </button>
                    </div>
                </div>

                <!-- 查询按钮 -->
                <div class="form-item query-btn-wrapper">
                    <button class="query-submit-btn" @onclick="HandleSearch">
                        <svg viewBox="0 0 16 16" width="16" height="16" fill="white" stroke="white" stroke-width="1.5">
                            <circle cx="7" cy="7" r="5"/>
                            <line x1="11" y1="11" x2="15" y2="15"/>
                        </svg>
                        <span>查询</span>
                    </button>
                </div>
            </div>
        </div>

        <!-- 右侧数据表格区域 -->
        <div class="table-panel">
            <!-- 工具栏 -->
            <div class="table-toolbar">
                <div class="toolbar-left">
                    <button class="toolbar-btn primary-btn" @onclick="HandleAddNew">
                        <svg viewBox="0 0 16 16" width="14" height="14" fill="white">
                            <path d="M8 3v10M3 8h10" stroke="white" stroke-width="2" stroke-linecap="round"/>
                        </svg>
                        <span>新增</span>
                    </button>
                    <button class="toolbar-btn export-btn" @onclick="HandleExport">
                        <svg viewBox="0 0 16 16" width="14" height="14" fill="#666666">
                            <path d="M8 12V4m0 0L5 7m3-3l3 3" stroke="#666666" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                            <path d="M2 11v2a1 1 0 001 1h10a1 1 0 001-1v-2" stroke="#666666" stroke-width="1.5" fill="none" stroke-linecap="round"/>
                        </svg>
                        <span>导出</span>
                    </button>
                </div>
            </div>

            <!-- 数据表格 -->
            <div class="data-table-container">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th class="col-item-no">项次</th>
                            <th class="col-date sortable">单据日期<svg viewBox="0 0 12 12" width="10" height="10" fill="#999999"><path d="M6 3l3 3H9l-3-3-3 3H3z"/><path d="M6 9l-3-3h3l3 3h-3z" opacity="0.3"/></svg></th>
                            <th class="col-doc-no sortable">单据号码<svg viewBox="0 0 12 12" width="10" height="10" fill="#999999"><path d="M6 3l3 3H9l-3-3-3 3H3z"/><path d="M6 9l-3-3h3l3 3h-3z" opacity="0.3"/></svg></th>
                            <th class="col-wh-code sortable">仓库代号<svg viewBox="0 0 12 12" width="10" height="10" fill="#999999"><path d="M6 3l3 3H9l-3-3-3 3H3z"/><path d="M6 9l-3-3h3l3 3h-3z" opacity="0.3"/></svg></th>
                            <th class="col-wh-name">仓库名称</th>
                            <th class="col-vendor-code sortable">厂商代号<svg viewBox="0 0 12 12" width="10" height="10" fill="#999999"><path d="M6 3l3 3H9l-3-3-3 3H3z"/><path d="M6 9l-3-3h3l3 3h-3z" opacity="0.3"/></svg></th>
                            <th class="col-vendor-name">厂商名称</th>
                            <th class="col-apply-no">申请单号(笔)</th>
                            <th class="col-order-no">单据号码</th>
                            <th class="col-closed sortable">结案否<svg viewBox="0 0 12 12" width="10" height="10" fill="#999999"><path d="M6 3l3 3H9l-3-3-3 3H3z"/><path d="M6 9l-3-3h3l3 3h-3z" opacity="0.3"/></svg></th>
                            <th class="col-action">操作</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (dataSource.Count == 0)
                        {
                            <tr><td colspan="11" class="empty-data-cell"><div class="empty-data"><svg viewBox="0 0 64 64" width="80" height="80" fill="none"><rect x="8" y="8" width="48" height="48" rx="8" fill="#F5F5F5" stroke="#E0E0E0" stroke-width="1"/><path d="M24 28h16M24 36h12" stroke="#D9D9D9" stroke-width="2" stroke-linecap="round"/></svg><p class="empty-text">暂无数据</p></div></td></tr>
                        }
                        else
                        {
                            @foreach (var item in dataSource)
                            {
                                <tr>
                                    <td>@item.ItemNo</td>
                                    <td>@item.DocumentDate.ToString("yyyy-MM-dd")</td>
                                    <td>@item.DocumentNumber</td>
                                    <td>@item.WarehouseCode</td>
                                    <td>@item.WarehouseName</td>
                                    <td>@item.VendorCode</td>
                                    <td>@item.VendorName</td>
                                    <td>@item.ApplyOrderNumber</td>
                                    <td>@item.OrderNumber</td>
                                    <td>@(item.IsClosed ? "是" : "否")</td>
                                    <td><button class="action-btn" title="操作"><svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="#1890FF" stroke-width="1.5"><circle cx="8" cy="3" r="1" fill="#1890FF"/><circle cx="8" cy="8" r="1" fill="#1890FF"/><circle cx="8" cy="13" r="1" fill="#1890FF"/></svg></button></td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@code {
    private bool isFavorited = false;
    private bool showFavoriteSuccess = false;
    private bool isCollapsed = false;
    private bool showSettingsMenu = false;
    private InboundNoticeQuery query = new();
    private List<InboundNoticeModel> dataSource = new();

    // ===== 日历状态 =====
    private bool ShowCalendar = false;
    private int ViewYear;
    private int ViewMonth;
    private DateTime? SelectedStart;
    private DateTime? SelectedEnd;
    private bool PickingEnd = false;
    private ElementReference datePickerTriggerRef;
    private ElementReference datePickerDropdownRef;

    [CascadingParameter(Name = "OnFavoriteChanged")] public Action? OnFavoriteChanged { get; set; }

    // ===== 计算属性 =====
    private string DateDisplayText
    {
        get
        {
            if (SelectedStart.HasValue && SelectedEnd.HasValue)
                return $"{SelectedStart.Value:yyyy-MM-dd} → {SelectedEnd.Value:yyyy-MM-dd}";
            return "请选择日期";
        }
    }

    private List<CalCell> LeftCalendarCells => BuildCalendar(ViewYear, ViewMonth);

    private List<CalCell> RightCalendarCells
    {
        get
        {
            var m = ViewMonth + 1;
            var y = ViewYear;
            if (m > 12) { m = 1; y++; }
            return BuildCalendar(y, m);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var today = DateTime.Today;
        query.DateFrom = today;
        query.DateTo = today;
        SelectedStart = today;
        SelectedEnd = today;
        ViewYear = today.Year;
        ViewMonth = today.Month;
        await LoadFavoriteStatus();
        await LoadData();
    }

    // ===== 日历方法 =====
    private async Task ToggleDatePicker()
    {
        ShowCalendar = !ShowCalendar;
        if (ShowCalendar && SelectedStart.HasValue)
        {
            ViewYear = SelectedStart.Value.Year;
            ViewMonth = SelectedStart.Value.Month;
        }
        PickingEnd = false;
        if (ShowCalendar)
        {
            await JS.InvokeVoidAsync("eval", @"(function(){
                var trigger = arguments[0];
                var dropdown = arguments[1];
                var rect = trigger.getBoundingClientRect();
                dropdown.style.left = rect.left + 'px';
                dropdown.style.top = (rect.bottom + 4) + 'px';
            })()", datePickerTriggerRef, datePickerDropdownRef);
        }
        StateHasChanged();
    }

    private void QYesterday() => QuickSet("yesterday");
    private void QLastWeek() => QuickSet("lastWeek");
    private void QLastMonth() => QuickSet("lastMonth");
    private void QLastYear() => QuickSet("lastYear");
    private void QToday() => QuickSet("today");
    private void QThisWeek() => QuickSet("thisWeek");
    private void QThisMonth() => QuickSet("thisMonth");
    private void QThisQuarter() => QuickSet("thisQuarter");
    private void QThisYear() => QuickSet("thisYear");

    private void GoPrevYear()
    {
        ViewYear--;
        StateHasChanged();
    }

    private void GoNextYear()
    {
        ViewYear++;
        StateHasChanged();
    }

    private void GoPrevMonth()
    {
        ViewMonth--;
        if (ViewMonth < 1) { ViewMonth = 12; ViewYear--; }
        StateHasChanged();
    }

    private void GoNextMonth()
    {
        ViewMonth++;
        if (ViewMonth > 12) { ViewMonth = 1; ViewYear++; }
        StateHasChanged();
    }

    private void PickDate(int year, int month, int day)
    {
        var dt = new DateTime(year, month, day);
        DoPick(dt);
    }

    private void DoPick(DateTime dt)
    {
        if (!PickingEnd || !SelectedStart.HasValue || (SelectedStart.HasValue && SelectedEnd.HasValue))
        {
            SelectedStart = dt;
            SelectedEnd = null;
            PickingEnd = true;
        }
        else
        {
            if (dt >= SelectedStart.Value) SelectedEnd = dt;
            else { SelectedEnd = SelectedStart; SelectedStart = dt; }
        }
        query.DateFrom = SelectedStart ?? DateTime.Today;
        query.DateTo = SelectedEnd ?? SelectedStart ?? DateTime.Today;
        StateHasChanged();

        if (SelectedStart.HasValue && SelectedEnd.HasValue) ShowCalendar = false;
    }

    private void QuickSet(string type)
    {
        var t = DateTime.Today;
        switch (type)
        {
            case "yesterday": SelectedStart = t.AddDays(-1); SelectedEnd = t.AddDays(-1); break;
            case "lastWeek": var lm = t.AddDays(-(int)t.DayOfWeek - 6); SelectedStart = lm; SelectedEnd = lm.AddDays(6); break;
            case "lastMonth": SelectedStart = new DateTime(t.Year, t.Month, 1).AddMonths(-1); SelectedEnd = new DateTime(t.Year, t.Month, 1).AddDays(-1); break;
            case "lastYear": SelectedStart = new DateTime(t.Year - 1, 1, 1); SelectedEnd = new DateTime(t.Year - 1, 12, 31); break;
            case "today": SelectedStart = t; SelectedEnd = t; break;
            case "thisWeek": var tw = t.AddDays(-(int)t.DayOfWeek); SelectedStart = tw; SelectedEnd = tw.AddDays(6); break;
            case "thisMonth": SelectedStart = new DateTime(t.Year, t.Month, 1); SelectedEnd = new DateTime(t.Year, t.Month, DateTime.DaysInMonth(t.Year, t.Month)); break;
            case "thisQuarter":
                var tq = (t.Month - 1) / 3 + 1;
                SelectedStart = new DateTime(t.Year, (tq - 1) * 3 + 1, 1);
                SelectedEnd = new DateTime(t.Year, tq * 3, DateTime.DaysInMonth(t.Year, tq * 3)); break;
            case "thisYear": SelectedStart = new DateTime(t.Year, 1, 1); SelectedEnd = new DateTime(t.Year, 12, 31); break;
        }
        query.DateFrom = SelectedStart.Value;
        query.DateTo = SelectedEnd.Value;
        ViewYear = SelectedStart.Value.Year;
        ViewMonth = SelectedStart.Value.Month;
        ShowCalendar = false;
        StateHasChanged();
    }

    // ===== 日历数据构建 =====
    private List<CalCell> BuildCalendar(int year, int month)
    {
        var list = new List<CalCell>();
        var first = new DateTime(year, month, 1);
        // 周一为第一天：DayOfWeek.Monday=0 ... Sunday=6
        int dow = ((int)first.DayOfWeek + 6) % 7;
        // 前补
        for (int i = dow - 1; i >= 0; i--)
        {
            var d = first.AddDays(-(i + 1));
            list.Add(new CalCell(d.Year, d.Month, d.Day, false));
        }
        // 当月
        int dim = DateTime.DaysInMonth(year, month);
        for (int d = 1; d <= dim; d++)
            list.Add(new CalCell(year, month, d, true));
        // 后补到42格
        while (list.Count < 42)
        {
            var last = list[list.Count - 1];
            var nd = new DateTime(last.Year, last.Month, last.Day).AddDays(1);
            list.Add(new CalCell(nd.Year, nd.Month, nd.Day, false));
        }
        // 标记选中状态
        for (int i = 0; i < list.Count; i++)
        {
            var c = list[i];
            var cDate = new DateTime(c.Year, c.Month, c.Day);
            c.IsSelected = (SelectedStart.HasValue && cDate == SelectedStart.Value.Date)
                         || (SelectedEnd.HasValue && cDate == SelectedEnd.Value.Date);
            c.IsToday = cDate == DateTime.Today;
            c.IsInRange = SelectedStart.HasValue && SelectedEnd.HasValue
                           && cDate > SelectedStart.Value.Date && cDate < SelectedEnd.Value.Date;
        }
        return list;
    }

