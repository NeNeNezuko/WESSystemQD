@code {
    private bool isFavorited = false;
    private bool showFavoriteSuccess = false;
    private bool isCollapsed = false;
    private bool showSettingsMenu = false;
    private bool showExportDialog = false;
    private string exportFileName = "";
    private bool showColumnSettingsDialog = false;
    private string columnSearchKeyword = "";
    private List<ColumnConfig> columnConfigs = new();
    private List<ColumnConfig> defaultColumnConfigs = new();
    private InboundNoticeQuery query = new();
    private List<InboundNoticeModel> dataSource = new();

    // ===== 仓库选择器状态 =====
    private bool showWarehouseDialog = false;
    private string warehouseSearchKeyword = "";
    private List<WarehouseItem> warehouseData = new();
    private int warehousePageIndex = 1;
    private int warehousePageSize = 20;
    private int warehouseTotalCount = 0;
    private List<ColumnConfig> whColumnConfigs = new();
    private List<ColumnConfig> whDefaultColumnConfigs = new();
    private bool showWhColumnSettingsDialog = false;
    private string whColumnSearchKeyword = "";
    private const string WH_COLUMN_SETTINGS_KEY = "wms_column_settings_warehouse_selector";

    // ===== 日历状态 =====
    private bool ShowCalendar = false;
    private int ViewYear;
    private int ViewMonth;
    private DateTime? SelectedStart;
    private DateTime? SelectedEnd;
    private bool PickingEnd = false;
    private ElementReference datePickerTriggerRef;
    private ElementReference datePickerDropdownRef;

    [CascadingParameter(Name = "OnFavoriteChanged")] public Action? OnFavoriteChanged { get; set; }

    // ===== 计算属性 =====
    private string DateDisplayText
    {
        get
        {
            if (SelectedStart.HasValue && SelectedEnd.HasValue)
                return $"{SelectedStart.Value:yyyy-MM-dd} → {SelectedEnd.Value:yyyy-MM-dd}";
            return "请选择日期";
        }
    }

    private List<CalCell> LeftCalendarCells => BuildCalendar(ViewYear, ViewMonth);

    private List<CalCell> RightCalendarCells
    {
        get
        {
            var m = ViewMonth + 1;
            var y = ViewYear;
            if (m > 12) { m = 1; y++; }
            return BuildCalendar(y, m);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var today = DateTime.Today;
        query.DateFrom = today;
        query.DateTo = today;
        SelectedStart = today;
        SelectedEnd = today;
        ViewYear = today.Year;
        ViewMonth = today.Month;
        InitDefaultColumnConfigs();
        await LoadColumnSettings();
        await LoadFavoriteStatus();
        await LoadData();
    }

    // ===== 日历方法 =====
    private async Task ToggleDatePicker()
    {
        ShowCalendar = !ShowCalendar;
        if (ShowCalendar && SelectedStart.HasValue)
        {
            ViewYear = SelectedStart.Value.Year;
            ViewMonth = SelectedStart.Value.Month;
        }
        PickingEnd = false;
        if (ShowCalendar)
        {
            await JS.InvokeVoidAsync("eval", @"(function(){
                var trigger = arguments[0];
                var dropdown = arguments[1];
                var rect = trigger.getBoundingClientRect();
                dropdown.style.left = rect.left + 'px';
                dropdown.style.top = (rect.bottom + 4) + 'px';
            })()", datePickerTriggerRef, datePickerDropdownRef);
        }
        StateHasChanged();
    }

    private void QYesterday() => QuickSet("yesterday");
    private void QLastWeek() => QuickSet("lastWeek");
    private void QLastMonth() => QuickSet("lastMonth");
    private void QLastYear() => QuickSet("lastYear");
    private void QToday() => QuickSet("today");
    private void QThisWeek() => QuickSet("thisWeek");
    private void QThisMonth() => QuickSet("thisMonth");
    private void QThisQuarter() => QuickSet("thisQuarter");
    private void QThisYear() => QuickSet("thisYear");

    private void GoPrevYear()
    {
        ViewYear--;
        StateHasChanged();
    }

    private void GoNextYear()
    {
        ViewYear++;
        StateHasChanged();
    }

    private void GoPrevMonth()
    {
        ViewMonth--;
        if (ViewMonth < 1) { ViewMonth = 12; ViewYear--; }
        StateHasChanged();
    }

    private void GoNextMonth()
    {
        ViewMonth++;
        if (ViewMonth > 12) { ViewMonth = 1; ViewYear++; }
        StateHasChanged();
    }

    private void PickDate(int year, int month, int day)
    {
        var dt = new DateTime(year, month, day);
        DoPick(dt);
    }

    private void DoPick(DateTime dt)
    {
        if (!PickingEnd || !SelectedStart.HasValue || (SelectedStart.HasValue && SelectedEnd.HasValue))
        {
            SelectedStart = dt;
            SelectedEnd = null;
            PickingEnd = true;
        }
        else
        {
            if (dt >= SelectedStart.Value) SelectedEnd = dt;
            else { SelectedEnd = SelectedStart; SelectedStart = dt; }
        }
        query.DateFrom = SelectedStart ?? DateTime.Today;
        query.DateTo = SelectedEnd ?? SelectedStart ?? DateTime.Today;
        StateHasChanged();

        if (SelectedStart.HasValue && SelectedEnd.HasValue) ShowCalendar = false;
    }

    private void QuickSet(string type)
    {
        var t = DateTime.Today;
        switch (type)
        {
            case "yesterday": SelectedStart = t.AddDays(-1); SelectedEnd = t.AddDays(-1); break;
            case "lastWeek": var lm = t.AddDays(-(int)t.DayOfWeek - 6); SelectedStart = lm; SelectedEnd = lm.AddDays(6); break;
            case "lastMonth": SelectedStart = new DateTime(t.Year, t.Month, 1).AddMonths(-1); SelectedEnd = new DateTime(t.Year, t.Month, 1).AddDays(-1); break;
            case "lastYear": SelectedStart = new DateTime(t.Year - 1, 1, 1); SelectedEnd = new DateTime(t.Year - 1, 12, 31); break;
            case "today": SelectedStart = t; SelectedEnd = t; break;
            case "thisWeek": var tw = t.AddDays(-(int)t.DayOfWeek); SelectedStart = tw; SelectedEnd = tw.AddDays(6); break;
            case "thisMonth": SelectedStart = new DateTime(t.Year, t.Month, 1); SelectedEnd = new DateTime(t.Year, t.Month, DateTime.DaysInMonth(t.Year, t.Month)); break;
            case "thisQuarter":
                var tq = (t.Month - 1) / 3 + 1;
                SelectedStart = new DateTime(t.Year, (tq - 1) * 3 + 1, 1);
                SelectedEnd = new DateTime(t.Year, tq * 3, DateTime.DaysInMonth(t.Year, tq * 3)); break;
            case "thisYear": SelectedStart = new DateTime(t.Year, 1, 1); SelectedEnd = new DateTime(t.Year, 12, 31); break;
        }
        query.DateFrom = SelectedStart.Value;
        query.DateTo = SelectedEnd.Value;
        ViewYear = SelectedStart.Value.Year;
        ViewMonth = SelectedStart.Value.Month;
        ShowCalendar = false;
        StateHasChanged();
    }

    // ===== 日历数据构建 =====
    private List<CalCell> BuildCalendar(int year, int month)
    {
        var list = new List<CalCell>();
        var first = new DateTime(year, month, 1);
        // 周一为第一天：DayOfWeek.Monday=0 ... Sunday=6
        int dow = ((int)first.DayOfWeek + 6) % 7;
        // 前补
        for (int i = dow - 1; i >= 0; i--)
        {
            var d = first.AddDays(-(i + 1));
            list.Add(new CalCell(d.Year, d.Month, d.Day, false));
        }
        // 当月
        int dim = DateTime.DaysInMonth(year, month);
        for (int d = 1; d <= dim; d++)
            list.Add(new CalCell(year, month, d, true));
        // 后补到42格
        while (list.Count < 42)
        {
            var last = list[list.Count - 1];
            var nd = new DateTime(last.Year, last.Month, last.Day).AddDays(1);
            list.Add(new CalCell(nd.Year, nd.Month, nd.Day, false));
        }
        // 标记选中状态
        for (int i = 0; i < list.Count; i++)
        {
            var c = list[i];
            var cDate = new DateTime(c.Year, c.Month, c.Day);
            c.IsSelected = (SelectedStart.HasValue && cDate == SelectedStart.Value.Date)
                         || (SelectedEnd.HasValue && cDate == SelectedEnd.Value.Date);
            c.IsToday = cDate == DateTime.Today;
            c.IsInRange = SelectedStart.HasValue && SelectedEnd.HasValue
                           && cDate > SelectedStart.Value.Date && cDate < SelectedEnd.Value.Date;
        }
        return list;
    }

    // ===== 原有方法 =====
    private void ToggleCollapse()
    {
        isCollapsed = !isCollapsed;
        StateHasChanged();
    }

    // ===== 设置菜单方法 =====
    private void ToggleSettingsMenu()
    {
        showSettingsMenu = !showSettingsMenu;
        StateHasChanged();
    }

    private void BatchAddCondition() { showSettingsMenu = false; StateHasChanged(); }
    private void AddSingleCondition() { showSettingsMenu = false; StateHasChanged(); }
    private void CustomCondition() { showSettingsMenu = false; StateHasChanged(); }
    private void RemoveCondition() { showSettingsMenu = false; StateHasChanged(); }
    private void SaveConditionValues() { showSettingsMenu = false; StateHasChanged(); }

    private async Task LoadFavoriteStatus()
    {
        try { var r = await JS.InvokeAsync<string>("localStorage.getItem", "wms_favorite_inbound_notice"); isFavorited = r == "true"; }
        catch { isFavorited = false; }
