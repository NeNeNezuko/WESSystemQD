    private void InitWhDefaultColumnConfigs()
    {
        whDefaultColumnConfigs = new List<ColumnConfig>
        {
            new() { FieldKey = "wh", OriginalName = "仓库代号", DisplayName = "仓库代号", Visible = true, Width = 100, DefaultWidth = 100 },
            new() { FieldKey = "name", OriginalName = "仓库名称", DisplayName = "仓库名称", Visible = true, Width = 120, DefaultWidth = 120 },
            new() { FieldKey = "wH_TYPE", OriginalName = "仓库类型", DisplayName = "仓库类型", Visible = true, Width = 80, DefaultWidth = 80 },
            new() { FieldKey = "attrib", OriginalName = "属性", DisplayName = "属性", Visible = false, Width = 60, DefaultWidth = 60 },
            new() { FieldKey = "dep", OriginalName = "部门", DisplayName = "部门", Visible = false, Width = 80, DefaultWidth = 80 },
            new() { FieldKey = "invalid", OriginalName = "作废否", DisplayName = "作废否", Visible = false, Width = 60, DefaultWidth = 60 }
        };
        whColumnConfigs = whDefaultColumnConfigs.Select(c => new ColumnConfig
        {
            FieldKey = c.FieldKey,
            OriginalName = c.OriginalName,
            DisplayName = c.DisplayName,
            Visible = c.Visible,
            Width = c.Width,
            DefaultWidth = c.DefaultWidth
        }).ToList();
    }

