@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@using WmsPlus.Components

<link rel="stylesheet" href="css/import-initial-inventory.css" />

<div class="import-initial-inventory-page" style="display:flex;flex-direction:column;flex:1 1 0%;overflow:hidden;">
    <!-- 顶部标题栏 -->
    <div class="page-header">
        <div class="header-left">
            <button class="favorite-btn @(isFavorited ? "favorited" : "")" @onclick="ToggleFavorite" title="收藏">
                <svg viewBox="0 0 24 24" width="24" height="24">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
                          fill="@((isFavorited ? "#FFD700" : "none"))"
                          stroke="@((isFavorited ? "#FFD700" : "#666666"))"
                          stroke-width="2"/>
                </svg>
            </button>
            <span class="page-title">导入期初库存</span>
        </div>
        <div class="header-center">
            <button class="collapse-btn-fixed @(isCollapsed ? "collapsed" : "")" @onclick="ToggleCollapse" title="@(isCollapsed ? "展开查询" : "收起查询")">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="#666666">
                    <rect x="3" y="6" width="18" height="2" rx="1"/>
                    <rect x="3" y="11" width="18" height="2" rx="1"/>
                    <rect x="3" y="16" width="18" height="2" rx="1"/>
                </svg>
            </button>
</div>
<div class="header-right">
        
                    <button class="header-action-btn primary" @onclick="HandleImport">
                        <svg viewBox="0 0 16 16" width="14" height="14" fill="white">
                            <path d="M8 3v10M3 8h10" stroke="white" stroke-width="2" stroke-linecap="round"/>
                        </svg>
                        <span>导入</span>
                    </button>
                </div>
    </div>

    <!-- 收藏成功提示 -->
    @if (showFavoriteSuccess)
    {
        <div class="favorite-success-toast">
            <div class="toast-content">
                <svg viewBox="0 0 16 16" width="16" height="16" fill="#52C41A">
                    <circle cx="8" cy="8" r="8"/>
                    <path d="M5 8l2 2 4-4" stroke="white" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>收藏成功</span>
            </div>
        </div>
    }

    <!-- 主内容区域 -->
    <div class="page-content">
        <!-- 左侧查询区域 -->
        <div class="query-panel @(isCollapsed ? "collapsed" : "")">
            <div class="query-header">
                <span class="query-title">查询</span>
            </div>

            <div class="query-form">
                <!-- 仓库代号 -->
                <div class="form-item">
                    <label class="form-label">仓库代号</label>
                    <WarehouseCodeInput @bind-Value="query.Wh" />
                </div>

                <!-- 货品代号 -->
                <div class="form-item">
                    <label class="form-label">货品代号</label>
                    <input type="text" class="form-input" placeholder="" @bind="query.PrdNo" />
                </div>

                <!-- 批号 -->
                <div class="form-item">
                    <label class="form-label">批号</label>
                    <input type="text" class="form-input" placeholder="" @bind="query.BatNo" />
                </div>

                <!-- 查询按钮 -->
                <div class="form-item query-btn-wrapper">
                    <button class="query-submit-btn" @onclick="HandleSearch">
                        <svg viewBox="0 0 16 16" width="16" height="16" fill="white" stroke="white" stroke-width="1.5">
                            <circle cx="7" cy="7" r="5"/>
                            <line x1="11" y1="11" x2="15" y2="15"/>
                        </svg>
                        <span>查询</span>
                    </button>
                </div>
            </div>
        </div>

        <!-- 右侧数据表格区域 -->
        <div class="table-panel">
            <!-- 工具栏 -->
            

            <!-- 数据表格 -->
            <div class="data-table-container">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th style="width:120px">仓库代号</th>
                            <th style="width:140px">货品代号</th>
                            <th style="width:120px">批号</th>
                            <th style="width:80px">数量</th>
                            <th style="width:120px">储位</th>
                            <th class="col-action">操作</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr><td colspan="6" class="empty-data-cell"><div class="empty-data"><svg viewBox="0 0 64 64" width="80" height="80" fill="none"><rect x="8" y="8" width="48" height="48" rx="8" fill="#F5F5F5" stroke="#E0E0E0" stroke-width="1"/><path d="M24 28h16M24 36h12" stroke="#D9D9D9" stroke-width="2" stroke-linecap="round"/></svg><p class="empty-text">暂无数据</p></div></td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@code {
    private const string FAVORITE_KEY = "wms_favorite_import_initial_inventory";

    private bool isFavorited = false;
    private bool showFavoriteSuccess = false;
    private bool isCollapsed = false;

    private ImportInitialInventoryQuery query = new();

    [CascadingParameter(Name = "OnFavoriteChanged")] public Action? OnFavoriteChanged { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadFavoriteStatus();
    }

    private void ToggleCollapse()
    {
        isCollapsed = !isCollapsed;
        StateHasChanged();
    }

    private async Task LoadFavoriteStatus()
    {
        try { var r = await JS.InvokeAsync<string>("localStorage.getItem", FAVORITE_KEY); isFavorited = r == "true"; }
        catch { isFavorited = false; }
    }

    private async Task ToggleFavorite()
    {
        isFavorited = !isFavorited;
        try { await JS.InvokeVoidAsync("localStorage.setItem", FAVORITE_KEY, isFavorited.ToString().ToLower()); } catch { }
        OnFavoriteChanged?.Invoke();
        if (isFavorited)
        {
            showFavoriteSuccess = true; StateHasChanged(); await Task.Delay(2000); showFavoriteSuccess = false;
        }
        StateHasChanged();
    }

    private void HandleSearch() { }
    private void HandleImport() { }

    private class ImportInitialInventoryQuery
    {
        public string Wh { get; set; } = "";
        public string PrdNo { get; set; } = "";
        public string BatNo { get; set; } = "";
    }
}
