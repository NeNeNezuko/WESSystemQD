@page "/dashboard"
@layout DashboardLayout
@inject IJSRuntime JS
@inject NavigationManager NavigationManager

<!-- 常用功能卡片 -->
<div class="db-card">
    <div class="db-card-title">
        <span>常用功能</span>
        <span class="db-func-edit-btn">编辑</span>
    </div>

    <!-- 收藏的功能 -->
    @if (showFavoriteInboundNotice)
    {
        <div class="db-favorite-item" @onclick="NavigateToInboundNotice">
            <svg viewBox="0 0 48 48" width="40" height="40">
                <rect x="8" y="4" width="32" height="38" rx="3" fill="#E6F7FF" stroke="#1890FF" stroke-width="1.5"/>
                <path d="M30 4 L40 14 L40 4 Z" fill="#BAE7FF"/>
                <path d="M30 4 L40 14 L30 14 z" fill="#91D5FF"/>
                <rect x="16" y="20" width="16" height="12" rx="2" fill="#52C41A" opacity="0.15"/>
                <path d="M24 17 L24 33 M19 25 L24 20 L29 25" stroke="#52C41A" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span class="favorite-text">入库通知单</span>
        </div>
    }
    @if (showFavoriteInboundOrder)
    {
        <div class="db-favorite-item" @onclick="NavigateToInboundOrder">
            <svg viewBox="0 0 48 48" width="40" height="40">
                <rect x="8" y="4" width="32" height="38" rx="3" fill="#FFF7E6" stroke="#FA8C16" stroke-width="1.5"/>
                <path d="M30 4 L40 14 L40 4 Z" fill="#FFE7BA"/>
                <path d="M30 4 L40 14 L30 14 z" fill="#FFD591"/>
                <rect x="16" y="20" width="16" height="12" rx="2" fill="#1890FF" opacity="0.1"/>
                <path d="M24 17 L24 33 M19 25 L24 20 L29 25" stroke="#1890FF" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span class="favorite-text">入库单</span>
        </div>
    }
    @if (showFavoriteInboundNoticeChange)
    {
        <div class="db-favorite-item" @onclick="NavigateToInboundNoticeChange">
            <svg viewBox="0 0 48 48" width="40" height="40">
                <rect x="8" y="4" width="32" height="38" rx="3" fill="#F9F0FF" stroke="#722ED1" stroke-width="1.5"/>
                <path d="M30 4 L40 14 L40 4 Z" fill="#EFDBFF"/>
                <path d="M30 4 L40 14 L30 14 z" fill="#D3ADF7"/>
                <path d="M18 18h12v3H18zM18 24h8v3H18z" fill="#722ED1" opacity="0.3"/>
                <path d="M28 28l4 4m0-4l-4 4" stroke="#EB2F96" stroke-width="2.5" fill="none" stroke-linecap="round"/>
            </svg>
            <span class="favorite-text">入库通知变更单</span>
        </div>
    }

    @* ===== 基础资料-货品 ===== *@
    @if (showFavoriteProductCodeSetting)
    {
        <div class="db-favorite-item" @onclick="NavigateToProductCodeSetting">
            <svg viewBox="0 0 48 48" width="40" height="40"><rect x="8" y="4" width="32" height="38" rx="3" fill="#E6F7FF" stroke="#1890FF" stroke-width="1.5"/><path d="M18 14h12M18 22h12M18 30h8" stroke="#1890FF" stroke-width="2.5" stroke-linecap="round"/></svg>
            <span class="favorite-text">货品代号设定</span>
        </div>
    }
    @if (showFavoriteMidClassSetting)
    {
        <div class="db-favorite-item" @onclick="NavigateToMidClassSetting">
            <svg viewBox="0 0 48 48" width="40" height="40"><rect x="8" y="4" width="32" height="38" rx="3" fill="#FFF7E6" stroke="#FA8C16" stroke-width="1.5"/><path d="M16 16l8 8-8 8" stroke="#FA8C16" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/><path d="M24 24h10" stroke="#FA8C16" stroke-width="2.5" stroke-linecap="round"/></svg>
            <span class="favorite-text">中类代号设定</span>
        </div>
    }
    @if (showFavoriteStorageNatureSetting)
    {
        <div class="db-favorite-item" @onclick="NavigateToStorageNatureSetting">
            <svg viewBox="0 0 48 48" width="40" height="40"><rect x="8" y="4" width="32" height="38" rx="3" fill="#F6FFED" stroke="#52C41A" stroke-width="1.5"/><rect x="16" y="14" width="16" height="6" rx="1" fill="#52C41A" opacity="0.3"/><rect x="16" y="24" width="16" height="6" rx="1" fill="#52C41A" opacity="0.3"/><rect x="16" y="34" width="10" height="6" rx="1" fill="#52C41A" opacity="0.3"/></svg>
            <span class="favorite-text">储存性质设定</span>
        </div>
    }
    @if (showFavoriteProductAttrSetting)
    {
        <div class="db-favorite-item" @onclick="NavigateToProductAttrSetting">
            <svg viewBox="0 0 48 48" width="40" height="40"><rect x="8" y="4" width="32" height="38" rx="3" fill="#FFF0F6" stroke="#EB2F96" stroke-width="1.5"/><circle cx="24" cy="18" r="5" stroke="#EB2F96" stroke-width="2" fill="none"/><path d="M16 30h16M18 36h12" stroke="#EB2F96" stroke-width="2" stroke-linecap="round"/></svg>
            <span class="favorite-text">货品属性信息</span>
        </div>
    }
    @if (showFavoriteProductMarkSetting)
    {
        <div class="db-favorite-item" @onclick="NavigateToProductMarkSetting">
            <svg viewBox="0 0 48 48" width="40" height="40"><rect x="8" y="4" width="32" height="38" rx="3" fill="#F9F0FF" stroke="#722ED1" stroke-width="1.5"/><path d="M16 16h6v6h-6zM26 16h6v6h-6zM16 26h6v6h-6zM26 26h6v6h-6z" fill="#722ED1" opacity="0.25"/></svg>
            <span class="favorite-text">货品特征码段</span>
        </div>
    }

    @* ===== 基础资料-仓库 ===== *@
    @if (showFavoriteWarehouseCodeSetting)
    {
        <div class="db-favorite-item" @onclick="NavigateToWarehouseCodeSetting">
            <svg viewBox="0 0 48 48" width="40" height="40"><rect x="8" y="4" width="32" height="38" rx="3" fill="#E6F7FF" stroke="#1890FF" stroke-width="1.5"/><path d="M16 14h16v8H16zM16 26h16v12H16z" fill="#1890FF" opacity="0.15" stroke="#1890FF" stroke-width="1"/></svg>
            <span class="favorite-text">仓库代号设定</span>
        </div>
    }
    @if (showFavoriteStorageLocationDetail)
    {
        <div class="db-favorite-item" @onclick="NavigateToStorageLocationDetail">
            <svg viewBox="0 0 48 48" width="40" height="40"><rect x="8" y="4" width="32" height="38" rx="3" fill="#FFF7E6" stroke="#FA8C16" stroke-width="1.5"/><rect x="14" y="12" width="8" height="8" rx="1" fill="#FA8C16" opacity="0.25"/><rect x="26" y="12" width="8" height="8" rx="1" fill="#FA8C16" opacity="0.25"/><rect x="14" y="24" width="8" height="8" rx="1" fill="#FA8C16" opacity="0.25"/><rect x="26" y="24" width="8" height="8" rx="1" fill="#FA8C16" opacity="0.25"/><rect x="14" y="36" width="8" height="4" rx="1" fill="#FA8C16" opacity="0.25"/><rect x="26" y="36" width="8" height="4" rx="1" fill="#FA8C16" opacity="0.25"/></svg>
            <span class="favorite-text">储位明细</span>
        </div>
    }
    @if (showFavoriteWarehouseArrivalConfirm)
    {
        <div class="db-favorite-item" @onclick="NavigateToWarehouseArrivalConfirm">
            <svg viewBox="0 0 48 48" width="40" height="40"><rect x="8" y="4" width="32" height="38" rx="3" fill="#F6FFED" stroke="#52C41A" stroke-width="1.5"/><path d="M16 24l6 6 10-12" stroke="#52C41A" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span class="favorite-text">到货确认</span>
        </div>
    }

    @* ===== 基础资料-策略 ===== *@
    @if (showFavoriteWaveStrategy)
    {
        <div class="db-favorite-item" @onclick="NavigateToWaveStrategy">
            <svg viewBox="0 0 48 48" width="40" height="40"><rect x="8" y="4" width="32" height="38" rx="3" fill="#FFF1F0" stroke="#F5222D" stroke-width="1.5"/><path d="M16 28c0-6 4-10 8-14s8-4 8 0" stroke="#F5222D" stroke-width="2.5" fill="none"/></svg>
            <span class="favorite-text">波次策略</span>
        </div>
    }
    @if (showFavoritePickStrategy)
    {
        <div class="db-favorite-item" @onclick="NavigateToPickStrategy">
            <svg viewBox="0 0 48 48" width="40" height="40"><rect x="8" y="4" width="32" height="38" rx="3" fill="#E6F7FF" stroke="#1890FF" stroke-width="1.5"/><path d="M18 32l6-10 6 10H18z" fill="#1890FF" opacity="0.2" stroke="#1890FF" stroke-width="1.5"/></svg>
            <span class="favorite-text">拣货策略</span>
        </div>
    }
    @if (showFavoriteUnshelveStrategy)
    {
        <div class="db-favorite-item" @onclick="NavigateToUnshelveStrategy">
            <svg viewBox="0 0 48 48" width="40" height="40"><rect x="8" y="4" width="32" height="38" rx="3" fill="#FFF7E6" stroke="#FA8C16" stroke-width="1.5"/><path d="M18 16l6 14 6-14H18z" fill="#FA8C16" opacity="0.2" stroke="#FA8C16" stroke-width="1.5"/></svg>
            <span class="favorite-text">下架策略</span>
        </div>
    }

    @* ===== 基础资料-其他 ===== *@
    @if (showFavoriteDeptSetting)
    {
        <div class="db-favorite-item" @onclick="NavigateToDeptSetting">
            <svg viewBox="0 0 48 48" width="40" height="40"><rect x="8" y="4" width="32" height="38" rx="3" fill="#F9F0FF" stroke="#722ED1" stroke-width="1.5"/><circle cx="24" cy="20" r="6" stroke="#722ED1" stroke-width="2" fill="none"/><path d="M24 28v8M20 33h8" stroke="#722ED1" stroke-width="2" stroke-linecap="round"/></svg>
            <span class="favorite-text">部门设定</span>
        </div>
    }
    @if (showFavoriteDocTypeSetting)
    {
        <div class="db-favorite-item" @onclick="NavigateToDocTypeSetting">
            <svg viewBox="0 0 48 48" width="40" height="40"><rect x="8" y="4" width="32" height="38" rx="3" fill="#E6F7FF" stroke="#1890FF" stroke-width="1.5"/><path d="M16 14h16M16 22h12M16 30h14" stroke="#1890FF" stroke-width="2" stroke-linecap="round"/></svg>
            <span class="favorite-text">单据类别设定</span>
        </div>
    }
    @if (showFavoriteCountReasonSetting)
    {
        <div class="db-favorite-item" @onclick="NavigateToCountReasonSetting">
            <svg viewBox="0 0 48 48" width="40" height="40"><rect x="8" y="4" width="32" height="38" rx="3" fill="#FFF1F0" stroke="#F5222D" stroke-width="1.5"/><path d="M18 18l12 12M30 18L18 30" stroke="#F5222D" stroke-width="2.5" stroke-linecap="round"/></svg>
            <span class="favorite-text">查盘/原因设定</span>
        </div>
    }
    @if (showFavoriteNoticeSetting)
    {
        <div class="db-favorite-item" @onclick="NavigateToNoticeSetting">
            <svg viewBox="0 0 48 48" width="40" height="40"><rect x="8" y="4" width="32" height="38" rx="3" fill="#FFF7E6" stroke="#FA8C16" stroke-width="1.5"/><path d="M24 14v8h8" stroke="#FA8C16" stroke-width="2.5" fill="none" stroke-linecap="round"/><circle cx="24" cy="26" r="10" stroke="#FA8C16" stroke-width="2" fill="none"/></svg>
            <span class="favorite-text">消息通知设定</span>
        </div>
    }
    @if (showFavoriteIndustryCodeSetting)
    {
        <div class="db-favorite-item" @onclick="NavigateToIndustryCodeSetting">
            <svg viewBox="0 0 48 48" width="40" height="40"><rect x="8" y="4" width="32" height="38" rx="3" fill="#F6FFED" stroke="#52C41A" stroke-width="1.5"/><path d="M16 18h16v4H16zM16 26h12v4H16zM16 34h14v4H14z" fill="#52C41A" opacity="0.2"/></svg>
            <span class="favorite-text">行业代号设定</span>
        </div>
    }
    @if (showFavoriteForkliftManagement)
    {
        <div class="db-favorite-item" @onclick="NavigateToForkliftManagement">
            <svg viewBox="0 0 48 48" width="40" height="40"><rect x="8" y="4" width="32" height="38" rx="3" fill="#E6F7FF" stroke="#1890FF" stroke-width="1.5"/><path d="M18 28h12M24 22v12M18 20h12" stroke="#1890FF" stroke-width="2.5" stroke-linecap="round"/></svg>
            <span class="favorite-text">叉车车号管理</span>
        </div>
    }
    @if (showFavoriteBatchNoPickingSetting)
    {
        <div class="db-favorite-item" @onclick="NavigateToBatchNoPickingSetting">
            <svg viewBox="0 0 48 48" width="40" height="40"><rect x="8" y="4" width="32" height="38" rx="3" fill="#FFF0F6" stroke="#EB2F96" stroke-width="1.5"/><circle cx="20" cy="20" r="4" stroke="#EB2F96" stroke-width="2" fill="none"/><circle cx="30" cy="28" r="4" stroke="#EB2F96" stroke-width="2" fill="none"/><path d="M23 22l4 4" stroke="#EB2F96" stroke-width="2"/></svg>
            <span class="favorite-text">批号设置</span>
        </div>
    }

    @if (!showFavoriteInboundNotice && !showFavoriteInboundOrder && !showFavoriteInboundNoticeChange &&
         !showFavoriteProductCodeSetting && !showFavoriteMidClassSetting && !showFavoriteStorageNatureSetting &&
         !showFavoriteProductAttrSetting && !showFavoriteProductMarkSetting && !showFavoriteWarehouseCodeSetting &&
         !showFavoriteStorageLocationDetail && !showFavoriteWarehouseArrivalConfirm && !showFavoriteWaveStrategy &&
         !showFavoritePickStrategy && !showFavoriteUnshelveStrategy && !showFavoriteDeptSetting &&
         !showFavoriteDocTypeSetting && !showFavoriteCountReasonSetting && !showFavoriteNoticeSetting &&
         !showFavoriteIndustryCodeSetting && !showFavoriteForkliftManagement && !showFavoriteBatchNoPickingSetting)
    {
        <div style="padding:20px;text-align:center;color:#999999;font-size:13px;">
            点击页面左上角星标收藏常用功能
        </div>
    }
</div>

<!-- 仓库视图卡片 -->
<div class="db-card">
    <div class="db-card-title">
        <span>仓库概况</span>
    </div>

    <!-- 三列信息卡片 -->
    <div class="db-info-cards">
        <!-- 入库信息 -->
        <div class="db-info-card">
            <div class="db-info-card-title">入库信息</div>
            <div class="db-info-item">
                <span class="db-info-label">当日待入库</span>
                <span class="db-info-number">0</span>
                <span class="db-info-unit">单</span>
            </div>
            <div class="db-info-item">
                <span class="db-info-label">当日已入库</span>
                <span class="db-info-number">0</span>
                <span class="db-info-unit">单</span>
            </div>
        </div>

        <!-- 出库信息 -->
        <div class="db-info-card">
            <div class="db-info-card-title">出库信息</div>
            <div class="db-info-item">
                <span class="db-info-label">当日待出库</span>
                <span class="db-info-number">0</span>
                <span class="db-info-unit">单</span>
            </div>
            <div class="db-info-item">
                <span class="db-info-label">当日已出库</span>
                <span class="db-info-number">0</span>
                <span class="db-info-unit">单</span>
            </div>
        </div>

        <!-- 储位信息 -->
        <div class="db-info-card">
            <div class="db-info-card-title">储位信息</div>
            <div class="db-info-disabled">
                <svg class="db-no-data-icon" viewBox="0 0 48 48" width="64" height="64" fill="none">
                    <path d="M24 4C12.954 4 4 12.954 4 24s8.954 20 20 20 20-8.954 20-20S35.046 4 24 4z" fill="#F5F5F5"/>
                    <path d="M24 14v10m0 6h.01" stroke="#D9D9D9" stroke-width="2.5" stroke-linecap="round"/>
                </svg>
                <span class="db-no-data-text">无信息</span>
            </div>
        </div>
    </div>

    <!-- 近7天收发状况 -->
    <div class="db-chart-section">
        <div class="db-chart-header">
            <span class="db-chart-title">近7天收发状况</span>
            <select class="db-chart-select">
                <option value="all">全部</option>
                <option value="picking">待拣货</option>
                <option value="picking_ing">拣货中</option>
                <option value="outbound">待出库</option>
                <option value="done">已出库</option>
            </select>
        </div>

        <div class="db-chart-area">
            <!-- 左侧环形图 -->
            <div class="db-chart-left">
                <svg class="db-donut-chart" viewBox="0 0 200 200">
                    <!-- 背景圆环 -->
                    <circle cx="100" cy="100" r="70" fill="none" stroke="#F0F0F0" stroke-width="25"/>
                    
                    <!-- 蓝色段 - 待接货 -->
                    <circle cx="100" cy="100" r="70" fill="none" 
                            stroke="#1890FF" 
                            stroke-width="25"
                            stroke-dasharray="110 329.87"
                            stroke-dashoffset="-82.47"
                            transform="rotate(-90 100 100)"/>
                    
                    <!-- 黄色段 - 拣货中 -->
                    <circle cx="100" cy="100" r="70" fill="none" 
                            stroke="#FAAD14" 
                            stroke-width="25"
                            stroke-dasharray="109.96 329.87"
                            stroke-dashoffset="-192.43"
                            transform="rotate(-90 100 100)"/>
                    
                    <!-- 绿色段 - 待出库 -->
                    <circle cx="100" cy="100" r="70" fill="none" 
                            stroke="#52C41A" 
                            stroke-width="25"
                            stroke-dasharray="109.96 329.87"
                            stroke-dashoffset="-302.39"
                            transform="rotate(-90 100 100)"/>
                    
                    <!-- 红色段 - 已出库 -->
                    <circle cx="100" cy="100" r="70" fill="none" 
                            stroke="#FF4D4F" 
                            stroke-width="25"
                            stroke-dasharray="0 329.87"
                            stroke-dashoffset="-412.35"
                            transform="rotate(-90 100 100)"/>
                    
                    <!-- 中心文字 -->
                    <text x="100" y="95" text-anchor="middle" font-size="13" fill="#666666" font-weight="500">出库状况</text>
                    <text x="100" y="115" text-anchor="middle" font-size="11" fill="#999999">暂无数据</text>
                    
                    <!-- 图例 -->
                    <g transform="translate(22, 185)">
                        <rect width="10" height="10" rx="2" fill="#1890FF"/>
                        <text x="14" y="9" font-size="11" fill="#666666">待处理</text>
                        
                        <rect x="65" width="10" height="10" rx="2" fill="#FAAD14"/>
                        <text x="79" y="9" font-size="11" fill="#666666">拣货中</text>
                        
                        <rect x="125" width="10" height="10" rx="2" fill="#52C41A"/>
                        <text x="139" y="9" font-size="11" fill="#666666">待出库</text>
                        
                        <rect x="-21" y="18" width="10" height="10" rx="2" fill="#FF4D4F"/>
                        <text x="-7" y="27" font-size="11" fill="#666666">已出库</text>
                    </g>
                </svg>
            </div>

            <!-- 右侧数据表格 -->
            <div class="db-chart-right">
                <table class="db-table">
                    <thead>
                        <tr>
                            <th>业务类型</th>
                            <th>出库通知单号</th>
                            <th>申请单号</th>
                            <th>出库状态</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td colspan="4" class="db-table-empty">
                                <svg class="db-table-empty-icon" viewBox="0 0 48 48" width="48" height="48" fill="none">
                                    <path d="M24 4C12.954 4 4 12.954 4 24s8.954 20 20 20 20-8.954 20-20S35.046 4 24 4z" fill="#FAFAFA"/>
                                    <path d="M24 14v10m0 6h.01" stroke="#D9D9D9" stroke-width="2" stroke-linecap="round"/>
                                </svg>
                                <div>
                                    <p class="db-table-empty-text">暂无数据</p>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@code {
    // ===== 原有3个业务单据收藏 =====
    private bool showFavoriteInboundNotice = false;
    private bool showFavoriteInboundOrder = false;
    private bool showFavoriteInboundNoticeChange = false;

    // ===== 基础资料-货品（5个）=====
    private bool showFavoriteProductCodeSetting = false;
    private bool showFavoriteMidClassSetting = false;
    private bool showFavoriteStorageNatureSetting = false;
    private bool showFavoriteProductAttrSetting = false;
    private bool showFavoriteProductMarkSetting = false;

    // ===== 基础资料-仓库（3个）=====
    private bool showFavoriteWarehouseCodeSetting = false;
    private bool showFavoriteStorageLocationDetail = false;
    private bool showFavoriteWarehouseArrivalConfirm = false;

    // ===== 基础资料-策略（3个）=====
    private bool showFavoriteWaveStrategy = false;
    private bool showFavoritePickStrategy = false;
    private bool showFavoriteUnshelveStrategy = false;

    // ===== 基础资料-其他（7个）=====
    private bool showFavoriteDeptSetting = false;
    private bool showFavoriteDocTypeSetting = false;
    private bool showFavoriteCountReasonSetting = false;
    private bool showFavoriteNoticeSetting = false;
    private bool showFavoriteIndustryCodeSetting = false;
    private bool showFavoriteForkliftManagement = false;
    private bool showFavoriteBatchNoPickingSetting = false;

    private int _lastFavoriteVersion = -1;

    [CascadingParameter(Name = "OpenTabCallback")] public Action<string, string>? OpenTabCallback { get; set; }
    [CascadingParameter(Name = "FavoriteVersion")] public int FavoriteVersion { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadAllFavorites();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender || FavoriteVersion != _lastFavoriteVersion)
        {
            _lastFavoriteVersion = FavoriteVersion;
            await LoadAllFavorites();
            StateHasChanged();
        }
    }

    private async Task LoadAllFavorites()
    {
        try
        {
            // 业务单据（原有）
            var r1 = await JS.InvokeAsync<string>("localStorage.getItem", "wms_favorite_inbound_notice"); showFavoriteInboundNotice = r1 == "true";
            var r2 = await JS.InvokeAsync<string>("localStorage.getItem", "wms_favorite_inbound_order"); showFavoriteInboundOrder = r2 == "true";
            var r3 = await JS.InvokeAsync<string>("localStorage.getItem", "wms_favorite_inbound_notice_change"); showFavoriteInboundNoticeChange = r3 == "true";

            // 基础资料-货品
            var r4 = await JS.InvokeAsync<string>("localStorage.getItem", "wms_favorite_product_code_setting"); showFavoriteProductCodeSetting = r4 == "true";
            var r5 = await JS.InvokeAsync<string>("localStorage.getItem", "wms_favorite_mid_class_setting"); showFavoriteMidClassSetting = r5 == "true";
