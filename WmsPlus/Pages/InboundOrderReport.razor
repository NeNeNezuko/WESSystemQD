                        </tbody>
                    </table>
                    <div class="prd-pagination"><span class="prd-total-info">共 @productTotalCount 笔记录</span><div class="prd-page-controls"><button class="prd-page-btn" disabled="@(productPageIndex <= 1)" @click="async () => await GoToPrdPage(productPageIndex - 1)">&lt;</button><input type="number" class="prd-page-input" value="@productPageIndex" min="1" max="@PrdTotalPages" @change="async (ChangeEventArgs e) => { if(int.TryParse(e.Value?.ToString(), out var p)) await GoToPrdPage(p); }" /><span>/ @PrdTotalPages</span><button class="prd-page-btn" disabled="@(productPageIndex >= PrdTotalPages)" @click="async () => await GoToPrdPage(productPageIndex + 1)">&gt;</button></div></div>
                </div>
            </div>
