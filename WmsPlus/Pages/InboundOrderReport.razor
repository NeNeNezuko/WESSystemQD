    }

    private async Task ExportToExcel()
    {
        if (activeReportTab == "detail")
        {
            var visibleCols = detailColumnConfigs.Where(c => c.Visible).ToList();
            var headers = visibleCols.Select(c => c.DisplayName).ToArray();
            var rows = new List<object[]>();
            rows.Add(headers);
            foreach (var item in detailDataSource)
            {
                var row = new object[visibleCols.Count];
                for (int i = 0; i < visibleCols.Count; i++)
                    row[i] = GetDetailCellValue(item, visibleCols[i].FieldKey);
                rows.Add(row);
            }
            var fileName = string.IsNullOrWhiteSpace(exportFileName) ? $"入库单报表_明细_{DateTime.Now:yyyyMMddHHmmss}" : exportFileName;
            if (!fileName.EndsWith(".xlsx", StringComparison.OrdinalIgnoreCase)) fileName += ".xlsx";
            await JS.InvokeVoidAsync("exportToExcel", rows, fileName);
        }
        else
        {
            var visibleCols = statsColumnConfigs.Where(c => c.Visible).ToList();
            var headers = visibleCols.Select(c => c.DisplayName).ToArray();
            var rows = new List<object[]>();
            rows.Add(headers);
            foreach (var item in statsDataSource)
            {
                var row = new object[visibleCols.Count];
                for (int i = 0; i < visibleCols.Count; i++)
                    row[i] = GetStatsCellValue(item, visibleCols[i].FieldKey);
                rows.Add(row);
            }
            var fileName = string.IsNullOrWhiteSpace(exportFileName) ? $"入库单报表_统计_{DateTime.Now:yyyyMMddHHmmss}" : exportFileName;
            if (!fileName.EndsWith(".xlsx", StringComparison.OrdinalIgnoreCase)) fileName += ".xlsx";
            await JS.InvokeVoidAsync("exportToExcel", rows, fileName);
        }
