    {
        showStatsColumnSettingsDialog = false;
        _ = LoadStatsColumnSettings();
        StateHasChanged();
    }

    private void SelectAllStatsColumns()
    {
        foreach (var col in statsColumnConfigs)
            col.Visible = true;
        StateHasChanged();
    }

    private void RestoreDefaultStatsColumns()
    {
        for (int i = 0; i < statsColumnConfigs.Count && i < statsDefaultColumnConfigs.Count; i++)
        {
            statsColumnConfigs[i].Visible = statsDefaultColumnConfigs[i].Visible;
            statsColumnConfigs[i].DisplayName = statsDefaultColumnConfigs[i].DisplayName;
            statsColumnConfigs[i].Width = statsDefaultColumnConfigs[i].Width;
        }
        StateHasChanged();
    }

    private List<ColumnConfig> FilteredStatsColumnConfigs =>
        string.IsNullOrWhiteSpace(statsColumnSearchKeyword)
            ? statsColumnConfigs
            : statsColumnConfigs.Where(c => c.OriginalName.Contains(statsColumnSearchKeyword, StringComparison.OrdinalIgnoreCase) ||
                                            c.FieldKey.Contains(statsColumnSearchKeyword, StringComparison.OrdinalIgnoreCase)).ToList();

    private int StatsVisibleColumnCount => statsColumnConfigs.Count(c => c.Visible);

