    // ===== 货品选择器状态 =====
    private bool showProductDialog = false;
    private string activePrdSelector = "";
    private string productSearchKeyword = "";
    private List<PrdItem> productData = new();
    private int productPageIndex = 1;
    private int productPageSize = 20;
    private int productTotalCount = 0;

    private class PrdItem
    {
        public string PRD_NO { get; set; } = "";
        public string NAME { get; set; } = "";
        public string SNM { get; set; } = "";
        public string UT { get; set; } = "";
    }

    private class PrdSearchResult
    {
        public List<PrdItem>? Items { get; set; }
        public int TotalCount { get; set; }
    }

    private async Task OpenPrdFromSelector()
    {
        activePrdSelector = "from";
        productSearchKeyword = ""; productPageIndex = 1;
        await SearchProduct(); showProductDialog = true; StateHasChanged();
    }

    private async Task OpenPrdToSelector()
    {
        activePrdSelector = "to";
        productSearchKeyword = ""; productPageIndex = 1;
        await SearchProduct(); showProductDialog = true; StateHasChanged();
    }

    private void CloseProductSelector() { showProductDialog = false; StateHasChanged(); }

    private async Task SearchProduct()
    {
        try
        {
            var url = $"{ApiConfig.BaseUrl}/api/warehouse/prdsearch?keyword={Uri.EscapeDataString(productSearchKeyword ?? "")}&pageIndex={productPageIndex}&pageSize={productPageSize}";
            var jsonOptions = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var request = AuthHttpClient.CreateRequest(HttpMethod.Get, url, TokenProvider.Token);
            var responseMsg = await Http.SendAsync(request);
            if (responseMsg.IsSuccessStatusCode)
            {
                var json = await responseMsg.Content.ReadAsStringAsync();
                var result = System.Text.Json.JsonSerializer.Deserialize<PrdSearchResult>(json, jsonOptions);
                if (result != null) { productData = result.Items ?? new List<PrdItem>(); productTotalCount = result.TotalCount; }
            }
        }
        catch (Exception ex) { Console.WriteLine($"[InboundOrderReport] 查询货品数据失败: {ex.Message}"); }
        StateHasChanged();
    }

    private void SelectProduct(PrdItem item)
    {
        if (activePrdSelector == "from") query.PrdNoFrom = item.PRD_NO;
        else if (activePrdSelector == "to") query.PrdNoTo = item.PRD_NO;
        showProductDialog = false; StateHasChanged();
    }

    private int PrdTotalPages => productPageSize > 0 ? (int)Math.Ceiling((double)productTotalCount / productPageSize) : 1;

    private async Task GoToPrdPage(int page)
    {
        if (page >= 1 && page <= PrdTotalPages) { productPageIndex = page; await SearchProduct(); }
    }
}
