    private async Task HandleSearch()
    {
        if (activeReportTab == "detail")
            await LoadDetailData();
        else
            await LoadStatsData();
    }

    private async Task LoadDetailData()
    {
        try
        {

            // 解析DateRange
            var dateFromStr = "";
            var dateToStr = "";
            if (!string.IsNullOrWhiteSpace(query.DateRange) && query.DateRange.Contains("→"))
            {
                var parts = query.DateRange.Split("→", StringSplitOptions.TrimEntries);
                if (parts.Length >= 2)
                {
                    dateFromStr = parts[0];
                    dateToStr = parts[1];
                }
            }

            // 构建URL
            var url = $"{ApiConfig.BaseUrl}/api/InboundOrderReport/detailSearch?dateFrom={dateFromStr}&dateTo={dateToStr}";
            if (!string.IsNullOrWhiteSpace(query.ErpApNo)) url += $"&erpApNo={Uri.EscapeDataString(query.ErpApNo)}";
            url += $"&erpApNoFuzzy={query.ErpApNoFuzzy}";
            if (!string.IsNullOrWhiteSpace(query.BilNoFrom)) url += $"&bilNoFrom={Uri.EscapeDataString(query.BilNoFrom)}";
            if (!string.IsNullOrWhiteSpace(query.BilNoTo)) url += $"&bilNoTo={Uri.EscapeDataString(query.BilNoTo)}";
            if (!string.IsNullOrWhiteSpace(query.PrdNoFrom)) url += $"&prdNoFrom={Uri.EscapeDataString(query.PrdNoFrom)}";
            if (!string.IsNullOrWhiteSpace(query.PrdNoTo)) url += $"&prdNoTo={Uri.EscapeDataString(query.PrdNoTo)}";
            if (!string.IsNullOrWhiteSpace(query.PrdName)) url += $"&prdName={Uri.EscapeDataString(query.PrdName)}";
            url += $"&prdNameFuzzy={query.PrdNameFuzzy}";
            if (!string.IsNullOrWhiteSpace(query.WhName)) url += $"&whName={Uri.EscapeDataString(query.WhName)}";
            url += $"&whNameFuzzy={query.WhNameFuzzy}";
            if (!string.IsNullOrWhiteSpace(query.ChuwFrom)) url += $"&chuwFrom={Uri.EscapeDataString(query.ChuwFrom)}";
            if (!string.IsNullOrWhiteSpace(query.ChuwTo)) url += $"&chuwTo={Uri.EscapeDataString(query.ChuwTo)}";
            url += $"&pageIndex={detailPageIndex}&pageSize={detailPageSize}";

            var jsonOptions = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var request = AuthHttpClient.CreateRequest(HttpMethod.Get, url, TokenProvider.Token);
            var responseMsg = await Http.SendAsync(request);
            var response = await responseMsg.Content.ReadFromJsonAsync<ApiResponse<List<InboundOrderReportDetailItem>>>(jsonOptions);
            if (response != null && response.Success && response.Data != null)
            {
                detailDataSource = response.Data;
                detailTotalCount = response.Total > 0 ? response.Total : response.Data.Count;
                totalCount = detailTotalCount;
            }
            else
            {
                detailDataSource = new List<InboundOrderReportDetailItem>();
                detailTotalCount = 0;
                totalCount = 0;
            }
        }
        catch (Exception ex)
        {
            _logger?.LogError(ex, "加载入库单报表明细数据失败");
            detailDataSource = new List<InboundOrderReportDetailItem>();
            detailTotalCount = 0;
            totalCount = 0;
        }
        StateHasChanged();
    }

