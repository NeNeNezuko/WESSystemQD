@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@inject HttpClient Http
@inject ILogger<InboundOrderReport> _logger
@inject TokenProvider TokenProvider


<div class="inbound-order-report-page" style="display:flex;flex-direction:column;flex:1 1 0%;overflow:hidden;">
    <!-- 顶部标题栏 -->
    <div class="page-header">
        <div class="header-left">
            <button class="favorite-btn @(isFavorited ? "favorited" : "")" @onclick="ToggleFavorite" title="收藏">
                <svg viewBox="0 0 24 24" width="24" height="24">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
                          fill="@((isFavorited ? "#FFD700" : "none"))"
                          stroke="@((isFavorited ? "#FFD700" : "#666666"))"
                          stroke-width="2"/>
                </svg>
            </button>
            <span class="page-title">入库单报表/查询</span>
        </div>
        <div class="header-right">
            <button class="header-toolbar-btn" @onclick="HandleTypeConfig">
                <svg viewBox="0 0 16 16" width="14" height="14" fill="#666666">
                    <rect x="1" y="2" width="6" height="5" rx="1" stroke="#666666" stroke-width="1.2" fill="none"/>
                    <rect x="9" y="2" width="6" height="5" rx="1" stroke="#666666" stroke-width="1.2" fill="none"/>
                    <rect x="1" y="9" width="6" height="5" rx="1" stroke="#666666" stroke-width="1.2" fill="none"/>
                    <rect x="9" y="9" width="6" height="5" rx="1" stroke="#666666" stroke-width="1.2" fill="none"/>
                </svg>
                <span>类别</span>
            </button>
            <button class="header-toolbar-btn" @onclick="HandleExport">
                <svg viewBox="0 0 16 16" width="14" height="14" fill="#666666">
                    <path d="M8 12V4m0 0L5 7m3-3l3 3" stroke="#666666" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M2 11v2a1 1 0 001 1h10a1 1 0 001-1v-2" stroke="#666666" stroke-width="1.5" fill="none" stroke-linecap="round"/>
                </svg>
                <span>导出Excel</span>
            </button>
            <button class="header-toolbar-btn" @onclick="HandlePrint">
                <svg viewBox="0 0 16 16" width="14" height="14" fill="#666666">
                    <path d="M4 2h8v3H4V2zm10 4H2v7h12V6zM5 13v2h6v-2" stroke="#666666" stroke-width="1.2" fill="none" stroke-linejoin="round"/>
                </svg>
                <span>打印</span>
            </button>
            <button class="header-toolbar-btn" @onclick="HandleColumnDesign">
                <svg viewBox="0 0 16 16" width="14" height="14" fill="#666666">
                    <path d="M2 3h12v2H2V3zm0 4h12v2H2V7zm0 4h12v2H2v-2z" stroke="#666666" stroke-width="1" fill="none"/>
                </svg>
                <span>类型设计</span>
            </button>
            <button class="collapse-btn-fixed @(isCollapsed ? "collapsed" : "")" @onclick="ToggleCollapse" title="@(isCollapsed ? "展开查询" : "收起查询")">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="#666666">
                    <rect x="3" y="6" width="18" height="2" rx="1"/>
                    <rect x="3" y="11" width="18" height="2" rx="1"/>
                    <rect x="3" y="16" width="18" height="2" rx="1"/>
                </svg>
            </button>
        </div>
    </div>

    <!-- 收藏成功提示 -->
    @if (showFavoriteSuccess)
    {
        <div class="favorite-success-toast">
            <div class="toast-content">
                <svg viewBox="0 0 16 16" width="16" height="16" fill="#52C41A">
                    <circle cx="8" cy="8" r="8"/>
                    <path d="M5 8l2 2 4-4" stroke="white" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>收藏成功</span>
            </div>
        </div>
    }

    <!-- 主内容区域 -->
    <div class="page-content">
        <!-- 左侧查询区域 -->
        <div class="query-panel @(isCollapsed ? "collapsed" : "")">
            <div class="query-header">
                <span class="query-title">查询</span>
                <button class="query-settings-btn" title="设置" @onclick="ToggleSettingsMenu">
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="#999999" stroke-width="2">
                        <circle cx="12" cy="12" r="3"/>
                        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/>
                    </svg>
                </button>
                @if (showSettingsMenu)
                {
                    <div class="settings-dropdown" @onclick:stopPropagation>
                        <div class="settings-dropdown-item" @onclick="BatchAddCondition">批次添加条件</div>
                        <div class="settings-dropdown-item" @onclick="AddSingleCondition">添加单一条件</div>
                        <div class="settings-dropdown-item" @onclick="CustomCondition">自定义条件</div>
                        <div class="settings-dropdown-item" @onclick="RemoveCondition">移除条件</div>
                        <div class="settings-dropdown-item" @onclick="SaveConditionValues">保存条件值</div>
                    </div>
                }
            </div>

            <div class="query-form">
                <!-- 制表日期 - 日期范围选择器 -->
                <DateRangeInput @bind-Value="query.DateRange" Label="制表日期" />

                <!-- ERP申请单号 + 模糊复选框 -->
                <div class="form-item">
                    <label class="form-label">ERP申请单号</label>
                    <div class="input-with-fuzzy">
                        <input type="text" class="form-input" placeholder="" @bind="query.ErpApNo" />
                        <label class="fuzzy-checkbox">
                            <input type="checkbox" @bind="query.ErpApNoFuzzy" />
                            <span>模糊</span>
                        </label>
                    </div>
                </div>

                <!-- 单据号码 起/止 -->
                <div class="form-item-fused">
                    <div class="fused-row">
                        <label class="form-label">单据号码 起</label>
                        <input type="text" class="fused-input" placeholder="" @bind="query.BilNoFrom" />
                    </div>
                    <div class="fused-divider"></div>
                    <div class="fused-row">
                        <label class="form-label">单据号码 止</label>
                        <input type="text" class="fused-input" placeholder="" @bind="query.BilNoTo" />
                    </div>
                </div>

                <!-- 货品代号 起/止 -->
                <div class="form-item-fused">
                    <div class="fused-row">
                        <label class="form-label">货品代号 起</label>
                        <div class="fused-input-area">
                            <input type="text" class="fused-input" placeholder="" @bind="query.PrdNoFrom" />
                            <button class="fused-search-btn" title="选择货品" @onclick="OpenPrdFromSelector">
                                <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="#999999" stroke-width="1.5">
                                    <circle cx="7" cy="7" r="5"/><line x1="11" y1="11" x2="15" y2="15"/>
                                </svg>
                            </button>
                        </div>
                    </div>
                    <div class="fused-divider"></div>
                    <div class="fused-row">
                        <label class="form-label">货品代号 止</label>
                        <div class="fused-input-area">
                            <input type="text" class="fused-input" placeholder="" @bind="query.PrdNoTo" />
                            <button class="fused-search-btn" title="选择货品" @onclick="OpenPrdToSelector">
                                <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="#999999" stroke-width="1.5">
                                    <circle cx="7" cy="7" r="5"/><line x1="11" y1="11" x2="15" y2="15"/>
                                </svg>
                            </button>
                        </div>
                    </div>
                </div>

                <!-- 货品名称 + 模糊复选框 -->
                <div class="form-item">
                    <label class="form-label">货品名称</label>
                    <div class="input-with-fuzzy">
                        <input type="text" class="form-input" placeholder="" @bind="query.PrdName" />
                        <label class="fuzzy-checkbox">
                            <input type="checkbox" @bind="query.PrdNameFuzzy" />
                            <span>模糊</span>
                        </label>
                    </div>
                </div>

                <!-- 仓库名称 + 模糊复选框 -->
                <div class="form-item">
                    <label class="form-label">仓库名称</label>
                    <div class="input-with-fuzzy">
                        <input type="text" class="form-input" placeholder="" @bind="query.WhName" />
                        <label class="fuzzy-checkbox">
                            <input type="checkbox" @bind="query.WhNameFuzzy" />
                            <span>模糊</span>
                        </label>
                    </div>
                </div>

                <!-- 储位代号 起/止 -->
                <div class="form-item-fused">
                    <div class="fused-row">
                        <label class="form-label">储位代号 起</label>
                        <input type="text" class="fused-input" placeholder="" @bind="query.ChuwFrom" />
                    </div>
                    <div class="fused-divider"></div>
                    <div class="fused-row">
                        <label class="form-label">储位代号 止</label>
                        <input type="text" class="fused-input" placeholder="" @bind="query.ChuwTo" />
                    </div>
                </div>

                <!-- 查询按钮 -->
                <div class="form-item query-btn-wrapper">
                    <button class="query-submit-btn" @onclick="HandleSearch">
                        <svg viewBox="0 0 16 16" width="16" height="16" fill="white" stroke="white" stroke-width="1.5">
                            <circle cx="7" cy="7" r="5"/>
                            <line x1="11" y1="11" x2="15" y2="15"/>
                        </svg>
                        <span>查询</span>
                    </button>
                </div>
            </div>
        </div>

        <!-- 右侧数据表格区域 -->
        <div class="table-panel">
            <!-- 工具栏 -->
            <div class="table-toolbar">
                <div class="toolbar-left">
                </div>
                <div class="toolbar-right"></div>
            </div>

            <!-- 嵌套选项卡导航 -->
            <div class="inner-tab-bar-inline">
                <div class="inner-tab-item @(activeReportTab == "detail" ? "active" : "")" @onclick='() => SwitchReportTab("detail")'>明细表</div>
                <div class="inner-tab-item @(activeReportTab == "stats" ? "active" : "")" @onclick='() => SwitchReportTab("stats")'>统计表</div>
            </div>

            <!-- 数据表格区域 -->
            <div class="data-table-container">
                @if (activeReportTab == "detail")
                {
                    <!-- 明细表 -->
                    <table class="data-table">
                        <thead>
                            <tr>
                                @foreach (var col in detailColumnConfigs.Where(c => c.Visible))
                                {
                                    var widthStyle = col.Width > 0 ? $"width:{col.Width}px" : "";
                                    <th style="@widthStyle">@col.DisplayName</th>
                                }
                                <th class="col-action" style="display:flex;align-items:center;justify-content:space-between;white-space:nowrap;">
                                    <span>操作</span>
                                    <button class="column-settings-btn" title="栏位设置" @onclick="OpenDetailColumnSettings">
                                        <svg viewBox="0 0 16 16" width="14" height="14" fill="#666666">
                                            <path d="M2 3h4v2H2V3zm0 4h4v2H2V7zm0 4h4v2H2v-2zm6-8h6v2H8V3zm0 4h6v2H8V7zm0 4h6v2H8v-2z"/>
                                        </svg>
                                    </button>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (detailDataSource.Count == 0)
                            {
                                <tr><td colspan="@(DetailVisibleColumnCount + 1)" class="empty-data-cell"><div class="empty-data"><svg viewBox="0 0 64 64" width="80" height="80" fill="none"><rect x="8" y="8" width="48" height="48" rx="8" fill="#F5F5F5" stroke="#E0E0E0" stroke-width="1"/><path d="M24 28h16M24 36h12" stroke="#D9D9D9" stroke-width="2" stroke-linecap="round"/></svg><p class="empty-text">暂无数据</p></div></td></tr>
                            }
                            else
                            {
                                @foreach (var item in detailDataSource)
                                {
                                    var rowIdx = detailDataSource.IndexOf(item) + 1;
                                    <tr>
                                        <td style="width:45px">@rowIdx</td>
                                        @foreach (var col in detailColumnConfigs.Where(c => c.Visible).Skip(1))
                                        {
                                            var widthStyle = col.Width > 0 ? $"width:{col.Width}px" : "";
                                            <td style="@widthStyle">@GetDetailCellValue(item, col.FieldKey)</td>
                                        }
                                        <td><button class="action-btn" title="操作"><svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="#1890FF" stroke-width="1.5"><circle cx="8" cy="3" r="1" fill="#1890FF"/><circle cx="8" cy="8" r="1" fill="#1890FF"/><circle cx="8" cy="13" r="1" fill="#1890FF"/></svg></button></td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                }
                else if (activeReportTab == "stats")
                {
                    <!-- 统计表 -->
                    <table class="data-table">
                        <thead>
                            <tr>
                                @foreach (var col in statsColumnConfigs.Where(c => c.Visible))
                                {
                                    var widthStyle = col.Width > 0 ? $"width:{col.Width}px" : "";
                                    <th style="@widthStyle">@col.DisplayName</th>
                                }
                                <th class="col-action" style="display:flex;align-items:center;justify-content:space-between;white-space:nowrap;">
                                    <span>操作</span>
                                    <button class="column-settings-btn" title="栏位设置" @onclick="OpenStatsColumnSettings">
                                        <svg viewBox="0 0 16 16" width="14" height="14" fill="#666666">
                                            <path d="M2 3h4v2H2V3zm0 4h4v2H2V7zm0 4h4v2H2v-2zm6-8h6v2H8V3zm0 4h6v2H8V7zm0 4h6v2H8v-2z"/>
                                        </svg>
                                    </button>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (statsDataSource.Count == 0)
                            {
                                <tr><td colspan="@(StatsVisibleColumnCount + 1)" class="empty-data-cell"><div class="empty-data"><svg viewBox="0 0 64 64" width="80" height="80" fill="none"><rect x="8" y="8" width="48" height="48" rx="8" fill="#F5F5F5" stroke="#E0E0E0" stroke-width="1"/><path d="M24 28h16M24 36h12" stroke="#D9D9D9" stroke-width="2" stroke-linecap="round"/></svg><p class="empty-text">暂无数据</p></div></td></tr>
                            }
                            else
                            {
                                @foreach (var item in statsDataSource)
                                {
                                    var rowIdx = statsDataSource.IndexOf(item) + 1;
                                    <tr>
                                        <td style="width:45px">@rowIdx</td>
                                        @foreach (var col in statsColumnConfigs.Where(c => c.Visible).Skip(1))
                                        {
                                            var widthStyle = col.Width > 0 ? $"width:{col.Width}px" : "";
                                            <td style="@widthStyle">@GetStatsCellValue(item, col.FieldKey)</td>
                                        }
                                        <td><button class="action-btn" title="操作"><svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="#1890FF" stroke-width="1.5"><circle cx="8" cy="3" r="1" fill="#1890FF"/><circle cx="8" cy="8" r="1" fill="#1890FF"/><circle cx="8" cy="13" r="1" fill="#1890FF"/></svg></button></td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                }
            </div>

            <!-- 底部统计栏 -->
            <div class="report-footer-bar">
                <div class="footer-left">
                    <span class="group-label">分组统计字段:</span>
                    <label class="group-check"><input type="checkbox" checked /><span>制单日年季</span></label>
                    <label class="group-check"><input type="checkbox" checked /><span>制单日起季</span></label>
                    <label class="group-check"><input type="checkbox" checked /><span>制单日期月</span></label>
                    <label class="group-check"><input type="checkbox" checked /><span>制单日期周</span></label>
                    <label class="group-check"><input type="checkbox" checked /><span>货品代号</span></label>
                    <label class="group-check"><input type="checkbox" checked /><span>仓库代号</span></label>
                    <label class="group-check"><input type="checkbox" checked /><span>客户名称</span></label>
                </div>
                <div class="footer-right">
                    <span>共 @totalCount 笔记录</span>
                    <span class="page-info">&lt; 1 &gt;</span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 导出对话框 -->
@if (showExportDialog)
{
    <div class="export-dialog-overlay" @onclick="CancelExport">
        <div class="export-dialog" @onclick:stopPropagation>
            <div class="export-dialog-header">
                <span>导出 Excel</span>
                <button class="export-dialog-close" @onclick="CancelExport">&times;</button>
            </div>
            <div class="export-dialog-body">
                <label class="export-label">文件名</label>
                <input type="text" class="export-filename-input" @bind="exportFileName" @bind:event="oninput" />
            </div>
            <div class="export-dialog-footer">
                <button class="export-btn-cancel" @onclick="CancelExport">取消</button>
                <button class="export-btn-confirm" @onclick="ConfirmExport">确认导出</button>
            </div>
        </div>
    </div>
}

<!-- 明细表栏位设计对话框 -->
@if (showDetailColumnSettingsDialog)
{
    <div class="column-settings-overlay" @onclick="CloseDetailColumnSettings">
        <div class="column-settings-dialog" @onclick:stopPropagation>
            <div class="column-settings-header">
                <span>明细表 - 栏位设计</span>
                <button class="column-settings-close" @onclick="CloseDetailColumnSettings">&times;</button>
            </div>
            <div class="column-settings-search">
                <input type="text" class="column-search-input" placeholder="搜索栏位原名..." @bind="detailColumnSearchKeyword" @bind:event="oninput" />
            </div>
            <div class="column-settings-body">
                <table class="column-settings-table">
                    <thead>
                        <tr>
                            <th class="col-seq">项次</th>
                            <th class="col-visible">显示否</th>
                            <th class="col-original">原栏位名</th>
                            <th class="col-display">栏位标题</th>
                            <th class="col-width">宽度</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < FilteredDetailColumnConfigs.Count; i++)
                        {
                            var col = FilteredDetailColumnConfigs[i];
                            var idx = detailColumnConfigs.IndexOf(col) + 1;
                            <tr>
                                <td class="col-seq">@idx</td>
                                <td class="col-visible">
                                    <label class="toggle-switch">
                                        <input type="checkbox" checked="@col.Visible" @onchange="@((ChangeEventArgs e) => col.Visible = (bool)e.Value!)" />
                                        <span class="toggle-slider"></span>
                                    </label>
                                </td>
                                <td class="col-original">@col.OriginalName</td>
                                <td class="col-display">
                                    <input type="text" class="col-title-input" value="@col.DisplayName"
                                           @onchange="@((ChangeEventArgs e) => col.DisplayName = e.Value?.ToString() ?? col.OriginalName)" />
                                </td>
                                <td class="col-width">
                                    <input type="number" class="col-width-input" value="@col.Width"
                                           min="0" max="500"
                                           @onchange="@((ChangeEventArgs e) => { if(int.TryParse(e.Value?.ToString(), out var w)) col.Width = w; })" />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="column-settings-footer">
                <div class="footer-left">
                    <button class="col-select-all" @onclick="SelectAllDetailColumns">全选</button>
                    <button class="col-restore-default" @onclick="RestoreDefaultDetailColumns">恢复默认</button>
                </div>
                <div class="footer-right">
                    <button class="col-btn-confirm" @onclick="ConfirmDetailColumnSettings">确定</button>
                    <button class="col-btn-cancel" @onclick="CancelDetailColumnSettings">取消</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- 统计表栏位设计对话框 -->
@if (showStatsColumnSettingsDialog)
{
    <div class="column-settings-overlay" @onclick="CloseStatsColumnSettings">
        <div class="column-settings-dialog" @onclick:stopPropagation>
            <div class="column-settings-header">
                <span>统计表 - 栏位设计</span>
                <button class="column-settings-close" @onclick="CloseStatsColumnSettings">&times;</button>
            </div>
            <div class="column-settings-search">
                <input type="text" class="column-search-input" placeholder="搜索栏位原名..." @bind="statsColumnSearchKeyword" @bind:event="oninput" />
            </div>
            <div class="column-settings-body">
                <table class="column-settings-table">
                    <thead>
                        <tr>
                            <th class="col-seq">项次</th>
                            <th class="col-visible">显示否</th>
                            <th class="col-original">原栏位名</th>
                            <th class="col-display">栏位标题</th>
                            <th class="col-width">宽度</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < FilteredStatsColumnConfigs.Count; i++)
                        {
                            var col = FilteredStatsColumnConfigs[i];
                            var idx = statsColumnConfigs.IndexOf(col) + 1;
                            <tr>
                                <td class="col-seq">@idx</td>
                                <td class="col-visible">
                                    <label class="toggle-switch">
                                        <input type="checkbox" checked="@col.Visible" @onchange="@((ChangeEventArgs e) => col.Visible = (bool)e.Value!)" />
                                        <span class="toggle-slider"></span>
                                    </label>
                                </td>
                                <td class="col-original">@col.OriginalName</td>
                                <td class="col-display">
                                    <input type="text" class="col-title-input" value="@col.DisplayName"
                                           @onchange="@((ChangeEventArgs e) => col.DisplayName = e.Value?.ToString() ?? col.OriginalName)" />
                                </td>
                                <td class="col-width">
                                    <input type="number" class="col-width-input" value="@col.Width"
                                           min="0" max="500"
                                           @onchange="@((ChangeEventArgs e) => { if(int.TryParse(e.Value?.ToString(), out var w)) col.Width = w; })" />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="column-settings-footer">
                <div class="footer-left">
