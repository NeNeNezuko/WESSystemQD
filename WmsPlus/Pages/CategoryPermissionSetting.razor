@inject IJSRuntime JS
@inject HttpClient Http
@inject ILogger<CategoryPermissionSetting> _logger
@inject TokenProvider TokenProvider

<link rel="stylesheet" href="css/category-permission-setting.css" />

<div class="category-permission-setting-page">
    <div class="page-header">
        <div class="header-left">
            <span class="page-title">类别权限设定/查询</span>
        </div>
    </div>

    <div class="page-content">
        <div class="query-panel">
            <div class="query-header">
                <span class="query-title">查询</span>
            </div>
            <div class="query-form">
                <div class="form-item">
                    <label class="form-label">角色代号</label>
                    <input type="text" class="form-input" placeholder="" @bind="query.RoleNo" />
                </div>
                <div class="form-item">
                    <label class="form-label">角色名称</label>
                    <input type="text" class="form-input" placeholder="" @bind="query.Name" />
                </div>
                <div class="form-item query-btn-wrapper">
                    <button class="query-submit-btn" @onclick="HandleSearch">
                        <svg viewBox="0 0 16 16" width="16" height="16" fill="white" stroke="white" stroke-width="1.5">
                            <circle cx="7" cy="7" r="5"/>
                            <line x1="11" y1="11" x2="15" y2="15"/>
                        </svg>
                        <span>查询</span>
                    </button>
                </div>
            </div>
        </div>

        <div class="table-panel">
            <div class="table-toolbar">
                <div class="toolbar-left">
                    <button class="toolbar-btn primary-btn" @onclick="HandleAddNew">
                        <svg viewBox="0 0 16 16" width="14" height="14" fill="white">
                            <path d="M8 3v10M3 8h10" stroke="white" stroke-width="2" stroke-linecap="round"/>
                        </svg>
                        <span>新增</span>
                    </button>
                </div>
            </div>

            <div class="data-table-container">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th style="width:140px">角色代号</th>
                            <th style="width:200px">角色名称</th>
                            <th style="width:120px">部门代号</th>
                            <th style="width:120px">公司代号</th>
                            <th style="width:120px">权限分类</th>
                            <th style="width:180px">备注</th>
                            <th class="col-action">操作</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (dataSource.Count == 0)
                        {
                            <tr><td colspan="7" class="empty-data-cell"><div class="empty-data"><p class="empty-text">暂无数据</p></div></td></tr>
                        }
                        else
                        {
                            @foreach (var item in dataSource)
                            {
                                <tr>
                                    <td>@item.RoleNo</td>
                                    <td>@item.Name</td>
                                    <td>@item.Dep</td>
                                    <td>@item.CompNo</td>
                                    <td>@item.TypeId</td>
                                    <td>@item.Rem</td>
                                    <td><button class="action-btn" title="编辑" @onclick="() => HandleEdit(item)">编辑</button></td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            <div class="table-footer">
                <div class="footer-right">
                    <span class="record-count">共 @dataSource.Count 条记录</span>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private CategoryPermissionSettingQuery query = new();
    private List<CategoryPermissionSettingModel> dataSource = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task HandleSearch()
    {
        await LoadData();
    }

    private void HandleAddNew()
    {
        // TODO: 新增功能
    }

    private void HandleEdit(CategoryPermissionSettingModel item)
    {
        // TODO: 编辑功能
    }

    private async Task LoadData()
    {
        try
        {
            var url = "http://localhost:5102/api/CategoryPermissionSetting/search";
            if (!string.IsNullOrWhiteSpace(query.RoleNo))
                url += $"?roleNo={Uri.EscapeDataString(query.RoleNo)}";
            if (!string.IsNullOrWhiteSpace(query.Name))
                url += (url.Contains("?") ? "&" : "?") + $"name={Uri.EscapeDataString(query.Name)}";

            var jsonOptions = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var request = AuthHttpClient.CreateRequest(HttpMethod.Get, url, TokenProvider.Token);
            var responseMsg = await Http.SendAsync(request);
            var response = await responseMsg.Content.ReadFromJsonAsync<ApiResponse<List<CategoryPermissionSettingModel>>>(jsonOptions);
            if (response != null && response.Success && response.Data != null)
            {
                dataSource = response.Data;
            }
            else
            {
                dataSource = new List<CategoryPermissionSettingModel>();
            }
        }
        catch (Exception ex)
        {
            _logger?.LogError(ex, "加载类别权限设定数据失败");
            dataSource = new List<CategoryPermissionSettingModel>();
        }
        StateHasChanged();
    }

    private class ApiResponse<T>
    {
        public bool Success { get; set; }
        public string Message { get; set; } = "";
        public T? Data { get; set; }
        public int Total { get; set; }
    }
}
