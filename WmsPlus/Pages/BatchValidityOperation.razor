@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@inject HttpClient Http
@inject ILogger<BatchValidityOperation> _logger
@inject TokenProvider TokenProvider

<link rel="stylesheet" href="css/batch-validity-operation.css" />

<div class="batch-validity-operation-page" style="display:flex;flex-direction:column;flex:1 1 0%;overflow:hidden;">
    <!-- 顶部标题栏 -->
    <div class="page-header">
        <div class="header-left">
            <button class="favorite-btn @(isFavorited ? "favorited" : "")" @onclick="ToggleFavorite" title="收藏">
                <svg viewBox="0 0 24 24" width="24" height="24">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
                          fill="@((isFavorited ? "#FFD700" : "none"))"
                          stroke="@((isFavorited ? "#FFD700" : "#666666"))"
                          stroke-width="2"/>
                </svg>
            </button>
            <span class="page-title">修改批号有效期限作业</span>
        </div>
        <div class="header-center">
            <button class="collapse-btn-fixed @(isCollapsed ? "collapsed" : "")" @onclick="ToggleCollapse" title="@(isCollapsed ? "展开查询" : "收起查询")">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="#666666">
                    <rect x="3" y="6" width="18" height="2" rx="1"/>
                    <rect x="3" y="11" width="18" height="2" rx="1"/>
                    <rect x="3" y="16" width="18" height="2" rx="1"/>
                </svg>
            </button>
</div>
<div class="header-right">
        
                    <button class="header-action-btn" disabled title="修改有效期">
                        <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="#999999" stroke-width="1.5">
                            <path d="M11 3l3 3m0 0l-7 7H4v-3l7-7z" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                        <span>修改有效期</span>
                    </button>
                    <button class="header-action-btn" @onclick="HandleExport">
                        <svg viewBox="0 0 16 16" width="14" height="14" fill="#666666">
                            <path d="M8 12V4m0 0L5 7m3-3l3 3" stroke="#666666" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                            <path d="M2 11v2a1 1 0 001 1h10a1 1 0 001-1v-2" stroke="#666666" stroke-width="1.5" fill="none" stroke-linecap="round"/>
                        </svg>
                        <span>导出</span>
                    </button>
                </div>
    </div>

    <!-- 收藏成功提示 -->
    @if (showFavoriteSuccess)
    {
        <div class="favorite-success-toast">
            <div class="toast-content">
                <svg viewBox="0 0 16 16" width="16" height="16" fill="#52C41A">
                    <circle cx="8" cy="8" r="8"/>
                    <path d="M5 8l2 2 4-4" stroke="white" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>收藏成功</span>
            </div>
        </div>
    }

    <!-- 主内容区域 -->
    <div class="page-content">
        <!-- 左侧查询区域 -->
        <div class="query-panel @(isCollapsed ? "collapsed" : "")">
            <div class="query-header">
                <span class="query-title">查询</span>
                <button class="query-settings-btn" title="设置" @onclick="ToggleSettingsMenu">
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="#999999" stroke-width="2">
                        <circle cx="12" cy="12" r="3"/>
                        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2.83 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2.83 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/>
                    </svg>
                </button>
                @if (showSettingsMenu)
                {
                    <div class="settings-dropdown" @onclick:stopPropagation>
                        <div class="settings-dropdown-item" @onclick="BatchAddCondition">批次添加条件</div>
                        <div class="settings-dropdown-item" @onclick="AddSingleCondition">添加单一条件</div>
                        <div class="settings-dropdown-item" @onclick="CustomCondition">自定义条件</div>
                        <div class="settings-dropdown-item" @onclick="RemoveCondition">移除条件</div>
                        <div class="settings-dropdown-item" @onclick="SaveConditionValues">保存条件值</div>
                    </div>
                }
            </div>

            <div class="query-form">
                <!-- 有效日期 - 日期范围选择器 -->
                <DateRangeInput @bind-Value="query.DateRange" Label="有效日期" />

                <!-- 仓库代号 -->
                <WarehouseCodeInput @bind-Value="query.Wh" />

                <!-- 货品代号 起 -->
                <div class="form-item">
                    <label class="form-label">货品代号 起</label>
                    <ProductCodeInput @bind-Value="query.PrdNoFrom" />
                </div>

                <!-- 货品代号 止 -->
                <div class="form-item">
                    <label class="form-label">货品代号 止</label>
                    <ProductCodeInput @bind-Value="query.PrdNoTo" />
                </div>

                <!-- 批号（带按图索骥按钮） -->
                <div class="form-item">
                    <label class="form-label">批号</label>
                    <div class="input-with-search-btn">
                        <input type="text" class="form-input" placeholder="" @bind="query.BatNo" />
                        <button class="search-action-btn" title="按图索骥">
                            <svg viewBox="0 0 16 16" width="14" height="14" fill="#999999">
                                <circle cx="7" cy="7" r="5" stroke="#999999" stroke-width="1.5" fill="none"/>
                                <line x1="10.5" y1="10.5" x2="14.5" y2="14.5" stroke="#999999" stroke-width="1.5"/>
                                <text x="9" y="11" font-size="7" fill="#999999" font-weight="bold">?</text>
                            </svg>
                        </button>
                    </div>
                </div>

                <!-- 中类（带放大镜按钮） -->
                <div class="form-item">
                    <label class="form-label">中类</label>
                    <div class="input-with-search-btn">
                        <input type="text" class="form-input" placeholder="" @bind="query.IdxNo" />
                        <button class="search-action-btn" title="搜索">
                            <svg viewBox="0 0 16 16" width="14" height="14" fill="#999999">
                                <circle cx="7" cy="7" r="5" stroke="#999999" stroke-width="1.5" fill="none"/>
                                <line x1="10.5" y1="10.5" x2="14.5" y2="14.5" stroke="#999999" stroke-width="1.5"/>
                            </svg>
                        </button>
                    </div>
                </div>

                <!-- 判断有效日期为空的记录（Toggle Switch） -->
                <div class="toggle-switch-row">
                    <span class="toggle-switch-label">判断有效日期为空的记录</span>
                    <label class="query-toggle-switch">
                        <input type="checkbox" checked="@query.EmptyValidDateOnly"
                               @onchange="@((ChangeEventArgs e) => query.EmptyValidDateOnly = (bool)e.Value!)" />
                        <span class="query-toggle-slider"></span>
                    </label>
                </div>

                <!-- 查询按钮 -->
                <div class="form-item query-btn-wrapper">
                    <button class="query-submit-btn" @onclick="HandleSearch">
                        <svg viewBox="0 0 16 16" width="16" height="16" fill="white" stroke="white" stroke-width="1.5">
                            <circle cx="7" cy="7" r="5"/>
                            <line x1="11" y1="11" x2="15" y2="15"/>
                        </svg>
                        <span>查询</span>
                    </button>
                </div>
            </div>
        </div>

        <!-- 右侧数据表格区域 -->
        <div class="table-panel">
            <!-- 工具栏 -->
            

            <!-- 数据表格 -->
            <div class="data-table-container">
                <table class="data-table">
                    <thead>
                        <tr>
                            @foreach (var col in columnConfigs.Where(c => c.Visible))
                            {
                                var widthStyle = col.Width > 0 ? $"width:{col.Width}px" : "";
                                if (col.Sortable)
                                {
                                    <th style="@widthStyle" class="sortable">
                                        @col.DisplayName
                                        <svg viewBox="0 0 12 12" width="10" height="10" fill="#999999">
                                            <path d="M6 3l3 3H9l-3-3-3 3H3z"/>
                                            <path d="M6 9l-3-3h3l3 3h-3z" opacity="0.3"/>
                                        </svg>
                                    </th>
                                }
                                else
                                {
                                    <th style="@widthStyle">@col.DisplayName</th>
                                }
                            }
                            <th class="col-action" style="display:flex;align-items:center;justify-content:space-between;white-space:nowrap;">
                                <span>操作</span>
                                <button class="column-settings-btn" title="栏位设置" @onclick="OpenColumnSettings">
                                    <svg viewBox="0 0 16 16" width="14" height="14" fill="#666666">
                                        <path d="M2 3h4v2H2V3zm0 4h4v2H2V7zm0 4h4v2H2v-2zm6-8h6v2H8V3zm0 4h6v2H8V7zm0 4h6v2H8v-2z"/>
                                    </svg>
                                </button>
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (dataSource.Count == 0)
                        {
                            <tr><td colspan="@(VisibleColumnCount + 1)" class="empty-data-cell"><div class="empty-data"><svg viewBox="0 0 64 64" width="80" height="80" fill="none"><rect x="8" y="8" width="48" height="48" rx="8" fill="#F5F5F5" stroke="#E0E0E0" stroke-width="1"/><path d="M24 28h16M24 36h12" stroke="#D9D9D9" stroke-width="2" stroke-linecap="round"/></svg><p class="empty-text">暂无数据</p></div></td></tr>
                        }
                        else
                        {
                            @foreach (var item in dataSource)
                            {
                                <tr>
                                    @foreach (var col in columnConfigs.Where(c => c.Visible))
                                    {
                                        var widthStyle = col.Width > 0 ? $"width:{col.Width}px" : "";
                                        <td style="@widthStyle">@GetCellValue(item, col.FieldKey)</td>
                                    }
                                    <td><button class="action-btn" title="操作"><svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="#1890FF" stroke-width="1.5"><circle cx="8" cy="3" r="1" fill="#1890FF"/><circle cx="8" cy="8" r="1" fill="#1890FF"/><circle cx="8" cy="13" r="1" fill="#1890FF"/></svg></button></td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
            <!-- 表格底部栏 -->
            <div class="table-footer">
                <div class="footer-left">
                    <span class="footer-label">分页栏位字段：</span>
                    <div class="footer-checkboxes">
                        @foreach (var col in columnConfigs.Where(c => c.Visible))
                        {
                            <label class="footer-checkbox-item">
                                <input type="checkbox" checked />
                                <span>@col.DisplayName</span>
                            </label>
                        }
                    </div>
                </div>
                <div class="footer-right">
                    <span class="record-count">共 @dataSource.Count 条记录</span>
                    <div class="pagination-info"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 导出对话框 -->
@if (showExportDialog)
{
    <div class="export-dialog-overlay" @onclick="CancelExport">
        <div class="export-dialog" @onclick:stopPropagation>
            <div class="export-dialog-header">
                <span>导出 Excel</span>
                <button class="export-dialog-close" @onclick="CancelExport">&times;</button>
            </div>
            <div class="export-dialog-body">
                <label class="export-label">文件名</label>
                <input type="text" class="export-filename-input" @bind="exportFileName" @bind:event="oninput" />
            </div>
            <div class="export-dialog-footer">
                <button class="export-btn-cancel" @onclick="CancelExport">取消</button>
                <button class="export-btn-confirm" @onclick="ConfirmExport">确认导出</button>
            </div>
        </div>
    </div>
}

<!-- 栏位设计对话框 -->
@if (showColumnSettingsDialog)
{
    <div class="column-settings-overlay" @onclick="CloseColumnSettings">
        <div class="column-settings-dialog" @onclick:stopPropagation>
            <div class="column-settings-header">
                <span>栏位设计</span>
                <button class="column-settings-close" @onclick="CloseColumnSettings">&times;</button>
            </div>
            <div class="column-settings-search">
                <input type="text" class="column-search-input" placeholder="搜索栏位原名..." @bind="columnSearchKeyword" @bind:event="oninput" />
            </div>
            <div class="column-settings-body">
                <table class="column-settings-table">
                    <thead>
                        <tr>
                            <th class="col-seq">项次</th>
                            <th class="col-visible">显示否</th>
                            <th class="col-original">原栏位名</th>
                            <th class="col-display">栏位标题</th>
                            <th class="col-width">宽度</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < FilteredColumnConfigs.Count; i++)
                        {
                            var col = FilteredColumnConfigs[i];
                            var idx = columnConfigs.IndexOf(col) + 1;
                            <tr>
                                <td class="col-seq">@idx</td>
                                <td class="col-visible">
                                    <label class="toggle-switch">
                                        <input type="checkbox" checked="@col.Visible" @onchange="@((ChangeEventArgs e) => col.Visible = (bool)e.Value!)" />
                                        <span class="toggle-slider"></span>
                                    </label>
                                </td>
                                <td class="col-original">@col.OriginalName</td>
                                <td class="col-display">
                                    <input type="text" class="col-title-input" value="@col.DisplayName"
                                           @onchange="@((ChangeEventArgs e) => col.DisplayName = e.Value?.ToString() ?? col.OriginalName)" />
                                </td>
                                <td class="col-width">
                                    <input type="number" class="col-width-input" value="@col.Width"
                                           min="0" max="500"
                                           @onchange="@((ChangeEventArgs e) => { if(int.TryParse(e.Value?.ToString(), out var w)) col.Width = w; })" />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="column-settings-footer">
                <div class="footer-left">
                    <button class="col-select-all" @onclick="SelectAllColumns">全选</button>
                    <button class="col-restore-default" @onclick="RestoreDefaultColumns">恢复默认</button>
                </div>
                <div class="footer-right">
                    <button class="col-btn-confirm" @onclick="ConfirmColumnSettings">确定</button>
                    <button class="col-btn-cancel" @onclick="CancelColumnSettings">取消</button>
                </div>
            </div>
        </div>
    </div>
}


<!-- 货品选择器对话框 -->
@if (showProductDialog)
{
    <div class="prd-selector-overlay" @onclick="CloseProductSelector">
        <div class="prd-selector-dialog" @onclick:stopPropagation>
            <div class="prd-selector-header">
                <span>货品(PRDT)</span>
                <button class="prd-close-btn" @onclick="CloseProductSelector">&times;</button>
            </div>
            <div class="prd-selector-body">
                <div class="prd-left-panel">
                    <div class="prd-filter-title">过滤</div>
                    <input type="text" class="prd-search-input" placeholder="输入关键字查询" @bind="productSearchKeyword" @bind:event="oninput" @onkeyup="@((KeyboardEventArgs e) => { if(e.Key == "Enter") _ = SearchProduct(); })" />
                    <button class="prd-query-btn" @click="@(() => _ = SearchProduct())">查询</button>
                </div>
                <div class="prd-right-panel">
                    <table class="prd-data-table">
                        <thead><tr><th class="prd-col-action">操作</th><th style="width:50px">项次</th><th>货品代号</th><th>货品名称</th><th>规格</th><th>单位</th></tr></thead>
                        <tbody>
                            @if (productData.Count == 0) { <tr><td colspan="6" style="text-align:center;padding:30px;color:#999;">暂无数据</td></tr> }
                            else { @for (int i = 0; i < productData.Count; i++) { var item = productData[i]; var rowIdx = (productPageIndex - 1) * productPageSize + i + 1; <tr><td><button class="prd-select-btn" @click="() => SelectProduct(item)">选择</button></td><td style="text-align:center">@rowIdx</td><td>@item.PRD_NO</td><td>@item.NAME</td><td>@item.SNM</td><td>@item.UT</td></tr> } }
                        </tbody>
                    </table>
                    <div class="prd-pagination"><span class="prd-total-info">共 @productTotalCount 笔记录</span><div class="prd-page-controls"><button class="prd-page-btn" disabled="@(productPageIndex <= 1)" @click="async () => await GoToPrdPage(productPageIndex - 1)">&lt;</button><input type="number" class="prd-page-input" value="@productPageIndex" min="1" max="@PrdTotalPages" @change="async (ChangeEventArgs e) => { if(int.TryParse(e.Value?.ToString(), out var p)) await GoToPrdPage(p); }" /><span>/ @PrdTotalPages</span><button class="prd-page-btn" disabled="@(productPageIndex >= PrdTotalPages)" @click="async () => await GoToPrdPage(productPageIndex + 1)">&gt;</button></div></div>
                </div>
            </div>
            <div class="prd-selector-footer"><button class="prd-footer-cancel" @click="CloseProductSelector">取消</button></div>
        </div>
    </div>
}

@code {
    private bool isFavorited = false;
    private bool showFavoriteSuccess = false;
    private bool isCollapsed = false;
    private bool showSettingsMenu = false;
    private bool showExportDialog = false;
    private string exportFileName = "";
    private bool showColumnSettingsDialog = false;
    private string columnSearchKeyword = "";
    private List<ColumnConfig> columnConfigs = new();
    private List<ColumnConfig> defaultColumnConfigs = new();
    private BatchValidityOperationQuery query = new();
    private List<BatchValidityOperationModel> dataSource = new();

    [CascadingParameter(Name = "OnFavoriteChanged")] public Action? OnFavoriteChanged { get; set; }
    [CascadingParameter(Name = "OpenTabCallback")] public Action<string, string>? OpenTabCallback { get; set; }

    protected override async Task OnInitializedAsync()
    {
        InitDefaultColumnConfigs();
        await LoadColumnSettings();
        await LoadFavoriteStatus();
        await LoadData();
    }

    // ===== 折叠/设置方法 =====
    private void ToggleCollapse()
    {
        isCollapsed = !isCollapsed;
        StateHasChanged();
    }

    private void ToggleSettingsMenu()
    {
        showSettingsMenu = !showSettingsMenu;
        StateHasChanged();
    }

    private void BatchAddCondition() { showSettingsMenu = false; StateHasChanged(); }
    private void AddSingleCondition() { showSettingsMenu = false; StateHasChanged(); }
    private void CustomCondition() { showSettingsMenu = false; StateHasChanged(); }
    private void RemoveCondition() { showSettingsMenu = false; StateHasChanged(); }
    private void SaveConditionValues() { showSettingsMenu = false; StateHasChanged(); }

    // ===== 收藏方法 =====
    private async Task LoadFavoriteStatus()
    {
        try { var r = await JS.InvokeAsync<string>("localStorage.getItem", "wms_favorite_batch_validity_operation"); isFavorited = r == "true"; }
        catch { isFavorited = false; }
    }

    private async Task ToggleFavorite()
    {
        isFavorited = !isFavorited;
        try { await JS.InvokeVoidAsync("localStorage.setItem", "wms_favorite_batch_validity_operation", isFavorited.ToString().ToLower()); } catch { }
        OnFavoriteChanged?.Invoke();
        if (isFavorited)
        {
            showFavoriteSuccess = true; StateHasChanged(); await Task.Delay(2000); showFavoriteSuccess = false;
        }
        StateHasChanged();
    }

    // ===== 查询/导出方法 =====
    private async Task HandleSearch() { await LoadData(); }

    private async Task HandleExport()
    {
        if (dataSource.Count == 0) { await JS.InvokeVoidAsync("alert", "暂无数据可导出"); return; }
        exportFileName = $"批号有效期作业_{DateTime.Now:yyyyMMddHHmmss}";
        showExportDialog = true;
        StateHasChanged();
    }

    private void CancelExport()
    {
        showExportDialog = false;
        StateHasChanged();
    }

    private async Task ConfirmExport()
    {
        showExportDialog = false;
        try { await ExportToExcel(); } catch (Exception ex) { await JS.InvokeVoidAsync("alert", $"导出失败: {ex.Message}"); }
    }

    // ===== 数据加载 =====
    private async Task LoadData()
    {
        try
        {
            var today = DateTime.Today;
            var dateFromStr = today.ToString("yyyy-MM-dd");
            var dateToStr = today.ToString("yyyy-MM-dd");
            if (!string.IsNullOrWhiteSpace(query.DateRange) && query.DateRange.Contains("→"))
            {
                var parts = query.DateRange.Split("→", StringSplitOptions.TrimEntries);
                if (parts.Length >= 2)
                {
                    dateFromStr = parts[0];
                    dateToStr = parts[1];
                }
            }
            var url = $"{ApiConfig.BaseUrl}/api/BatchValidityOperation/search?dateFrom={dateFromStr}&dateTo={dateToStr}";
            if (!string.IsNullOrWhiteSpace(query.Wh))
                url += $"&wh={Uri.EscapeDataString(query.Wh)}";
            if (!string.IsNullOrWhiteSpace(query.PrdNoFrom))
                url += $"&prdNoFrom={Uri.EscapeDataString(query.PrdNoFrom)}";
            if (!string.IsNullOrWhiteSpace(query.PrdNoTo))
                url += $"&prdNoTo={Uri.EscapeDataString(query.PrdNoTo)}";
            if (!string.IsNullOrWhiteSpace(query.BatNo))
                url += $"&batNo={Uri.EscapeDataString(query.BatNo)}";
            if (!string.IsNullOrWhiteSpace(query.IdxNo))
                url += $"&idxNo={Uri.EscapeDataString(query.IdxNo)}";
            if (query.EmptyValidDateOnly)
                url += $"&emptyValidDateOnly=true";

            var jsonOptions = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var request = AuthHttpClient.CreateRequest(HttpMethod.Get, url, TokenProvider.Token);
            var responseMsg = await Http.SendAsync(request);
            var response = await responseMsg.Content.ReadFromJsonAsync<ApiResponse<List<BatchValidityOperationModel>>>(jsonOptions);
            if (response != null && response.Success && response.Data != null)
            {
                dataSource = response.Data;
            }
            else
            {
                dataSource = new List<BatchValidityOperationModel>();
            }
        }
        catch (Exception ex)
        {
            _logger?.LogError(ex, "加载批号有效期作业数据失败");
            dataSource = new List<BatchValidityOperationModel>();
        }
        StateHasChanged();
    }

    private async Task ExportToExcel()
    {
        var visibleCols = columnConfigs.Where(c => c.Visible).ToList();
        var headers = visibleCols.Select(c => c.DisplayName).ToArray();
        var rows = new List<object[]>();
        rows.Add(headers);
        foreach (var item in dataSource)
        {
            var row = new object[visibleCols.Count];
            for (int i = 0; i < visibleCols.Count; i++)
                row[i] = GetCellValue(item, visibleCols[i].FieldKey);
            rows.Add(row);
        }
        var fileName = string.IsNullOrWhiteSpace(exportFileName) ? $"批号有效期作业_{DateTime.Now:yyyyMMddHHmmss}" : exportFileName;
        if (!fileName.EndsWith(".xlsx", StringComparison.OrdinalIgnoreCase)) fileName += ".xlsx";
        await JS.InvokeVoidAsync("exportToExcel", rows, fileName);
    }

    // ===== 栏位配置 =====
    private class ColumnConfig
    {
        public string FieldKey { get; set; } = "";
        public string OriginalName { get; set; } = "";
        public string DisplayName { get; set; } = "";
        public bool Visible { get; set; } = true;
        public int Width { get; set; } = 0;
        public int DefaultWidth { get; set; } = 0;
        public bool Sortable { get; set; } = false;
    }

    private const string COLUMN_SETTINGS_KEY = "wms_column_settings_batch_validity_operation";

    private void InitDefaultColumnConfigs()
    {
        defaultColumnConfigs = new List<ColumnConfig>
        {
            new() { FieldKey = "HisNo", OriginalName = "项次", DisplayName = "项次", Visible = true, Width = 45, DefaultWidth = 45 },
            new() { FieldKey = "Wh", OriginalName = "仓库代号", DisplayName = "仓库代号", Visible = true, Width = 70, DefaultWidth = 70, Sortable = true },
            new() { FieldKey = "WhName", OriginalName = "仓库名称", DisplayName = "仓库名称", Visible = true, Width = 90, DefaultWidth = 90 },
            new() { FieldKey = "PrdNo", OriginalName = "货品代号", DisplayName = "货品代号", Visible = true, Width = 100, DefaultWidth = 100, Sortable = true },
            new() { FieldKey = "PrdName", OriginalName = "货品名称", DisplayName = "货品名称", Visible = true, Width = 100, DefaultWidth = 100 },
            new() { FieldKey = "BatNo", OriginalName = "批号", DisplayName = "批号", Visible = true, Width = 90, DefaultWidth = 90, Sortable = true },
            new() { FieldKey = "ValidDDCur", OriginalName = "有效日期", DisplayName = "有效日期", Visible = true, Width = 85, DefaultWidth = 85, Sortable = true },
            new() { FieldKey = "ValidDDOrg", OriginalName = "履迟近品日", DisplayName = "履迟近品日", Visible = true, Width = 95, DefaultWidth = 95 },
            new() { FieldKey = "LastOutDate", OriginalName = "最近出库日", DisplayName = "最近出库日", Visible = true, Width = 90, DefaultWidth = 90, Sortable = true },
            new() { FieldKey = "LastInDate", OriginalName = "最近入库日", DisplayName = "最近入库日", Visible = true, Width = 90, DefaultWidth = 90, Sortable = true },
            new() { FieldKey = "LastInspectDate", OriginalName = "最近检验日期", DisplayName = "最近检验日期", Visible = true, Width = 100, DefaultWidth = 100, Sortable = true },
            new() { FieldKey = "ProduceDate", OriginalName = "生产日期", DisplayName = "生产日期", Visible = true, Width = 85, DefaultWidth = 85, Sortable = true },
            new() { FieldKey = "IdxNo", OriginalName = "中类代号", DisplayName = "中类代号", Visible = true, Width = 80, DefaultWidth = 80, Sortable = true },
            new() { FieldKey = "IdxName", OriginalName = "中类名称", DisplayName = "中类名称", Visible = true, Width = 90, DefaultWidth = 90 },
            new() { FieldKey = "Qty", OriginalName = "数量", DisplayName = "数量", Visible = true, Width = 70, DefaultWidth = 70, Sortable = true }
        };
        columnConfigs = defaultColumnConfigs.Select(c => new ColumnConfig
        {
            FieldKey = c.FieldKey,
            OriginalName = c.OriginalName,
            DisplayName = c.DisplayName,
            Visible = c.Visible,
            Width = c.Width,
            DefaultWidth = c.DefaultWidth,
            Sortable = c.Sortable
        }).ToList();
    }

    private async Task LoadColumnSettings()
    {
        try
        {
            var json = await JS.InvokeAsync<string>("localStorage.getItem", COLUMN_SETTINGS_KEY);
            if (!string.IsNullOrWhiteSpace(json))
            {
                var options = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
                var saved = System.Text.Json.JsonSerializer.Deserialize<List<ColumnConfig>>(json, options);
                if (saved != null && saved.Count > 0)
                {
                    foreach (var col in columnConfigs)
                    {
                        var savedCol = saved.FirstOrDefault(s => s.FieldKey == col.FieldKey);
                        if (savedCol != null)
                        {
                            col.Visible = savedCol.Visible;
                            col.DisplayName = !string.IsNullOrWhiteSpace(savedCol.DisplayName) ? savedCol.DisplayName : col.OriginalName;
                            col.Width = savedCol.Width >= 0 ? savedCol.Width : col.DefaultWidth;
                        }
                    }
                }
            }
        }
        catch { }
    }

    private async Task SaveColumnSettings()
    {
        try
        {
            var json = System.Text.Json.JsonSerializer.Serialize(columnConfigs);
            await JS.InvokeVoidAsync("localStorage.setItem", COLUMN_SETTINGS_KEY, json);
        }
        catch { }
    }

    private void OpenColumnSettings()
    {
        columnSearchKeyword = "";
        showColumnSettingsDialog = true;
        StateHasChanged();
    }

    private void CloseColumnSettings()
    {
        showColumnSettingsDialog = false;
        StateHasChanged();
    }

    private void ConfirmColumnSettings()
    {
        showColumnSettingsDialog = false;
        _ = SaveColumnSettings();
        StateHasChanged();
    }

    private void CancelColumnSettings()
    {
        showColumnSettingsDialog = false;
        _ = LoadColumnSettings();
        StateHasChanged();
    }

    private void SelectAllColumns()
    {
        foreach (var col in columnConfigs)
            col.Visible = true;
        StateHasChanged();
    }

    private void RestoreDefaultColumns()
    {
        for (int i = 0; i < columnConfigs.Count && i < defaultColumnConfigs.Count; i++)
        {
            columnConfigs[i].Visible = defaultColumnConfigs[i].Visible;
            columnConfigs[i].DisplayName = defaultColumnConfigs[i].DisplayName;
            columnConfigs[i].Width = defaultColumnConfigs[i].Width;
        }
        StateHasChanged();
    }

    private List<ColumnConfig> FilteredColumnConfigs =>
        string.IsNullOrWhiteSpace(columnSearchKeyword)
            ? columnConfigs
            : columnConfigs.Where(c => c.OriginalName.Contains(columnSearchKeyword, StringComparison.OrdinalIgnoreCase) ||
                                       c.FieldKey.Contains(columnSearchKeyword, StringComparison.OrdinalIgnoreCase)).ToList();

    private int VisibleColumnCount => columnConfigs.Count(c => c.Visible);

    // 获取单元格渲染值
    private object GetCellValue(BatchValidityOperationModel item, string fieldKey) => fieldKey switch
    {
        "HisNo" => item.HisNo,
        "Wh" => item.Wh,
        "WhName" => item.WhName,
        "PrdNo" => item.PrdNo,
        "PrdName" => item.PrdName,
        "BatNo" => item.BatNo,
        "ValidDDCur" => item.ValidDDCur.HasValue ? item.ValidDDCur.Value.ToString("yyyy-MM-dd") : "",
        "ValidDDOrg" => item.ValidDDOrg.HasValue ? item.ValidDDOrg.Value.ToString("yyyy-MM-dd") : "",
        "LastOutDate" => item.LastOutDate.HasValue ? item.LastOutDate.Value.ToString("yyyy-MM-dd") : "",
        "LastInDate" => item.LastInDate.HasValue ? item.LastInDate.Value.ToString("yyyy-MM-dd") : "",
        "LastInspectDate" => item.LastInspectDate.HasValue ? item.LastInspectDate.Value.ToString("yyyy-MM-dd") : "",
        "ProduceDate" => item.ProduceDate.HasValue ? item.ProduceDate.Value.ToString("yyyy-MM-dd") : "",
        "IdxNo" => item.IdxNo,
        "IdxName" => item.IdxName,
        "Qty" => item.Qty,
        _ => ""
    };

    // ===== API响应模型 =====
    private class ApiResponse<T>
    {
        public bool Success { get; set; }
        public string Message { get; set; } = "";
        public T? Data { get; set; }
        public int Total { get; set; }
    }

    // ===== 货品选择器状态 =====
    private bool showProductDialog = false;
    private string activePrdSelector = "";
    private string productSearchKeyword = "";
    private List<PrdItem> productData = new();
    private int productPageIndex = 1;
    private int productPageSize = 20;
    private int productTotalCount = 0;

    private class PrdItem
    {
        public string PRD_NO { get; set; } = "";
        public string NAME { get; set; } = "";
        public string SNM { get; set; } = "";
        public string UT { get; set; } = "";
    }

    private class PrdSearchResult
    {
        public List<PrdItem>? Items { get; set; }
        public int TotalCount { get; set; }
    }

    private async Task OpenPrdFromSelector()
    {
        activePrdSelector = "from";
        productSearchKeyword = ""; productPageIndex = 1;
        await SearchProduct(); showProductDialog = true; StateHasChanged();
    }

    private async Task OpenPrdToSelector()
    {
        activePrdSelector = "to";
        productSearchKeyword = ""; productPageIndex = 1;
        await SearchProduct(); showProductDialog = true; StateHasChanged();
    }

    private void CloseProductSelector() { showProductDialog = false; StateHasChanged(); }

    private async Task SearchProduct()
    {
        try
        {
            var url = $"{ApiConfig.BaseUrl}/api/warehouse/prdsearch?keyword={Uri.EscapeDataString(productSearchKeyword ?? "")}&pageIndex={productPageIndex}&pageSize={productPageSize}";
            var jsonOptions = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var request = AuthHttpClient.CreateRequest(HttpMethod.Get, url, TokenProvider.Token);
            var responseMsg = await Http.SendAsync(request);
            if (responseMsg.IsSuccessStatusCode)
            {
                var json = await responseMsg.Content.ReadAsStringAsync();
                var result = System.Text.Json.JsonSerializer.Deserialize<PrdSearchResult>(json, jsonOptions);
                if (result != null) { productData = result.Items ?? new List<PrdItem>(); productTotalCount = result.TotalCount; }
            }
        }
        catch (Exception ex) { Console.WriteLine($"[BatchValidityOperation] 查询货品数据失败: {ex.Message}"); }
        StateHasChanged();
    }

    private void SelectProduct(PrdItem item)
    {
        if (activePrdSelector == "from") query.PrdNoFrom = item.PRD_NO;
        else if (activePrdSelector == "to") query.PrdNoTo = item.PRD_NO;
        showProductDialog = false; StateHasChanged();
    }

    private int PrdTotalPages => productPageSize > 0 ? (int)Math.Ceiling((double)productTotalCount / productPageSize) : 1;

    private async Task GoToPrdPage(int page)
    {
        if (page >= 1 && page <= PrdTotalPages) { productPageIndex = page; await SearchProduct(); }
    }
}
