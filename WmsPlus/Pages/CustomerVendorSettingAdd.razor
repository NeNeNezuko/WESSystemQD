@inject IJSRuntime JS
@inject HttpClient Http
@inject ILogger<CustomerVendorSettingAdd> _logger
@inject TokenProvider TokenProvider

<link rel="stylesheet" href="css/customer-vendor-setting-add.css" />

<div class="cvsadd-page">
    <!-- 页面标题栏 -->
    <div class="page-header">
        <div class="header-left">
            <button class="favorite-btn @(isFavorited ? "favorited" : "")" @onclick="ToggleFavorite" title="收藏">
                <svg viewBox="0 0 24 24" width="24" height="24">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
                          fill="@((isFavorited ? "#FFD700" : "none"))"
                          stroke="@((isFavorited ? "#FFD700" : "#666666"))"
                          stroke-width="2"/>
                </svg>
            </button>
            <span class="page-title">@(IsEditMode ? "客户/厂商资料设定/编辑" : "客户/厂商资料*新增")</span>
        </div>
        <div class="header-right">
            <button class="header-action-btn primary" @onclick="HandleSave">
                <svg viewBox="0 0 16 16" width="14" height="14" fill="white">
                    <path d="M13.78 4.22a.75.75 0 010 1.06l-7.25 7.25a.75.75 0 01-1.06 0L2.22 8.28a.75.75 0 011.06-1.06L6 9.94l6.72-6.72a.75.75 0 011.06 0z"/>
                </svg>
                <span>保存</span>
            </button>
            <button class="header-action-btn primary" @onclick="HandleSaveAndNew">
                <svg viewBox="0 0 16 16" width="14" height="14" fill="white">
                    <path d="M8 3v10M3 8h10" stroke="white" stroke-width="2" stroke-linecap="round"/>
                </svg>
                <span>新增</span>
            </button>
            <button class="header-action-btn" @onclick="HandleDelete">
                <svg viewBox="0 0 16 16" width="14" height="14" fill="#666666">
                    <path d="M5.5 4h5l.5.5v9l-.5.5h-5L5 13.5v-9l.5-.5zM6 5v8h4V5H6z M4 3.5V4h1v-.5a.5.5 0 00-.5-.5h-1a.5.5 0 00-.5.5zm8 0V4h1v-.5a.5.5 0 00-.5-.5h-1a.5.5 0 00-.5.5z"/>
                </svg>
                <span>删除</span>
            </button>
            <button class="header-action-btn" @onclick="HandleColumnSettings">
                <svg viewBox="0 0 16 16" width="14" height="14" fill="#666666">
                    <path d="M2 3h4v2H2V3zm0 4h4v2H2V7zm0 4h4v2H2v-2zm6-8h6v2H8V3zm0 4h6v2H8V7zm0 4h6v2H8v-2z"/>
                </svg>
                <span>栏位</span>
            </button>
            <button class="header-action-btn" @onclick="HandleQuery">
                <svg viewBox="0 0 16 16" width="14" height="14" fill="#666666">
                    <circle cx="7" cy="7" r="5"/>
                    <line x1="11" y1="11" x2="15" y2="15" stroke="#666666" stroke-width="1.5"/>
                </svg>
                <span>查询</span>
            </button>
        </div>
    </div>

    @if (showFavoriteSuccess)
    {
        <div class="favorite-success-toast">
            <div class="toast-content">
                <svg viewBox="0 0 16 16" width="16" height="16" fill="#52C41A">
                    <circle cx="8" cy="8" r="8"/>
                    <path d="M5 8l2 2 4-4" stroke="white" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>收藏成功</span>
            </div>
        </div>
    }

    <!-- 表单区域 -->
    <div class="form-area-scroll">

        <!-- 基本信息 -->
        <div class="form-section">
            <div class="form-section-title">基本信息</div>

            <div class="form-grid-4col">
                <div class="form-item-add">
                    <label class="form-label-add"><span class="required-mark">*</span>厂商代号</label>
                    <input type="text" class="form-input-add" placeholder="" @bind="model.CusNo" @bind:event="oninput" disabled="@IsEditMode" />
                </div>
                <div class="form-item-add">
                    <label class="form-label-add"><span class="required-mark">*</span>厂商名称</label>
                    <input type="text" class="form-input-add" placeholder="" @bind="model.CusName" />
                </div>
                <div class="form-item-add">
                    <label class="form-label-add">停用日期</label>
                    <input type="date" class="form-input-add" @bind="model.StopDd" @bind:format="yyyy-MM-dd" />
                </div>
                <div class="form-item-add">
                    <label class="form-label-add"></label>
                    <div style="flex:1;"></div>
                </div>

                <div class="form-textarea-wrapper-full">
                    <label class="form-label-add">备注</label>
                    <textarea class="form-textarea-add" rows="3" placeholder="" @bind="model.Rem"></textarea>
                </div>
            </div>
        </div>
    </div>
</div>


@code {
    private CustomerVendorSettingAddModel model = new();
    private bool isSaving = false;

    [Parameter] public string? EditCusNo { get; set; }

    private bool IsEditMode => !string.IsNullOrWhiteSpace(EditCusNo);

    [CascadingParameter(Name = "OpenTabCallback")] public Action<string, string>? OpenTab { get; set; }
    [CascadingParameter(Name = "OnFavoriteChanged")] public Action? NotifyFavoriteChanged { get; set; }

    // ===== 收藏功能 =====
    private bool isFavorited = false;
    private bool showFavoriteSuccess = false;
    private const string FAVORITE_KEY = "wms_favorite_customer_vendor_setting_add";

    protected override async Task OnInitializedAsync()
    {
        try { var r = await JS.InvokeAsync<string>("localStorage.getItem", FAVORITE_KEY); isFavorited = r == "true"; } catch { }

        if (IsEditMode)
        {
            await LoadDataForEdit();
        }
    }

    private async Task ToggleFavorite()
    {
        isFavorited = !isFavorited;
        try { await JS.InvokeVoidAsync("localStorage.setItem", FAVORITE_KEY, isFavorited.ToString().ToLower()); } catch { }
        NotifyFavoriteChanged?.Invoke();
        showFavoriteSuccess = true;
        StateHasChanged();
        await Task.Delay(1500);
        showFavoriteSuccess = false;
        StateHasChanged();
    }

    // ===== 编辑模式：加载详情 =====
    private async Task LoadDataForEdit()
    {
        try
        {
            var url = $"{ApiConfig.BaseUrl}/api/CustomerVendorSetting/getByCusNo?cusNo={Uri.EscapeDataString(EditCusNo!)}";
            var request = AuthHttpClient.CreateRequest(HttpMethod.Get, url, TokenProvider.Token);
            var responseMsg = await Http.SendAsync(request);
            var jsonOptions = new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase };
            var response = await responseMsg.Content.ReadFromJsonAsync<ApiResponse<CustomerVendorSettingAddModel>>(jsonOptions);

            if (response != null && response.Success && response.Data != null)
            {
                model = response.Data;
            }
            else
            {
                var msg = response?.Message ?? "加载数据失败";
                await JS.InvokeVoidAsync("alert", $"加载失败: {msg}");
            }
        }
        catch (Exception ex)
        {
            _logger?.LogError(ex, "加载客户/厂商详情时发生错误");
            await JS.InvokeVoidAsync("alert", $"加载失败: {ex.Message}");
        }
    }

    // ===== 工具栏按钮事件 =====
    private async Task HandleSave()
    {
        if (isSaving) return;

        // 必填校验
        if (string.IsNullOrWhiteSpace(model.CusNo))
        {
            await JS.InvokeVoidAsync("alert", "请输入厂商代号");
            return;
        }
        if (string.IsNullOrWhiteSpace(model.CusName))
        {
            await JS.InvokeVoidAsync("alert", "请输入厂商名称");
            return;
        }

        isSaving = true;
        try
        {
            var url = IsEditMode
                ? $"{ApiConfig.BaseUrl}/api/CustomerVendorSetting/update"
                : $"{ApiConfig.BaseUrl}/api/CustomerVendorSetting/create";
            var httpMethod = IsEditMode ? HttpMethod.Put : HttpMethod.Post;
            var jsonOptions = new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase };
            var jsonContent = System.Text.Json.JsonSerializer.Serialize(model, jsonOptions);
            var request = AuthHttpClient.CreateRequest(httpMethod, url, TokenProvider.Token);
            request.Content = new StringContent(jsonContent, System.Text.Encoding.UTF8, "application/json");

            var responseMsg = await Http.SendAsync(request);
            var response = await responseMsg.Content.ReadFromJsonAsync<ApiResponse<object>>(jsonOptions);

            if (response != null && response.Success)
            {
                await JS.InvokeVoidAsync("alert", IsEditMode ? "修改成功" : "保存成功");
            }
            else
            {
                var msg = response?.Message ?? (IsEditMode ? "修改失败" : "保存失败");
                await JS.InvokeVoidAsync("alert", $"{(IsEditMode ? "修改" : "保存")}失败: {msg}");
            }
        }
        catch (Exception ex)
        {
            _logger?.LogError(ex, $"{(IsEditMode ? "修改" : "保存")}客户/厂商资料设定时发生错误");
            await JS.InvokeVoidAsync("alert", $"{(IsEditMode ? "修改" : "保存")}失败: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task HandleSaveAndNew()
    {
        await HandleSave();
        // 重置表单
        model = new CustomerVendorSettingAddModel();
        StateHasChanged();
    }

    private void HandleDelete() { /* TODO: 删除功能 */ }
    private void HandleColumnSettings() { /* TODO: 栏位设置功能 */ }
    private void HandleQuery() { OpenTab?.Invoke("customer-vendor-setting", "客户/厂商资料设定/查询"); }

    // ===== API响应模型 =====
    private class ApiResponse<T>
    {
        public bool Success { get; set; }
        public string Message { get; set; } = "";
        public T? Data { get; set; }
    }
}
