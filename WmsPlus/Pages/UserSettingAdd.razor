@inject IJSRuntime JS
@inject HttpClient Http
@inject ILogger<UserSettingAdd> _logger
@inject TokenProvider TokenProvider

<link rel="stylesheet" href="css/user-setting-add.css" />

<div class="usradd-page">
    <!-- 页面标题栏 -->
    <div class="page-header">
        <div class="header-left">
            <button class="favorite-btn @(isFavorited ? "favorited" : "")" @onclick="ToggleFavorite" title="收藏">
                <svg viewBox="0 0 24 24" width="24" height="24">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
                          fill="@((isFavorited ? "#FFD700" : "none"))"
                          stroke="@((isFavorited ? "#FFD700" : "#666666"))"
                          stroke-width="2"/>
                </svg>
            </button>
            <span class="page-title">@(IsEditMode ? "用户设定/编辑" : "用户设定-新增")</span>
        </div>
        <div class="header-right">
            <button class="header-action-btn primary" @onclick="HandleSave">
                <svg viewBox="0 0 16 16" width="14" height="14" fill="white">
                    <path d="M13.78 4.22a.75.75 0 010 1.06l-7.25 7.25a.75.75 0 01-1.06 0L2.22 8.28a.75.75 0 011.06-1.06L6 9.94l6.72-6.72a.75.75 0 011.06 0z"/>
                </svg>
                <span>保存</span>
            </button>
            <button class="header-action-btn primary" @onclick="HandleSaveAndNew">
                <svg viewBox="0 0 16 16" width="14" height="14" fill="white">
                    <path d="M8 3v10M3 8h10" stroke="white" stroke-width="2" stroke-linecap="round"/>
                </svg>
                <span>新增</span>
            </button>
            <button class="header-action-btn" @onclick="HandleDelete">
                <svg viewBox="0 0 16 16" width="14" height="14" fill="#666666">
                    <path d="M5.5 4h5l.5.5v9l-.5.5h-5L5 13.5v-9l.5-.5zM6 5v8h4V5H6z M4 3.5V4h1v-.5a.5.5 0 00-.5-.5h-1a.5.5 0 00-.5.5zm8 0V4h1v-.5a.5.5 0 00-.5-.5h-1a.5.5 0 00-.5.5z"/>
                </svg>
                <span>删除</span>
            </button>
            <button class="header-action-btn" @onclick="HandleColumnSettings">
                <svg viewBox="0 0 16 16" width="14" height="14" fill="#666666">
                    <path d="M2 3h4v2H2V3zm0 4h4v2H2V7zm0 4h4v2H2v-2zm6-8h6v2H8V3zm0 4h6v2H8V7zm0 4h6v2H8v-2z"/>
                </svg>
                <span>栏位</span>
            </button>
            <button class="header-action-btn" @onclick="HandleQuery">
                <svg viewBox="0 0 16 16" width="14" height="14" fill="#666666">
                    <circle cx="7" cy="7" r="5"/>
                    <line x1="11" y1="11" x2="15" y2="15" stroke="#666666" stroke-width="1.5"/>
                </svg>
                <span>查询</span>
            </button>
        </div>
    </div>

    @if (showFavoriteSuccess)
    {
        <div class="favorite-success-toast">
            <div class="toast-content">
                <svg viewBox="0 0 16 16" width="16" height="16" fill="#52C41A">
                    <circle cx="8" cy="8" r="8"/>
                    <path d="M5 8l2 2 4-4" stroke="white" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>收藏成功</span>
            </div>
        </div>
    }

    <!-- 表单区域 -->
    <div class="form-area-scroll">
        <div class="form-section">
            <div class="form-section-title">基本信息</div>

            <div class="form-grid-3col">
                <div class="form-item-add">
                    <label class="form-label-add"><span class="required-mark">*</span>用户代号</label>
                    <input type="text" class="form-input-add" placeholder="" @bind="model.Usr" @bind:event="oninput" disabled="@IsEditMode" />
                </div>
                <div class="form-item-add">
                    <label class="form-label-add"><span class="required-mark">*</span>用户名称</label>
                    <input type="text" class="form-input-add" placeholder="" @bind="model.Name" />
                </div>
                <div class="form-item-add">
                    <label class="form-label-add"><span class="required-mark">*</span>部门代号</label>
                    <input type="text" class="form-input-add" placeholder="" @bind="model.Dep" />
                    <div class="input-search-icon" title="选择部门" @onclick="OpenDeptSelector">
                        <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="#999999" stroke-width="1.5">
                            <circle cx="7" cy="7" r="5"/><line x1="11" y1="11" x2="15" y2="15" stroke="#999999" stroke-width="1.5"/>
                        </svg>
                    </div>
                </div>

                <div class="form-item-add">
                    <label class="form-label-add">密码</label>
                    <input type="password" class="form-input-add" placeholder="" @bind="model.Pwd" />
                    <button class="pwd-toggle-btn" title="显示/隐藏密码" @onclick="TogglePwdVisibility">
                        <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="#999999" stroke-width="1.5">
                            @if (showPwd)
                            {
                                <path d="M8 3C4.5 3 1.73 5.11 1 8c.73 2.89 3.5 5 7 5s6.27-2.11 7-5c-.73-2.89-3.5-5-7-5zm0 8a3 3 0 110-6 3 3 0 010 6zm0-2a1 1 0 100-2 1 1 0 000 2z"/>
                            }
                            else
                            {
                                <path d="M13.36 8A6.18 6.18 0 019 4.64 6.17 6.17 0 004.64 9 6.18 6.18 0 019 12.36 6.17 6.17 0 0013.36 8zM2.64 8A6.18 6.18 0 017 11.36 6.17 6.17 0 0011.36 7 6.18 6.18 0 012.64 8zM8 5.5a2.5 2.5 0 100 5 2.5 2.5 0 000-5z"/>
                                <line x1="2" y1="14" x2="14" y2="2" stroke="#999999" stroke-width="1.5"/>
                            }
                        </svg>
                    </button>
                </div>
                <div class="form-item-add">
                    <label class="form-label-add">确认密码</label>
                    <input type="password" class="form-input-add" placeholder="" @bind="pwdConfirm" />
                </div>
                <div class="form-item-add">
                    <label class="form-label-add">主管</label>
                    <input type="text" class="form-input-add" placeholder="" @bind="model.Mng" />
                    <div class="input-search-icon" title="搜索">
                        <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="#999999" stroke-width="1.5">
                            <circle cx="7" cy="7" r="5"/><line x1="11" y1="11" x2="15" y2="15" stroke="#999999" stroke-width="1.5"/>
                        </svg>
                    </div>
                </div>

                <div class="checkbox-wrapper-inline">
                    <input type="checkbox" id="pwdChg" @bind="model.PwdChg" />
                    <label for="pwdChg">下次登陆必须修改密码</label>
                </div>
                <div class="form-item-add">
                    <label class="form-label-add">截止有效期</label>
                    <input type="date" class="form-input-add" @bind="model.EDat" @bind:format="yyyy-MM-dd" />
                </div>
                <div class="form-item-add">
                    <label class="form-label-add">开始有效期</label>
                    <input type="date" class="form-input-add" @bind="model.BDat" @bind:format="yyyy-MM-dd" />
                </div>

                <div class="form-item-add">
                    <label class="form-label-add">所属类别</label>
                    <input type="text" class="form-input-add" placeholder="" @bind="model.DeproNo" />
                    <div class="input-search-icon" title="搜索">
                        <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="#999999" stroke-width="1.5">
                            <circle cx="7" cy="7" r="5"/><line x1="11" y1="11" x2="15" y2="15" stroke="#999999" stroke-width="1.5"/>
                        </svg>
                    </div>
                </div>
                <div class="checkbox-wrapper-inline">
                    <input type="checkbox" id="isGroup" @bind="model.IsGroup" />
                    <label for="isGroup">集团用户</label>
                </div>
                <div class="checkbox-wrapper-inline">
                    <input type="checkbox" id="isCust" @bind="model.IsCust" />
                    <label for="isCust">供应商</label>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 部门选择器对话框 -->
@if (showDeptDialog)
{
    <div class="dept-selector-overlay" @onclick="CloseDeptSelector">
        <div class="dept-selector-dialog" @onclick:stopPropagation>
            <div class="dept-selector-header">
                <span>部门资料(DEPT)</span>
                <button class="dept-close-btn" @onclick="CloseDeptSelector">&times;</button>
            </div>
            <div class="dept-selector-body">
                <div class="dept-left-panel">
                    <div class="dept-filter-title">过滤</div>
                    <input type="text" class="dept-search-input" placeholder="输入关键字查询" @bind="deptSearchKeyword" @bind:event="oninput" @onkeyup="@((KeyboardEventArgs e) => { if(e.Key == "Enter") _ = SearchDept(); })" />
                    <button class="dept-query-btn" @onclick="@(() => _ = SearchDept())">查询</button>
                </div>
                <div class="dept-right-panel">
                    <table class="dept-data-table">
                        <thead>
                            <tr>
                                <th style="width:60px">操作</th>
                                <th style="width:80px">部门代号</th>
                                <th>部门名称</th>
                                <th>上层部门</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (deptData.Count == 0)
                            {
                                <tr><td colspan="4" style="text-align:center;padding:30px;color:#999;">暂无数据</td></tr>
                            }
                            else
                            {
                                @for (int i = 0; i < deptData.Count; i++)
                                {
                                    var item = deptData[i];
                                    <tr>
                                        <td><button class="dept-select-btn" @onclick="() => SelectDept(item)">选择</button></td>
                                        <td>@item.DEP</td>
                                        <td>@item.NAME</td>
                                        <td>@item.UP</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                    <div class="dept-pagination">
                        <span class="dept-total-info">共 @deptTotalCount 笔记录</span>
                        <div class="dept-page-controls">
                            <button class="dept-page-btn" disabled="@(deptPageIndex <= 1)" @onclick="async () => await GoToDeptPage(deptPageIndex - 1)">&lt;</button>
                            <input type="number" class="dept-page-input" value="@deptPageIndex" min="1" max="@DeptTotalPages"
                                   @onchange="async (ChangeEventArgs e) => { if(int.TryParse(e.Value?.ToString(), out var p)) await GoToDeptPage(p); }" />
                            <span>/ @DeptTotalPages</span>
                            <button class="dept-page-btn" disabled="@(deptPageIndex >= DeptTotalPages)" @onclick="async () => await GoToDeptPage(deptPageIndex + 1)">&gt;</button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="dept-selector-footer">
                <button class="dept-footer-cancel" @onclick="CloseDeptSelector">取消</button>
            </div>
        </div>
    </div>
}


@code {
    private UserSettingCreateRequest model = new();
    private string pwdConfirm = "";
    private bool showPwd = false;
    private bool isSaving = false;

    // ===== 部门选择器状态 =====
    private bool showDeptDialog = false;
    private string deptSearchKeyword = "";
    private List<DeptItem> deptData = new();
    private int deptPageIndex = 1;
    private int deptPageSize = 10;
    private int deptTotalCount = 0;

    [Parameter] public string? EditUsr { get; set; }

    private bool IsEditMode => !string.IsNullOrWhiteSpace(EditUsr);

    [CascadingParameter(Name = "OpenTabCallback")] public Action<string, string>? OpenTab { get; set; }
    [CascadingParameter(Name = "OnFavoriteChanged")] public Action? NotifyFavoriteChanged { get; set; }

    // ===== 收藏功能 =====
    private bool isFavorited = false;
    private bool showFavoriteSuccess = false;
    private const string FAVORITE_KEY = "wms_favorite_user_setting_add";

    protected override async Task OnInitializedAsync()
    {
        try { var r = await JS.InvokeAsync<string>("localStorage.getItem", FAVORITE_KEY); isFavorited = r == "true"; } catch { }

        if (IsEditMode)
        {
            await LoadDataForEdit();
        }
    }

    private async Task ToggleFavorite()
    {
        isFavorited = !isFavorited;
        try { await JS.InvokeVoidAsync("localStorage.setItem", FAVORITE_KEY, isFavorited.ToString().ToLower()); } catch { }
        NotifyFavoriteChanged?.Invoke();
        showFavoriteSuccess = true;
        StateHasChanged();
        await Task.Delay(1500);
        showFavoriteSuccess = false;
        StateHasChanged();
    }

    // ===== 编辑模式：加载用户详情 =====
    private async Task LoadDataForEdit()
    {
        try
        {
            var url = $"{ApiConfig.BaseUrl}/api/UserSetting/getByUsr?usr={Uri.EscapeDataString(EditUsr!)}";
            var request = AuthHttpClient.CreateRequest(HttpMethod.Get, url, TokenProvider.Token);
            var responseMsg = await Http.SendAsync(request);
            var jsonOptions = new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase };
            var response = await responseMsg.Content.ReadFromJsonAsync<ApiResponse<UserSettingCreateRequest>>(jsonOptions);

            if (response != null && response.Success && response.Data != null)
            {
                model = response.Data;
            }
            else
            {
                var msg = response?.Message ?? "加载数据失败";
                await JS.InvokeVoidAsync("alert", $"加载失败: {msg}");
            }
        }
        catch (Exception ex)
        {
            _logger?.LogError(ex, "加载用户详情时发生错误");
            await JS.InvokeVoidAsync("alert", $"加载失败: {ex.Message}");
        }
    }

    // ===== 密码可见性切换 =====
    private void TogglePwdVisibility() { showPwd = !showPwd; StateHasChanged(); }

    // ===== 工具栏按钮事件 =====
    private async Task HandleSave()
    {
        if (isSaving) return;

        // 必填校验
        if (string.IsNullOrWhiteSpace(model.Usr))
        {
            await JS.InvokeVoidAsync("alert", "请输入用户代号");
            return;
        }
        if (string.IsNullOrWhiteSpace(model.Name))
        {
            await JS.InvokeVoidAsync("alert", "请输入用户名称");
            return;
        }
        if (string.IsNullOrWhiteSpace(model.Dep))
        {
            await JS.InvokeVoidAsync("alert", "请输入部门代号");
            return;
        }
        // 新增模式下必须输入密码
        if (!IsEditMode && string.IsNullOrWhiteSpace(model.Pwd))
        {
            await JS.InvokeVoidAsync("alert", "请输入密码");
            return;
        }
        // 密码一致性校验（仅当有输入密码时）
        if (!string.IsNullOrWhiteSpace(model.Pwd) && model.Pwd != pwdConfirm)
        {
            await JS.InvokeVoidAsync("alert", "两次输入的密码不一致");
            return;
        }

        isSaving = true;
        try
        {
            var url = IsEditMode
                ? $"{ApiConfig.BaseUrl}/api/UserSetting/update"
                : $"{ApiConfig.BaseUrl}/api/UserSetting/create";
            var httpMethod = IsEditMode ? HttpMethod.Put : HttpMethod.Post;
            var jsonOptions = new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase };
            var jsonContent = System.Text.Json.JsonSerializer.Serialize(model, jsonOptions);
            var request = AuthHttpClient.CreateRequest(httpMethod, url, TokenProvider.Token);
            request.Content = new StringContent(jsonContent, System.Text.Encoding.UTF8, "application/json");

            var responseMsg = await Http.SendAsync(request);
            var response = await responseMsg.Content.ReadFromJsonAsync<ApiResponse<object>>(jsonOptions);

            if (response != null && response.Success)
            {
                await JS.InvokeVoidAsync("alert", IsEditMode ? "修改成功" : "保存成功");
            }
            else
            {
                var msg = response?.Message ?? (IsEditMode ? "修改失败" : "保存失败");
                await JS.InvokeVoidAsync("alert", $"{(IsEditMode ? "修改" : "保存")}失败: {msg}");
            }
        }
        catch (Exception ex)
        {
            _logger?.LogError(ex, $"{(IsEditMode ? "修改" : "保存")}用户设定时发生错误");
            await JS.InvokeVoidAsync("alert", $"{(IsEditMode ? "修改" : "保存")}失败: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task HandleSaveAndNew()
    {
        await HandleSave();
        // 重置表单
        model = new UserSettingCreateRequest();
        pwdConfirm = "";
        StateHasChanged();
    }

    private void HandleDelete() { /* TODO: 删除功能 */ }
    private void HandleColumnSettings() { /* TODO: 栏位设置功能 */ }
    private void HandleQuery() { OpenTab?.Invoke("user-setting", "用户设定"); }

    // ===== 部门选择器方法 =====
    private async Task OpenDeptSelector()
    {
        deptSearchKeyword = "";
        deptPageIndex = 1;
        await SearchDept();
        showDeptDialog = true;
        StateHasChanged();
    }

    private void CloseDeptSelector()
    {
        showDeptDialog = false;
        StateHasChanged();
    }

    private async Task SearchDept()
    {
        try
        {
            var url = $"{ApiConfig.BaseUrl}/api/warehouse/deptsearch?keyword={Uri.EscapeDataString(deptSearchKeyword ?? "")}&pageIndex={deptPageIndex}&pageSize={deptPageSize}";
            var jsonOptions = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var request = AuthHttpClient.CreateRequest(HttpMethod.Get, url, TokenProvider.Token);
            var responseMsg = await Http.SendAsync(request);
            if (responseMsg.IsSuccessStatusCode)
            {
                var json = await responseMsg.Content.ReadAsStringAsync();
                var result = System.Text.Json.JsonSerializer.Deserialize<DeptSearchResult>(json, jsonOptions);
                if (result != null)
                {
                    deptData = result.Items ?? new List<DeptItem>();
                    deptTotalCount = result.TotalCount;
                }
            }
        }
        catch (Exception ex)
        {
            _logger?.LogError(ex, "部门选择器查询失败");
        }
        StateHasChanged();
    }

    private void SelectDept(DeptItem item)
    {
        model.Dep = item.DEP;
        showDeptDialog = false;
        StateHasChanged();
    }

    private int DeptTotalPages => deptPageSize > 0 ? (int)Math.Ceiling((double)deptTotalCount / deptPageSize) : 1;

    private async Task GoToDeptPage(int page)
    {
        if (page >= 1 && page <= DeptTotalPages)
        {
            deptPageIndex = page;
            await SearchDept();
        }
    }

    // ===== 部门数据模型 =====
    public class DeptItem
    {
        public string DEP { get; set; } = "";
        public string NAME { get; set; } = "";
        public string UP { get; set; } = "";
    }

    private class DeptSearchResult
    {
        public List<DeptItem>? Items { get; set; }
        public int TotalCount { get; set; }
    }

    // ===== API响应模型 =====
    private class ApiResponse<T>
    {
        public bool Success { get; set; }
        public string Message { get; set; } = "";
        public T? Data { get; set; }
    }
}
